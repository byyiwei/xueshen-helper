/* ============================================================
 * html2image-server · 配置文件（中文注释版）
 *
 * 说明：本文件支持 // 单行注释 和 /* 多行注释 * / 。
 *       配置读取顺序（优先级从高到低）：
 *         1. 环境变量（H2I_ 前缀，例如 H2I_SERVER_PORT=8080）
 *         2. 本文件 config.json
 *         3. 代码内置默认值
 *
 *       修改后需要重启服务才生效。
 * ============================================================ */
{
  /* ---- HTTP 服务监听配置 ------------------------------------------- */
  "server": {
    // 监听地址：0.0.0.0 表示允许来自所有网卡的请求（局域网可访问）
    // 如需仅本机访问，改为 "127.0.0.1"
    "host": "0.0.0.0",

    // 监听端口。被占用时可改为 8080、8888 等
    "port": 3001
  },

  /* ---- 进程相关 ----------------------------------------------------- */
  "process": {
    // 运行时 PID 写入的文件路径。用于 stop 脚本识别进程。
    // 相对路径会自动解析为项目目录下的绝对路径。
    "pidFile": ".app.pid"
  },

  /* ---- 日志相关 ----------------------------------------------------- */
  "logging": {
    // 日志输出目录（相对路径会自动变成绝对路径）
    "logDir": "logs",

    // 脚本后台启动时，Node 子进程 stdout/stderr 的重定向文件名
    "stdoutLog": "app_output.log",

    // start-server 脚本写入的启动日志
    "startupLog": "startup.log",

    // stop-server 脚本写入的停止日志
    "stopLog": "stop.log"
  },

  /* ---- 无头浏览器（Chromium）配置 ------------------------------------ */
  "browser": {
    // 强制指定 Chrome/Chromium 可执行文件路径。
    // 留空字符串 "" 表示由 puppeteer 自动查找（会优先用自带的 Chromium）。
    // 例子：
    //   Windows:  "C:/Program Files/Google/Chrome/Application/chrome.exe"
    //   macOS:    "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
    //   Linux:    "/usr/bin/google-chrome" 或 "/usr/bin/chromium"
    //
    // 提示：若 puppeteer 自带的 Chromium 下载失败，可在这里指向系统已安装的 Chrome
    "executablePath": "",

    // 是否以无头模式运行。true 推荐（无图形界面、内存占用低）。
    // 若需要调试可见的浏览器窗口，可临时改为 false。
    "headless": true,

    // 浏览器启动超时（毫秒）。机器较慢时可调大到 60000 或 90000。
    "launchTimeoutMs": 45000,

    // Puppeteer 与 Chromium DevTools 协议的超时（毫秒）。
    // 渲染超大页面时可能需要加大。
    "protocolTimeoutMs": 30000,

    // 传给 Chromium 的命令行参数（数组）。
    // 以下是一组在容器/沙箱/无 GUI 环境中较稳定的默认值。
    // 如需自定义可在此数组中追加或删除。
    "args": [
      "--no-sandbox",                         // 禁用沙箱（Linux 容器必需）
      "--disable-setuid-sandbox",              // 配合上一条
      "--disable-dev-shm-usage",               // 避免 Docker /dev/shm 过小崩溃
      "--disable-gpu",                         // 无 GPU 环境跳过硬件加速
      "--disable-software-rasterizer",
      "--disable-features=VizDisplayCompositor",
      "--no-first-run",                        // 跳过首次运行引导
      "--no-default-browser-check",            // 不弹出"设为默认浏览器"
      "--disable-default-apps",
      "--disable-popup-blocking",              // 允许弹出（某些跳转场景）
      "--disable-background-networking",
      "--disable-extensions"                   // 禁用扩展以节省内存
    ]
  },

  /* ---- HTML 转图片的默认渲染参数 ------------------------------------- */
  "rendering": {
    // 默认视口（CSS 像素）。请求中若未指定 options.width/height/deviceScaleFactor，
    // 会使用这里的值。deviceScaleFactor 影响清晰度，1 最模糊但最快，2 推荐，3-5 很清晰但较慢。
    "defaultViewport": {
      "width": 1280,
      "height": 800,
      "deviceScaleFactor": 2
    },

    // 默认图片格式：png（无损，带透明）/ jpeg（体积小，不透明）/ webp（压缩比最佳）
    "defaultFormat": "png",

    // jpeg/webp 默认质量（1-100），90 已相当清晰，60 可进一步压体积
    "defaultQuality": 90,

    // 页面加载超时（毫秒）。超过此时间未加载完成（network idle）则返回错误。
    "loadTimeoutMs": 30000,

    // 页面声明"已加载"后再等待的毫秒数（用于等待 JS 动画/字体渲染完成）。默认 0。
    "defaultWaitForMs": 0,

    // 是否默认对整页进行截图（自动滚动到底部，而不是只截取当前视口）。
    // true = 默认整页；false = 按请求者指定。
    "fullPageByDefault": false
  },

  /* ---- HTTP 请求相关 ------------------------------------------------- */
  "http": {
    // 请求体最大字节数（默认 10 MB = 10 * 1024 * 1024）。
    // 非常大的 HTML 内容可能需要调高。
    "maxRequestBodyBytes": 10485760,

    // start-server 脚本等待 .app.pid 文件出现的最长秒数。
    // 机器慢或 npm install 首次启动时，可调大。
    "startupWaitSeconds": 30
  }
}
