# ===========================================
# 养龟档案后端环境变量配置
# 部署时复制为 .env 并填入真实值
# ===========================================

# 服务端口
PORT=3004
HOST=0.0.0.0

# 数据库
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=turtle-records
DB_PASSWORD=你的数据库密码
DB_NAME=turtle-records

# JWT 密钥（生成方式: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"）
JWT_SECRET=
ADMIN_JWT_SECRET=
JWT_EXPIRES=30d

# 微信小程序
WX_APPID=你的微信AppID
WX_APPSECRET=你的微信AppSecret

# 文件上传目录
UPLOAD_DIR=./uploads

# 公开访问域名
BASE_URL=https://pets.openget.cn

# 邮件配置（可选）
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
