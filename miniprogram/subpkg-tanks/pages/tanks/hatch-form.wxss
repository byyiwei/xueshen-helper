/* ====== 页面容器 ====== */
.page-form {
  min-height: 100vh;
  background: #FAF8F5;
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx 20rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.06);
}

.nav-back { width: 60rpx; height: 60rpx; display: flex; align-items: center; justify-content: center; }
.nav-back-icon { font-size: 48rpx; color: #1A1A1A; font-weight: 300; line-height: 1; }
.nav-title { font-size: 32rpx; font-weight: 700; color: #1A1A1A; flex: 1; text-align: center; }
.nav-placeholder { width: 60rpx; }

.form-scroll { height: 100vh; box-sizing: border-box; }
.form-inner { padding: 28rpx; }

.form-group { margin-bottom: 28rpx; }
.form-label { font-size: 26rpx; color: #999; display: block; margin-bottom: 12rpx; }

.form-input, .form-textarea {
  width: 100%;
  background: #fff;
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.form-textarea { min-height: 160rpx; }

.form-picker {
  width: 100%;
  height: 88rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  color: #1A1A1A;
}

.form-display {
  width: 100%;
  height: 88rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  color: #999;
}

.submit-btn {
  width: 100%;
  margin-top: 20rpx;
  padding: 28rpx 0;
  text-align: center;
  background: #E8A400;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.submit-btn.disabled { opacity: 0.6; pointer-events: none; }
.safe-bottom { height: calc(100rpx + env(safe-area-inset-bottom)); }
