.page {
  min-height: 100vh;
  background-color: #F0F7FF;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #F8FAFC 100%);
  padding-left: 24rpx;
  padding-right: 24rpx;
  border-bottom: 2rpx solid #F1F5F9;
}

.nav-back {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F0F7FF;
  border-radius: 50%;
  border: 2rpx solid #E2E8F0;
}

.nav-back-icon {
  font-size: 36rpx;
  color: #3A7CFF;
  font-weight: 300;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  margin-top: -4rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1E293B;
}

.nav-placeholder {
  width: 56rpx;
}

.content {
  padding: 32rpx;
}

/* 模式切换 */
.mode-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(58, 124, 255, 0.04);
}

/* 单位选择 */
.unit-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(58, 124, 255, 0.04);
}

.unit-switch {
  display: flex;
  gap: 16rpx;
}

.unit-btn {
  flex: 1;
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #E2E8F0;
  transition: all 0.2s ease;
}

.unit-btn.active {
  background: linear-gradient(135deg, #E0F2FE 0%, #BAE6FD 100%);
  border-color: #0EA5E9;
  box-shadow: 0 4rpx 16rpx rgba(14, 165, 233, 0.2);
}

.unit-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #64748B;
}

.unit-btn.active .unit-text {
  color: #0EA5E9;
}

.section-label {
  font-size: 26rpx;
  color: #64748B;
  margin-bottom: 20rpx;
  display: block;
}

.mode-switch {
  display: flex;
  gap: 20rpx;
}

.mode-btn {
  flex: 1;
  background: #F8FAFC;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid #E2E8F0;
  transition: all 0.2s ease;
}

.mode-btn.active {
  background: linear-gradient(135deg, #3A7CFF 0%, #2563EB 100%);
  border-color: #3A7CFF;
  box-shadow: 0 8rpx 24rpx rgba(58, 124, 255, 0.25);
}

.mode-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #475569;
}

.mode-btn.active .mode-text {
  color: #FFFFFF;
}

.mode-desc {
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 6rpx;
}

.mode-btn.active .mode-desc {
  color: rgba(255, 255, 255, 0.85);
}

/* 输入区域 */
.input-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(58, 124, 255, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 24rpx;
  display: block;
}

.input-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.input-grid:nth-child(2) {
  grid-template-columns: repeat(2, 1fr);
}

.input-item {
  display: flex;
  flex-direction: column;
}

.input-label {
  font-size: 24rpx;
  color: #64748B;
  margin-bottom: 12rpx;
}

.input-wrap {
  display: flex;
  align-items: center;
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 0 20rpx;
  height: 80rpx;
  border: 2rpx solid #E2E8F0;
}

.input-field {
  flex: 1;
  font-size: 28rpx;
  color: #1E293B;
  font-weight: 600;
  text-align: right;
}

.input-unit {
  font-size: 24rpx;
  color: #94A3B8;
  margin-left: 8rpx;
}

/* 计算按钮 */
.calc-btn {
  background: linear-gradient(135deg, #3A7CFF 0%, #2563EB 100%);
  border-radius: 24rpx;
  padding: 28rpx;
  margin: 32rpx 0;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(58, 124, 255, 0.25);
  transition: all 0.2s ease;
}

.calc-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(58, 124, 255, 0.2);
}

.calc-btn-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

/* 警告提示 */
.warning-box {
  background: #FEF3E0;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  border-left: 6rpx solid #F59E0B;
}

.warning-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.warning-text {
  font-size: 26rpx;
  color: #92400E;
  flex: 1;
}

/* 结果区域 */
.result-section {
  margin-top: 24rpx;
}

.result-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(58, 124, 255, 0.04);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #3A7CFF;
}

.copy-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #F0F7FF;
  border-radius: 20rpx;
  border: 2rpx solid #E0E7FF;
  transition: all 0.2s ease;
}

.copy-btn:active {
  background: #E0E7FF;
  transform: scale(0.96);
}

.copy-icon {
  font-size: 24rpx;
}

.copy-text {
  font-size: 24rpx;
  color: #3A7CFF;
  font-weight: 500;
}

/* 表格 */
.table-scroll {
  white-space: nowrap;
  overflow-x: auto;
}

.table {
  display: table;
  width: max-content;
  min-width: 100%;
}

.table-header {
  display: table-row;
  background: #F8FAFC;
  border-radius: 12rpx;
}

.th {
  display: table-cell;
  font-size: 22rpx;
  font-weight: 600;
  color: #64748B;
  text-align: center;
  padding: 16rpx 16rpx;
  min-width: 140rpx;
  white-space: nowrap;
}

.table-row {
  display: table-row;
}

.table-row:last-child {
  border-bottom: none;
}

.td {
  display: table-cell;
  font-size: 24rpx;
  color: #1E293B;
  text-align: center;
  padding: 16rpx 16rpx;
  min-width: 140rpx;
  border-bottom: 2rpx solid #F1F5F9;
  white-space: nowrap;
}

.total-row {
  background: #FEF3C7;
}

.total-label {
  font-weight: 600;
  color: #D97706;
}

.total-value {
  font-weight: 600;
  color: #D97706;
}

/* 费用明细 */
.expense-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #F1F5F9;
}

.expense-row:last-child {
  border-bottom: none;
}

.expense-row.total {
  background: #F8FAFC;
  margin: 16rpx -28rpx -28rpx;
  padding: 24rpx 28rpx;
  border-radius: 0 0 24rpx 24rpx;
}

.expense-label {
  font-size: 28rpx;
  color: #475569;
}

.expense-row.total .expense-label {
  font-weight: 700;
  color: #1E293B;
}

.expense-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #3A7CFF;
}

.expense-value.total-value {
  font-size: 36rpx;
  color: #E76F51;
}

/* 统计汇总 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.stat-item {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #3A7CFF;
  display: block;
}

.stat-label {
  font-size: 20rpx;
  color: #94A3B8;
  margin-top: 8rpx;
  display: block;
}

/* 备注 */
.remark-box {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-top: 8rpx;
}

.remark-text {
  font-size: 24rpx;
  color: #94A3B8;
  line-height: 1.6;
}

/* 结构示意图容器 */
.model-container {
  margin-top: 24rpx;
  padding: 32rpx 24rpx 28rpx;
  background: linear-gradient(145deg, #F0F9FF, #E8F4FD);
  border-radius: 24rpx;
  border: 1rpx solid #BFDBFE;
}

/* 3D 容器外包裹 */
.tank-3d-wrap {
  position: relative;
  padding: 16rpx 0 0;
}

/* ========== 等距视角 3D 鱼缸 ========== */
.tank-3d {
  position: relative;
  width: 400rpx;
  height: 300rpx;
  margin: 0 auto;
}

/* 底部投影 */
.t3d-shadow {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: radial-gradient(ellipse at 50% 85%, rgba(30,41,59,0.1), transparent 65%);
  clip-path: polygon(20% 72%, 80% 72%, 75% 98%, 25% 98%);
  z-index: 0;
}

/* 底部（灰色底座） */
.t3d-bottom {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: linear-gradient(145deg, #D1D5DB 0%, #9CA3AF 50%, #6B7280 100%);
  clip-path: polygon(50% 55%, 80% 70%, 50% 85%, 20% 70%);
  z-index: 1;
}

/* 后左侧面（侧玻璃 - 青色玻璃质感） */
.t3d-back-left {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: linear-gradient(155deg, 
    rgba(34,211,238,0.22) 0%, 
    rgba(6,182,212,0.14) 40%, 
    rgba(8,145,178,0.1) 100%);
  clip-path: polygon(20% 70%, 50% 55%, 50% 10%, 20% 25%);
  z-index: 2;
}

/* 后右侧面（侧玻璃 - 青色玻璃质感） */
.t3d-back-right {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: linear-gradient(205deg, 
    rgba(34,211,238,0.18) 0%, 
    rgba(6,182,212,0.12) 40%, 
    rgba(8,145,178,0.08) 100%);
  clip-path: polygon(50% 55%, 80% 70%, 80% 25%, 50% 10%);
  z-index: 3;
}

/* 内壁-后左（深度感） */
.t3d-inner-left {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: linear-gradient(155deg, rgba(6,182,212,0.06), rgba(14,116,144,0.04));
  clip-path: polygon(23.5% 67%, 50% 53.5%, 50% 13.5%, 23.5% 27%);
  z-index: 4;
}

/* 内壁-后右（深度感） */
.t3d-inner-right {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: linear-gradient(205deg, rgba(6,182,212,0.05), rgba(14,116,144,0.03));
  clip-path: polygon(50% 53.5%, 76.5% 67%, 76.5% 27%, 50% 13.5%);
  z-index: 5;
}

/* 水面（半截时） */
.t3d-water {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: linear-gradient(180deg, 
    rgba(34,211,238,0.18) 0%, 
    rgba(6,182,212,0.12) 100%);
  z-index: 6;
  opacity: 0;
  transition: opacity 0.35s ease;
}
.t3d-water.visible {
  opacity: 1;
}

/* 顶部开口（描边框） */
.t3d-top {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: transparent;
  clip-path: polygon(50% 10%, 80% 25%, 50% 40%, 20% 25%);
  border: none;
  z-index: 7;
}

/* 顶部开口内环线 */
.t3d-top-inner {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(148,163,184,0.08);
  clip-path: polygon(50% 12%, 77% 25.5%, 50% 39%, 23% 25.5%);
  z-index: 7;
}

/* 正面玻璃（红色，动态高度）— 视觉主体 */
.t3d-front {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: linear-gradient(160deg, 
    rgba(251,113,133,0.55) 0%, 
    rgba(244,63,94,0.5) 30%, 
    rgba(225,29,72,0.6) 70%, 
    rgba(190,18,60,0.7) 100%);
  z-index: 8;
}

/* 正面高光反射 */
.t3d-front-glare {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: linear-gradient(155deg, 
    rgba(255,255,255,0.35) 0%, 
    rgba(255,255,255,0.1) 40%, 
    transparent 100%);
  z-index: 9;
  pointer-events: none;
}

/* 正面顶部边缘线（半截时） */
.t3d-front-edge {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: linear-gradient(90deg, #E11D48, #F43F5E, #E11D48);
  z-index: 10;
  opacity: 0;
  transition: opacity 0.35s ease;
}
.t3d-front-edge.visible {
  opacity: 1;
}

/* ========== 结构边缘线 ========== */
.t3d-edge {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 11;
  pointer-events: none;
}

/* 前垂直边 */
.t3d-edge-front {
  background: rgba(71,85,105,0.55);
  clip-path: polygon(49.5% 85%, 50.5% 85%, 50.5% 40%, 49.5% 40%);
}

/* 左垂直边 */
.t3d-edge-left {
  background: rgba(71,85,105,0.4);
  clip-path: polygon(19.5% 70%, 20.5% 70%, 20.5% 25%, 19.5% 25%);
}

/* 右垂直边 */
.t3d-edge-right {
  background: rgba(71,85,105,0.4);
  clip-path: polygon(79.5% 70%, 80.5% 70%, 80.5% 25%, 79.5% 25%);
}

/* 后垂直边 */
.t3d-edge-back {
  background: rgba(71,85,105,0.3);
  clip-path: polygon(49.5% 55%, 50.5% 55%, 50.5% 10%, 49.5% 10%);
}

/* 顶部左斜边 */
.t3d-edge-top-left {
  background: rgba(71,85,105,0.35);
  clip-path: polygon(20% 24.8%, 50% 9.8%, 50% 10.5%, 20% 25.5%);
}

/* 顶部右斜边 */
.t3d-edge-top-right {
  background: rgba(71,85,105,0.35);
  clip-path: polygon(50% 9.8%, 80% 24.8%, 80% 25.5%, 50% 10.5%);
}

/* ========== 高度标注 ========== */
.model-dimension {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 16rpx;
  opacity: 0;
  transform: translateY(-10rpx);
  transition: opacity 0.3s ease, transform 0.3s ease;
}

.model-dimension.visible {
  opacity: 1;
  transform: translateY(0);
}

.dim-line {
  width: 80rpx;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, #E11D48, transparent);
  border-radius: 2rpx;
}

.dim-text {
  font-size: 22rpx;
  color: #E11D48;
  font-weight: 600;
}

/* ========== 图例 ========== */
.model-legend {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-top: 24rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

.legend-dot.front-dot {
  background: linear-gradient(135deg, #FB7185, #E11D48);
  box-shadow: 0 0 8rpx rgba(225,29,72,0.3);
}

.legend-dot.side-dot {
  background: linear-gradient(135deg, #22D3EE, #0891B2);
  box-shadow: 0 0 8rpx rgba(6,182,212,0.3);
}

.legend-text {
  font-size: 22rpx;
  color: #64748B;
  font-weight: 500;
}

/* 提示文字 */
.model-tip {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #64748B;
  margin-top: 14rpx;
  line-height: 1.5;
  font-weight: 500;
}