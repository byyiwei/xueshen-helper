<view class="container">
  <view class="login-box">
    <!-- Logo -->
    <view class="logo-section">
      <image class="logo-img" src="/images/logo-new.png" mode="aspectFit"/>
    </view>

    <!-- 中间留白区域 -->
    <view class="spacer"></view>

    <!-- 底部区域：协议 + 登录 -->
    <view class="bottom-section">
      <view class="agreement-section">
        <view class="checkbox-wrapper" bindtap="toggleAgreement">
          <view class="checkbox {{agreed ? 'checked' : ''}}">
            <text wx:if="{{agreed}}" class="check-icon">✓</text>
          </view>
          <text class="agreement-text">我已阅读并同意</text>
          <text class="link" bindtap="showUserAgreement">《用户协议》</text>
          <text class="divider">和</text>
          <text class="link" bindtap="showPrivacyPolicy">《隐私政策》</text>
        </view>
      </view>

      <view class="login-btn" bindtap="handleLogin">
        <button class="wechat-btn" loading="{{loading}}">
          <text class="btn-text">微信一键登录</text>
        </button>
      </view>
    </view>
  </view>

  <view wx:if="{{showModal}}" class="modal-overlay" bindtap="hideModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">{{modalTitle}}</text>
        <view class="modal-close" bindtap="hideModal">×</view>
      </view>
      <scroll-view class="modal-body" scroll-y>
        <view class="article">
          <view wx:for="{{agreementContent}}" wx:key="index" wx:for-item="sectionItem" class="section">
            <view wx:if="{{sectionItem.type === 'title'}}" class="section-title">{{sectionItem.content}}</view>
            <view wx:if="{{sectionItem.type === 'subtitle'}}" class="section-subtitle">{{sectionItem.content}}</view>
            <view wx:if="{{sectionItem.type === 'paragraph'}}" class="section-paragraph">{{sectionItem.content}}</view>
            <view wx:if="{{sectionItem.type === 'list'}}" class="section-list">
              <view wx:for="{{sectionItem.items}}" wx:key="listIndex" wx:for-index="listIndex" class="list-item">
                <text class="list-number">{{sectionItem.prefix || ''}}{{listIndex + 1}}.</text>
                <text class="list-text">{{sectionItem.items[listIndex]}}</text>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
      <view class="modal-footer">
        <view class="modal-btn" bindtap="hideModal">我知道了</view>
      </view>
    </view>
  </view>
</view>
