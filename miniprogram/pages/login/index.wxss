.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFFFFF 0%, #F8FAFB 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.login-box {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ===== 心形龟甲+萌芽 Logo（基于 logo.html 的 SVG 实现 - 带白色圆角背景框）===== */
.logo-wrapper {
  margin-bottom: 40rpx;
}

.logo-svg-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.logo-frame {
  width: 220rpx;
  height: 220rpx;
  background: #ffffff;
  border-radius: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 36rpx rgba(45, 106, 79, 0.08);
  margin-bottom: 20rpx;
  overflow: hidden;
}

.logo-img {
  width: 176rpx;
  height: 176rpx;
  display: block;
}

/* 品牌文字 */
.logo-text {
  font-size: 64rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #2D6A4F 0%, #1B4332 100%);
  -webkit-background-clip: text;
  color: transparent;
  letter-spacing: 8rpx;
  text-shadow: 0 4rpx 12rpx rgba(45, 106, 79, 0.1);
  white-space: nowrap;
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

/* ===== 副标题 ===== */
.subtitle {
  font-size: 28rpx;
  color: #94A3B8;
  margin-bottom: 100rpx;
}

/* ===== 登录按钮 ===== */
.login-btn {
  width: 100%;
  margin-bottom: 60rpx;
}

.wechat-btn {
  width: 100% !important;
  height: 96rpx !important;
  background: linear-gradient(135deg, #2D6A4F 0%, #1B4332 100%) !important;
  color: #ffffff !important;
  border-radius: 48rpx !important;
  font-size: 32rpx !important;
  line-height: 96rpx !important;
  box-shadow: 0 8rpx 24rpx rgba(45, 106, 79, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-text {
  margin-left: 16rpx;
}

/* ===== 协议区域 ===== */
.agreement-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding-bottom: 60rpx;
}

.checkbox-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #CBD5E1;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.checkbox.checked {
  background: #2D6A4F;
  border-color: #2D6A4F;
}

.check-icon {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: bold;
}

.agreement-text {
  font-size: 28rpx;
  color: #5A6C7D;
}

.agreement-links {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.link {
  font-size: 28rpx;
  color: #2A6F97;
  text-decoration: underline;
}

.divider {
  font-size: 26rpx;
  color: #94A3B8;
}

/* ===== 协议弹窗 ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(45, 106, 79, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
  z-index: 10000;
}

.modal-content {
  width: 650rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  max-height: 75vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  padding: 32rpx;
  border-bottom: 1rpx solid #E8F5EE;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.modal-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #2D6A4F;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #94A3B8;
}

.modal-body {
  padding: 24rpx;
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  max-height: 55vh;
  width: 602rpx;
}

.article {
  width: 100%;
  overflow: hidden;
}

.section {
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #2D6A4F;
  text-align: center;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #E8F5EE;
  word-break: break-all;
}

.section-subtitle {
  font-size: 24rpx;
  font-weight: bold;
  color: #2D6A4F;
  margin-bottom: 12rpx;
  padding-left: 12rpx;
  border-left: 4rpx solid #2D6A4F;
  word-break: break-all;
}

.section-paragraph {
  font-size: 22rpx;
  color: #5A6C7D;
  line-height: 1.8;
  text-indent: 44rpx;
  margin-bottom: 12rpx;
  word-break: break-all;
}

.section-list {
  padding-left: 16rpx;
}

.list-item {
  display: flex;
  margin-bottom: 10rpx;
}

.list-number {
  font-size: 22rpx;
  color: #2D6A4F;
  font-weight: 500;
  flex-shrink: 0;
  margin-right: 8rpx;
}

.list-text {
  font-size: 22rpx;
  color: #5A6C7D;
  line-height: 1.8;
  flex: 1;
  word-break: break-all;
}

.modal-footer {
  padding: 28rpx 36rpx;
  border-top: 1rpx solid #E8F5EE;
  flex-shrink: 0;
}

.modal-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #2D6A4F 0%, #1B4332 100%);
  color: #ffffff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

/* 跳过登录按钮 */
.skip-btn {
  margin-top: 40rpx;
  padding: 20rpx 40rpx;
  text-align: center;
}

.skip-text {
  font-size: 28rpx;
  color: #94A3B8;
}
