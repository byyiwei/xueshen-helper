.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #faf8f3 0%, #f5f0e6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.login-box {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ===== 心形龟甲+萌芽 Logo（基于 logo.html 的 SVG 实现 - 带白色圆角背景框）===== */
.logo-wrapper {
  margin-bottom: 40rpx;
}

.logo-svg-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.logo-frame {
  width: 220rpx;
  height: 220rpx;
  background: #ffffff;
  border-radius: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 36rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 20rpx;
  overflow: hidden;
}

.logo-img {
  width: 176rpx;
  height: 176rpx;
  display: block;
}

/* 品牌文字 */
.logo-text {
  font-size: 64rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #E68A2E 0%, #F7C56E 100%);
  -webkit-background-clip: text;
  color: transparent;
  letter-spacing: 8rpx;
  text-shadow: 0 4rpx 12rpx rgba(184, 134, 11, 0.15);
  white-space: nowrap;
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

/* ===== 副标题 ===== */
.subtitle {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 100rpx;
}

/* ===== 登录按钮 ===== */
.login-btn {
  width: 100%;
  margin-bottom: 60rpx;
}

.wechat-btn {
  width: 100% !important;
  height: 96rpx !important;
  background: linear-gradient(135deg, #1a1a1a 0%, #333 100%) !important;
  color: #fff !important;
  border-radius: 48rpx !important;
  font-size: 32rpx !important;
  line-height: 96rpx !important;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-text {
  margin-left: 16rpx;
}

/* ===== 协议区域 ===== */
.agreement-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding-bottom: 60rpx;
}

.checkbox-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ccc;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.checkbox.checked {
  background: #B8860B;
  border-color: #B8860B;
}

.check-icon {
  color: #fff;
  font-size: 26rpx;
  font-weight: bold;
}

.agreement-text {
  font-size: 28rpx;
  color: #666;
}

.agreement-links {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.link {
  font-size: 28rpx;
  color: #B8860B;
  text-decoration: underline;
}

.divider {
  font-size: 26rpx;
  color: #999;
}

/* ===== 协议弹窗 ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
  z-index: 1000;
}

.modal-content {
  width: 650rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  max-height: 75vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  padding: 32rpx;
  border-bottom: 1rpx solid #eee;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.modal-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #999;
}

.modal-body {
  padding: 24rpx;
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  max-height: 55vh;
  width: 602rpx;
}

.article {
  width: 100%;
  overflow: hidden;
}

.section {
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #eee;
  word-break: break-all;
}

.section-subtitle {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  padding-left: 12rpx;
  border-left: 4rpx solid #B8860B;
  word-break: break-all;
}

.section-paragraph {
  font-size: 22rpx;
  color: #666;
  line-height: 1.8;
  text-indent: 44rpx;
  margin-bottom: 12rpx;
  word-break: break-all;
}

.section-list {
  padding-left: 16rpx;
}

.list-item {
  display: flex;
  margin-bottom: 10rpx;
}

.list-number {
  font-size: 22rpx;
  color: #B8860B;
  font-weight: 500;
  flex-shrink: 0;
  margin-right: 8rpx;
}

.list-text {
  font-size: 22rpx;
  color: #666;
  line-height: 1.8;
  flex: 1;
  word-break: break-all;
}

.modal-footer {
  padding: 28rpx 36rpx;
  border-top: 1rpx solid #eee;
  flex-shrink: 0;
}

.modal-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #B8860B 0%, #DAA520 100%);
  color: #fff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

/* ===== 主题覆盖样式 ===== */

/* 1. .container 背景渐变 */
.theme-mocha .container {
  background: linear-gradient(180deg, #f5f5f0 0%, #faf8f3 100%);
}
.theme-olive .container {
  background: linear-gradient(180deg, #e8ede4 0%, #f0f3ef 100%);
}

/* 2. .logo-text 文字阴影 */
.theme-mocha .logo-text {
  text-shadow: 0 4rpx 12rpx rgba(139, 119, 101, 0.15);
}
.theme-olive .logo-text {
  text-shadow: 0 4rpx 12rpx rgba(85, 107, 47, 0.15);
}

/* 3. .checkbox.checked 背景和边框 */
.theme-mocha .checkbox.checked {
  background: #8B7765;
  border-color: #8B7765;
}
.theme-olive .checkbox.checked {
  background: #556B2F;
  border-color: #556B2F;
}

/* 4. .link 颜色 */
.theme-mocha .link {
  color: #8B7765;
}
.theme-olive .link {
  color: #556B2F;
}

/* 5. .section-subtitle 左边框 */
.theme-mocha .section-subtitle {
  border-left-color: #8B7765;
}
.theme-olive .section-subtitle {
  border-left-color: #556B2F;
}

/* 6. .list-number 颜色 */
.theme-mocha .list-number {
  color: #8B7765;
}
.theme-olive .list-number {
  color: #556B2F;
}

/* 7. .modal-btn 背景渐变 */
.theme-mocha .modal-btn {
  background: linear-gradient(135deg, #8B7765 0%, #a8927e 100%);
}
.theme-olive .modal-btn {
  background: linear-gradient(135deg, #556B2F 0%, #6d8a3c 100%);
}