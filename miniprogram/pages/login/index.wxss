.container {
  min-height: 100vh;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.login-box {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ===== Logo ===== */
.logo-section {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 200rpx;
}

.logo-img {
  width: 440rpx;
  height: 440rpx;
  display: block;
}

/* ===== 中间留白 ===== */
.spacer {
  flex: 1;
}

/* ===== 底部区域 ===== */
.bottom-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

/* ===== 协议区域 ===== */
.agreement-section {
  display: flex;
  justify-content: center;
}

.checkbox-wrapper {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #D1D5DB;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.checkbox.checked {
  background: #E8A400;
  border-color: #E8A400;
}

.check-icon {
  color: #ffffff;
  font-size: 22rpx;
  font-weight: bold;
}

.agreement-text {
  font-size: 24rpx;
  color: #6B7280;
}

.link {
  font-size: 24rpx;
  color: #576B95;
}

.divider {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* ===== 登录按钮 ===== */
.login-btn {
  width: 100%;
}

.wechat-btn {
  width: 100% !important;
  height: 96rpx !important;
  background: linear-gradient(135deg, #E8A400 0%, #C98D00 100%) !important;
  color: #ffffff !important;
  border-radius: 48rpx !important;
  font-size: 32rpx !important;
  line-height: 96rpx !important;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none !important;
  box-shadow: 0 8rpx 24rpx rgba(232, 164, 0, 0.2);
}

.wechat-btn::after {
  border: none !important;
}

.btn-text {
  margin-left: 16rpx;
}

/* ===== 协议弹窗 ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
  z-index: 10000;
}

.modal-content {
  width: 650rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  max-height: 75vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  padding: 32rpx;
  border-bottom: 1rpx solid #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.modal-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1E293B;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #94A3B8;
}

.modal-body {
  padding: 24rpx;
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  max-height: 55vh;
  width: 602rpx;
}

.article {
  width: 100%;
  overflow: hidden;
}

.section {
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #1E293B;
  text-align: center;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #F3F4F6;
  word-break: break-all;
}

.section-subtitle {
  font-size: 24rpx;
  font-weight: bold;
  color: #1E293B;
  margin-bottom: 12rpx;
  padding-left: 12rpx;
  border-left: 4rpx solid #E8A400;
  word-break: break-all;
}

.section-paragraph {
  font-size: 22rpx;
  color: #475569;
  line-height: 1.8;
  text-indent: 44rpx;
  margin-bottom: 12rpx;
  word-break: break-all;
}

.section-list {
  padding-left: 16rpx;
}

.list-item {
  display: flex;
  margin-bottom: 10rpx;
}

.list-number {
  font-size: 22rpx;
  color: #E8A400;
  font-weight: 500;
  flex-shrink: 0;
  margin-right: 8rpx;
}

.list-text {
  font-size: 22rpx;
  color: #475569;
  line-height: 1.8;
  flex: 1;
  word-break: break-all;
}

.modal-footer {
  padding: 28rpx 36rpx;
  border-top: 1rpx solid #F3F4F6;
  flex-shrink: 0;
}

.modal-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #E8A400 0%, #C98D00 100%);
  color: #ffffff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}
