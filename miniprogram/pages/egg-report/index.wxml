<view class="egg-report-page">
  <!-- 未登录提示栏 -->
  <view wx:if="{{!isLoggedIn}}" class="login-hint-bar">
    <text class="login-hint-text">登录后可管理宠物资料、记录和打印标签</text>
    <view class="login-hint-btn" bindtap="goToLogin">登录</view>
  </view>
  <!-- 筛选区域 -->
  <view class="filter-section">
    <view class="filter-row">
      <view class="filter-item">
        <text class="filter-label">开始</text>
        <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
          <view class="picker-btn">
            <text>{{startDate || '开始日期'}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
      <view class="filter-item">
        <text class="filter-label">结束</text>
        <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
          <view class="picker-btn">
            <text>{{endDate || '结束日期'}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
    </view>
    <view class="filter-row">
      <view class="filter-item">
        <text class="filter-label">种母</text>
        <picker mode="selector" range="{{femaleOptions}}" value="{{femaleIndex}}" bindchange="onFemaleChange">
          <view class="picker-btn">
            <text>{{femaleOptions[femaleIndex] || '全部'}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
      <view class="filter-actions">
        <view class="action-btn primary" bindtap="onQuery">查询</view>
        <view class="action-btn secondary" bindtap="onMonthStats">月统</view>
      </view>
    </view>
  </view>

  <!-- 表格头部 -->
  <view class="table-header">
    <text class="th th-serial">序号</text>
    <view class="th th-date sortable" bindtap="onSortDate">
      <text>日期</text>
      <text class="sort-icon">{{sortBy === 'date' ? (sortDesc ? '↑' : '↓') : '↕'}}</text>
    </view>
    <text class="th th-female">种母</text>
    <view class="th th-egg sortable" bindtap="onSortEgg">
      <text>产蛋-受精</text>
      <text class="sort-icon">{{sortBy === 'egg' ? (sortDesc ? '↑' : '↓') : '↕'}}</text>
    </view>
    <text class="th th-remark">备注</text>
  </view>

  <!-- 数据列表 -->
  <scroll-view scroll-y class="data-scroll">
    <view class="data-content">
      <view wx:for="{{groupedRecords}}" wx:key="year" class="year-group">
        <view class="year-label">{{item.year}}</view>
        <view wx:for="{{item.records}}" wx:key="index" wx:for-item="record" class="data-row">
          <text class="td td-serial">{{record.serial}}</text>
          <text class="td td-date">{{record.date}}</text>
          <text class="td td-female">{{record.femaleName}}</text>
          <text class="td td-egg">{{record.eggCount}}-{{record.fertilizedCount}}</text>
          <text class="td td-remark">{{record.remark || '-'}}</text>
        </view>
      </view>
      <view wx:if="{{!hasData}}" class="empty-state">
        <text class="empty-icon">📋</text>
        <text class="empty-text">暂无产蛋记录</text>
      </view>
    </view>
  </scroll-view>

  <!-- 统计区域 -->
  <view class="stats-section">
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-title">产蛋</text>
        <view class="stat-content">
          <text class="stat-value">{{stats.totalNests}}窝</text>
          <text class="stat-divider">|</text>
          <text class="stat-value">{{stats.totalEggs}}枚</text>
        </view>
      </view>
      <view class="stat-item">
        <text class="stat-title">受精</text>
        <view class="stat-content">
          <text class="stat-value">{{stats.fertilizedNests}}窝</text>
          <text class="stat-divider">|</text>
          <text class="stat-value">{{stats.fertilizedEggs}}枚</text>
        </view>
      </view>
      <view class="stat-item fertilization-rate">
        <text class="stat-title">受精率</text>
        <text class="stat-rate">{{stats.fertilizationRate}}%</text>
      </view>
    </view>
  </view>
</view>