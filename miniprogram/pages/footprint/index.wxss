/* ====== 基础布局 ====== */
.page {
  position: relative;
  min-height: 100vh;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #F8FAFB;
}

/* ====== 自定义导航栏 ====== */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: #F8FAFB;
}

.custom-nav.is-refreshing {
  flex-direction: column;
  height: auto;
  padding: 12rpx 0;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2D6A4F;
  text-align: center;
}

.nav-refresh-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #E8F5EE;
  border-top-color: #2D6A4F;
  border-radius: 50%;
  animation: navSpin 0.8s linear infinite;
}

@keyframes navSpin {
  to { transform: rotate(360deg); }
}

.nav-refresh-text {
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 4rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 360rpx;
  background: linear-gradient(180deg, #EDF2F7 0%, #F8FAFB 100%);
  z-index: 0;
}

/* ====== 顶部统计卡片 ====== */
.stats-card {
  position: relative;
  margin: 32rpx;
  margin-top: 48rpx;
  padding: 40rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #ffffff 0%, #EDF2F7 100%);
  box-shadow: 0 8rpx 32rpx rgba(45, 106, 79, 0.06);
  z-index: 1;
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.stats-title-wrap {
  display: flex;
  flex-direction: column;
}

.stats-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #2D6A4F;
  display: block;
  margin-bottom: 8rpx;
}

.stats-subtitle {
  font-size: 24rpx;
  color: rgba(82, 121, 111, 0.5);
}

.days-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  padding: 16rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(45, 106, 79, 0.08);
}

.days-num {
  font-size: 40rpx;
  font-weight: bold;
  line-height: 1;
  color: #2D6A4F;
}

.days-unit {
  font-size: 22rpx;
  margin-top: 6rpx;
  color: #2D6A4F;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-top: 28rpx;
  border-top: 2rpx solid rgba(45, 106, 79, 0.08);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-num {
  font-size: 44rpx;
  font-weight: bold;
  color: #2D6A4F;
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 6rpx;
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: rgba(45, 106, 79, 0.08);
}

/* ====== 时间线容器 ====== */
.timeline-wrapper {
  position: relative;
  margin: 0 32rpx;
  z-index: 1;
}

/* ====== 空状态 ====== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
  border-radius: 32rpx;
  background: #ffffff;
}

.empty-emoji {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.8;
}

.empty-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #2D6A4F;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #94A3B8;
  margin-bottom: 40rpx;
}

.empty-action {
  padding: 20rpx 48rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
  background: linear-gradient(135deg, #2D6A4F 0%, #1B4332 100%);
}

/* ====== 时间线分组 ====== */
.timeline-group {
  margin-bottom: 36rpx;
}

.group-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.group-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #2D6A4F;
  box-shadow: 0 0 0 6rpx rgba(45, 106, 79, 0.08);
  margin-right: 16rpx;
  flex-shrink: 0;
}

.group-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #2D6A4F;
  flex: 1;
}

.group-count {
  font-size: 24rpx;
  color: #94A3B8;
}

/* ====== 足迹卡片 ====== */
.group-items {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.footprint-card {
  display: flex;
  align-items: stretch;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(45, 106, 79, 0.08), 0 0 0 1rpx rgba(45, 106, 79, 0.04);
  position: relative;
  transition: all 0.22s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.fp-media {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  position: relative;
  background: #F8FAFB;
  overflow: hidden;
}

.fp-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.fp-video-wrapper {
  width: 100%;
  height: 100%;
  position: relative;
}

.fp-video-badge {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(45, 106, 79, 0.5);
  color: #ffffff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fp-content {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: flex-start;
  min-width: 0;
  min-height: 200rpx;
}

.fp-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.fp-type {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(45, 106, 79, 0.06);
  color: #2D6A4F;
  flex-shrink: 0;
}

.fp-date {
  font-size: 24rpx;
  color: #94A3B8;
  flex-shrink: 0;
}

.fp-desc {
  font-size: 28rpx;
  color: #2D6A4F;
  line-height: 1.5;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.fp-pet-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(45, 106, 79, 0.05);
  align-self: flex-start;
  margin-top: 8rpx;
}

.fp-pet-icon {
  font-size: 22rpx;
}

.fp-pet-name {
  font-size: 22rpx;
  color: #2D6A4F;
}

.fp-delete {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(45, 106, 79, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.fp-delete-icon {
  font-size: 28rpx;
  color: #94A3B8;
  line-height: 1;
}

/* ====== FAB 浮动按钮 ====== */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(180rpx + env(safe-area-inset-bottom));
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2D6A4F 0%, #1B4332 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(45, 106, 79, 0.25);
  transition: all 0.25s cubic-bezier(0.25, 1.5, 0.5, 1);
  z-index: 99;
}

.fab-icon {
  font-size: 52rpx;
  color: #ffffff;
  font-weight: 300;
  line-height: 1;
}

.fab-hidden {
  transform: scale(0.1);
  opacity: 0;
  pointer-events: none;
}

/* ====== 批量管理（列表上方） ====== */
.edit-entry {
  display: flex;
  justify-content: flex-end;
  margin: 0 32rpx 20rpx 32rpx;
}

.edit-entry-text {
  font-size: 26rpx;
  color: #2D6A4F;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(45, 106, 79, 0.05);
}

.edit-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 32rpx 20rpx 32rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #ffffff 0%, #F8FAFB 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(45, 106, 79, 0.06);
}

.edit-bar-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.select-all-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.select-all-text {
  font-size: 26rpx;
  color: #2D6A4F;
  font-weight: 500;
}

.selected-count {
  font-size: 22rpx;
  color: #94A3B8;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #CBD5E1;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ffffff;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.checkbox.checked {
  border-color: #2D6A4F;
  background-color: #2D6A4F;
}

.check-mark {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: bold;
  line-height: 1;
}

.edit-bar-right {
  display: flex;
  gap: 16rpx;
}

.edit-bar-btn {
  font-size: 26rpx;
  font-weight: 500;
  padding: 10rpx 24rpx;
  border-radius: 16rpx;
  color: #2D6A4F;
  background: rgba(45, 106, 79, 0.05);
}

.edit-bar-delete {
  color: #E76F51;
  background: rgba(231, 111, 81, 0.08);
}

/* ====== 卡片复选框 ====== */
.footprint-card.edit-mode {
  background: #FFFFFF;
}

.footprint-card.selected {
  border: 2rpx solid #2D6A4F;
  box-shadow: 0 0 0 2rpx rgba(45, 106, 79, 0.15);
}

.card-checkbox {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  z-index: 10;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-checkbox .checkbox {
  width: 40rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.95);
}

/* 编辑模式下，让图片稍微缩进显示复选框 */
.footprint-card.edit-mode .fp-media {
  width: 180rpx;
  height: 180rpx;
  margin-left: 12rpx;
}

/* ====== 预览弹窗 ====== */
.preview-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(45, 106, 79, 0.92);
}

.preview-scroll {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 100%;
}

.preview-content {
  width: 100%;
  padding: 40rpx;
  padding-top: calc(88rpx + env(safe-area-inset-top));
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.preview-header {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.preview-title {
  font-size: 30rpx;
  color: #ffffff;
  font-weight: 500;
}

.preview-close {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-close-icon {
  font-size: 40rpx;
  color: #ffffff;
  font-weight: bold;
  line-height: 1;
}

.preview-image-wrapper,
.preview-video-wrapper {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.preview-image {
  max-width: 100%;
  max-height: 70vh;
  border-radius: 20rpx;
}

.preview-video {
  width: 100%;
  max-height: 70vh;
  border-radius: 20rpx;
}

.preview-play-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(45, 106, 79, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 48rpx;
}

.preview-pet-tag {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 32rpx;
  padding: 12rpx 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.12);
}

.preview-pet-name {
  font-size: 24rpx;
  color: #ffffff;
}

.preview-desc {
  width: 100%;
  font-size: 28rpx;
  color: #ffffff;
  line-height: 1.6;
  margin-top: 24rpx;
  text-align: center;
}

/* ====== 加载更多 ====== */
.load-more {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0 32rpx;
  gap: 16rpx;
}

.load-more-spinner {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid #E8F5EE;
  border-top-color: #2D6A4F;
  animation: loadMoreSpin 0.9s linear infinite;
}

@keyframes loadMoreSpin {
  to { transform: rotate(360deg); }
}

.load-more-text {
  font-size: 24rpx;
  color: #94A3B8;
}

/* ========== 骨架屏样式 ========== */
.skeleton-container {
  padding: 0 32rpx;
  position: relative;
  overflow: hidden;
}

.skeleton-container::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 40%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent);
  animation: skeleton-sweep 1.8s ease-in-out infinite;
  z-index: 1;
  pointer-events: none;
  will-change: transform;
}

.skeleton-stats-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(45, 106, 79, 0.04);
}

.skeleton-stats-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.skeleton-stats-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.skeleton-stats-title {
  width: 120rpx;
  height: 40rpx;
  background: #EDF2F7;
  border-radius: 8rpx;
}

.skeleton-stats-subtitle {
  width: 280rpx;
  height: 24rpx;
  background: #EDF2F7;
  border-radius: 6rpx;
}

.skeleton-days-badge {
  width: 100rpx;
  height: 80rpx;
  background: #EDF2F7;
  border-radius: 16rpx;
}

.skeleton-stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.skeleton-stat-item {
  flex: 1;
  height: 60rpx;
  background: #EDF2F7;
  border-radius: 8rpx;
}

.skeleton-stat-divider {
  width: 2rpx;
  height: 40rpx;
  background: #EDF2F7;
}

.skeleton-footprint-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.skeleton-footprint-group {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.skeleton-group-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.skeleton-group-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #EDF2F7;
}

.skeleton-group-title {
  width: 160rpx;
  height: 32rpx;
  background: #EDF2F7;
  border-radius: 6rpx;
}

.skeleton-footprint-card {
  display: flex;
  gap: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(45, 106, 79, 0.04);
}

.skeleton-footprint-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background: #EDF2F7;
  flex-shrink: 0;
}

.skeleton-footprint-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 16rpx;
}

.skeleton-footprint-meta {
  width: 60%;
  height: 28rpx;
  background: #EDF2F7;
  border-radius: 6rpx;
}

.skeleton-footprint-desc {
  width: 80%;
  height: 24rpx;
  background: #EDF2F7;
  border-radius: 6rpx;
}

@keyframes skeleton-sweep {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(450%); }
}

