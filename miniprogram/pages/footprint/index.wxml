<view class="page" style="padding-top: {{totalNavHeight}}rpx;">
  
  <!-- 自定义导航栏（含刷新状态） -->
  <view class="custom-nav {{refreshing ? 'is-refreshing' : ''}}" style="padding-top: {{statusBarHeight}}px">
    <block wx:if="{{refreshing}}">
      <view class="nav-refresh-spinner"></view>
      <text class="nav-refresh-text">刷新中...</text>
    </block>
    <text wx:else class="nav-title">足迹</text>
  </view>

  <!-- 骨架屏 -->
  <view wx:if="{{showSkeleton}}" class="skeleton-container">
    <!-- 统计卡片骨架 -->
    <view class="skeleton-stats-card">
      <view class="skeleton-stats-header">
        <view class="skeleton-stats-info">
          <view class="skeleton-stats-title"></view>
          <view class="skeleton-stats-subtitle"></view>
        </view>
        <view class="skeleton-days-badge"></view>
      </view>
      <view class="skeleton-stats-row">
        <view class="skeleton-stat-item"></view>
        <view class="skeleton-stat-divider"></view>
        <view class="skeleton-stat-item"></view>
        <view class="skeleton-stat-divider"></view>
        <view class="skeleton-stat-item"></view>
      </view>
    </view>

    <!-- 足迹列表骨架 -->
    <view class="skeleton-footprint-list">
      <view class="skeleton-footprint-group">
        <view class="skeleton-group-header">
          <view class="skeleton-group-dot"></view>
          <view class="skeleton-group-title"></view>
        </view>
        <view class="skeleton-footprint-card">
          <view class="skeleton-footprint-image"></view>
          <view class="skeleton-footprint-content">
            <view class="skeleton-footprint-meta"></view>
            <view class="skeleton-footprint-desc"></view>
          </view>
        </view>
        <view class="skeleton-footprint-card">
          <view class="skeleton-footprint-image"></view>
          <view class="skeleton-footprint-content">
            <view class="skeleton-footprint-meta"></view>
            <view class="skeleton-footprint-desc"></view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 未登录提示 -->
  <view wx:elif="{{!isLoggedIn}}" class="not-logged-in">
    <view class="not-logged-in-icon">📝</view>
    <view class="not-logged-in-title">登录后查看足迹</view>
    <view class="not-logged-in-desc">登录后可查看您的操作记录和陪伴天数</view>
    <view class="not-logged-in-btn" bindtap="goToLogin">立即登录</view>
  </view>

  <!-- 真实内容 -->
  <view wx:else>
    <!-- 陪伴统计 -->
    <view class="stats-card">
      <view class="stats-header">
        <view class="stats-title-wrap">
          <text class="stats-title">足迹</text>
          <text class="stats-subtitle">记录和您一起走过的每一天</text>
        </view>
        <view class="days-badge">
          <text class="days-num">{{companyDays}}</text>
          <text class="days-unit">天</text>
        </view>
      </view>
      <view class="stats-row">
        <view class="stat-item">
          <text class="stat-num">{{totalPets}}</text>
          <text class="stat-label">宠物</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num">{{totalRecords}}</text>
          <text class="stat-label">档案</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num">{{footprints.length}}</text>
          <text class="stat-label">足迹</text>
        </view>
      </view>
    </view>

    <!-- 批量管理（列表上方） -->
  <view wx:if="{{!isEditMode && footprints.length > 0}}" class="edit-entry" bindtap="enterEditMode">
    <text class="edit-entry-text">批量管理</text>
  </view>
  <view wx:if="{{isEditMode}}" class="edit-bar">
    <view class="edit-bar-left">
      <view class="select-all-btn" bindtap="toggleSelectAll">
        <view class="checkbox {{allSelected ? 'checked' : ''}}">
          <text wx:if="{{allSelected}}" class="check-mark">✓</text>
        </view>
        <text class="select-all-text">{{allSelected ? '取消全选' : '全选'}}</text>
        <text wx:if="{{selectedCount > 0}}" class="selected-count">已选 {{selectedCount}} 条</text>
      </view>
    </view>
    <view class="edit-bar-right">
      <view class="edit-bar-btn" bindtap="exitEditMode">完成</view>
      <view class="edit-bar-btn edit-bar-delete {{selectedCount > 0 ? 'active' : ''}}" bindtap="deleteSelected">删除</view>
    </view>
  </view>

  <!-- 时间线 -->
  <view class="timeline-wrapper">
    <view wx:if="{{!footprints || footprints.length === 0}}" class="empty-state">
      <view class="empty-emoji">📷</view>
      <text class="empty-title">还没有足迹</text>
      <text class="empty-desc">记录下宠物的每一个瞬间吧</text>
      <view class="empty-action" bindtap="addFootprint">
        <text>添加第一条足迹</text>
      </view>
    </view>

    <block wx:else>
      <view wx:for="{{groupedFootprints}}" wx:for-item="group" wx:key="key" class="timeline-group">
        <view class="group-header">
          <view class="group-dot"></view>
          <text class="group-title">{{group.title}}</text>
          <text class="group-count">{{group.items.length}} 条</text>
        </view>
        <view class="group-items">
          <view wx:for="{{group.items}}" wx:for-item="fp" wx:key="id" class="footprint-card {{isEditMode ? 'edit-mode' : ''}} {{selectedMap[fp.id] ? 'selected' : ''}}" catchtap="onCardTap" data-id="{{fp.id}}" data-footprint="{{fp}}">
            <view class="fp-media">
              <view wx:if="{{fp.photos && fp.photos.length > 1}}" class="fp-images-grid">
                <image wx:for="{{fp.photos}}" wx:for-item="photo" wx:key="index" class="fp-grid-image" src="{{photo}}" mode="aspectFill" lazy-load="true" />
                <view wx:if="{{fp.photos.length > 9}}" class="fp-more-count">{{fp.photos.length}}</view>
              </view>
              <image wx:else class="fp-image" src="{{fp.photos && fp.photos[0] || fp.path || fp.url}}" mode="aspectFill" lazy-load="true" binderror="onPhotoError" data-id="{{fp.id}}" />
            </view>
            <view class="fp-content">
              <view class="fp-meta">
                <text class="fp-type">{{fp.action || '照片'}}</text>
                <text class="fp-date">{{fp.date}} {{fp.time}}</text>
              </view>
              <view wx:if="{{fp.description}}" class="fp-desc">{{fp.description}}</view>
              <view wx:if="{{fp.petName}}" class="fp-pet-tag">
                <text class="fp-pet-icon">🐢</text>
                <text class="fp-pet-name">{{fp.petName}}</text>
              </view>
            </view>
            <view wx:if="{{!isEditMode}}" class="fp-delete" catchtap="deleteFootprint" data-id="{{fp.id}}">
              <text class="fp-delete-icon">×</text>
            </view>
          </view>
        </view>
      </view>
      
      <view wx:if="{{hasMore || loadingMore}}" class="load-more">
        <view wx:if="{{loadingMore}}" class="load-more-spinner"></view>
        <text wx:if="{{loadingMore}}" class="load-more-text">加载中...</text>
        <text wx:elif="{{hasMore}}" class="load-more-text">上拉加载更多</text>
      </view>
    </block>
  </view>

  <!-- 浮动添加按钮 -->
  <view class="fab {{isEditMode ? 'fab-hidden' : ''}}" bindtap="addFootprint">
    <view class="fab-icon">+</view>
  </view>

  <!-- 预览弹窗 -->
  <view wx:if="{{showPreviewModal && selectedFootprint}}" class="preview-modal">
    <view class="preview-overlay" bindtap="hidePreview"></view>
    
    <!-- 顶部栏 -->
    <view class="preview-top-bar">
      <text class="preview-title">{{selectedFootprint.date}} {{selectedFootprint.time}}</text>
      <view class="preview-close" bindtap="hidePreview">
        <text class="preview-close-icon">✕</text>
      </view>
    </view>
    
    <!-- 图片区域 -->
    <view class="preview-images-area">
      <swiper 
        wx:if="{{selectedFootprint.photos && selectedFootprint.photos.length > 1}}" 
        class="preview-swiper" 
        indicator-dots 
        circular
        current="{{previewCurrent}}"
        bindchange="onPreviewSwiperChange"
      >
        <swiper-item wx:for="{{selectedFootprint.photos}}" wx:for-item="photo" wx:key="index">
          <image class="preview-image" src="{{photo}}" mode="widthFix" />
        </swiper-item>
      </swiper>
      <image wx:else class="preview-image" src="{{selectedFootprint.photos && selectedFootprint.photos[0] || selectedFootprint.path || selectedFootprint.url}}" mode="widthFix" binderror="onPhotoError" data-id="{{selectedFootprint.id}}" />
      <view wx:if="{{selectedFootprint.photos && selectedFootprint.photos.length > 1}}" class="preview-pagination">
        <text class="preview-page-text">{{previewCurrent + 1}} / {{selectedFootprint.photos.length}}</text>
      </view>
    </view>
    
    <!-- 底部信息 -->
    <view class="preview-bottom-bar">
      <view wx:if="{{selectedFootprint.description}}" class="preview-desc">{{selectedFootprint.description}}</view>
      <view wx:if="{{selectedFootprint.petName}}" class="preview-pet-tag">
        <text class="fp-pet-icon">🐢</text>
        <text class="preview-pet-name">{{selectedFootprint.petName}}</text>
      </view>
    </view>
  </view>

  <!-- 描述输入弹窗 -->
  <view wx:if="{{showDescModal}}" class="desc-modal">
    <view class="desc-overlay" bindtap="hideDescModal"></view>
    <view class="desc-content">
      <view class="desc-header">
        <text class="desc-title">添加描述</text>
        <view class="desc-close" bindtap="hideDescModal">×</view>
      </view>
      <view class="desc-body">
        <textarea 
          class="desc-input" 
          placeholder="输入这张照片的描述..." 
          value="{{descValue}}" 
          bindinput="onDescInput"
          maxlength="200"
          auto-height
        />
        <view class="desc-count">{{descValue.length}}/200</view>
      </view>
      <view class="desc-footer">
        <view class="desc-btn desc-btn-cancel" bindtap="hideDescModal">取消</view>
        <view class="desc-btn desc-btn-confirm" bindtap="confirmDesc">确定</view>
      </view>
    </view>
    </view>
  </view>
</view>