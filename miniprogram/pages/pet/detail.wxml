<view class="page-detail">
  <view class="nav-bar nav-bar-detail" style="padding-top:{{statusBarHeight}}px">
    <view class="nav-back" bindtap="goBack"><image class="nav-back-icon" src="/icons/返回.png" mode="aspectFit"/></view>
    <text class="nav-title">{{isPublicMode ? '公开档案' : '宠物详情'}}</text>
  </view>

  <scroll-view style="padding-top:{{totalNavHeight}}px" scroll-y class="scroll-main">
  <view class="detail-inner">
    <!-- 未登录 -->
    <view wx:if="{{!isLoggedIn && !isPublicMode}}" class="login-bar" bindtap="goToLogin">
      <text class="login-bar-text">登录后可管理宠物资料和记录</text>
      <view class="login-bar-btn"><text>立即登录 ›</text></view>
    </view>

    <!-- 图片轮播 -->
    <view wx:if="{{pet.photos&&pet.photos.length}}" class="photo-swiper">
      <swiper indicator-dots="{{pet.photos.length>1}}" circular autoplay class="photo-swiper-inner">
        <swiper-item wx:for="{{pet.photos}}" wx:key="*this">
          <image src="{{item}}" mode="aspectFill" style="width:100%;height:100%"/>
        </swiper-item>
      </swiper>
      <!-- 名字浮在图片左下角 -->
      <view class="photo-name-badge">{{pet.alias||pet.name||'未命名'}}</view>
    </view>
    <view wx:else class="photo-empty">
      <text>🐢</text>
      <view class="photo-name-badge-static">{{pet.alias||pet.name||'未命名'}}</view>
    </view>

    <!-- 名称 & 标签 -->
    <view class="section-card profile-card">
      <view class="profile-header">
        <view class="profile-title-col">
          <view class="profile-name-line">
            <text class="profile-name">{{pet.alias||pet.name||'未命名'}}</text>
            <view class="tag {{pet.gender==='公'?'tag-male':pet.gender==='母'?'tag-female':'tag-primary'}} profile-gender-tag">{{pet.gender}}</view>
          </view>
          <view class="profile-info-line">
            <text class="profile-category">{{pet.category||'未分类'}}</text>
            <text class="profile-dot">·</text>
            <view class="profile-status-tag status-{{pet.status==='预警'?'warning':pet.status==='待配'?'pending':'normal'}}">{{pet.status||'正常'}}</view>
            <view wx:if="{{pet.price}}" class="profile-offspring-price">子代 ¥{{pet.price}}</view>
          </view>
        </view>
      </view>
      <view class="profile-tags-row">
        <view class="profile-big-tag tag-father">
          <text class="big-tag-label">父本</text>
          <text class="big-tag-value">{{pet.fatherName || '未关联'}}</text>
        </view>
        <view class="profile-big-tag tag-mother">
          <text class="big-tag-label">母本</text>
          <text class="big-tag-value">{{pet.motherName || '未关联'}}</text>
        </view>
        <view class="profile-big-tag tag-partner">
          <text class="big-tag-label">配偶</text>
          <text class="big-tag-value">{{pet.partnerName || '未关联'}}</text>
        </view>
      </view>
    </view>

    <!-- 家族谱系 -->
    <view wx:if="{{pet.father || pet.mother || pet.partner || pet.fatherName || pet.motherName || pet.partnerName || paternalLine.length || maternalLine.length || pedigreeStats.totalAncestors > 0}}" class="section-card">
      <view class="section-heading">
        <text class="section-title">家族谱系</text>
        <text class="section-sub">先看血缘主线，再继续追到配偶和子代。</text>
      </view>
      <view class="family-tree">
        <view class="tree-current-row">
          <view class="tree-spacer"></view>
          <view class="tree-current-node">
            <view class="tree-badge tree-badge-current">当前个体</view>
            <view class="tree-avatar-hero">
              <image wx:if="{{pet.photos&&pet.photos.length}}" src="{{pet.photos[0]}}" mode="aspectFill"/>
              <text wx:else>🐢</text>
            </view>
            <text class="tree-current-name">{{pet.alias||pet.name||'未命名'}}</text>
          </view>
          <view class="tree-partner-node" bindtap="{{!isReadOnly?'openPartnerModal':''}}">
            <text class="tree-partner-label">当前配偶</text>
            <view class="tree-avatar tree-avatar-partner {{pet.partnerName?'':'tree-empty'}}">
              <image wx:if="{{pet.partnerPhoto}}" src="{{pet.partnerPhoto}}" mode="aspectFill"/>
              <text wx:else>💕</text>
            </view>
            <text class="tree-name">{{pet.partnerName||'未配对'}}</text>
            <text class="tree-arrow">›</text>
          </view>
        </view>

        <view class="tree-down-line"></view>

        <view class="tree-parent-section">
          <view class="tree-badge tree-badge-parent">父母辈</view>
          <text class="tree-parent-desc">第1代 · 当前个体的直接亲本</text>
          <view class="tree-parent-grid">
            <view class="tree-node" bindtap="onFatherTreeTap">
              <text class="tree-role">父本</text>
              <view class="tree-avatar {{(pedigreeData.fullTree.father || pet.fatherName) ? '' : 'tree-empty'}}">
                <image wx:if="{{pedigreeData.fullTree.father.photos && pedigreeData.fullTree.father.photos.length}}" src="{{pedigreeData.fullTree.father.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree"/>
                <text wx:else>♂</text>
              </view>
              <text class="tree-name">{{pedigreeData.fullTree.father.alias || pedigreeData.fullTree.father.name || pet.fatherName || '未知'}}</text>
              <text class="tree-arrow" wx:if="{{pedigreeData.fullTree.father || !isReadOnly}}">›</text>
            </view>
            <view class="tree-node" bindtap="onMotherTreeTap">
              <text class="tree-role">母本</text>
              <view class="tree-avatar {{(pedigreeData.fullTree.mother || pet.motherName) ? '' : 'tree-empty'}}">
                <image wx:if="{{pedigreeData.fullTree.mother.photos && pedigreeData.fullTree.mother.photos.length}}" src="{{pedigreeData.fullTree.mother.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree"/>
                <text wx:else>♀</text>
              </view>
              <text class="tree-name">{{pedigreeData.fullTree.mother.alias || pedigreeData.fullTree.mother.name || pet.motherName || '未知'}}</text>
              <text class="tree-arrow" wx:if="{{pedigreeData.fullTree.mother || !isReadOnly}}">›</text>
            </view>
          </view>
        </view>

        <!-- 第2代：祖父母 -->
        <block wx:if="{{pedigreeData.hasGen2}}">
          <view class="tree-down-line"></view>
          <view class="tree-parent-section tree-ancestor-section">
            <view class="tree-badge tree-badge-ancestor">祖父母辈</view>
            <text class="tree-parent-desc">第2代 · 父母双方的上一代</text>
            <view class="tree-ancestor-grid">
              <view wx:if="{{pedigreeData.fullTree.father.father}}" class="tree-node tree-node-ancestor" bindtap="viewAncestorDetail" data-id="{{pedigreeData.fullTree.father.father.id}}">
                <text class="tree-role">祖父</text>
                <view class="tree-avatar tree-avatar-ancestor">
                  <image wx:if="{{pedigreeData.fullTree.father.father.photos && pedigreeData.fullTree.father.father.photos.length}}" src="{{pedigreeData.fullTree.father.father.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree"/>
                  <text wx:else>♂</text>
                </view>
                <text class="tree-name">{{pedigreeData.fullTree.father.father.alias || pedigreeData.fullTree.father.father.name || '未命名'}}</text>
              </view>
              <view wx:if="{{pedigreeData.fullTree.father.mother}}" class="tree-node tree-node-ancestor" bindtap="viewAncestorDetail" data-id="{{pedigreeData.fullTree.father.mother.id}}">
                <text class="tree-role">祖母</text>
                <view class="tree-avatar tree-avatar-ancestor">
                  <image wx:if="{{pedigreeData.fullTree.father.mother.photos && pedigreeData.fullTree.father.mother.photos.length}}" src="{{pedigreeData.fullTree.father.mother.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree"/>
                  <text wx:else>♀</text>
                </view>
                <text class="tree-name">{{pedigreeData.fullTree.father.mother.alias || pedigreeData.fullTree.father.mother.name || '未命名'}}</text>
              </view>
              <view wx:if="{{pedigreeData.fullTree.mother.father}}" class="tree-node tree-node-ancestor" bindtap="viewAncestorDetail" data-id="{{pedigreeData.fullTree.mother.father.id}}">
                <text class="tree-role">外祖父</text>
                <view class="tree-avatar tree-avatar-ancestor">
                  <image wx:if="{{pedigreeData.fullTree.mother.father.photos && pedigreeData.fullTree.mother.father.photos.length}}" src="{{pedigreeData.fullTree.mother.father.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree"/>
                  <text wx:else>♂</text>
                </view>
                <text class="tree-name">{{pedigreeData.fullTree.mother.father.alias || pedigreeData.fullTree.mother.father.name || '未命名'}}</text>
              </view>
              <view wx:if="{{pedigreeData.fullTree.mother.mother}}" class="tree-node tree-node-ancestor" bindtap="viewAncestorDetail" data-id="{{pedigreeData.fullTree.mother.mother.id}}">
                <text class="tree-role">外祖母</text>
                <view class="tree-avatar tree-avatar-ancestor">
                  <image wx:if="{{pedigreeData.fullTree.mother.mother.photos && pedigreeData.fullTree.mother.mother.photos.length}}" src="{{pedigreeData.fullTree.mother.mother.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree"/>
                  <text wx:else>♀</text>
                </view>
                <text class="tree-name">{{pedigreeData.fullTree.mother.mother.alias || pedigreeData.fullTree.mother.mother.name || '未命名'}}</text>
              </view>
            </view>
          </view>
        </block>

        <!-- 第3代：曾祖父母 -->
        <block wx:if="{{pedigreeData.hasGen3}}">
          <view class="tree-down-line"></view>
          <view class="tree-parent-section tree-ancestor-section">
            <view class="tree-badge tree-badge-ancestor">曾祖父母辈</view>
            <text class="tree-parent-desc">第3代 · 再上一代的直系血亲</text>
            <view class="tree-ancestor-grid">
              <view wx:if="{{pedigreeData.fullTree.father.father.father}}" class="tree-node tree-node-ancestor" bindtap="viewAncestorDetail" data-id="{{pedigreeData.fullTree.father.father.father.id}}">
                <text class="tree-role">曾祖父</text>
                <view class="tree-avatar tree-avatar-ancestor">
                  <image wx:if="{{pedigreeData.fullTree.father.father.father.photos && pedigreeData.fullTree.father.father.father.photos.length}}" src="{{pedigreeData.fullTree.father.father.father.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree"/>
                  <text wx:else>♂</text>
                </view>
                <text class="tree-name">{{pedigreeData.fullTree.father.father.father.alias || pedigreeData.fullTree.father.father.father.name || '未命名'}}</text>
              </view>
              <view wx:if="{{pedigreeData.fullTree.father.father.mother}}" class="tree-node tree-node-ancestor" bindtap="viewAncestorDetail" data-id="{{pedigreeData.fullTree.father.father.mother.id}}">
                <text class="tree-role">曾祖母</text>
                <view class="tree-avatar tree-avatar-ancestor">
                  <image wx:if="{{pedigreeData.fullTree.father.father.mother.photos && pedigreeData.fullTree.father.father.mother.photos.length}}" src="{{pedigreeData.fullTree.father.father.mother.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree"/>
                  <text wx:else>♀</text>
                </view>
                <text class="tree-name">{{pedigreeData.fullTree.father.father.mother.alias || pedigreeData.fullTree.father.father.mother.name || '未命名'}}</text>
              </view>
              <view wx:if="{{pedigreeData.fullTree.mother.father.father}}" class="tree-node tree-node-ancestor" bindtap="viewAncestorDetail" data-id="{{pedigreeData.fullTree.mother.father.father.id}}">
                <text class="tree-role">曾外祖父</text>
                <view class="tree-avatar tree-avatar-ancestor">
                  <image wx:if="{{pedigreeData.fullTree.mother.father.father.photos && pedigreeData.fullTree.mother.father.father.photos.length}}" src="{{pedigreeData.fullTree.mother.father.father.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree"/>
                  <text wx:else>♂</text>
                </view>
                <text class="tree-name">{{pedigreeData.fullTree.mother.father.father.alias || pedigreeData.fullTree.mother.father.father.name || '未命名'}}</text>
              </view>
              <view wx:if="{{pedigreeData.fullTree.mother.father.mother}}" class="tree-node tree-node-ancestor" bindtap="viewAncestorDetail" data-id="{{pedigreeData.fullTree.mother.father.mother.id}}">
                <text class="tree-role">曾外祖母</text>
                <view class="tree-avatar tree-avatar-ancestor">
                  <image wx:if="{{pedigreeData.fullTree.mother.father.mother.photos && pedigreeData.fullTree.mother.father.mother.photos.length}}" src="{{pedigreeData.fullTree.mother.father.mother.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree"/>
                  <text wx:else>♀</text>
                </view>
                <text class="tree-name">{{pedigreeData.fullTree.mother.father.mother.alias || pedigreeData.fullTree.mother.father.mother.name || '未命名'}}</text>
              </view>
            </view>
          </view>
        </block>
      </view>
    </view>

    <!-- 提醒 -->
    <view wx:if="{{upcomingReminders.length}}" class="section-card reminder-section-card">
      <view class="section-header">
        <text class="section-title">待办提醒</text>
        <text class="section-badge">{{upcomingReminders.length}}项</text>
      </view>
      <view class="reminder-card-grid">
        <view wx:for="{{upcomingReminders}}" wx:key="id" class="reminder-item">
          <view class="rem-icon">
            <text wx:if="{{item.type==='换水'}}">💧</text>
            <text wx:elif="{{item.type==='喂食'}}">🍽</text>
            <text wx:elif="{{item.type==='健康'}}">❤</text>
            <text wx:else>🥚</text>
          </view>
          <view class="rem-info">
            <text class="rem-type">{{item.type}}</text>
            <text class="rem-date">每{{item.intervalDays}}天 · 下次{{item.nextDueDate}}</text>
          </view>
          <view wx:if="{{!isReadOnly}}" class="rem-done {{item.doneToday?'done':''}}" catchtap="markReminderDone" data-id="{{item.id}}">
            <text>{{item.doneToday?'已完成':'完成'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 事件时间线 -->
    <view class="section-card event-section">
      <view class="pet-event-title-row">
        <text class="section-title pet-event-title">宠物事件</text>
        <view class="report-entries" wx:if="{{pet.gender === '母' || (pet.gender === '公' && (pet.partner || pet.partnerName))}}">
          <view class="report-entry press" bindtap="goToEggReport">
            <text class="report-entry-icon">🥚</text>
            <text class="report-entry-text">产蛋</text>
          </view>
          <view class="report-entry press" bindtap="goToHatchReport">
            <text class="report-entry-icon">🐣</text>
            <text class="report-entry-text">出苗</text>
          </view>
        </view>
      </view>

      <view class="date-filter-bar">
        <picker mode="date" value="{{selectedDate}}" bindchange="onDateChange" class="date-filter-picker">
          <view class="date-filter-btn press {{selectedDate ? 'active' : ''}}">
            <text class="date-filter-value">{{selectedDate || '选择日期'}}</text>
            <text class="date-filter-arrow">▾</text>
          </view>
        </picker>
        <view class="date-filter-sep"></view>
        <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange" class="date-filter-picker">
          <view class="date-filter-btn press {{endDate ? 'active' : ''}}">
            <text class="date-filter-value">{{endDate || '选择日期'}}</text>
            <text class="date-filter-arrow">▾</text>
          </view>
        </picker>
        <view wx:if="{{selectedDate || endDate}}" class="date-filter-clear press" bindtap="clearDateFilter">
          <text>×</text>
        </view>
      </view>

      <view class="pet-event-tabs">
        <view class="pet-event-tab {{currentEventTab==='全部事件'?'active':''}}" bindtap="setEventTab" data-tab="全部事件">
          <text class="pet-event-tab-icon">📋</text>
          <text class="pet-event-tab-text">全部</text>
        </view>
        <view class="pet-event-tab {{currentEventTab==='交配'?'active':''}}" bindtap="setEventTab" data-tab="交配">
          <text class="pet-event-tab-icon">💕</text>
          <text class="pet-event-tab-text">交配</text>
        </view>
        <view wx:if="{{pet.gender === '母'}}" class="pet-event-tab {{currentEventTab==='产蛋'?'active':''}}" bindtap="setEventTab" data-tab="产蛋">
          <text class="pet-event-tab-icon">🥚</text>
          <text class="pet-event-tab-text">产蛋</text>
        </view>
        <view wx:if="{{pet.gender === '母'}}" class="pet-event-tab {{currentEventTab==='出苗'?'active':''}}" bindtap="setEventTab" data-tab="出苗">
          <text class="pet-event-tab-icon">🐣</text>
          <text class="pet-event-tab-text">出苗</text>
        </view>
      </view>

      <view wx:if="{{filteredRecords.length}}" class="pet-event-grid">
        <view wx:for="{{filteredRecords}}" wx:key="id" class="pet-event-card press" bindtap="showRecordDetail" bindlongpress="onEventCardLongPress" data-id="{{item.id || item._id}}">
          <view class="pet-event-icon">
            <text>{{item.recordIcon}}</text>
          </view>
          <text class="pet-event-name">{{item.type || '事件'}}</text>
          <text class="pet-event-date">{{item.date || item.displayDate}}</text>
        </view>
      </view>
      <view wx:else class="empty-box pet-event-empty">
        <text class="empty-icon">📝</text>
        <text class="empty-text">暂无事件记录</text>
      </view>

      <view class="event-divider"></view>

      <view class="event-header">
        <text class="section-title">记录（{{filteredRecords.length}} 条）</text>
        <view class="event-collapse" bindtap="toggleEventCollapsed">
          <text>{{eventCollapsed ? '展开记录' : '收起记录'}}</text>
        </view>
      </view>
      <view wx:if="{{!eventCollapsed}}" class="event-tabs">
        <text wx:for="{{['全部事件','交配','产蛋','出苗','健康']}}" wx:key="*this"
              class="chip {{currentEventTab===item?'active':''}}"
              bindtap="setEventTab" data-tab="{{item}}">{{item}}</text>
      </view>
      <view wx:if="{{filteredRecords.length && !eventCollapsed}}" class="timeline">
        <view wx:for="{{filteredRecords}}" wx:key="id" class="timeline-item press" bindtap="showRecordDetail" bindlongpress="onEventCardLongPress" data-id="{{item.id || item._id}}">
          <view wx:if="{{item.showYear}}" class="tl-year-row">
            <text class="tl-year">{{item.displayYear}}</text>
            <view class="tl-year-line"></view>
          </view>
          <view class="tl-body">
            <view class="tl-rail">
              <view class="tl-dot {{item.type==='交配'?'dot-love':item.type==='产蛋'?'dot-egg':item.type==='出苗'?'dot-hatch':item.type==='健康'?'dot-health':'dot-default'}}"></view>
              <view class="tl-line"></view>
            </view>
            <view class="tl-card">
              <text class="tl-icon">{{item.recordIcon}}</text>
              <text class="tl-text">{{item.displayText}}</text>
              <image wx:if="{{item.coverImage}}" class="tl-image" src="{{item.coverImage}}" mode="aspectFill"/>
              <text class="tl-date">{{item.displayDate}}</text>
            </view>
          </view>
        </view>
      </view>
      <view wx:if="{{!filteredRecords.length}}" class="empty-box" style="padding:40rpx 0">
        <text class="empty-icon">📝</text>
        <text class="empty-text">暂无事件记录</text>
      </view>
    </view>

    <!-- 换公记录（仅母龟显示） -->
    <view wx:if="{{pet.gender === '母' && mateMaleList.length > 0}}" class="section-card mate-male-card">
      <view class="mate-male-header">
        <text class="mate-male-title">换公记录</text>
        <text class="mate-male-count">{{mateMaleList.length}} 只</text>
      </view>
      <scroll-view scroll-x class="mate-male-scroll">
        <view class="mate-male-list">
          <view wx:for="{{mateMaleList}}" wx:key="partnerId" class="mate-male-item {{item.isLatest?'latest':''}}">
            <view class="mate-male-photo-wrap">
              <image wx:if="{{item.photo}}" class="mate-male-photo" src="{{item.photo}}" mode="aspectFill"/>
              <view wx:else class="mate-male-photo mate-male-photo-placeholder">🐢</view>
              <view wx:if="{{item.isLatest}}" class="mate-male-latest-badge">最新</view>
            </view>
            <text class="mate-male-name">{{item.partnerName}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="safe-bottom"></view>
  </view>
  </scroll-view>

  <view wx:if="{{!isReadOnly}}" class="detail-action-bar safe-bottom">
    <view class="detail-action secondary press" bindtap="showMore">
      <text class="action-icon">•••</text>
      <text class="action-text">更多</text>
    </view>
    <button class="detail-action secondary press share-btn" open-type="share">
      <image class="action-icon-img" src="/icons/分享.png" mode="aspectFit"/>
      <text class="action-text">分享</text>
    </button>
    <view class="detail-action primary press" bindtap="addRecord">
      <image class="action-icon-img" src="/icons/加.png" mode="aspectFit"/>
      <text class="action-text">记录</text>
    </view>
  </view>

  <view wx:if="{{showEditModal}}" class="record-modal-mask" bindtap="hideEditModal">
    <view class="record-modal edit-pet-modal" catchtap="stopPropagation">
      <view class="record-modal-head">
        <text class="record-modal-title">编辑信息</text>
        <text class="record-modal-close" bindtap="hideEditModal">×</text>
      </view>

      <scroll-view scroll-y class="edit-pet-body">
        <!-- 照片 -->
        <view class="edit-pet-field">
          <text class="edit-pet-label">照片</text>
          <view class="edit-photo-grid">
            <view wx:for="{{editPhotoList}}" wx:key="*this" class="edit-photo-item">
              <image src="{{item}}" mode="aspectFill" class="edit-photo-img"/>
              <view class="edit-photo-del press" catchtap="removeEditPhoto" data-index="{{index}}"><text>×</text></view>
            </view>
            <view wx:if="{{editPhotoList.length<5}}" class="edit-photo-add press" bindtap="chooseEditPhoto"><text>＋</text></view>
          </view>
        </view>

        <view class="edit-pet-field">
          <text class="edit-pet-label">名称</text>
          <input class="record-input" placeholder="宠物名称" value="{{editForm.name}}" bindinput="onEditNameInput" />
        </view>
        <view class="edit-pet-field">
          <text class="edit-pet-label">别名</text>
          <input class="record-input" placeholder="可选" value="{{editForm.alias}}" bindinput="onEditAliasInput" />
        </view>
        <view class="edit-pet-field">
          <text class="edit-pet-label">价格</text>
          <input class="record-input" type="digit" placeholder="可选" value="{{editForm.price}}" bindinput="onEditPriceInput" />
        </view>
        <view class="edit-pet-field">
          <view class="edit-pet-label-row">
            <text class="edit-pet-label">分类</text>
            <text class="edit-pet-hint">点击分类选中，长按编辑名称</text>
          </view>
          <view class="edit-pet-chip-row">
            <view wx:for="{{categories}}" wx:key="*this" class="chip {{editForm.category===item?'active':''}}" bindtap="selectEditCategory" bindlongpress="editCategory" data-category="{{item}}">{{item}}</view>
            <view class="chip chip-add press" bindtap="addCategory">＋</view>
          </view>
        </view>
        <view class="edit-pet-field">
          <text class="edit-pet-label">性别</text>
          <view class="edit-pet-chip-row">
            <text class="chip {{editForm.gender==='公'?'active':''}}" bindtap="selectEditGender" data-gender="公">公</text>
            <text class="chip {{editForm.gender==='母'?'active':''}}" bindtap="selectEditGender" data-gender="母">母</text>
            <text class="chip {{editForm.gender==='未知'?'active':''}}" bindtap="selectEditGender" data-gender="未知">未知</text>
          </view>
        </view>
        <view class="edit-pet-field">
          <text class="edit-pet-label">状态</text>
          <view class="edit-pet-chip-row">
            <text class="chip {{editForm.status==='正常'?'active':''}}" bindtap="selectEditStatus" data-status="正常">正常</text>
            <text class="chip {{editForm.status==='待配'?'active':''}}" bindtap="selectEditStatus" data-status="待配">待配</text>
            <text class="chip {{editForm.status==='预警'?'active':''}}" bindtap="selectEditStatus" data-status="预警">预警</text>
          </view>
        </view>

        <!-- 更多：父本/母本/配偶 -->
        <view class="edit-pet-field">
          <view class="edit-pet-more-header press" bindtap="toggleEditManual">
            <text class="edit-pet-label">更多设置</text>
            <text class="edit-pet-more-arrow {{showEditManual?'open':''}}">▾</text>
          </view>
          <view wx:if="{{showEditManual}}" class="edit-pet-more-body">
            <view class="edit-pet-field">
              <text class="edit-pet-label">父本</text>
              <view class="edit-parent-row" bindtap="openFatherModal">
                <text class="edit-parent-value {{editForm.fatherName?'':'empty'}}">{{editForm.fatherName||'点击选择父本'}}</text>
                <text class="edit-parent-arrow">›</text>
              </view>
              <text wx:if="{{editForm.fatherName}}" class="edit-parent-clear press" bindtap="clearFather">清除</text>
            </view>
            <view class="edit-pet-field">
              <text class="edit-pet-label">母本</text>
              <view class="edit-parent-row" bindtap="openMotherModal">
                <text class="edit-parent-value {{editForm.motherName?'':'empty'}}">{{editForm.motherName||'点击选择母本'}}</text>
                <text class="edit-parent-arrow">›</text>
              </view>
              <text wx:if="{{editForm.motherName}}" class="edit-parent-clear press" bindtap="clearMother">清除</text>
            </view>
            <view class="edit-pet-field">
              <text class="edit-pet-label">配偶</text>
              <view class="edit-parent-row" bindtap="openPartnerModal">
                <text class="edit-parent-value {{editForm.partnerName?'':'empty'}}">{{editForm.partnerName||'点击选择配偶'}}</text>
                <text class="edit-parent-arrow">›</text>
              </view>
              <text wx:if="{{editForm.partnerName}}" class="edit-parent-clear press" bindtap="clearPartner">清除</text>
            </view>
          </view>
        </view>

        <view class="edit-pet-field edit-pet-switch-row">
          <view>
            <text class="edit-pet-label">公开展示</text>
            <text class="edit-pet-hint">允许通过分享页查看这只宠物</text>
          </view>
          <switch checked="{{editForm.isPublic}}" bindchange="onPublicSwitchChange" color="{{switchColor}}" />
        </view>
      </scroll-view>

      <view class="record-modal-actions">
        <view class="record-cancel press" bindtap="hideEditModal">取消</view>
        <view class="record-confirm press" bindtap="saveEdit">保存</view>
      </view>
    </view>
  </view>

  <view wx:if="{{showReminderEditModal}}" class="record-modal-mask" bindtap="closeReminderEdit">
    <view class="record-modal reminder-edit-modal" catchtap="stopPropagation">
      <view class="record-modal-head">
        <text class="record-modal-title">{{editingReminder ? '编辑提醒' : '新增提醒'}}</text>
        <text class="record-modal-close" bindtap="closeReminderEdit">×</text>
      </view>

      <view class="reminder-edit-body">
        <view class="edit-pet-field">
          <text class="edit-pet-label">提醒类型</text>
          <view class="reminder-type-grid">
            <view wx:for="{{reminderTypes}}" wx:key="*this" class="reminder-type-chip {{reminderForm.type===item?'active':''}}" bindtap="selectReminderType" data-type="{{item}}">
              <text class="reminder-type-icon">{{item==='换水'?'💧':item==='喂食'?'🍽':item==='健康'?'❤':'🥚'}}</text>
              <text class="reminder-type-text">{{item}}</text>
            </view>
          </view>
        </view>
        <view class="edit-pet-field">
          <text class="edit-pet-label">间隔天数</text>
          <view class="reminder-input-wrap">
            <input class="record-input reminder-days-input" type="number" placeholder="如 7" value="{{reminderForm.intervalDays}}" bindinput="onReminderIntervalInput" />
            <text class="reminder-unit">天</text>
          </view>
        </view>
        <view class="edit-pet-field">
          <text class="edit-pet-label">上次完成日期</text>
          <picker mode="date" value="{{reminderForm.lastDone || today}}" end="{{today}}" bindchange="onReminderLastDoneChange">
            <view class="reminder-date-picker">
              <text>{{reminderForm.lastDone || '选择日期（可选）'}}</text>
              <text class="date-filter-arrow">▾</text>
            </view>
          </picker>
          <text class="edit-pet-hint">不选则从今天开始计算</text>
        </view>
      </view>

      <view class="record-modal-actions">
        <view class="record-cancel press" bindtap="closeReminderEdit">取消</view>
        <view class="record-confirm press" bindtap="submitReminder">{{editingReminder ? '保存' : '添加'}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{showAddRecordModal}}" class="record-modal-mask" bindtap="hideAddRecordModal">
    <view class="record-modal" catchtap="stopPropagation">
      <view class="record-modal-head">
        <text class="record-modal-title">新增记录</text>
        <text class="record-modal-close" bindtap="hideAddRecordModal">×</text>
      </view>

      <view class="record-type-row">
        <text wx:for="{{addRecordTypes}}" wx:key="*this"
              class="chip {{newRecord.type===item?'active':''}}"
              bindtap="selectRecordType" data-type="{{item}}">{{item}}</text>
      </view>

      <view wx:if="{{newRecord.type==='产蛋'}}" class="record-field-grid">
        <input class="record-input" type="number" placeholder="产蛋数" value="{{newRecord.eggCount}}" bindinput="onEggCountInput"/>
        <input class="record-input" type="number" placeholder="受精数" value="{{newRecord.fertilizedCount}}" bindinput="onFertilizedCountInput"/>
      </view>

      <view wx:if="{{newRecord.type==='出苗'}}" class="record-field-grid">
        <input class="record-input" type="number" placeholder="出苗数" value="{{newRecord.hatchCount}}" bindinput="onHatchCountInput"/>
        <input class="record-input" type="number" placeholder="全品数" value="{{newRecord.gradeACount}}" bindinput="onGradeAInput"/>
        <input class="record-input" type="number" placeholder="瑕疵数" value="{{newRecord.defectCount}}" bindinput="onDefectInput"/>
      </view>

      <!-- 交配记录：选择配对对象 -->
      <view wx:if="{{newRecord.type==='交配'}}" class="record-partner-row">
        <text class="record-partner-label">配对对象</text>
        <view wx:if="{{recordPartner}}" class="record-partner-selected press" bindtap="openRecordPartnerModal">
          <text class="record-partner-name">{{recordPartner.alias||recordPartner.name}}</text>
          <text class="record-partner-change">更换</text>
        </view>
        <view wx:else class="record-partner-select press" bindtap="openRecordPartnerModal">
          <text class="record-partner-placeholder">选择{{pet.gender==='公'?'母':'公'}}龟</text>
          <text class="record-partner-arrow">›</text>
        </view>
      </view>

      <textarea class="record-textarea" placeholder="记录今天发生了什么..." value="{{newRecord.text}}" bindinput="onRecordTextInput"/>

      <view class="record-modal-actions">
        <view class="record-cancel press" bindtap="hideAddRecordModal">取消</view>
        <view class="record-confirm press" bindtap="confirmAddRecord">保存记录</view>
      </view>
    </view>
  </view>

  <view wx:if="{{showRecordModal}}" class="record-detail-mask" bindtap="hideRecordModal">
    <view class="record-detail-modal" catchtap="stopPropagation">
      <view class="record-detail-head">
        <view class="record-detail-badge {{currentRecord.type === '产蛋' ? 'egg' : currentRecord.type === '出苗' ? 'hatch' : currentRecord.type === '交配' ? 'mate' : ''}}">
          <text>{{currentRecord.recordIcon || (currentRecord.type === '建档' ? '📁' : currentRecord.type === '交配' ? '💕' : currentRecord.type === '产蛋' ? '🥚' : currentRecord.type === '出苗' ? '🐣' : '📝')}}</text>
        </view>
        <view class="record-detail-title-wrap">
          <text class="record-detail-title">{{currentRecord.type || '事件记录'}}</text>
          <text class="record-detail-subtitle">{{currentRecord.date}} {{currentRecord.time}}</text>
        </view>
        <text class="record-detail-close" bindtap="hideRecordModal">×</text>
      </view>

      <scroll-view scroll-y class="record-detail-body">
        <text class="record-detail-text">{{currentRecord.displayText || currentRecord.text || '暂无记录内容'}}</text>

        <view wx:if="{{currentRecord.type === '产蛋' && currentRecord.eggCount}}" class="record-detail-metrics">
          <view class="record-detail-metric">
            <text class="metric-label">下蛋总数</text>
            <text class="metric-value">{{currentRecord.eggCount}} 枚</text>
          </view>
          <view class="record-detail-metric">
            <text class="metric-label">受精数</text>
            <text class="metric-value">{{currentRecord.fertilizedCount || 0}} 枚</text>
          </view>
          <view class="record-detail-metric">
            <text class="metric-label">受精率</text>
            <text class="metric-value {{currentRecord.eggRateLow ? 'low' : ''}}">{{currentRecord.eggRateText || '0%'}}</text>
          </view>
        </view>

        <view wx:if="{{currentRecord.type === '出苗' && currentRecord.hatchCount}}" class="record-detail-metrics">
          <view class="record-detail-metric">
            <text class="metric-label">破壳数量</text>
            <text class="metric-value">{{currentRecord.hatchCount}} 只</text>
          </view>
          <view class="record-detail-metric">
            <text class="metric-label">全品数</text>
            <text class="metric-value">{{currentRecord.gradeACount || 0}} 只</text>
          </view>
          <view class="record-detail-metric">
            <text class="metric-label">瑕疵数</text>
            <text class="metric-value">{{currentRecord.defectCount || 0}} 只</text>
          </view>
          <view class="record-detail-metric">
            <text class="metric-label">全品率</text>
            <text class="metric-value">{{currentRecord.gradeRateText || '0%'}}</text>
          </view>
        </view>

        <view wx:if="{{currentRecord.type === '交配' && currentRecord.partnerName}}" class="record-detail-metrics">
          <view class="record-detail-metric">
            <text class="metric-label">配对对象</text>
            <text class="metric-value">{{currentRecord.partnerName}}</text>
          </view>
        </view>

        <view wx:if="{{currentRecord.photos && currentRecord.photos.length}}" class="record-detail-photos">
          <text class="record-detail-photo-title">关联照片</text>
          <scroll-view class="record-detail-photo-scroll" scroll-x>
            <view class="record-detail-photo-list">
              <image wx:for="{{currentRecord.photos}}" wx:key="*this" class="record-detail-photo" src="{{item}}" mode="aspectFill" bindtap="previewRecordPhoto" data-url="{{item}}" />
            </view>
          </scroll-view>
        </view>
      </scroll-view>

      <view class="record-detail-actions">
        <view wx:if="{{printerConfig.enabled}}" class="record-detail-print press" bindtap="printRecord">
          <text>🖨</text>
          <text>打印</text>
        </view>
        <view class="record-detail-ok press" bindtap="hideRecordModal">知道了</view>
      </view>
    </view>
  </view>

  <!-- 父本选择弹窗 -->
  <view wx:if="{{showFatherModal}}" class="record-modal-mask" bindtap="hideFatherModal">
    <view class="record-modal" catchtap="stopPropagation">
      <view class="record-modal-head">
        <text class="record-modal-title">选择父本</text>
        <text class="record-modal-close" bindtap="hideFatherModal">×</text>
      </view>
      <input class="record-input" placeholder="搜索名称..." value="{{fatherSearchText}}" bindinput="onFatherSearchInput" />
      <scroll-view scroll-y class="edit-pet-body">
        <view wx:if="{{fatherList.length===0}}" class="edit-empty-hint">暂无可选公宠物</view>
        <view wx:for="{{fatherList}}" wx:key="id" class="edit-pet-pick press" bindtap="selectFather" data-id="{{item.id}}">
          <image wx:if="{{item.photos&&item.photos[0]}}" src="{{item.photos[0]}}" class="edit-pet-pick-avatar" mode="aspectFill"/>
          <text wx:else class="edit-pet-pick-avatar edit-pet-pick-emoji">🐢</text>
          <text class="edit-pet-pick-name">{{item.alias||item.name}}</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 母本选择弹窗 -->
  <view wx:if="{{showMotherModal}}" class="record-modal-mask" bindtap="hideMotherModal">
    <view class="record-modal" catchtap="stopPropagation">
      <view class="record-modal-head">
        <text class="record-modal-title">选择母本</text>
        <text class="record-modal-close" bindtap="hideMotherModal">×</text>
      </view>
      <input class="record-input" placeholder="搜索名称..." value="{{motherSearchText}}" bindinput="onMotherSearchInput" />
      <scroll-view scroll-y class="edit-pet-body">
        <view wx:if="{{motherList.length===0}}" class="edit-empty-hint">暂无可选母宠物</view>
        <view wx:for="{{motherList}}" wx:key="id" class="edit-pet-pick press" bindtap="selectMother" data-id="{{item.id}}">
          <image wx:if="{{item.photos&&item.photos[0]}}" src="{{item.photos[0]}}" class="edit-pet-pick-avatar" mode="aspectFill"/>
          <text wx:else class="edit-pet-pick-avatar edit-pet-pick-emoji">🐢</text>
          <text class="edit-pet-pick-name">{{item.alias||item.name}}</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 配偶选择弹窗 -->
  <view wx:if="{{showPartnerModal}}" class="record-modal-mask" bindtap="hidePartnerModal">
    <view class="record-modal" catchtap="stopPropagation">
      <view class="record-modal-head">
        <text class="record-modal-title">选择配偶</text>
        <text class="record-modal-close" bindtap="hidePartnerModal">×</text>
      </view>
      <input class="record-input" placeholder="搜索名称..." value="{{partnerSearchText}}" bindinput="onPartnerSearchInput" />
      <scroll-view scroll-y class="edit-pet-body">
        <view wx:if="{{partnerList.length===0}}" class="edit-empty-hint">暂无可选宠物</view>
        <view wx:for="{{partnerList}}" wx:key="id" class="edit-pet-pick press" bindtap="selectPartner" data-id="{{item.id}}">
          <image wx:if="{{item.photos&&item.photos[0]}}" src="{{item.photos[0]}}" class="edit-pet-pick-avatar" mode="aspectFill"/>
          <text wx:else class="edit-pet-pick-avatar edit-pet-pick-emoji">🐢</text>
          <text class="edit-pet-pick-name">{{item.alias||item.name}}</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 记录配对对象选择弹窗 -->
  <view wx:if="{{showRecordPartnerModal}}" class="record-modal-mask" bindtap="hideRecordPartnerModal">
    <view class="record-modal" catchtap="stopPropagation">
      <view class="record-modal-head">
        <text class="record-modal-title">选择配对对象</text>
        <text class="record-modal-close" bindtap="hideRecordPartnerModal">×</text>
      </view>
      <input class="record-input" placeholder="搜索名称..." value="{{recordPartnerSearchText}}" bindinput="onRecordPartnerSearch" />
      <scroll-view scroll-y class="edit-pet-body">
        <view wx:if="{{recordPartnerList.length===0}}" class="edit-empty-hint">暂无可选{{pet.gender==='公'?'母':'公'}}宠物</view>
        <view wx:for="{{recordPartnerList}}" wx:key="id" class="edit-pet-pick press" bindtap="selectRecordPartner" data-id="{{item.id}}">
          <image wx:if="{{item.photos&&item.photos[0]}}" src="{{item.photos[0]}}" class="edit-pet-pick-avatar" mode="aspectFill"/>
          <text wx:else class="edit-pet-pick-avatar edit-pet-pick-emoji">🐢</text>
          <text class="edit-pet-pick-name">{{item.alias||item.name}}</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 添加分类模态框 -->
  <view wx:if="{{showAddCategoryModal}}" class="record-modal-mask" bindtap="hideAddCategoryModal">
    <view class="record-modal" catchtap="stopPropagation">
      <view class="record-modal-head">
        <text class="record-modal-title">新增分类</text>
        <text class="record-modal-close" bindtap="hideAddCategoryModal">×</text>
      </view>
      <view class="edit-pet-field">
        <input class="record-input" placeholder="输入分类名称" value="{{newCategoryName}}" bindinput="onCategoryInput"/>
      </view>
      <view class="record-modal-actions">
        <view class="record-cancel press" bindtap="hideAddCategoryModal">取消</view>
        <view class="record-confirm press" bindtap="confirmAddCategory">添加</view>
      </view>
    </view>
  </view>

  <!-- 编辑分类模态框 -->
  <view wx:if="{{showEditCategoryModal}}" class="record-modal-mask" bindtap="hideEditCategoryModal">
    <view class="record-modal" catchtap="stopPropagation">
      <view class="record-modal-head">
        <text class="record-modal-title">编辑分类</text>
        <text class="record-modal-close" bindtap="hideEditCategoryModal">×</text>
      </view>
      <view class="edit-pet-field">
        <input class="record-input" placeholder="输入新名称" value="{{editCategoryNewName}}" bindinput="onEditCategoryInput"/>
      </view>
      <view class="record-modal-actions">
        <view class="record-cancel press" bindtap="hideEditCategoryModal">取消</view>
        <view class="record-delete-btn press" bindtap="deleteCategory" data-category="{{editCategoryOldName}}">删除</view>
        <view class="record-confirm press" bindtap="confirmEditCategory">保存</view>
      </view>
    </view>
  </view>
</view>
