<view class="page">

  <!-- 未登录提示栏 -->
  <view wx:if="{{!isLoggedIn}}" class="login-hint-bar">
    <text class="login-hint-text">登录后可管理宠物资料、记录和打印标签</text>
    <view class="login-hint-btn" bindtap="goToLogin">登录</view>
  </view>

  <view wx:if="{{showSkeleton}}" class="skeleton-container">
    <!-- 头部骨架 -->
    <view class="skeleton-header"></view>
    
    <!-- 图片区骨架 -->
    <view class="skeleton-photo-banner">
      <view class="skeleton-photo"></view>
    </view>
    
    <!-- 宠物信息骨架 -->
    <view class="skeleton-pet-info">
      <view class="skeleton-info-row">
        <view class="skeleton-pet-name"></view>
        <view class="skeleton-gender-badge"></view>
      </view>
      <view class="skeleton-info-tags">
        <view class="skeleton-info-tag"></view>
        <view class="skeleton-info-tag"></view>
      </view>
      <view class="skeleton-relation-row">
        <view class="skeleton-relation-item"></view>
        <view class="skeleton-relation-divider"></view>
        <view class="skeleton-relation-item"></view>
      </view>
    </view>
    
    <!-- 事件区域骨架 -->
    <view class="skeleton-section">
      <view class="skeleton-section-title"></view>
      <view class="skeleton-event-tabs">
        <view class="skeleton-event-tab"></view>
        <view class="skeleton-event-tab"></view>
        <view class="skeleton-event-tab"></view>
        <view class="skeleton-event-tab"></view>
      </view>
      <view class="skeleton-event-list">
        <view class="skeleton-event-card">
          <view class="skeleton-event-icon"></view>
          <view class="skeleton-event-content">
            <view class="skeleton-event-title"></view>
            <view class="skeleton-event-date"></view>
          </view>
        </view>
        <view class="skeleton-event-card">
          <view class="skeleton-event-icon"></view>
          <view class="skeleton-event-content">
            <view class="skeleton-event-title"></view>
            <view class="skeleton-event-date"></view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:elif="{{loading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view wx:else class="content">
    <!-- 图片展示区 -->
    <view wx:if="{{pet.photos && pet.photos.length > 0}}" class="photo-banner">
      <swiper class="photo-swiper" indicator-dots="{{pet.photos.length > 1}}" circular autoplay>
        <swiper-item wx:for="{{pet.photos}}" wx:key="*this">
          <image class="photo-swiper-img" src="{{item}}" mode="aspectFill" binderror="onPhotoError" data-index="{{index}}" data-type="hero" />
        </swiper-item>
      </swiper>
    </view>

    <view class="pet-info">
      <view class="pet-name-row">
        <text class="pet-name">{{pet.alias || pet.name}}</text>
        <view class="gender-tag gender-{{pet.gender === '公' ? 'male' : pet.gender === '母' ? 'female' : 'unknown'}}">
          <text class="gender-text">{{pet.gender}}</text>
        </view>
      </view>
      
      <view class="info-tags">
        <text class="info-tag">{{pet.category}}</text>
        <text class="info-tag status-{{statusClass}}">{{pet.status}}</text>
        <text wx:if="{{pet.alias}}" class="info-tag alias">{{pet.name}}</text>
      </view>
      
      <view class="relation-row">
        <view class="relation-item">
          <text class="relation-label">父本</text>
          <text class="relation-value {{pet.father ? 'gender-male' : 'unlinked'}}">{{pet.fatherName || '未关联'}}</text>
        </view>
        <view class="relation-divider"></view>
        <view class="relation-item">
          <text class="relation-label">母本</text>
          <text class="relation-value {{pet.mother ? 'gender-female' : 'unlinked-red'}}">{{pet.motherName || '未关联'}}</text>
        </view>
        <view class="relation-divider"></view>
        <view class="relation-item">
          <text class="relation-label">配对</text>
          <text class="relation-value {{pet.partner ? 'gender-partner' : 'unlinked-gray'}}">{{pet.partnerName || '未配对'}}</text>
        </view>
      </view>
    </view>

    <!-- 提醒事件展示区 -->
    <view wx:if="{{upcomingReminders.length > 0}}" class="reminder-section" bindtap="tapUpcomingReminder">
      <view class="reminder-header">
        <text class="reminder-header-title">提醒</text>
        <text class="reminder-header-count">共 {{upcomingReminders.length}} 项</text>
      </view>
      <view class="reminder-list">
        <view wx:for="{{upcomingReminders}}" wx:for-item="r" wx:key="id" class="reminder-card reminder-{{r.statusClass}}">
          <view class="reminder-icon-box">
            <text class="reminder-icon">{{r.type === '换水' ? '💧' : r.type === '喂食' ? '🍽' : r.type === '健康' ? '❤' : '🥚'}}</text>
          </view>
          <view class="reminder-main">
            <view class="reminder-top">
              <text class="reminder-type">{{r.type}}</text>
              <text class="reminder-status">{{r.statusText}}</text>
            </view>
            <view class="reminder-bottom">
              <text class="reminder-meta">每 {{r.intervalDays}} 天 · 下次 {{r.nextDueDate}}</text>
            </view>
          </view>
          <view wx:if="{{!isReadOnly}}" class="reminder-action {{r.doneToday ? 'done' : ''}}" catchtap="markReminderDone" data-id="{{r.id}}">
            <text class="reminder-action-text">{{r.doneToday ? '已完成' : '完成'}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-title-row">
        <text class="section-title">宠物事件</text>
        <view class="report-entries" wx:if="{{pet.gender === '母' || (pet.gender === '公' && pet.partner)}}">
          <view class="report-entry" bindtap="goToEggReport">
            <text class="report-entry-icon">🥚</text>
            <text class="report-entry-text">产蛋</text>
          </view>
          <view class="report-entry" bindtap="goToHatchReport">
            <text class="report-entry-icon">🐣</text>
            <text class="report-entry-text">出苗</text>
          </view>
        </view>
      </view>

      <!-- 日期筛选栏 -->
      <view class="date-filter-bar">
        <picker mode="date" value="{{selectedDate}}" bindchange="onDateChange" class="date-filter-picker">
          <view class="date-filter-btn {{selectedDate ? 'active' : ''}}">
            <text class="date-filter-label">开始</text>
            <text class="date-filter-value">{{selectedDate || '选择日期'}}</text>
            <text class="date-filter-arrow">▾</text>
          </view>
        </picker>
        <text class="date-filter-sep">~</text>
        <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange" class="date-filter-picker">
          <view class="date-filter-btn {{endDate ? 'active' : ''}}">
            <text class="date-filter-label">结束</text>
            <text class="date-filter-value">{{endDate || '选择日期'}}</text>
            <text class="date-filter-arrow">▾</text>
          </view>
        </picker>
        <view wx:if="{{selectedDate || endDate}}" class="date-filter-clear" bindtap="clearDateFilter">
          <text>清除</text>
        </view>
      </view>

      <view class="event-tabs">
        <view class="event-tab {{currentEventTab === '全部事件' ? 'active' : ''}}" bindtap="setEventTab" data-tab="全部事件">
          <text class="event-tab-icon">📋</text>
          <text class="event-tab-text">全部</text>
        </view>
        <view class="event-tab {{currentEventTab === '交配' ? 'active' : ''}}" bindtap="setEventTab" data-tab="交配">
          <text class="event-tab-icon">💕</text>
          <text class="event-tab-text">交配</text>
        </view>
        <view wx:if="{{pet.gender === '母'}}" class="event-tab {{currentEventTab === '产蛋' ? 'active' : ''}}" bindtap="setEventTab" data-tab="产蛋">
          <text class="event-tab-icon">🥚</text>
          <text class="event-tab-text">产蛋</text>
        </view>
        <view wx:if="{{pet.gender === '母'}}" class="event-tab {{currentEventTab === '出苗' ? 'active' : ''}}" bindtap="setEventTab" data-tab="出苗">
          <text class="event-tab-icon">🐣</text>
          <text class="event-tab-text">出苗</text>
        </view>
      </view>

      <view wx:if="{{filteredRecords.length > 0}}" class="event-list">
        <view wx:for="{{filteredRecords}}" wx:key="id" class="event-card" bindtap="showRecordDetail" bindlongpress="onEventCardLongPress" data-id="{{item.id}}">
          <view class="event-icon {{item.type === '产蛋' ? 'event-icon-lay' : item.type === '出苗' ? 'event-icon-hatch' : ''}}">
            <text class="icon-emoji">{{item.type === '建档' ? '📁' : item.type === '交配' ? '💕' : item.type === '产蛋' ? '🥚' : item.type === '出苗' ? '🐣' : '📝'}}</text>
          </view>
          <view class="event-info">
            <text class="event-title">{{item.type}}</text>
            <text class="event-content">{{item.text}}</text>
            <view class="event-date">
              <text class="date">{{item.date}}</text>
              <text wx:if="{{item.photos && item.photos.length > 0}}" class="event-photo-hint">📷 {{item.photos.length}}</text>
            </view>
          </view>
        </view>
      </view>

      <view wx:else class="empty-events">
        <text class="empty-text">暂无事件记录</text>
      </view>

      <view class="timeline-section">
        <view class="timeline-header">
          <text class="timeline-title">记录（{{filteredRecords.length}}条）</text>
          <view class="timeline-actions">
            <view class="timeline-btn timeline-btn-expand" bindtap="expandTimeline">展开</view>
          </view>
        </view>
        <text class="timeline-hint">点上方事件卡或展开查看完整时间线</text>
      </view>
    </view>

    <!-- 家族谱系 -->
    <view class="section section-pedigree">
      <view class="section-header" bindtap="togglePedigree">
        <view class="section-title-row">
          <text class="section-title">家族谱系</text>
          <view wx:if="{{pedigreeStats.totalAncestors > 0}}" class="pedigree-badge">
            <text class="pedigree-count">有血系</text>
          </view>
        </view>
        <view class="expand-btn {{showPedigree ? 'expanded' : ''}}">
          <text class="expand-text">{{showPedigree ? '收起' : '展开'}}</text>
          <text class="expand-icon">▾</text>
        </view>
      </view>
      
      <!-- 收起状态：简洁预览 -->
      <view wx:if="{{!showPedigree}}" class="pedigree-preview">
        <!-- 有父系或母系数据时显示谱系预览 -->
        <view wx:if="{{paternalLine.length > 0 || maternalLine.length > 0}}" class="pedigree-cards">
          <view wx:if="{{paternalLine.length > 0}}" class="pedigree-card">
            <view class="card-gender-tag male">父系</view>
            <view class="card-avatar">
              <image wx:if="{{paternalLine[0].photos && paternalLine[0].photos.length > 0}}" class="card-img" src="{{paternalLine[0].photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree" />
            </view>
            <view class="card-info">
              <text class="card-label">{{paternalLine[0].alias || paternalLine[0].name || '父本'}}</text>
              <text class="card-name">{{paternalLine[0].alias || paternalLine[0].name || '未命名'}}</text>
              <text wx:if="{{paternalLine.length > 1}}" class="card-more">+{{paternalLine.length - 1}}代</text>
            </view>
          </view>
          <view wx:if="{{maternalLine.length > 0}}" class="pedigree-card">
            <view class="card-gender-tag female">母系</view>
            <view class="card-avatar">
              <image wx:if="{{maternalLine[0].photos && maternalLine[0].photos.length > 0}}" class="card-img" src="{{maternalLine[0].photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree" />
            </view>
            <view class="card-info">
              <text class="card-label">{{maternalLine[0].alias || maternalLine[0].name || '母本'}}</text>
              <text class="card-name">{{maternalLine[0].alias || maternalLine[0].name || '未命名'}}</text>
              <text wx:if="{{maternalLine.length > 1}}" class="card-more">+{{maternalLine.length - 1}}代</text>
            </view>
          </view>
        </view>
        <!-- 没有谱系数据时显示空状态 -->
        <view wx:else class="family-tree-empty">
          <view class="family-status">等待补全</view>
          <text class="family-title">还没有父母谱系</text>
          <text class="family-hint">补充父本或母本后，这里就会显示当前个体的溯源关系。</text>
          <view class="family-btn" bindtap="editInfo">编辑信息</view>
        </view>
      </view>
      
      <!-- 展开状态：完整族谱 -->
      <view wx:if="{{showPedigree}}" class="pedigree-full">
        <!-- 统计信息 -->
        <view class="pedigree-stats">
          <view class="stat-item">
            <text class="stat-num">{{pedigreeStats.totalAncestors}}</text>
            <text class="stat-label">祖先总数</text>
          </view>
          <view class="stat-item">
            <text class="stat-num">{{pedigreeStats.maleCount}}</text>
            <text class="stat-label">父系</text>
          </view>
          <view class="stat-item">
            <text class="stat-num">{{pedigreeStats.femaleCount}}</text>
            <text class="stat-label">母系</text>
          </view>
          <view class="stat-item">
            <text class="stat-num">{{pedigreeStats.maxDepth}}</text>
            <text class="stat-label">最深远</text>
          </view>
        </view>
        
        <!-- 血缘主线 -->
        <view class="bloodline-section">
          <view class="bloodline-title">
            <text class="title-text">血缘主线</text>
            <view class="bloodline-tabs">
              <view class="tab {{bloodlineTab === 'paternal' ? 'active' : ''}}" bindtap="switchBloodlineTab" data-tab="paternal">父本</view>
              <view class="tab {{bloodlineTab === 'maternal' ? 'active' : ''}}" bindtap="switchBloodlineTab" data-tab="maternal">母本</view>
            </view>
          </view>
          
          <!-- 父系主线 -->
          <view wx:if="{{bloodlineTab === 'paternal'}}" class="bloodline-content">
            <view wx:if="{{paternalLine.length === 0}}" class="empty-line">
              <text class="empty-text">暂无父系谱系</text>
            </view>
            <view wx:else class="bloodline-chain">
              <view wx:for="{{paternalLine}}" wx:key="id" class="bloodline-node">
                <view class="node-card" bindtap="viewAncestorDetail" data-id="{{item.id}}">
                  <view class="node-avatar">
                    <image wx:if="{{item.photos && item.photos.length > 0}}" class="avatar-img" src="{{item.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree" />
                  </view>
                  <view class="node-info">
                    <text class="node-name">{{item.alias || item.name || '未命名'}}</text>
                    <text class="node-category">{{item.category || '无'}} · 第{{item.generation}}代</text>
                  </view>
                </view>
                <view wx:if="{{index < paternalLine.length - 1}}" class="chain-arrow">↓</view>
              </view>
            </view>
          </view>
          
          <!-- 母系主线 -->
          <view wx:if="{{bloodlineTab === 'maternal'}}" class="bloodline-content">
            <view wx:if="{{maternalLine.length === 0}}" class="empty-line">
              <text class="empty-text">暂无母系谱系</text>
            </view>
            <view wx:else class="bloodline-chain">
              <view wx:for="{{maternalLine}}" wx:key="id" class="bloodline-node">
                <view class="node-card" bindtap="viewAncestorDetail" data-id="{{item.id}}">
                  <view class="node-avatar">
                    <image wx:if="{{item.photos && item.photos.length > 0}}" class="avatar-img" src="{{item.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree" />
                  </view>
                  <view class="node-info">
                    <text class="node-name">{{item.alias || item.name || '未命名'}}</text>
                    <text class="node-category">{{item.category || '无'}} · 第{{item.generation}}代</text>
                  </view>
                </view>
                <view wx:if="{{index < maternalLine.length - 1}}" class="chain-arrow">↓</view>
              </view>
            </view>
          </view>
        </view>
        
        <!-- 完整家谱树 -->
        <view class="family-tree-section">
          <view class="tree-title">
            <text class="title-text">完整家谱</text>
            <text class="tree-hint">（最多展示3代）</text>
          </view>
          <view wx:if="{{!pedigreeData.fullTree || (!pedigreeData.fullTree.father && !pedigreeData.fullTree.mother)}}" class="empty-tree">
            <text class="empty-text">暂无家谱数据</text>
          </view>
          <view wx:else class="family-tree-visual">
            <!-- 当前宠物 -->
            <view class="tree-level level-0">
              <view class="tree-node current">
                <view class="current-badge">当前</view>
                <view class="node-avatar-wrapper">
                  <image wx:if="{{pet.photos && pet.photos.length > 0}}" class="node-img" src="{{pet.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree" />
                  <text wx:else class="node-icon current">🐢</text>
                </view>
                <text class="node-name current">{{pet.alias || pet.name || '未命名'}}</text>
                <text wx:if="{{pet.alias}}" class="node-alias current">{{pet.name}}</text>
                <text class="node-gender-text">{{pet.gender || '未知'}}</text>
              </view>
            </view>

            <!-- 第1代：父母 -->
            <block wx:if="{{pedigreeData.hasGen1}}">
              <view class="tree-connections">
                <view class="connection-line center"></view>
              </view>
              <view class="generation-label">第1代（父母）</view>
              <view class="tree-level level-1">
                <view wx:if="{{pedigreeData.fullTree.father}}" class="tree-node parent" bindtap="viewAncestorDetail" data-id="{{pedigreeData.fullTree.father.id}}">
                  <view class="node-gender-tag male">父本</view>
                  <view class="node-avatar-wrapper">
                    <image wx:if="{{pedigreeData.fullTree.father.photos && pedigreeData.fullTree.father.photos.length > 0}}" class="node-img" src="{{pedigreeData.fullTree.father.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree" />
                  </view>
                  <text class="node-name">{{pedigreeData.fullTree.father.alias || pedigreeData.fullTree.father.name || '未命名'}}</text>
                  <text wx:if="{{pedigreeData.fullTree.father.alias}}" class="node-alias">{{pedigreeData.fullTree.father.name}}</text>
                </view>
                <view wx:if="{{pedigreeData.fullTree.mother}}" class="tree-node parent" bindtap="viewAncestorDetail" data-id="{{pedigreeData.fullTree.mother.id}}">
                  <view class="node-gender-tag female">母本</view>
                  <view class="node-avatar-wrapper">
                    <image wx:if="{{pedigreeData.fullTree.mother.photos && pedigreeData.fullTree.mother.photos.length > 0}}" class="node-img" src="{{pedigreeData.fullTree.mother.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree" />
                  </view>
                  <text class="node-name">{{pedigreeData.fullTree.mother.alias || pedigreeData.fullTree.mother.name || '未命名'}}</text>
                  <text wx:if="{{pedigreeData.fullTree.mother.alias}}" class="node-alias">{{pedigreeData.fullTree.mother.name}}</text>
                </view>
              </view>
            </block>

            <!-- 第2代：祖父母 -->
            <block wx:if="{{pedigreeData.hasGen2}}">
              <view class="tree-connections">
                <view class="connection-line" wx:if="{{pedigreeData.fullTree.father && (pedigreeData.fullTree.father.father || pedigreeData.fullTree.father.mother)}}"></view>
                <view class="connection-line" wx:if="{{pedigreeData.fullTree.mother && (pedigreeData.fullTree.mother.father || pedigreeData.fullTree.mother.mother)}}"></view>
              </view>
              <view class="generation-label">第2代（祖父母）</view>
              <view class="tree-level level-2">
                <view wx:if="{{pedigreeData.fullTree.father && pedigreeData.fullTree.father.father}}" class="tree-node ancestor" bindtap="viewAncestorDetail" data-id="{{pedigreeData.fullTree.father.father.id}}">
                  <view class="node-gender-tag male">祖父</view>
                  <view class="node-avatar-wrapper">
                    <image wx:if="{{pedigreeData.fullTree.father.father.photos && pedigreeData.fullTree.father.father.photos.length > 0}}" class="node-img" src="{{pedigreeData.fullTree.father.father.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree" />
                  </view>
                  <text class="node-name">{{pedigreeData.fullTree.father.father.alias || pedigreeData.fullTree.father.father.name || '未命名'}}</text>
                  <text wx:if="{{pedigreeData.fullTree.father.father.alias}}" class="node-alias">{{pedigreeData.fullTree.father.father.name}}</text>
                </view>
                <view wx:if="{{pedigreeData.fullTree.father && pedigreeData.fullTree.father.mother}}" class="tree-node ancestor" bindtap="viewAncestorDetail" data-id="{{pedigreeData.fullTree.father.mother.id}}">
                  <view class="node-gender-tag female">祖母</view>
                  <view class="node-avatar-wrapper">
                    <image wx:if="{{pedigreeData.fullTree.father.mother.photos && pedigreeData.fullTree.father.mother.photos.length > 0}}" class="node-img" src="{{pedigreeData.fullTree.father.mother.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree" />
                  </view>
                  <text class="node-name">{{pedigreeData.fullTree.father.mother.alias || pedigreeData.fullTree.father.mother.name || '未命名'}}</text>
                  <text wx:if="{{pedigreeData.fullTree.father.mother.alias}}" class="node-alias">{{pedigreeData.fullTree.father.mother.name}}</text>
                </view>
                <view wx:if="{{pedigreeData.fullTree.mother && pedigreeData.fullTree.mother.father}}" class="tree-node ancestor" bindtap="viewAncestorDetail" data-id="{{pedigreeData.fullTree.mother.father.id}}">
                  <view class="node-gender-tag male">外祖父</view>
                  <view class="node-avatar-wrapper">
                    <image wx:if="{{pedigreeData.fullTree.mother.father.photos && pedigreeData.fullTree.mother.father.photos.length > 0}}" class="node-img" src="{{pedigreeData.fullTree.mother.father.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree" />
                  </view>
                  <text class="node-name">{{pedigreeData.fullTree.mother.father.alias || pedigreeData.fullTree.mother.father.name || '未命名'}}</text>
                  <text wx:if="{{pedigreeData.fullTree.mother.father.alias}}" class="node-alias">{{pedigreeData.fullTree.mother.father.name}}</text>
                </view>
                <view wx:if="{{pedigreeData.fullTree.mother && pedigreeData.fullTree.mother.mother}}" class="tree-node ancestor" bindtap="viewAncestorDetail" data-id="{{pedigreeData.fullTree.mother.mother.id}}">
                  <view class="node-gender-tag female">外祖母</view>
                  <view class="node-avatar-wrapper">
                    <image wx:if="{{pedigreeData.fullTree.mother.mother.photos && pedigreeData.fullTree.mother.mother.photos.length > 0}}" class="node-img" src="{{pedigreeData.fullTree.mother.mother.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree" />
                  </view>
                  <text class="node-name">{{pedigreeData.fullTree.mother.mother.alias || pedigreeData.fullTree.mother.mother.name || '未命名'}}</text>
                  <text wx:if="{{pedigreeData.fullTree.mother.mother.alias}}" class="node-alias">{{pedigreeData.fullTree.mother.mother.name}}</text>
                </view>
              </view>
            </block>

            <!-- 第3代：曾祖父母 -->
            <block wx:if="{{pedigreeData.hasGen3}}">
              <view class="tree-connections">
                <view class="connection-line" wx:if="{{pedigreeData.fullTree.father && pedigreeData.fullTree.father.father && (pedigreeData.fullTree.father.father.father || pedigreeData.fullTree.father.father.mother)}}"></view>
                <view class="connection-line" wx:if="{{pedigreeData.fullTree.mother && pedigreeData.fullTree.mother.father && (pedigreeData.fullTree.mother.father.father || pedigreeData.fullTree.mother.father.mother)}}"></view>
              </view>
              <view class="generation-label">第3代（曾祖父母）</view>
              <view class="tree-level level-3">
                <view wx:if="{{pedigreeData.fullTree.father && pedigreeData.fullTree.father.father && pedigreeData.fullTree.father.father.father}}" class="tree-node ancestor" bindtap="viewAncestorDetail" data-id="{{pedigreeData.fullTree.father.father.father.id}}">
                  <view class="node-gender-tag male">曾祖父</view>
                  <view class="node-avatar-wrapper">
                    <image wx:if="{{pedigreeData.fullTree.father.father.father.photos && pedigreeData.fullTree.father.father.father.photos.length > 0}}" class="node-img" src="{{pedigreeData.fullTree.father.father.father.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree" />
                  </view>
                  <text class="node-name">{{pedigreeData.fullTree.father.father.father.alias || pedigreeData.fullTree.father.father.father.name || '未命名'}}</text>
                  <text wx:if="{{pedigreeData.fullTree.father.father.father.alias}}" class="node-alias">{{pedigreeData.fullTree.father.father.father.name}}</text>
                </view>
                <view wx:if="{{pedigreeData.fullTree.father && pedigreeData.fullTree.father.father && pedigreeData.fullTree.father.father.mother}}" class="tree-node ancestor" bindtap="viewAncestorDetail" data-id="{{pedigreeData.fullTree.father.father.mother.id}}">
                  <view class="node-gender-tag female">曾祖母</view>
                  <view class="node-avatar-wrapper">
                    <image wx:if="{{pedigreeData.fullTree.father.father.mother.photos && pedigreeData.fullTree.father.father.mother.photos.length > 0}}" class="node-img" src="{{pedigreeData.fullTree.father.father.mother.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree" />
                  </view>
                  <text class="node-name">{{pedigreeData.fullTree.father.father.mother.alias || pedigreeData.fullTree.father.father.mother.name || '未命名'}}</text>
                  <text wx:if="{{pedigreeData.fullTree.father.father.mother.alias}}" class="node-alias">{{pedigreeData.fullTree.father.father.mother.name}}</text>
                </view>
                <view wx:if="{{pedigreeData.fullTree.mother && pedigreeData.fullTree.mother.father && pedigreeData.fullTree.mother.father.father}}" class="tree-node ancestor" bindtap="viewAncestorDetail" data-id="{{pedigreeData.fullTree.mother.father.father.id}}">
                  <view class="node-gender-tag male">曾外祖父</view>
                  <view class="node-avatar-wrapper">
                    <image wx:if="{{pedigreeData.fullTree.mother.father.father.photos && pedigreeData.fullTree.mother.father.father.photos.length > 0}}" class="node-img" src="{{pedigreeData.fullTree.mother.father.father.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree" />
                  </view>
                  <text class="node-name">{{pedigreeData.fullTree.mother.father.father.alias || pedigreeData.fullTree.mother.father.father.name || '未命名'}}</text>
                  <text wx:if="{{pedigreeData.fullTree.mother.father.father.alias}}" class="node-alias">{{pedigreeData.fullTree.mother.father.father.name}}</text>
                </view>
                <view wx:if="{{pedigreeData.fullTree.mother && pedigreeData.fullTree.mother.father && pedigreeData.fullTree.mother.father.mother}}" class="tree-node ancestor" bindtap="viewAncestorDetail" data-id="{{pedigreeData.fullTree.mother.father.mother.id}}">
                  <view class="node-gender-tag female">曾外祖母</view>
                  <view class="node-avatar-wrapper">
                    <image wx:if="{{pedigreeData.fullTree.mother.father.mother.photos && pedigreeData.fullTree.mother.father.mother.photos.length > 0}}" class="node-img" src="{{pedigreeData.fullTree.mother.father.mother.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree" />
                  </view>
                  <text class="node-name">{{pedigreeData.fullTree.mother.father.mother.alias || pedigreeData.fullTree.mother.father.mother.name || '未命名'}}</text>
                  <text wx:if="{{pedigreeData.fullTree.mother.father.mother.alias}}" class="node-alias">{{pedigreeData.fullTree.mother.father.mother.name}}</text>
                </view>
              </view>
            </block>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{currentEventTab === '产蛋'}}" class="section">
      <view class="section-title">产蛋统计</view>
    </view>
  </view>

  <view wx:if="{{!isPublicMode && !isReadOnly}}" class="bottom-bar">
    <view class="bar-btn bar-btn-more" bindtap="showMore">
      <text class="bar-btn-icon">···</text>
      <text class="bar-btn-text">更多</text>
    </view>
    <view class="bar-btn bar-btn-share" bindtap="sharePet">
      <image class="bar-share-img" src="/images/share-icon.png"></image>
      <text class="bar-btn-text">分享</text>
    </view>
    <view class="bar-btn bar-btn-record" bindtap="addRecord">
      <image class="bar-record-img" src="/images/record-icon.png"></image>
      <text class="bar-btn-text bar-record-text">记录</text>
    </view>
  </view>

  <!-- 编辑弹窗 -->
  <view wx:if="{{showEditModal}}" class="modal-overlay" bindtap="hideEditModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">编辑宠物信息</text>
        <view class="modal-close" bindtap="hideEditModal">×</view>
      </view>
      
      <view class="modal-content-scroll">
        <view class="edit-form">
          <view class="form-item">
            <text class="form-label">名称</text>
            <view class="input-with-voice">
              <input class="form-input" placeholder="宠物名称" value="{{editForm.name}}" bindinput="onEditNameInput" />
              <view class="voice-btn {{isRecording && currentVoiceField === 'editName' ? 'recording' : ''}}" bindtap="toggleVoice" data-field="editName">
                <text class="voice-btn-icon">●</text>
              </view>
              <view wx:if="{{isRecording && currentVoiceField === 'editName'}}" class="voice-cancel-btn" bindtap="cancelVoice">✕</view>
            </view>
          </view>
          
          <view class="form-item">
            <text class="form-label">别名</text>
            <view class="input-with-voice">
              <input class="form-input" placeholder="可选" value="{{editForm.alias}}" bindinput="onEditAliasInput" />
              <view class="voice-btn {{isRecording && currentVoiceField === 'editAlias' ? 'recording' : ''}}" bindtap="toggleVoice" data-field="editAlias">
                <text class="voice-btn-icon">●</text>
              </view>
              <view wx:if="{{isRecording && currentVoiceField === 'editAlias'}}" class="voice-cancel-btn" bindtap="cancelVoice">✕</view>
            </view>
          </view>
          
          <view class="form-item">
            <text class="form-label">分类</text>
            <view class="form-options">
              <view wx:for="{{categories}}" wx:key="*this" class="option {{editForm.category === item ? 'active' : ''}}" bindtap="selectEditCategory" data-category="{{item}}">{{item}}</view>
            </view>
          </view>
          
          <view class="form-item">
            <text class="form-label">性别</text>
            <view class="form-options">
              <view class="option {{editForm.gender === '公' ? 'active' : ''}}" bindtap="selectEditGender" data-gender="公">公</view>
              <view class="option {{editForm.gender === '母' ? 'active' : ''}}" bindtap="selectEditGender" data-gender="母">母</view>
              <view class="option {{editForm.gender === '未知' ? 'active' : ''}}" bindtap="selectEditGender" data-gender="未知">未知</view>
            </view>
          </view>
          
          <view class="form-item">
            <text class="form-label">状态</text>
            <view class="form-options">
              <view class="option {{editForm.status === '正常' ? 'active' : ''}}" bindtap="selectEditStatus" data-status="正常">正常</view>
              <view class="option {{editForm.status === '待配' ? 'active' : ''}}" bindtap="selectEditStatus" data-status="待配">待配</view>
              <view class="option {{editForm.status === '预警' ? 'active' : ''}}" bindtap="selectEditStatus" data-status="预警">预警</view>
            </view>
          </view>
          
          <view class="form-item">
            <text class="form-label">公开展示</text>
            <view class="form-switch-row">
              <text class="switch-hint">允许他人通过分享码查看此宠物</text>
              <switch checked="{{editForm.isPublic}}" bindchange="onPublicSwitchChange" color="{{switchColor}}" />
            </view>
          </view>
          
          <view class="section-title">
            <text>更多配置</text>
            <view class="toggle-btn" bindtap="toggleEditManual">
              <text>{{showEditManual ? '收起-' : '展开-'}}</text>
            </view>
          </view>
          
          <view class="manual-section" wx:if="{{showEditManual}}">
            <view class="form-item">
              <text class="form-label">价格（元/只）</text>
              <input class="form-input" type="digit" placeholder="可选，公开展示时使用" value="{{editForm.price}}" bindinput="onEditPriceInput" />
            </view>

            <view class="form-item">
              <text class="form-label">父本</text>
              <view class="family-selector" bindtap="openFatherModal">
                <view wx:if="{{selectedFather}}" class="family-selected">
                  <image wx:if="{{selectedFather.photos && selectedFather.photos[0]}}" class="family-avatar" src="{{selectedFather.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree" />
                  <view class="family-info">
                    <text class="family-name">{{selectedFather.alias || selectedFather.name}}</text>
                    <text class="family-desc">公龟</text>
                  </view>
                </view>
                <text wx:else class="family-placeholder">点击选择父本</text>
              </view>
              <view wx:if="{{selectedFather}}" class="family-clear" bindtap="clearFather">清空</view>
            </view>
            
            <view class="form-item">
              <text class="form-label">母本</text>
              <view class="family-selector" bindtap="openMotherModal">
                <view wx:if="{{selectedMother}}" class="family-selected">
                  <image wx:if="{{selectedMother.photos && selectedMother.photos[0]}}" class="family-avatar" src="{{selectedMother.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree" />
                  <view class="family-info">
                    <text class="family-name">{{selectedMother.alias || selectedMother.name}}</text>
                    <text class="family-desc">母龟</text>
                  </view>
                </view>
                <text wx:else class="family-placeholder">点击选择母本</text>
              </view>
              <view wx:if="{{selectedMother}}" class="family-clear" bindtap="clearMother">清空</view>
            </view>

            <view class="form-item">
              <text class="form-label">当前配对</text>
              <view class="family-selector" bindtap="openPartnerModal">
                <view wx:if="{{selectedPartner}}" class="family-selected">
                  <image wx:if="{{selectedPartner.photos && selectedPartner.photos[0]}}" class="family-avatar" src="{{selectedPartner.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree" />
                  <view class="family-info">
                    <text class="family-name">{{selectedPartner.alias || selectedPartner.name}}</text>
                    <text class="family-desc">{{pet.gender === '公' ? '母龟' : '公龟'}}</text>
                  </view>
                </view>
                <text wx:else class="family-placeholder">点击选择配对对象</text>
              </view>
              <view wx:if="{{selectedPartner}}" class="family-clear" bindtap="clearPartner">清空</view>
            </view>

            <!-- 图片管理 -->
            <view class="form-item">
              <text class="form-label">照片</text>
              <view class="photo-manager">
                <view wx:for="{{editPhotoList}}" wx:key="*this" class="photo-thumb-wrap">
                  <image class="photo-thumb" src="{{item}}" mode="aspectFill" binderror="onPhotoError" data-type="hero" data-index="{{index}}" />
                  <view class="photo-del" catchtap="removeEditPhoto" data-index="{{index}}">×</view>
                </view>
                <view wx:if="{{editPhotoList.length < 5}}" class="photo-add-btn" bindtap="chooseEditPhoto">
                  <text class="photo-add-icon">+</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
      
      <view class="modal-footer">
        <view class="btn-cancel" bindtap="hideEditModal">取消</view>
        <view class="btn-confirm" bindtap="saveEdit">保存</view>
      </view>
    </view>
  </view>

  <!-- 选择父本弹窗 -->
  <view wx:if="{{showFatherModal}}" class="modal-overlay" bindtap="hideFatherModal">
    <view class="family-modal-bottom" catchtap="stopPropagation">
      <view class="family-modal-header">
        <text class="family-modal-title">选择父本</text>
        <view class="modal-close" bindtap="hideFatherModal">×</view>
      </view>
      <view class="family-search">
        <input class="family-search-input" placeholder="搜索父本" value="{{fatherSearchText}}" bindinput="onFatherSearchInput" />
      </view>
      <scroll-view class="family-list" scroll-y>
        <view wx:for="{{fatherList}}" wx:key="id" class="family-item" bindtap="selectFather" data-id="{{item.id}}">
          <image wx:if="{{item.photos && item.photos[0]}}" class="family-item-avatar" src="{{item.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree" />
          <view class="family-item-placeholder" wx:else>宠物</view>
          <view class="family-item-info">
            <text class="family-item-name">{{item.alias || item.name}}</text>
            <text class="family-item-desc">公龟 · 最近 今天</text>
          </view>
          <text class="family-item-select">选择这只</text>
        </view>
        <view wx:if="{{fatherList.length === 0}}" class="empty-text">暂无公龟</view>
      </scroll-view>
    </view>
  </view>

  <!-- 选择母本弹窗 -->
  <view wx:if="{{showMotherModal}}" class="modal-overlay" bindtap="hideMotherModal">
    <view class="family-modal-bottom" catchtap="stopPropagation">
      <view class="family-modal-header">
        <text class="family-modal-title">选择母本</text>
        <view class="modal-close" bindtap="hideMotherModal">×</view>
      </view>
      <view class="family-search">
        <input class="family-search-input" placeholder="搜索母本" value="{{motherSearchText}}" bindinput="onMotherSearchInput" />
      </view>
      <scroll-view class="family-list" scroll-y>
        <view wx:for="{{motherList}}" wx:key="id" class="family-item" bindtap="selectMother" data-id="{{item.id}}">
          <image wx:if="{{item.photos && item.photos[0]}}" class="family-item-avatar" src="{{item.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree" />
          <view class="family-item-placeholder" wx:else>宠物</view>
          <view class="family-item-info">
            <text class="family-item-name">{{item.alias || item.name}}</text>
            <text class="family-item-desc">母龟 · 最近 今天</text>
          </view>
          <text class="family-item-select">选择这只</text>
        </view>
        <view wx:if="{{motherList.length === 0}}" class="empty-text">暂无母龟</view>
      </scroll-view>
    </view>
  </view>

  <!-- 选择配对对象弹窗 -->
  <view wx:if="{{showPartnerModal}}" class="modal-overlay" bindtap="hidePartnerModal">
    <view class="family-modal-bottom" catchtap="stopPropagation">
      <view class="family-modal-header">
        <text class="family-modal-title">选择配对对象</text>
        <view class="modal-close" bindtap="hidePartnerModal">×</view>
      </view>
      <view class="family-search">
        <input class="family-search-input" placeholder="搜索宠物" value="{{partnerSearchText}}" bindinput="onPartnerSearchInput" />
      </view>
      <scroll-view class="family-list" scroll-y>
        <view wx:for="{{partnerList}}" wx:key="id" class="family-item" bindtap="selectPartner" data-id="{{item.id}}">
          <image wx:if="{{item.photos && item.photos[0]}}" class="family-item-avatar" src="{{item.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-type="tree" />
          <view class="family-item-placeholder" wx:else>宠物</view>
          <view class="family-item-info">
            <text class="family-item-name">{{item.alias || item.name}}</text>
            <text class="family-item-desc">{{item.gender === '公' ? '公龟' : '母龟'}}</text>
          </view>
          <text class="family-item-select">选择这只</text>
        </view>
        <view wx:if="{{partnerList.length === 0}}" class="empty-text">暂无可配对宠物</view>
      </scroll-view>
    </view>
  </view>

  <!-- 删除确认弹窗 -->
  <view wx:if="{{showDeleteConfirm}}" class="modal-overlay-center" bindtap="hideDeleteConfirm">
    <view class="confirm-modal" catchtap="stopPropagation">
      <view class="confirm-content">
        <view class="confirm-icon-wrap">
          <text class="confirm-icon">🗑️</text>
        </view>
        <text class="confirm-title">确认删除</text>
        <text class="confirm-text">确定要删除"{{pet.name}}"吗？此操作不可恢复。</text>
        <view class="confirm-divider"></view>
        <view class="confirm-buttons">
          <view class="btn-cancel" bindtap="hideDeleteConfirm">取消</view>
          <view class="btn-delete" bindtap="confirmDelete">删除</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 添加记录弹窗 -->
  <view wx:if="{{showAddRecordModal}}" class="modal-overlay" bindtap="hideAddRecordModal">
    <view class="modal-content add-record-modal" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">添加记录</text>
        <view class="modal-close" bindtap="hideAddRecordModal">×</view>
      </view>
      
      <view class="add-record-body">
        <view class="form-item">
          <text class="form-label">记录类型</text>
          <view class="record-type-grid">
            <view wx:for="{{addRecordTypes}}" wx:for-item="type" wx:key="*this" 
                  class="record-type-item {{newRecord.type === type ? 'active' : ''}}" 
                  bindtap="selectRecordType" data-type="{{type}}">
              <text class="record-type-icon">{{type === '全部' ? '📋' : type === '建档' ? '📁' : type === '交配' ? '💕' : type === '产蛋' ? '🥚' : type === '出苗' ? '🐣' : type === '健康' ? '💊' : '📝'}}</text>
              <text class="record-type-text">{{type}}</text>
            </view>
          </view>
        </view>
        
        <!-- 交配记录配对选择器 -->
        <view wx:if="{{newRecord.type === '交配'}}" class="form-item form-item-content">
          <text class="form-label">配对对象</text>
          <view class="family-selector" bindtap="openRecordPartnerModal">
            <text class="family-selector-label">{{recordPartner ? (recordPartner.alias || recordPartner.name) : '点击选择配对'}}</text>
            <view class="family-selector-arrow">
              <text wx:if="{{recordPartner}}" class="clear-btn" catchtap="clearRecordPartner">✖</text>
              <text class="arrow-icon">›</text>
            </view>
          </view>
        </view>

        <view class="form-item form-item-content">
          <text class="form-label">记录内容</text>
          <view class="textarea-voice-wrap">
            <textarea class="form-textarea" placeholder="输入记录内容..." value="{{newRecord.text}}" bindinput="onRecordTextInput"></textarea>
            <view class="voice-row">
              <view class="voice-btn-inline {{isRecording && currentVoiceField === 'recordText' ? 'recording' : ''}}"
                    bindtap="toggleVoice"
                    data-field="recordText">
                <text class="voice-btn-inline-icon">●</text>
              </view>
              <view wx:if="{{isRecording && currentVoiceField === 'recordText'}}" class="voice-cancel-inline" bindtap="cancelVoice">取消</view>
            </view>
          </view>
        </view>

        <!-- 产蛋记录专属字段 -->
        <view wx:if="{{newRecord.type === '产蛋'}}" class="egg-fields">
          <text class="form-label">产蛋数据</text>
          <view class="egg-input-row">
            <view class="egg-input-group">
              <text class="egg-label">下蛋总数</text>
              <input class="egg-input" type="number" placeholder="0" value="{{newRecord.eggCount}}" bindinput="onEggCountInput" />
              <text class="egg-unit">枚</text>
            </view>
            <view class="egg-input-group">
              <text class="egg-label">受精数</text>
              <input class="egg-input" type="number" placeholder="0" value="{{newRecord.fertilizedCount}}" bindinput="onFertilizedCountInput" />
              <text class="egg-unit">枚</text>
            </view>
            <view wx:if="{{newRecord.eggCount > 0}}" class="egg-rate">
              <text class="egg-rate-label">受精率</text>
              <text class="egg-rate-value {{eggRateLow ? 'rate-low' : ''}}">{{eggRateText}}</text>
            </view>
          </view>
        </view>

        <!-- 出苗记录专属字段 -->
        <view wx:if="{{newRecord.type === '出苗'}}" class="egg-fields hatch-fields">
          <text class="form-label">出苗数据</text>
          <view class="egg-input-row">
            <view class="egg-input-group">
              <text class="egg-label">破壳数</text>
              <input class="egg-input" type="number" placeholder="0" value="{{newRecord.hatchCount}}" bindinput="onHatchCountInput" />
              <text class="egg-unit">只</text>
            </view>
            <view class="egg-input-group">
              <text class="egg-label">全品数</text>
              <input class="egg-input" type="number" placeholder="0" value="{{newRecord.gradeACount}}" bindinput="onGradeAInput" />
              <text class="egg-unit">只</text>
            </view>
            <view class="egg-input-group">
              <text class="egg-label">瑕疵数</text>
              <input class="egg-input" type="number" placeholder="0" value="{{newRecord.defectCount}}" bindinput="onDefectInput" />
              <text class="egg-unit">只</text>
            </view>
          </view>
          <view wx:if="{{newRecord.hatchCount > 0}}" class="egg-rate">
            <text class="egg-rate-label">全品率</text>
            <text class="egg-rate-value {{gradeRateLow ? 'rate-low' : ''}}">{{gradeRateText}}</text>
          </view>
        </view>
      </view>
      
      <view class="modal-footer add-record-footer">
        <view class="btn-cancel" bindtap="hideAddRecordModal">取消</view>
        <view wx:if="{{printerConfig.enabled}}" class="btn-save-only" bindtap="confirmAddRecord">仅保存</view>
        <view class="btn-confirm" bindtap="{{printerConfig.enabled ? 'printNewRecord' : 'confirmAddRecord'}}">
          <text wx:if="{{printerConfig.enabled}}" class="btn-confirm-icon">🖨 </text>
          <text>{{printerConfig.enabled ? '确认并打印' : '确认'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 记录配对对象弹窗（必须在添加记录弹窗之后，确保在上层） -->
  <view wx:if="{{showRecordPartnerModal}}" class="modal-overlay" bindtap="hideRecordPartnerModal">
    <view class="family-modal-bottom" catchtap="stopPropagation">
      <view class="family-modal-header">
        <text class="family-modal-title">选择配对对象</text>
        <view class="modal-close" bindtap="hideRecordPartnerModal">×</view>
      </view>
      <view class="family-search">
        <input class="family-search-input" placeholder="搜索宠物" value="{{recordPartnerSearchText}}" bindinput="onRecordPartnerSearch" />
      </view>
      <scroll-view class="family-list" scroll-y>
        <view wx:for="{{recordPartnerList}}" wx:key="id" class="family-item" bindtap="selectRecordPartner" data-id="{{item.id}}">
          <view class="family-item-placeholder">宠物</view>
          <view class="family-item-info">
            <text class="family-item-name">{{item.alias || item.name}}</text>
            <text class="family-item-desc">{{item.gender === '公' ? '公龟' : '母龟'}}</text>
          </view>
          <text class="family-item-select">选择这只</text>
        </view>
        <view wx:if="{{recordPartnerList.length === 0}}" class="empty-text">暂无可配对宠物</view>
      </scroll-view>
    </view>
  </view>

  <!-- 记录详情弹窗 -->
  <view wx:if="{{showRecordModal}}" class="modal-overlay-center" bindtap="hideRecordModal">
    <view class="record-detail-modal" catchtap="stopPropagation">
      <view class="record-detail-header">
        <view class="record-type-badge {{currentRecord.type === '产蛋' ? 'record-badge-lay' : currentRecord.type === '出苗' ? 'record-badge-hatch' : ''}}">
          <text class="record-type-icon">{{currentRecord.type === '建档' ? '📁' : currentRecord.type === '交配' ? '💕' : currentRecord.type === '产蛋' ? '🥚' : currentRecord.type === '出苗' ? '🐣' : '📝'}}</text>
        </view>
        <text class="record-detail-title">{{currentRecord.type}}</text>
        <view class="modal-close" bindtap="hideRecordModal">×</view>
      </view>
      
      <view class="record-detail-content">
        <text class="record-detail-text">{{currentRecord.text}}</text>
        <!-- 产蛋记录数据展示 -->
        <view wx:if="{{currentRecord.type === '产蛋' && currentRecord.eggCount}}" class="egg-detail-info">
          <view class="egg-detail-row">
            <text class="egg-detail-label">下蛋总数</text>
            <text class="egg-detail-value">{{currentRecord.eggCount}} 枚</text>
          </view>
          <view class="egg-detail-row">
            <text class="egg-detail-label">受精数</text>
            <text class="egg-detail-value">{{currentRecord.fertilizedCount || 0}} 枚</text>
          </view>
          <view class="egg-detail-row">
            <text class="egg-detail-label">受精率</text>
            <text class="egg-detail-value {{currentRecord.eggRateLow ? 'rate-low' : ''}}">{{currentRecord.eggRateText || '0%'}}</text>
          </view>
        </view>
        <!-- 出苗记录数据展示 -->
        <view wx:if="{{currentRecord.type === '出苗' && currentRecord.hatchCount}}" class="egg-detail-info">
          <view class="egg-detail-row">
            <text class="egg-detail-label">破壳数量</text>
            <text class="egg-detail-value">{{currentRecord.hatchCount}} 只</text>
          </view>
          <view class="egg-detail-row">
            <text class="egg-detail-label">全品数</text>
            <text class="egg-detail-value">{{currentRecord.gradeACount || 0}} 只</text>
          </view>
          <view class="egg-detail-row">
            <text class="egg-detail-label">瑕疵数</text>
            <text class="egg-detail-value">{{currentRecord.defectCount || 0}} 只</text>
          </view>
          <view class="egg-detail-row">
            <text class="egg-detail-label">全品率</text>
            <text class="egg-detail-value">{{currentRecord.gradeRateText || '0%'}}</text>
          </view>
        </view>
        <!-- 交配配对对象展示 -->
        <view wx:if="{{currentRecord.type === '交配' && currentRecord.partnerName}}" class="egg-detail-info">
          <view class="egg-detail-row">
            <text class="egg-detail-label">配对对象</text>
            <text class="egg-detail-value" style="color:#7C3AED">{{currentRecord.partnerName}}</text>
          </view>
        </view>
      </view>

      <!-- 记录照片 -->
      <view wx:if="{{currentRecord.photos && currentRecord.photos.length > 0}}" class="record-detail-photos">
        <text class="record-photos-title">📷 关联照片</text>
        <scroll-view class="record-photos-scroll" scroll-x>
          <view class="record-photos-list">
            <image wx:for="{{currentRecord.photos}}" wx:key="*this" class="record-photo-img" src="{{item}}" mode="aspectFill" bindtap="previewRecordPhoto" data-url="{{item}}" />
          </view>
        </scroll-view>
      </view>
      
      <view class="record-detail-footer">
        <view class="record-detail-date">
          <text class="date-label">记录时间</text>
          <text class="date-value">{{currentRecord.date}} {{currentRecord.time}}</text>
        </view>
        <view class="record-detail-actions">
          <view wx:if="{{printerConfig.enabled}}" class="btn-print" bindtap="printRecord">
            <text class="btn-print-icon">🖨</text>
            <text class="btn-print-text">打印</text>
          </view>
          <view class="btn-confirm btn-full" bindtap="hideRecordModal">知道了</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 时间线弹窗 -->
  <view wx:if="{{showTimelineModal}}" class="modal-overlay" bindtap="hideTimelineModal">
    <view class="timeline-modal" catchtap="stopPropagation">
      <view class="safe-area-top"></view>
      <view class="modal-header">
        <text class="modal-title">时间线</text>
        <view class="modal-close" bindtap="hideTimelineModal">×</view>
      </view>
      
      <scroll-view class="timeline-content" scroll-y>
        <view wx:if="{{records.length === 0}}" class="empty-timeline">
          <text class="empty-icon">📋</text>
          <text class="empty-text">暂无记录</text>
          <text class="empty-hint">点击下方按钮添加第一条记录</text>
        </view>
        
        <view wx:else class="timeline-list">
          <view wx:for="{{groupedRecords}}" wx:key="date" class="timeline-date-group">
            <view class="timeline-date-header">
              <text class="timeline-date">{{item.date}}</text>
              <text class="timeline-count">{{item.count}}条记录</text>
            </view>
            
            <view wx:for="{{item.records}}" wx:for-item="record" wx:key="record.id" class="timeline-item">
              <view class="timeline-dot-wrap">
                <view class="timeline-dot"></view>
                <view class="timeline-line"></view>
              </view>
              <view class="timeline-card">
                <view class="timeline-card-header">
                  <view class="timeline-type-wrap">
                    <text class="timeline-type-icon">{{getRecordIcon(record.type)}}</text>
                    <text class="timeline-type">{{record.type}}</text>
                  </view>
                  <view class="timeline-card-actions">
                    <text class="timeline-time">{{record.time}}</text>
                    <view class="timeline-delete-btn" bindtap="deleteRecord" data-id="{{record.id}}">
                      <text class="delete-icon">🗑</text>
                    </view>
                  </view>
                </view>
                <text class="timeline-text">{{record.text || '-'}}</text>
                <view wx:if="{{record.type === '产蛋' && record.eggCount}}" class="timeline-egg-info">
                  <text class="egg-info-text">🥚 {{record.eggCount}}枚 · 受精 {{record.fertilizedCount || 0}}枚</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 提醒事件管理弹窗 -->
  <view wx:if="{{showReminderModal}}" class="modal-overlay" bindtap="closeReminderModal">
    <view class="reminder-modal" catchtap="stopPropagation">
      <view class="safe-area-top"></view>
      <view class="modal-header">
        <text class="modal-title">提醒事件管理</text>
        <view class="modal-close" bindtap="closeReminderModal">×</view>
      </view>

      <view wx:if="{{reminders.length === 0}}" class="reminder-modal-empty">
        <text class="reminder-empty-icon">⏰</text>
        <text class="reminder-empty-text">还没有设置提醒</text>
        <text class="reminder-empty-hint">为这只宠物添加定期提醒，避免错过换水、喂食、健康检查等。</text>
      </view>

      <scroll-view wx:else class="reminder-modal-list" scroll-y>
        <view wx:for="{{allEnrichedReminders}}" wx:key="id" class="reminder-modal-item reminder-{{item.statusClass}}">
          <view class="reminder-modal-icon">
            <text>{{item.type === '换水' ? '💧' : item.type === '喂食' ? '🍽' : item.type === '健康' ? '❤' : '🥚'}}</text>
          </view>
          <view class="reminder-modal-main">
            <view class="reminder-modal-title">
              <text class="reminder-modal-type">{{item.type}}</text>
              <text class="reminder-modal-status reminder-status-{{item.statusClass}}">{{item.statusText}}</text>
            </view>
            <view class="reminder-modal-sub">
              <text class="reminder-modal-meta">⏱ 每 {{item.intervalDays}} 天 · 下次 {{item.nextDueDate}}</text>
            </view>
            <view class="reminder-modal-sub reminder-modal-sub-dim">
              <text class="reminder-modal-meta">{{item.lastDone ? '上次完成：' + item.lastDone : '尚未开始'}}</text>
            </view>
            <view class="reminder-modal-btns">
              <view class="reminder-modal-btn done" catchtap="markReminderDone" data-id="{{item.id}}">
                <text>✓ 完成</text>
              </view>
              <view class="reminder-modal-btn edit" catchtap="openReminderEdit" data-id="{{item.id}}">
                <text>编辑</text>
              </view>
              <view class="reminder-modal-btn delete" catchtap="deleteReminder" data-id="{{item.id}}">
                <text>删除</text>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>

      <view class="reminder-modal-footer">
        <view class="reminder-modal-add-btn" bindtap="openReminderEdit">
          <text class="reminder-modal-add-icon">+</text>
          <text class="reminder-modal-add-text">新增提醒</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 新增/编辑提醒弹窗 -->
  <view wx:if="{{showReminderEditModal}}" class="modal-overlay" bindtap="closeReminderEdit">
    <view class="reminder-edit-modal" catchtap="stopPropagation">
      <view class="safe-area-top"></view>
      <view class="modal-header">
        <text class="modal-title">{{editingReminder ? '编辑提醒' : '新增提醒'}}</text>
        <view class="modal-close" bindtap="closeReminderEdit">×</view>
      </view>

      <view class="reminder-edit-form">
        <view class="reminder-edit-row">
          <text class="reminder-edit-label">提醒类型</text>
          <view class="reminder-edit-type-grid">
            <view wx:for="{{['换水','喂食','健康','繁育']}}" wx:key="*this"
                  class="reminder-edit-type-chip {{reminderForm.type === item ? 'active' : ''}}"
                  bindtap="selectReminderType" data-type="{{item}}">
              <text class="type-chip-icon">{{item === '换水' ? '💧' : item === '喂食' ? '🍽' : item === '健康' ? '❤' : '🥚'}}</text>
              <text class="type-chip-text">{{item}}</text>
            </view>
          </view>
        </view>

        <view class="reminder-edit-row">
          <text class="reminder-edit-label">间隔天数</text>
          <view class="reminder-edit-input-wrap">
            <input class="reminder-edit-input" type="number" placeholder="如 7" value="{{reminderForm.intervalDays}}" bindinput="onReminderIntervalInput" />
            <text class="reminder-edit-unit">天</text>
          </view>
        </view>

        <view class="reminder-edit-row">
          <text class="reminder-edit-label">上次完成日期</text>
          <picker mode="date" value="{{reminderForm.lastDone || today}}" end="{{today}}" bindchange="onReminderLastDoneChange">
            <view class="reminder-edit-date">
              <text class="reminder-edit-date-text">{{reminderForm.lastDone || '选择日期（可选）'}}</text>
              <text class="reminder-edit-date-icon">▾</text>
            </view>
          </picker>
          <text class="reminder-edit-hint">不选则从今天开始计算</text>
        </view>
      </view>

      <view class="modal-footer">
        <view class="btn-cancel btn-full" bindtap="closeReminderEdit">
          <text>取消</text>
        </view>
        <view class="btn-confirm btn-full" bindtap="submitReminder">
          <text>{{editingReminder ? '保存' : '添加'}}</text>
        </view>
      </view>
    </view>
  </view>
</view>

  <!-- 打印调试弹窗 -->
  <view wx:if="{{showPrintDebugModal}}" class="modal-overlay" catchtap="hidePrintDebugModal">
    <view class="debug-modal" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">🔍 打印调试信息</text>
        <view class="modal-close" bindtap="hidePrintDebugModal">×</view>
      </view>
      <scroll-view class="debug-content" scroll-y style="max-height: 400rpx;">
        <view wx:for="{{printDebugSteps}}" wx:key="index" class="debug-line"
              style="color:{{item.indexOf('❌')===0 ? '#E53E3E' : (item.indexOf('⚠️')===0 ? '#DD6B20' : '#38A169')}}; font-size: 24rpx; padding: 6rpx 0;">
          {{item}}
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 录音状态提示条 -->
  <view wx:if="{{isRecording}}" class="voice-status-bar">
    <text class="voice-status-text">🎤 录音中... 点击按钮完成识别</text>
    <text class="voice-status-cancel" bindtap="cancelVoice">取消</text>
  </view>