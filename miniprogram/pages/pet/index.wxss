.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx 16rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.8) 0%, transparent 100%);
}

.series {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  overflow: hidden;
}

.filter-label {
  font-size: 24rpx;
  color: #aaaaaa;
  font-weight: 500;
  letter-spacing: 1rpx;
  flex-shrink: 0;
}

.filter-tags {
  display: flex;
  gap: 10rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 4rpx;
  scrollbar-width: none;
}

.filter-tags::-webkit-scrollbar {
  display: none;
}

.filter-tag {
  background-color: rgba(255,255,255,0.7);
  color: #888888;
  padding: 8rpx 20rpx;
  border-radius: 28rpx;
  font-size: 24rpx;
  white-space: nowrap;
  border: 1rpx solid rgba(0,0,0,0.06);
  transition: all 0.2s ease;
}

.filter-tag.active {
  background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
  color: #ffffff;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
}

.more-btn {
  background-color: #ffffff;
  color: #888888;
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  border: 1rpx solid rgba(0,0,0,0.05);
}

.more-btn.active {
  background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
  color: #ffffff;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
}

.filters {
  padding: 0 32rpx 24rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.8) 0%, transparent 100%);
  border-radius: 0 0 24rpx 24rpx;
  margin: 0 -16rpx;
  padding-left: 48rpx;
  padding-right: 48rpx;
}

.filter-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.search-box {
  margin-top: 8rpx;
}

.search-input {
  width: 100%;
  box-sizing: border-box;
  background-color: rgba(255,255,255,0.9);
  border-radius: 48rpx;
  padding: 20rpx 48rpx 20rpx 32rpx;
  min-height: 84rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: #333333;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  border: 1rpx solid rgba(0,0,0,0.06);
}

.content {
  padding: 16rpx 24rpx;
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  margin-bottom: 32rpx;
}

.empty-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fff9e6 0%, #f5e6c8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(184, 134, 11, 0.15);
}

.dots {
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #B8860B;
}

.empty-text {
  font-size: 32rpx;
  color: #333333;
}

.pet-list {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-between;
}

.pet-card {
  width: calc(50% - 10rpx);
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  border: none;
  margin-bottom: 20rpx;
  transition: all 0.22s cubic-bezier(0.25, 0.8, 0.25, 1);
  position: relative;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.07), 0 0 0 1rpx rgba(0,0,0,0.03);
}

.pet-card:active {
  transform: scale(0.97) translateY(2rpx);
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.12), 0 0 0 1rpx rgba(0,0,0,0.04);
}

/* 图片容器 */
.pet-image-wrapper {
  position: relative;
  width: 100%;
  padding-bottom: 100%;
  overflow: hidden;
  background: transparent;
}

/* 主题色背景 - 米金棕 */
.theme-gold .pet-image-wrapper {
  background: linear-gradient(135deg, #f5e6c8 0%, #e8d4a8 100%);
}

/* 主题色背景 - 摩卡纸本 */
.theme-mocha .pet-image-wrapper {
  background: linear-gradient(135deg, #d4cfc4 0%, #c4bdb0 100%);
}

/* 主题色背景 - 橄榄档案 */
.theme-olive .pet-image-wrapper {
  background: linear-gradient(135deg, #b8c9b8 0%, #a0b8a0 100%);
}

.pet-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
}

/* 主题色背景 - 米金棕 */
.theme-gold .pet-placeholder {
  background: linear-gradient(135deg, #f5e6c8 0%, #e8d4a8 100%);
}

/* 主题色背景 - 摩卡纸本 */
.theme-mocha .pet-placeholder {
  background: linear-gradient(135deg, #d4cfc4 0%, #c4bdb0 100%);
}

/* 主题色背景 - 橄榄档案 */
.theme-olive .pet-placeholder {
  background: linear-gradient(135deg, #b8c9b8 0%, #a0b8a0 100%);
}

/* 编辑模式卡片 */
.pet-card.edit-mode {
  width: 100%;
  flex-direction: row;
  align-items: center;
  padding: 16rpx;
  gap: 16rpx;
}

.pet-card.edit-mode .pet-image-wrapper {
  width: 120rpx;
  height: 120rpx;
  padding-bottom: 0;
  flex-shrink: 0;
  border-radius: 16rpx;
  overflow: hidden;
}

.pet-card.edit-mode .pet-gender-badge {
  top: 8rpx;
  right: 8rpx;
  padding: 4rpx 12rpx;
}

.pet-card.edit-mode .pet-info-overlay {
  position: relative;
  background: none;
  padding: 8rpx;
  gap: 2rpx;
}

.pet-card.edit-mode .pet-card-name {
  color: #333333;
  font-size: 28rpx;
}

.pet-card.selected {
  border-color: var(--primary-color);
  background-color: rgba(184, 134, 11, 0.03);
}

/* 选择框 */
.card-checkbox {
  flex-shrink: 0;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #cccccc;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.checkbox.checked {
  border-color: var(--primary-color);
}

.check-mark {
  color: #ffffff;
  font-size: 22rpx;
  font-weight: bold;
}

/* 批量操作栏 */
.edit-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  background: linear-gradient(135deg, #ffffff 0%, #faf8f3 100%);
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.edit-bar-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.select-all-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.select-all-text {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.selected-count {
  font-size: 24rpx;
  color: #999999;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #cccccc;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
  background-color: rgba(255, 255, 255, 0.8);
}

.checkbox.checked {
  border-color: #B8860B;
  background-color: #B8860B;
}

.check-mark {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: bold;
}

.edit-bar-right {
  display: flex;
  gap: 16rpx;
}

.edit-bar-btn {
  font-size: 28rpx;
  font-weight: 500;
  padding: 10rpx 20rpx;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.edit-bar-btn:active {
  transform: scale(0.95);
}

.edit-bar-done {
  color: #B8860B;
  background: linear-gradient(135deg, rgba(250, 248, 243, 0.9) 0%, rgba(245, 230, 200, 0.5) 100%);
  border: 1rpx solid rgba(184, 134, 11, 0.2);
  padding: 10rpx 28rpx;
}

/* 拖动排序 */
.drag-handle {
  flex-shrink: 0;
  padding: 20rpx 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 60rpx;
}

.drag-dots {
  font-size: 44rpx;
  color: #cccccc;
  letter-spacing: 2rpx;
  line-height: 1;
}

.pet-card.dragging {
  opacity: 0.92;
  transform: scale(1.04);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.18);
  z-index: 100;
  transition: box-shadow 0.15s ease, opacity 0.15s ease, transform 0.15s ease;
}

/* FAB */
.fab-hidden {
  opacity: 0;
  pointer-events: none;
  transform: scale(0.6) rotate(45deg);
}

.pet-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 24rpx 24rpx 0 0;
}

.pet-gender-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background-color: rgba(0, 0, 0, 0.55);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.gender-icon {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 500;
}

/* 宠物信息 - 图片下方 */
.pet-card-info {
  padding: 18rpx 20rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.pet-card-name {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  letter-spacing: 0.5rpx;
}

.pet-card-meta {
  font-size: 20rpx;
  color: #B8860B;
  background: linear-gradient(135deg, #fef9ec 0%, #fdf4dc 100%);
  align-self: flex-start;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  border: 1rpx solid rgba(184,134,11,0.12);
}

.load-more {
  width: 100%;
  text-align: center;
  padding: 32rpx 0;
}

.load-more-text {
  font-size: 24rpx;
  color: #999999;
}

.test-section {
  padding: 32rpx;
  text-align: center;
}

.test-title {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.test-btn {
  display: inline-block;
  padding: 24rpx 48rpx;
  background-color: #B8860B;
  color: #ffffff;
  border-radius: 32rpx;
  font-size: 28rpx;
  transition: all 0.2s ease;
}

.test-btn:active {
  transform: scale(0.95);
  background-color: #a07009;
}

.theme-mocha .test-btn {
  background-color: #8B7765;
}
.theme-mocha .test-btn:active {
  background-color: #7a654f;
}
.theme-olive .test-btn {
  background-color: #556B2F;
}
.theme-olive .test-btn:active {
  background-color: #4a5d24;
}

.fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(180rpx + env(safe-area-inset-bottom));
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1a1a1a 0%, #333333 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.25);
  transition: all 0.25s cubic-bezier(0.25, 1.5, 0.5, 1);
}

.fab:active {
  transform: scale(0.88);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.fab-icon {
  font-size: 52rpx;
  color: #ffffff;
  font-weight: 300;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
  overflow: hidden;
}

.modal-overlay-center {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 32rpx;
  overflow: hidden;
}

.modal-content {
  width: 100%;
  background: linear-gradient(180deg, #ffffff 0%, #faf8f3 100%);
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx 36rpx;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  max-height: 85vh;
  overflow-y: scroll;
  -webkit-overflow-scrolling: touch;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.08);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 36rpx;
}

.modal-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 1rpx;
}

.modal-close {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #666666;
  transition: all 0.2s ease;
}

.modal-close:active {
  background-color: rgba(0, 0, 0, 0.1);
  transform: scale(0.92);
}

.photo-section {
  position: relative;
  margin-bottom: 40rpx;
}

.photo-grid {
  border: 2rpx dashed rgba(184, 134, 11, 0.25);
  border-radius: 28rpx;
  padding: 28rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: flex-start;
  background: linear-gradient(135deg, rgba(250, 248, 243, 0.5) 0%, rgba(245, 230, 200, 0.2) 100%);
}

.photo-item {
  position: relative;
  width: calc((100% - 48rpx) / 3);
  aspect-ratio: 1;
}

.photo-image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.photo-delete {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #ffffff;
}

.photo-upload {
  width: calc((100% - 40rpx) / 3);
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #faf8f3 0%, #f5e6c8 100%);
  border-radius: 20rpx;
  border: 2rpx dashed rgba(184, 134, 11, 0.3);
  transition: all 0.2s ease;
}

.photo-upload:active {
  transform: scale(0.95);
  background: linear-gradient(135deg, #f5e6c8 0%, #f0dab8 100%);
}

.upload-icon {
  font-size: 52rpx;
  color: #B8860B;
  font-weight: 300;
}

.upload-text {
  font-size: 22rpx;
  color: #B8860B;
  opacity: 0.8;
}

.photo-count {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  font-size: 24rpx;
  color: #999999;
}

.input-section {
  margin-bottom: 36rpx;
  position: relative;
}

.pet-input {
  width: 100%;
  height: 96rpx;
  box-sizing: border-box;
  background-color: rgba(250, 248, 243, 0.9);
  border-radius: 28rpx;
  padding: 0 110rpx 0 32rpx;
  font-size: 30rpx;
  color: #1a1a1a;
  line-height: 96rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.04);
}

.voice-input {
  background-color: #1a1a1a;
  border-radius: 48rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.voice-icon {
  font-size: 40rpx;
}

.voice-text {
  font-size: 32rpx;
  color: #ffffff;
}

.voice-btn {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.voice-btn:active {
  background-color: rgba(184, 134, 11, 0.15);
  transform: translateY(-50%) scale(0.9);
}

.voice-btn-icon {
  font-size: 22rpx;
  color: #B8860B;
  line-height: 1;
}

.input-with-voice {
  position: relative;
  width: 100%;
}

.manual-section {
  margin-bottom: 32rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.section-title text:first-child {
  font-size: 32rpx;
  color: #1a1a1a;
  font-weight: 600;
}

.toggle-btn {
  font-size: 26rpx;
  color: #B8860B;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  background-color: rgba(184, 134, 11, 0.08);
  transition: all 0.2s ease;
}

.toggle-btn:active {
  background-color: rgba(184, 134, 11, 0.15);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
  display: block;
}

.form-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.form-switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.switch-hint {
  font-size: 26rpx;
  color: #666666;
  flex: 1;
}

.option {
  background-color: rgba(250, 248, 243, 0.8);
  color: #888888;
  padding: 16rpx 32rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.option:active {
  transform: scale(0.95);
}

.option.active {
  background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
  color: #ffffff;
  border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.18);
}

.option.add {
  background: linear-gradient(135deg, #fef9ec 0%, #fdf4dc 100%);
  color: #B8860B;
  border-color: rgba(184, 134, 11, 0.3);
}

.option-wrapper {
  position: relative;
  display: inline-block;
}

.option.editing {
  animation: shake 0.3s ease-in-out infinite;
  position: relative;
  transform-origin: center;
}

@keyframes shake {
  0%, 100% {
    transform: translateX(0) rotate(0deg);
  }
  25% {
    transform: translateX(-2rpx) rotate(-2deg);
  }
  75% {
    transform: translateX(2rpx) rotate(2deg);
  }
}

.delete-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: #ff3b30;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  line-height: 1;
  font-weight: bold;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

.exit-edit-btn {
  margin-top: 24rpx;
  padding: 20rpx 48rpx;
  background-color: #1a1a1a;
  color: white;
  border-radius: 40rpx;
  text-align: center;
  font-size: 28rpx;
}

.form-input {
  width: 100%;
  height: 96rpx;
  box-sizing: border-box;
  background-color: rgba(250, 248, 243, 0.8);
  border-radius: 28rpx;
  padding: 0 110rpx 0 28rpx;
  font-size: 30rpx;
  color: #1a1a1a;
  line-height: 96rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.04);
}

.form-switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  background: linear-gradient(135deg, rgba(250, 248, 243, 0.5) 0%, rgba(245, 230, 200, 0.2) 100%);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  margin-top: -8rpx;
}

.switch-hint {
  font-size: 28rpx;
  color: #666666;
  flex: 1;
  padding-right: 24rpx;
}

.family-selector {
  background: linear-gradient(135deg, rgba(250, 248, 243, 0.9) 0%, rgba(245, 230, 200, 0.3) 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  border: 1rpx dashed rgba(184, 134, 11, 0.25);
  transition: all 0.2s ease;
}

.family-selector:active {
  background: linear-gradient(135deg, rgba(245, 230, 200, 0.6) 0%, rgba(245, 230, 200, 0.4) 100%);
}

.family-placeholder {
  font-size: 28rpx;
  color: #999999;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.family-selected {
  display: flex;
  align-items: center;
  gap: 20rpx;
  width: 100%;
}

.family-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
}

.family-info {
  flex: 1;
}

.family-name {
  display: block;
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.family-desc {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
}

.family-clear {
  font-size: 26rpx;
  color: var(--primary-color);
  margin-top: 12rpx;
  text-align: right;
}

.family-modal {
  width: calc(100% - 80rpx);
  max-width: 680rpx;
  background: linear-gradient(180deg, #ffffff 0%, #faf8f3 100%);
  border-radius: 36rpx;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  box-sizing: border-box;
}

.family-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 36rpx 36rpx 28rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.family-modal-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 0.5rpx;
}

.family-modal-desc {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.family-search {
  padding: 24rpx 36rpx;
}

.family-search-input {
  width: 100%;
  height: 88rpx;
  box-sizing: border-box;
  padding: 0 36rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  border-radius: 44rpx;
  font-size: 28rpx;
  background: linear-gradient(135deg, rgba(250, 248, 243, 0.9) 0%, rgba(245, 230, 200, 0.3) 100%);
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.04);
}

.family-list {
  flex: 1;
  padding: 0 24rpx 24rpx;
  max-height: 50vh;
  box-sizing: border-box;
  overflow-y: auto;
}

.family-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 10rpx;
  margin-left: 4rpx;
  margin-right: 4rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(250, 248, 243, 0.8) 0%, rgba(245, 230, 200, 0.3) 100%);
  box-sizing: border-box;
  transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.family-item:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, rgba(245, 230, 200, 0.8) 0%, rgba(245, 230, 200, 0.5) 100%);
}

.family-item-avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 22rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.family-item-placeholder {
  width: 92rpx;
  height: 92rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #faf8f3 0%, #f0e6d0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.family-item-info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.family-item-name {
  display: block;
  font-size: 32rpx;
  color: #1a1a1a;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  letter-spacing: 0.5rpx;
}

.family-item-desc {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.family-item-select {
  font-size: 26rpx;
  color: #B8860B;
  font-weight: 600;
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, rgba(250, 248, 243, 0.9) 0%, rgba(245, 230, 200, 0.5) 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(184, 134, 11, 0.2);
  flex-shrink: 0;
  margin-left: 16rpx;
  transition: all 0.2s ease;
}

.family-item-select:active {
  transform: scale(0.95);
  background: linear-gradient(135deg, rgba(245, 230, 200, 0.8) 0%, rgba(245, 230, 200, 0.6) 100%);
}

.empty-family {
  padding: 60rpx 0;
  text-align: center;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.btn-cancel {
  flex: 1;
  background: linear-gradient(135deg, rgba(250, 248, 243, 0.9) 0%, rgba(245, 230, 200, 0.5) 100%);
  color: #B8860B;
  border-radius: 40rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  border: 1rpx solid rgba(184, 134, 11, 0.2);
  transition: all 0.2s ease;
}

.btn-cancel:active {
  transform: scale(0.97);
  background: linear-gradient(135deg, rgba(245, 230, 200, 0.8) 0%, rgba(245, 230, 200, 0.6) 100%);
}

.btn-confirm {
  flex: 1;
  background: linear-gradient(135deg, #1a1a1a 0%, #333333 100%);
  color: #ffffff;
  border-radius: 40rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.2s cubic-bezier(0.25, 1.5, 0.5, 1);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
}

.btn-confirm:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.25);
}

.record-modal-content {
  width: 100%;
  background: linear-gradient(180deg, #ffffff 0%, #faf8f3 100%);
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx 36rpx;
  padding-bottom: calc(36rpx + env(safe-area-inset-bottom));
  max-height: 75vh;
  overflow-y: auto;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.08);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.record-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 0.5rpx;
}

.record-actions {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.record-action {
  font-size: 28rpx;
  font-weight: 500;
}

.record-action.delete {
  color: #999999;
}

.record-action.share {
  background: linear-gradient(135deg, rgba(250, 248, 243, 0.9) 0%, rgba(245, 230, 200, 0.5) 100%);
  color: #B8860B;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(184, 134, 11, 0.2);
}

.record-action.detail {
  background: linear-gradient(135deg, #1a1a1a 0%, #333333 100%);
  color: #ffffff;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  transition: all 0.2s ease;
}

.record-action.detail:active {
  transform: scale(0.95);
}

.record-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 28rpx;
  padding-bottom: 28rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.record-tab {
  background-color: rgba(250, 248, 243, 0.8);
  color: #888888;
  padding: 14rpx 28rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.record-tab:active {
  transform: scale(0.95);
}

.record-tab.active {
  background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.record-list {
  flex: 1;
  min-height: 200rpx;
}

.record-empty {
  border: 1rpx dashed rgba(184, 134, 11, 0.25);
  border-radius: 28rpx;
  padding: 52rpx 32rpx;
  text-align: center;
  background: linear-gradient(135deg, rgba(250, 248, 243, 0.5) 0%, rgba(245, 230, 200, 0.2) 100%);
}

.record-empty-title {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.record-empty-hint {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-bottom: 32rpx;
  line-height: 1.6;
}

.record-empty-btn {
  background: linear-gradient(135deg, #fef9ec 0%, #fdf4dc 100%);
  color: #B8860B;
  padding: 20rpx 52rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  display: inline-block;
  border: 1rpx solid rgba(184, 134, 11, 0.25);
  transition: all 0.2s ease;
}

.record-empty-btn:active {
  transform: scale(0.95);
  background: linear-gradient(135deg, #fdf4dc 0%, #f5e6c8 100%);
}

.record-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  gap: 16rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.record-item:last-child {
  border-bottom: none;
}

.record-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background-color: #B8860B;
  flex-shrink: 0;
  box-shadow: 0 0 0 4rpx rgba(184, 134, 11, 0.15);
}

.record-tag {
  background: linear-gradient(135deg, rgba(250, 248, 243, 0.9) 0%, rgba(245, 230, 200, 0.5) 100%);
  color: #B8860B;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  flex-shrink: 0;
  border: 1rpx solid rgba(184, 134, 11, 0.15);
}

.record-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
}

.record-time {
  font-size: 24rpx;
  color: #999999;
  flex-shrink: 0;
}

.record-footer {
  padding-top: 28rpx;
  margin-top: 28rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.record-btn {
  background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
  color: #ffffff;
  padding: 28rpx;
  border-radius: 40rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
  transition: all 0.2s cubic-bezier(0.25, 1.5, 0.5, 1);
}

.record-btn:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.25);
}