@import "/styles/design.wxss";

.page-pet-list { min-height: 100vh; background: var(--c-bg); }

/* ====== 刷新中提示 ====== */
.refreshing-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  color: var(--c-text3);
  font-size: var(--fs-small);
}
.refreshing-spinner {
  width: 28rpx;
  height: 28rpx;
  margin-right: 12rpx;
  border: 3rpx solid var(--c-border);
  border-top-color: var(--c-primary);
  border-radius: 50%;
  animation: refreshing-spin 0.8s linear infinite;
}
@keyframes refreshing-spin {
  to { transform: rotate(360deg); }
}
.refreshing-text { color: var(--c-text2); }

/* ====== 筛选栏 ====== */
.filter-bar {
  display: flex; align-items: center;
  padding: 20rpx 28rpx 16rpx;
}
.filter-left {
  display: flex; align-items: center; flex: 1;
  min-width: 0;
}
.filter-label {
  font-size: var(--fs-small); color: var(--c-text);
  font-weight: 500; margin-right: 16rpx; flex-shrink: 0;
}
.chip-scroll {
  white-space: nowrap;
  width: 100%;
}
.filter-more {
  padding: 10rpx 28rpx; border-radius: var(--r-full);
  background: var(--c-primary-light); color: var(--c-primary);
  border: 1.5rpx solid transparent;
  font-size: var(--fs-mini); font-weight: 600; flex-shrink: 0; margin-left: 16rpx;
}

/* ====== 展开筛选 ====== */
.filter-expand {
  background: var(--c-surface) !important;
  box-shadow: none !important;
  margin: 0 !important;
  padding: 16rpx 28rpx 24rpx;
  border-top: 1rpx solid var(--c-border-light);
}
.expand-row {
  display: flex; align-items: center; flex-wrap: wrap;
  margin-bottom: 12rpx;
}
.expand-row:last-child { margin-bottom: 0; }
.expand-label {
  font-size: var(--fs-mini); color: var(--c-text3);
  width: 56rpx; flex-shrink: 0;
}
.chip-sm {
  display: inline-flex; align-items: center;
  padding: 8rpx 20rpx; border-radius: var(--r-full);
  font-size: var(--fs-mini); color: var(--c-text2);
  background: transparent; border: 1.5rpx solid var(--c-border);
  margin-right: 10rpx; margin-bottom: 6rpx;
  transition: all .15s;
}
.chip-sm.active {
  background: var(--c-primary-light); color: var(--c-primary);
  border-color: var(--c-primary); font-weight: 600;
}

.search-row {
  display: flex; align-items: center; gap: 12rpx;
  margin-top: 14rpx; padding-top: 14rpx;
  border-top: 1rpx solid var(--c-border-light);
}
.search-input {
  flex: 1; height: 68rpx; padding: 0 24rpx;
  background: var(--c-bg); border-radius: var(--r-full);
  font-size: var(--fs-small); color: var(--c-text);
}
.scan-btn {
  width: 68rpx; height: 68rpx;
  display: flex; align-items: center; justify-content: center;
  background: var(--c-bg); border-radius: 50%;
}

.scan-icon {
  position: relative;
  width: 32rpx;
  height: 32rpx;
}

.scan-frame {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  border: 3rpx solid var(--c-primary);
  border-radius: 6rpx;
  box-sizing: border-box;
}

.scan-frame::before,
.scan-frame::after {
  content: '';
  position: absolute;
  width: 8rpx; height: 8rpx;
  border-color: var(--c-primary);
  border-style: solid;
}

.scan-frame::before {
  top: -3rpx; left: -3rpx;
  border-width: 3rpx 0 0 3rpx;
  border-radius: 4rpx 0 0 0;
}

.scan-frame::after {
  bottom: -3rpx; right: -3rpx;
  border-width: 0 3rpx 3rpx 0;
  border-radius: 0 0 4rpx 0;
}

.scan-line {
  position: absolute;
  top: 50%; left: 10%;
  width: 80%; height: 3rpx;
  background: var(--c-primary);
  border-radius: 2rpx;
  transform: translateY(-50%);
  animation: scanMove 1.5s ease-in-out infinite;
}

@keyframes scanMove {
  0%, 100% { top: 15%; opacity: 1; }
  50% { top: 85%; opacity: 0.6; }
}

/* ====== 宠物网格 ====== */
.pet-grid {
  display: flex; flex-wrap: wrap;
  padding: 12rpx 28rpx;
  gap: 16rpx;
}
.pet-card {
  width: calc(50% - 8rpx);
  background: transparent;
  overflow: visible;
}
.pet-img-wrap {
  width: 100%; height: 410rpx;
  position: relative;
  background: var(--c-surface);
  border-radius: var(--r-xl);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}
.pet-img-wrap image {
  width: 100%; height: 100%;
  display: block;
}
.pet-img-wrap-empty {
  border: 1rpx solid #E0DDD8;
  box-sizing: border-box;
}

/* 无图占位 */
.pet-noimg {
  width: 100%; height: 100%;
  background: #F2F0EC;
  box-sizing: border-box;
}

/* 图片内信息叠加层（左下角） */
.pet-overlay-info {
  position: absolute;
  left: 14rpx;
  bottom: 14rpx;
  padding: 4rpx 16rpx;
  box-sizing: border-box;
  background: rgb(0 0 0 / 30%);
  border: 1.5rpx solid rgb(255 255 255 / 59%);
  border-radius: 18rpx;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  box-shadow: 0 8rpx 24rpx rgb(0 0 0 / 12%);
  z-index: 1;
}
.overlay-gender {
  position: absolute;
  top: 14rpx;
  right: 14rpx;
  min-width: 42rpx;
  height: 42rpx;
  padding: 0 12rpx;
  box-sizing: border-box;
  border-radius: var(--r-full);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: rgb(0 0 0 / 28%);
  border: 1.5rpx solid rgb(255 255 255 / 36%);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  font-size: var(--fs-mini);
  font-weight: 700;
  z-index: 2;
}
.overlay-category {
  display: block; font-size: var(--fs-mini); color: rgba(255,255,255,.75);
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,.25);
  margin-top: 2rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 浮动记录按钮 */
.pet-record-btn {
  position: absolute;
  right: 14rpx;
  bottom: 14rpx;
  padding: 3rpx 15rpx;
  background: rgb(255 255 255 / 31%);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1.5rpx solid rgb(255 255 255 / 42%);
  border-radius: var(--r-full);
  font-size: var(--fs-mini);
  color: var(--c-text);
  z-index: 2;
}
.pet-record-btn:active { transform: scale(.94); }

/* 卡片信息 */
.pet-card-info {
  padding: 14rpx 4rpx 0;
}
.pet-card-name {
  font-size: var(--fs-body); font-weight: 500; color: var(--c-text2);
  display: block;
}

/* ====== 已加载全部 ====== */
.load-all {
  text-align: center; padding: 40rpx 0 20rpx;
  font-size: var(--fs-small); color: var(--c-text3);
}

/* ====== 加载更多 ====== */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0 20rpx;
}
.load-more-spinner {
  width: 28rpx;
  height: 28rpx;
  margin-right: 12rpx;
  border: 3rpx solid var(--c-border);
  border-top-color: var(--c-primary);
  border-radius: 50%;
  animation: refreshing-spin 0.8s linear infinite;
}
.load-more-text {
  font-size: var(--fs-small);
  color: var(--c-text2);
}

/* ====== 加载更多按钮 ====== */
.load-more-btn-wrap {
  display: flex;
  justify-content: center;
  padding: 24rpx 0;
}
.load-more-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 56rpx;
  border-radius: var(--r-full);
  background: var(--c-primary-light);
  color: var(--c-primary);
  font-size: var(--fs-small);
  font-weight: 600;
  border: 1.5rpx solid var(--c-primary);
}

/* Edit bar (保留兼容) */
.edit-bar {
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 50;
  display: flex; align-items: center; justify-content: space-between;
  padding: var(--s-md) var(--s-lg); padding-bottom: calc(var(--s-md) + env(safe-area-inset-bottom));
  background: var(--c-surface); box-shadow: 0 -2rpx 12rpx rgba(0,0,0,.04);
}
.edit-select-all { display: flex; align-items: center; gap: var(--s-sm); font-size: var(--fs-small); }
.checkbox {
  width: 40rpx; height: 40rpx; border-radius: 50%;
  border: 2rpx solid var(--c-border); display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; color: #fff;
}
.checkbox.checked { background: var(--c-text); border-color: var(--c-text); }
.edit-actions { display: flex; gap: var(--s-sm); }

/* ====== 悬浮新增按钮 ====== */
.fab-add {
  position: fixed;
  right: 40rpx;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  z-index: 100;
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: var(--c-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 28rpx rgba(232,164,0,.30);
}

.fab-add-icon {
  color: #fff;
  font-size: 56rpx;
  font-weight: 300;
  line-height: 1;
}

/* ====== 模态框 ====== */
.modal-mask {
  position: fixed;
  left: 0; right: 0; top: 0; bottom: 0;
  z-index: 10000;
  display: flex;
  align-items: flex-end;
  background: rgba(0,0,0,.32);
}

.modal-sheet {
  width: 100%;
  max-height: 86vh;
  display: flex;
  flex-direction: column;
  border-radius: 34rpx 34rpx 0 0;
  background: var(--c-surface);
  box-sizing: border-box;
}

.modal-sheet-sm {
  max-height: 50vh;
}

.modal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 28rpx 20rpx;
  flex-shrink: 0;
}

.modal-title {
  color: var(--c-text);
  font-size: 34rpx;
  font-weight: 800;
}

.modal-close {
  width: 58rpx; height: 58rpx;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  color: var(--c-text2);
  background: var(--c-bg);
  font-size: 42rpx;
  line-height: 1;
}

.modal-body {
  height: 60vh;
  padding: 0 28rpx 20rpx;
  box-sizing: border-box;
}

.modal-body-sm {
  padding: 0 28rpx 20rpx;
}

.parent-list {
  max-height: 500rpx;
  margin-top: 16rpx;
}

.parent-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--c-border-light);
}

.parent-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.parent-avatar-placeholder {
  background: var(--c-bg);
}

.parent-name {
  font-size: var(--fs-base);
  color: var(--c-text);
  font-weight: 600;
}

.parent-empty {
  text-align: center;
  color: var(--c-text3);
  font-size: var(--fs-small);
  padding: 40rpx 0;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 28rpx calc(24rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}

.modal-btn {
  height: 82rpx;
  border-radius: var(--r-full);
  display: flex; align-items: center; justify-content: center;
  font-size: var(--fs-small);
  font-weight: 800;
  transition: all .15s;
}

.modal-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.modal-cancel {
  width: 180rpx;
  color: var(--c-text2);
  background: var(--c-bg);
}

.modal-confirm {
  flex: 1;
  color: #fff;
  background: var(--c-primary);
  box-shadow: var(--shadow-btn);
}

.modal-danger {
  width: 160rpx;
  color: #fff;
  background: #FF4D4F;
  box-shadow: 0 2rpx 8rpx rgba(255, 77, 79, 0.2);
}

/* ====== 表单 ====== */
.form-photos {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.form-photo-item {
  width: 160rpx; height: 160rpx;
  border-radius: var(--r-lg);
  overflow: hidden;
  position: relative;
}

.form-photo-img {
  width: 100%; height: 100%;
}

.form-photo-del {
  position: absolute;
  top: -6rpx; right: -6rpx;
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  background: rgba(0,0,0,.5);
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 28rpx; line-height: 1;
}

.form-photo-add {
  width: 160rpx; height: 160rpx;
  border-radius: var(--r-lg);
  background: var(--c-bg);
  border: 2rpx dashed var(--c-border);
  display: flex; align-items: center; justify-content: center;
  color: var(--c-text3);
  font-size: 48rpx;
}

.form-field {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  margin-bottom: 12rpx;
  color: var(--c-text);
  font-size: var(--fs-small);
  font-weight: 800;
  line-height: 1.25;
}

.form-label-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.form-label-row .form-label {
  margin-bottom: 0;
}

.form-hint {
  display: block;
  color: var(--c-text3);
  font-size: var(--fs-mini);
}

.form-input {
  height: 78rpx;
  padding: 0 22rpx;
  border-radius: var(--r-lg);
  background: var(--c-bg);
  color: var(--c-text);
  font-size: var(--fs-small);
  box-sizing: border-box;
}

.form-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.chip-add {
  color: var(--c-primary);
  border-color: var(--c-primary);
  font-weight: 700;
}

.form-parent-row {
  height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 22rpx;
  border-radius: var(--r-lg);
  background: var(--c-bg);
}

.form-parent-value {
  color: var(--c-text);
  font-size: var(--fs-small);
  font-weight: 600;
}

.form-parent-value.empty {
  color: var(--c-text3);
  font-weight: 500;
}

.form-parent-arrow {
  color: var(--c-text3);
  font-size: 32rpx;
  line-height: 1;
}

.form-switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 22rpx;
  border-radius: var(--r-lg);
  background: var(--c-bg);
}

.form-switch-row .form-label {
  margin-bottom: 0;
}
