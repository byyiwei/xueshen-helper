/* ========== 骨架屏样式 ========== */
.skeleton-container {
  padding: 0 32rpx;
  position: relative;
  overflow: hidden;
}

.skeleton-container::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 40%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent);
  animation: skeleton-sweep 1.8s ease-in-out infinite;
  z-index: 1;
  pointer-events: none;
  will-change: transform;
}

.skeleton-filter-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(45, 106, 79, 0.04);
}

.skeleton-filter-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.skeleton-title {
  width: 120rpx;
  height: 36rpx;
  background: #EDF2F7;
  border-radius: 8rpx;
}

.skeleton-more-btn {
  width: 100rpx;
  height: 32rpx;
  background: #EDF2F7;
  border-radius: 8rpx;
}

.skeleton-filter-group {
  margin-bottom: 32rpx;
}

.skeleton-filter-label {
  width: 80rpx;
  height: 28rpx;
  background: #EDF2F7;
  border-radius: 6rpx;
  margin-bottom: 24rpx;
}

.skeleton-filter-chips {
  display: flex;
  gap: 16rpx;
}

.skeleton-chip {
  width: 100rpx;
  height: 56rpx;
  background: #EDF2F7;
  border-radius: 28rpx;
}

.skeleton-search {
  width: 100%;
  height: 88rpx;
  background: #EDF2F7;
  border-radius: 24rpx;
}

.skeleton-pet-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.skeleton-pet-card {
  display: flex;
  gap: 24rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(45, 106, 79, 0.04);
}

.skeleton-pet-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 24rpx;
  background: #EDF2F7;
  flex-shrink: 0;
}

.skeleton-pet-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 20rpx;
}

.skeleton-pet-name {
  width: 60%;
  height: 40rpx;
  background: #EDF2F7;
  border-radius: 10rpx;
}

.skeleton-pet-meta {
  width: 40%;
  height: 28rpx;
  background: #EDF2F7;
  border-radius: 8rpx;
}

@keyframes skeleton-sweep {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(450%); }
}

@keyframes voice-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}
