.page {
  position: relative;
  min-height: 100vh;
  background-color: #f5f0e6;
  background-image: linear-gradient(180deg, #f8f4ea 0%, #f5f0e6 120rpx);
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  padding-top: 24rpx;
}

.page.theme-mocha {
  background-color: #faf8f3;
  background-image: linear-gradient(180deg, #fdfcfa 0%, #faf8f3 120rpx);
}

.page.theme-olive {
  background-color: #f0f3ef;
  background-image: linear-gradient(180deg, #f4f7f2 0%, #f0f3ef 120rpx);
}

/* ====== 筛选卡片 ====== */
.filter-card {
  margin: 16rpx 24rpx 24rpx;
  padding: 28rpx 28rpx 24rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06), 0 0 0 1rpx rgba(0, 0, 0, 0.03);
}

.filter-card.theme-gold {
  background: linear-gradient(160deg, #fffdf7 0%, #fdf6e6 100%);
  box-shadow: 0 4rpx 24rpx rgba(184, 134, 11, 0.08), 0 0 0 1rpx rgba(184, 134, 11, 0.08);
}

.filter-card.theme-mocha {
  background: linear-gradient(160deg, #fdfcfa 0%, #f5f0e8 100%);
  box-shadow: 0 4rpx 24rpx rgba(139, 119, 101, 0.08), 0 0 0 1rpx rgba(139, 119, 101, 0.08);
}

.filter-card.theme-olive {
  background: linear-gradient(160deg, #f8faf5 0%, #eef3ea 100%);
  box-shadow: 0 4rpx 24rpx rgba(85, 107, 47, 0.08), 0 0 0 1rpx rgba(85, 107, 47, 0.08);
}

.filter-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.filter-card-title {
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: #1a1a1a;
}

.theme-gold .filter-card-title { color: #3a2d0f; }
.theme-mocha .filter-card-title { color: #3d352c; }
.theme-olive .filter-card-title { color: #2f3a22; }

.more-btn {
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  transition: all 0.2s ease;
  line-height: 1.6;
  display: flex;
  align-items: center;
  justify-content: center;
}

.theme-gold .more-btn {
  background: rgba(184, 134, 11, 0.08);
  color: #B8860B;
}
.theme-gold .more-btn.active {
  background: linear-gradient(135deg, #B8860B 0%, #d4a84b 100%);
  color: #ffffff;
}

.theme-mocha .more-btn {
  background: rgba(139, 119, 101, 0.1);
  color: #8B7765;
}
.theme-mocha .more-btn.active {
  background: linear-gradient(135deg, #8B7765 0%, #a08a76 100%);
  color: #ffffff;
}

.theme-olive .more-btn {
  background: rgba(85, 107, 47, 0.1);
  color: #556B2F;
}
.theme-olive .more-btn.active {
  background: linear-gradient(135deg, #556B2F 0%, #6a8a3f 100%);
  color: #ffffff;
}

/* 筛选分组 */
.filter-group {
  margin-bottom: 20rpx;
}

.filter-group-label {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 14rpx;
  display: block;
  letter-spacing: 1rpx;
}

.filter-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-chip {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  background: #ffffff;
  color: #666666;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
  line-height: 1.6;
  display: flex;
  align-items: center;
  justify-content: center;
}

.theme-gold .filter-chip {
  background: rgba(255, 255, 255, 0.85);
  color: #5a4a20;
  border-color: rgba(184, 134, 11, 0.12);
}
.theme-gold .filter-chip.active {
  background: linear-gradient(135deg, #B8860B 0%, #d4a84b 100%);
  color: #ffffff;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(184, 134, 11, 0.25);
}

.theme-mocha .filter-chip {
  background: rgba(255, 255, 255, 0.85);
  color: #6b5e50;
  border-color: rgba(139, 119, 101, 0.12);
}
.theme-mocha .filter-chip.active {
  background: linear-gradient(135deg, #8B7765 0%, #a08a76 100%);
  color: #ffffff;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(139, 119, 101, 0.25);
}

.theme-olive .filter-chip {
  background: rgba(255, 255, 255, 0.85);
  color: #4a5a35;
  border-color: rgba(85, 107, 47, 0.12);
}
.theme-olive .filter-chip.active {
  background: linear-gradient(135deg, #556B2F 0%, #6a8a3f 100%);
  color: #ffffff;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(85, 107, 47, 0.25);
}

/* 搜索框 */
.search-wrap {
  margin-top: 16rpx;
  position: relative;
  border-radius: 48rpx;
  background: #ffffff;
  box-shadow: inset 0 0 0 1rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

.theme-gold .search-wrap {
  background: rgba(255, 255, 255, 0.9);
  box-shadow: inset 0 0 0 1rpx rgba(184, 134, 11, 0.12);
}
.theme-mocha .search-wrap {
  background: rgba(255, 255, 255, 0.9);
  box-shadow: inset 0 0 0 1rpx rgba(139, 119, 101, 0.12);
}
.theme-olive .search-wrap {
  background: rgba(255, 255, 255, 0.9);
  box-shadow: inset 0 0 0 1rpx rgba(85, 107, 47, 0.12);
}

.search-input {
  width: 100%;
  font-size: 28rpx;
  color: #1a1a1a;
  background: transparent;
  padding: 24rpx 32rpx;
  box-sizing: border-box;
  text-align: left;
  display: block;
}

.search-placeholder {
  color: #c0b8a8;
  font-size: 28rpx;
}

.theme-gold .empty-circle {
  background: linear-gradient(135deg, #fff9e6 0%, #f5e6c8 100%);
