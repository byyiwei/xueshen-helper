.page {
  position: relative;
  min-height: 100vh;
  background-color: #F8FAFB;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* ====== 自定义导航栏 ====== */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: #F8FAFB;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2D6A4F;
  text-align: center;
}

.custom-nav.is-refreshing {
  flex-direction: column;
  height: auto;
  padding: 12rpx 0;
}

.nav-refresh-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #E8F5EE;
  border-top-color: #2D6A4F;
  border-radius: 50%;
  animation: navSpin 0.8s linear infinite;
}

@keyframes navSpin {
  to { transform: rotate(360deg); }
}

.nav-refresh-text {
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 4rpx;
}

/* ====== 筛选卡片 ====== */
.filter-card {
  margin: 16rpx 24rpx 24rpx;
  padding: 28rpx 28rpx 24rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 24rpx rgba(45, 106, 79, 0.06), 0 0 0 1rpx rgba(45, 106, 79, 0.03);
}

.filter-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.filter-card-title {
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: #2D6A4F;
}

.more-btn {
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  transition: all 0.2s ease;
  line-height: 1.6;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 筛选分组 */
.filter-group {
  margin-bottom: 20rpx;
}

.filter-group-label {
  font-size: 22rpx;
  color: #94A3B8;
  margin-bottom: 14rpx;
  display: block;
  letter-spacing: 1rpx;
}

.filter-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-chip {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  background: #ffffff;
  color: #5A6C7D;
  border: 1rpx solid rgba(45, 106, 79, 0.06);
  transition: all 0.2s ease;
  line-height: 1.6;
  display: flex;
  align-items: center;
  justify-content: center;
}

.filter-chip.active {
  background: linear-gradient(135deg, #2D6A4F 0%, #1B4332 100%);
  color: #ffffff;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(45, 106, 79, 0.15);
}

/* 搜索框 */
.search-wrap {
  margin-top: 16rpx;
  position: relative;
  border-radius: 48rpx;
  background: #ffffff;
  box-shadow: inset 0 0 0 1rpx rgba(45, 106, 79, 0.05);
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1B4332;
  background: transparent;
  padding: 24rpx 20rpx 24rpx 32rpx;
  box-sizing: border-box;
  text-align: left;
  display: block;
}

.scan-btn {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  padding-right: 8rpx;
}

.scan-btn-hover {
  opacity: 0.6;
}

.scan-icon {
  width: 40rpx;
  height: 40rpx;
  position: relative;
}

.scan-corner {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  border: 4rpx solid #2D6A4F;
}

.scan-corner.tl { top: 0; left: 0; border-right: none; border-bottom: none; }
.scan-corner.tr { top: 0; right: 0; border-left: none; border-bottom: none; }
.scan-corner.bl { bottom: 0; left: 0; border-right: none; border-top: none; }
.scan-corner.br { bottom: 0; right: 0; border-left: none; border-top: none; }

.scan-line {
  position: absolute;
  top: 50%;
  left: 6rpx;
  right: 6rpx;
  height: 3rpx;
  background: #2D6A4F;
  transform: translateY(-50%);
}

.search-placeholder {
  color: #94A3B8;
  font-size: 28rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx 16rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.8) 0%, transparent 100%);
}

.series {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  overflow: hidden;
}

.filter-label {
  font-size: 24rpx;
  color: #94A3B8;
  font-weight: 500;
  letter-spacing: 1rpx;
  flex-shrink: 0;
}

.filter-tags {
  display: flex;
  gap: 10rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 4rpx;
  scrollbar-width: none;
}

.filter-tags::-webkit-scrollbar {
  display: none;
}

.filter-tag {
  background-color: rgba(255,255,255,0.7);
  color: #94A3B8;
  padding: 8rpx 20rpx;
  border-radius: 28rpx;
  font-size: 24rpx;
  white-space: nowrap;
  border: 1rpx solid rgba(45, 106, 79, 0.06);
  transition: all 0.2s ease;
}

.filter-tag.active {
  background: linear-gradient(135deg, #2D6A4F 0%, #1B4332 100%);
  color: #ffffff;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(45, 106, 79, 0.15);
}

.more-btn {
  background-color: #ffffff;
  color: #94A3B8;
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(45, 106, 79, 0.06);
  border: 1rpx solid rgba(45, 106, 79, 0.05);
}

.more-btn.active {
  background: linear-gradient(135deg, #2D6A4F 0%, #1B4332 100%);
  color: #ffffff;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(45, 106, 79, 0.15);
}

.filters {
  padding: 0 32rpx 24rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.8) 0%, transparent 100%);
  border-radius: 0 0 24rpx 24rpx;
  margin: 0 -16rpx;
  padding-left: 48rpx;
  padding-right: 48rpx;
}

.filter-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.search-box {
  margin-top: 8rpx;
}

.search-input {
  width: 100%;
  box-sizing: border-box;
  background-color: rgba(255,255,255,0.9);
  border-radius: 48rpx;
  padding: 20rpx 48rpx 20rpx 32rpx;
  min-height: 84rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: #2D6A4F;
  box-shadow: 0 2rpx 12rpx rgba(45, 106, 79, 0.06);
  border: 1rpx solid rgba(45, 106, 79, 0.06);
}

.content {
  padding: 16rpx 24rpx;
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  margin-bottom: 32rpx;
}

.empty-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #EDF2F7 0%, #EDF2F7 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(45, 106, 79, 0.08);
}

.dots {
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #2D6A4F;
}

.empty-text {
  font-size: 32rpx;
  color: #2D6A4F;
}

.pet-list {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-between;
}

.pet-card {
  width: calc(50% - 10rpx);
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  border: none;
  margin-bottom: 20rpx;
  transition: all 0.22s cubic-bezier(0.25, 0.8, 0.25, 1);
  position: relative;
  box-shadow: 0 2rpx 16rpx rgba(45, 106, 79, 0.07), 0 0 0 1rpx rgba(45, 106, 79, 0.03);
}

.pet-card:active {
  transform: scale(0.97) translateY(2rpx);
  box-shadow: 0 4rpx 24rpx rgba(45, 106, 79, 0.12), 0 0 0 1rpx rgba(45, 106, 79, 0.04);
}

/* 图片容器 */
.pet-image-wrapper {
  position: relative;
  width: 100%;
  padding-bottom: 100%;
  overflow: hidden;
  background: transparent;
}

.pet-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
}

/* 编辑模式卡片 */
.pet-card.edit-mode {
  width: 100%;
  flex-direction: row;
  align-items: center;
  padding: 16rpx;
  gap: 16rpx;
}

.pet-card.edit-mode .pet-image-wrapper {
  width: 120rpx;
  height: 120rpx;
  padding-bottom: 0;
  flex-shrink: 0;
  border-radius: 16rpx;
  overflow: hidden;
}

.pet-card.edit-mode .pet-gender-badge {
  top: 8rpx;
  right: 8rpx;
  padding: 4rpx 12rpx;
}

.pet-card.edit-mode .pet-info-overlay {
  position: relative;
  background: none;
  padding: 8rpx;
  gap: 2rpx;
}

.pet-card.edit-mode .pet-card-name {
  color: #2D6A4F;
  font-size: 28rpx;
}

.pet-card.selected {
  border-color: var(--primary-color);
  background-color: rgba(45, 106, 79, 0.03);
}

/* 选择框 */
.card-checkbox {
  flex-shrink: 0;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #CBD5E1;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.checkbox.checked {
  border-color: var(--primary-color);
}

.check-mark {
  color: #ffffff;
  font-size: 22rpx;
  font-weight: bold;
}

/* 批量操作栏 */
.edit-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  background: linear-gradient(135deg, #ffffff 0%, #F8FAFB 100%);
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(45, 106, 79, 0.05);
  box-shadow: 0 2rpx 12rpx rgba(45, 106, 79, 0.05);
}

.edit-bar-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.select-all-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.select-all-text {
  font-size: 28rpx;
  color: #2D6A4F;
  font-weight: 500;
}

.selected-count {
  font-size: 24rpx;
  color: #94A3B8;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #CBD5E1;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
  background-color: rgba(255, 255, 255, 0.8);
}

.checkbox.checked {
  border-color: #2D6A4F;
  background-color: #2D6A4F;
}

.check-mark {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: bold;
}

.edit-bar-right {
  display: flex;
  gap: 16rpx;
}

.edit-bar-btn {
  font-size: 28rpx;
  font-weight: 500;
  padding: 10rpx 20rpx;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.edit-bar-btn:active {
  transform: scale(0.95);
}

.edit-bar-done {
  color: #2D6A4F;
  background: linear-gradient(135deg, rgba(250, 248, 243, 0.9) 0%, rgba(45, 106, 79, 0.05) 100%);
  border: 1rpx solid rgba(45, 106, 79, 0.08);
  padding: 10rpx 28rpx;
}

/* 拖动排序 */
.drag-handle {
  flex-shrink: 0;
  padding: 20rpx 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 60rpx;
}

.drag-dots {
  font-size: 44rpx;
  color: #CBD5E1;
  letter-spacing: 2rpx;
  line-height: 1;
}

.pet-card.dragging {
  opacity: 0.92;
  transform: scale(1.04);
  box-shadow: 0 12rpx 40rpx rgba(45, 106, 79, 0.18);
  z-index: 100;
  transition: box-shadow 0.15s ease, opacity 0.15s ease, transform 0.15s ease;
}

/* FAB */
.fab-hidden {
  opacity: 0;
  pointer-events: none;
  transform: scale(0.6) rotate(45deg);
}

.pet-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 24rpx 24rpx 0 0;
}

.pet-gender-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background-color: rgba(45, 106, 79, 0.55);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.gender-icon {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 500;
}

/* 宠物信息 - 图片下方 */
.pet-card-info {
  padding: 18rpx 20rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.pet-card-name {
  font-size: 28rpx;
  color: #2D6A4F;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  letter-spacing: 0.5rpx;
}

.pet-card-meta {
  font-size: 20rpx;
  color: #2D6A4F;
  background: #EDF2F7;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  border: 1rpx solid rgba(45, 106, 79, 0.05);
}

.pet-card-meta-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.pet-status-tag {
  font-size: 18rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.pet-status-normal {
  color: #2D6A4F;
  background: #E8F5EE;
}

.pet-status-waiting {
  color: #7B4B94;
  background: #F3E8FF;
}

.pet-status-warning {
  color: #C2410C;
  background: #FEE2E2;
}

.pet-status-sold {
  color: #6B7280;
  background: #F3F4F6;
}

.pet-status-dead {
  color: #6B7280;
  background: #F3F4F6;
}

.load-more {
  width: 100%;
  text-align: center;
  padding: 32rpx 0;
}

.load-more-text {
  font-size: 24rpx;
  color: #94A3B8;
}

.fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(180rpx + env(safe-area-inset-bottom));
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2D6A4F 0%, #1B4332 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(45, 106, 79, 0.25);
  transition: all 0.25s cubic-bezier(0.25, 1.5, 0.5, 1);
}

.fab:active {
  transform: scale(0.88);
  box-shadow: 0 4rpx 16rpx rgba(45, 106, 79, 0.3);
}

.fab-icon {
  font-size: 52rpx;
  color: #ffffff;
  font-weight: 300;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(45, 106, 79, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 10000;
  animation: overlayFadeIn 0.2s ease-out;
}

@keyframes overlayFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-overlay-center {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(45, 106, 79, 0.5);
  display: flex;
  align-items: flex-start;
  justify-content: center;
  z-index: 10000;
  padding-top: calc(280rpx + constant(safe-area-inset-top));
  padding-top: calc(280rpx + env(safe-area-inset-top));
  padding-bottom: calc(32rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  padding-left: 32rpx;
  padding-right: 32rpx;
  box-sizing: border-box;
}

.modal-content {
  width: 100%;
  background: linear-gradient(180deg, #ffffff 0%, #F8FAFB 100%);
  border-radius: 40rpx 40rpx 0 0;
  padding: calc(60rpx + env(safe-area-inset-top)) 36rpx calc(40rpx + env(safe-area-inset-bottom));
  max-height: 92vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 -8rpx 40rpx rgba(45, 106, 79, 0.08);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 36rpx;
  flex-shrink: 0;
}

.modal-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D6A4F;
  letter-spacing: 1rpx;
}

.modal-close {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: rgba(45, 106, 79, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #5A6C7D;
  transition: all 0.2s ease;
}

.modal-close:active {
  background-color: rgba(45, 106, 79, 0.1);
  transform: scale(0.92);
}

.photo-section {
  position: relative;
  margin-bottom: 40rpx;
}

.photo-grid {
  border: 2rpx dashed rgba(45, 106, 79, 0.1);
  border-radius: 28rpx;
  padding: 28rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: flex-start;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.5) 0%, rgba(45, 106, 79, 0.03) 100%);
}

.photo-item {
  position: relative;
  width: calc((100% - 48rpx) / 3);
  aspect-ratio: 1;
}

.photo-image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.photo-delete {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(45, 106, 79, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #ffffff;
}

.photo-upload {
  width: calc((100% - 40rpx) / 3);
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #F8FAFB 0%, #EDF2F7 100%);
  border-radius: 20rpx;
  border: 2rpx dashed rgba(45, 106, 79, 0.12);
  transition: all 0.2s ease;
}

.photo-upload:active {
  transform: scale(0.95);
  background: linear-gradient(135deg, #EDF2F7 0%, #E8F5EE 100%);
}

.upload-icon {
  font-size: 52rpx;
  color: #2D6A4F;
  font-weight: 300;
}

.upload-text {
  font-size: 22rpx;
  color: #2D6A4F;
  opacity: 0.8;
}

.photo-count {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  font-size: 24rpx;
  color: #94A3B8;
}

.input-section {
  margin-bottom: 36rpx;
}

.pet-input {
  flex: 1;
  height: 96rpx;
  box-sizing: border-box;
  background-color: rgba(248, 252, 249, 0.9);
  border-radius: 28rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  color: #2D6A4F;
  line-height: 96rpx;
  border: 1rpx solid rgba(45, 106, 79, 0.06);
  box-shadow: inset 0 2rpx 4rpx rgba(45, 106, 79, 0.04);
  min-width: 0;
}

.voice-input {
  background-color: #2D6A4F;
  border-radius: 48rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.voice-icon {
  font-size: 40rpx;
}

.voice-text {
  font-size: 32rpx;
  color: #ffffff;
}

.voice-btn {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: rgba(45, 106, 79, 0.06);
  border: 1rpx solid rgba(45, 106, 79, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.voice-btn:active {
  background-color: rgba(45, 106, 79, 0.08);
  transform: scale(0.9);
}

.voice-btn.recording {
