.preview-page {
  min-height: 100vh;
  background-color: #F0F7FF;
  padding-bottom: 40rpx;
  --primary-color: #3A7CFF;
  --primary-light: #EDF2F7;
  --primary-dark: #1A5CD6;
  --bg-color: #F0F7FF;
  --bg-light: #F0F7FF;
}

/* 加载中 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 300rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #EDF2F7;
  border-top-color: #3A7CFF;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #94A3B8;
}

/* 内容区 */
.preview-content {
  padding: 0;
}

/* 图片轮播区 */
.photo-section {
  position: relative;
  width: 100%;
  height: 500rpx;
  background-color: #EDF2F7;
}

.photo-swiper {
  width: 100%;
  height: 100%;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.photo-count {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  padding: 8rpx 20rpx;
  background-color: rgba(58, 124, 255, 0.5);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #ffffff;
}

.empty-photo {
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-photo-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-photo-icon {
  font-size: 80rpx;
}

.empty-photo-text {
  font-size: 28rpx;
  color: #94A3B8;
}

/* 信息卡片 */
.info-card {
  margin: -40rpx 24rpx 24rpx;
  padding: 32rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(58, 124, 255, 0.08);
  position: relative;
  z-index: 10;
}

.pet-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.pet-avatar-section {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  overflow: hidden;
  flex-shrink: 0;
  border: 4rpx solid #F0F7FF;
}

.pet-avatar {
  width: 100%;
  height: 100%;
}

.pet-avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #3A7CFF 0%, #1A5CD6 100%);
}

.pet-basic-info {
  flex: 1;
}

.pet-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #1E293B;
  margin-bottom: 16rpx;
  display: block;
}

.pet-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.gender-tag {
  background-color: #E0F2F7;
  color: #2A6F97;
}

.category-tag {
  background-color: #EDF2F7;
  color: #475569;
}

.status-tag {
  background-color: #EDF2F7;
  color: #475569;
}

.status-sick {
  background-color: #FDECE8;
  color: #E76F51;
}

.status-dead {
  background-color: #F0F7FF;
  color: #94A3B8;
}

.status-sold {
  background-color: #EDF2F7;
  color: #64748B;
}

.alias-tag {
  background-color: #E8F0F7;
  color: #2A6F97;
}

/* 父母信息 */
.parents-row {
  display: flex;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx solid #EDF2F7;
}

.parent-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.parent-label {
  font-size: 24rpx;
  color: #94A3B8;
}

.parent-value {
  font-size: 28rpx;
  color: #2A6F97;
  font-weight: 500;
}

.parent-value.unlinked {
  color: #2A6F97;
}

.parent-value.unlinked-red {
  color: #E76F51;
}

.parent-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: #EDF2F7;
}

/* 详细信息卡片 */
.detail-card,
.notes-card,
.events-card {
  margin: 0 24rpx 24rpx;
  padding: 32rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(58, 124, 255, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1E293B;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.event-count {
  font-size: 26rpx;
  color: #94A3B8;
  font-weight: normal;
}

/* 详细信息网格 */
.detail-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
}

.detail-icon {
  font-size: 40rpx;
}

.detail-content {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.detail-label {
  font-size: 22rpx;
  color: #94A3B8;
}

.detail-value {
  font-size: 28rpx;
  color: #1E293B;
  font-weight: 500;
}

/* 备注 */
.notes-content {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.8;
}

/* 事件统计 */
.event-stats {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  margin-bottom: 24rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-icon {
  font-size: 36rpx;
}

.stat-text {
  font-size: 22rpx;
  color: #475569;
}

/* 事件列表 */
.event-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.event-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  width: calc(25% - 9rpx);
  box-sizing: border-box;
  transition: all 0.2s ease;
  box-shadow: 0 4rpx 16rpx rgba(58, 124, 255, 0.04);
  border: 1rpx solid #EDF2F7;
}

.event-card:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(58, 124, 255, 0.08);
  background-color: #FFFFFF;
}

.event-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  background: #EDF2F7;
}

.event-icon-lay {
  background: #EDF2F7;
}

.event-icon-lay .icon-emoji {
  font-size: 40rpx;
}

.icon-emoji {
  font-size: 36rpx;
  line-height: 1;
  font-weight: bold;
}

.event-info {
  width: 100%;
  text-align: center;
}

.event-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 4rpx;
}

.event-content {
  font-size: 18rpx;
  color: #475569;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.3;
}

.event-date {
  font-size: 18rpx;
  color: #94A3B8;
}

.event-date .date {
  margin-right: 4rpx;
}

.event-date .time {
  opacity: 0.8;
}

/* 空事件提示 */
.empty-events {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #94A3B8;
}

/* 底部提示 */
.preview-footer {
  padding: 40rpx 0;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: #CBD5E1;
}

/* 二维码区域 */
.qrcode-section {
  margin: 0 24rpx 24rpx;
}

.qrcode-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(58, 124, 255, 0.06);
}

.qrcode-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.qrcode-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1E293B;
}

.qrcode-subtitle {
  font-size: 24rpx;
  color: #94A3B8;
}

.qrcode-right {
  flex-shrink: 0;
}

.qrcode-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  border: 2rpx solid #EDF2F7;
}

.qrcode-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #CBD5E1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #FFFFFF;
  gap: 12rpx;
}

.qrcode-icon {
  font-size: 48rpx;
}

.qrcode-hint {
  font-size: 22rpx;
  color: #94A3B8;
}

/* 底部操作栏 */
.preview-bottom-bar {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 40rpx 24rpx 60rpx;
}

.save-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, var(--primary-color, #3A7CFF) 0%, var(--primary-dark, #1A5CD6) 100%);
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(58, 124, 255, 0.12);
}

.save-btn-icon {
  font-size: 32rpx;
}

.save-btn-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}

/* 隐藏的 Canvas */
.preview-canvas {
  position: absolute;
  left: -9999px;
  top: 0;
  width: 750px;
  height: 3000px;
}

/* ========== 家族谱系样式 ========== */
.section {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(58, 124, 255, 0.06);
}

.section-pedigree {
  padding-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
}

.section-title-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.pedigree-badge {
  background: linear-gradient(135deg, var(--primary-color, #3A7CFF) 0%, var(--primary-dark, #1A5CD6) 100%);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  vertical-align: middle;
}

.pedigree-count {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 500;
  line-height: 1.2;
}

/* 收起状态 - 谱系卡片 */
.pedigree-cards {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: stretch;
  gap: 24rpx;
  padding: 16rpx 0 24rpx;
}

.pedigree-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 28rpx 12rpx;
  background-color: #ffffff;
  border: 2rpx solid var(--primary-light, #EDF2F7);
  border-radius: 24rpx;
  min-width: 200rpx;
  box-shadow: 0 4rpx 16rpx rgba(58, 124, 255, 0.06);
  position: relative;
  overflow: visible;
}

.card-gender-tag {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  min-width: 44rpx;
  height: 44rpx;
  padding: 0 10rpx;
  border-radius: 22rpx;
  font-size: 22rpx;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(58, 124, 255, 0.3);
  z-index: 1;
}

.card-gender-tag.male {
  background: linear-gradient(135deg, #2A6F97 0%, #2A6F97 100%);
}

.card-gender-tag.female {
  background: linear-gradient(135deg, #C77D5F 0%, #C77D5F 100%);
}

.card-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #F0F7FF 0%, #E6F0FF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.card-icon {
  font-size: 60rpx;
  color: #CBD5E1;
}

.card-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.card-label {
  font-size: 24rpx;
  color: var(--primary-color, #3A7CFF);
  font-weight: 600;
  padding: 6rpx 20rpx;
  background-color: var(--primary-light, #EDF2F7);
  border-radius: 12rpx;
}

.card-name {
  font-size: 32rpx;
  color: #1E293B;
  font-weight: 600;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-more {
  font-size: 22rpx;
  color: #94A3B8;
  padding: 4rpx 16rpx;
  background-color: #F0F7FF;
  border-radius: 10rpx;
}

.expand-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background-color: #F0F7FF;
  border-radius: 24rpx;
  transition: all 0.3s ease;
}

.expand-btn.expanded {
  background-color: var(--primary-light, #EDF2F7);
}

.expand-text {
  font-size: 26rpx;
  color: #475569;
}

.expand-icon {
  font-size: 24rpx;
  color: #94A3B8;
  transition: transform 0.3s ease;
}

.expand-btn.expanded .expand-icon {
  transform: rotate(180deg);
}

/* 收起状态 - 简洁预览 */
.pedigree-preview {
  padding: 8rpx 0;
  position: relative;
  overflow: visible;
}

.family-tree-empty {
  border: 2rpx dashed #CBD5E1;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  background-color: #FFFFFF;
}

.family-status {
  display: inline-block;
  padding: 8rpx 24rpx;
  background-color: #EDF2F7;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #64748B;
  margin-bottom: 24rpx;
}

.family-title {
  font-size: 32rpx;
  color: #1E293B;
  display: block;
  margin-bottom: 16rpx;
}

.family-hint {
  font-size: 26rpx;
  color: #94A3B8;
  display: block;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

/* 展开状态 - 完整族谱 */
.pedigree-full {
  padding: 16rpx 0;
  animation: fadeIn 0.3s ease;
  position: relative;
  overflow: visible;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 统计信息 */
.pedigree-stats {
  display: flex;
  justify-content: space-around;
  padding: 16rpx;
  background: #F0F7FF;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.pedigree-stats .stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.pedigree-stats .stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #000000;
}

.pedigree-stats .stat-label {
  font-size: 24rpx;
  color: #94A3B8;
}

/* 血缘主线 */
.bloodline-section {
  margin-bottom: 32rpx;
}

.bloodline-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.bloodline-title .title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
}

.bloodline-tabs {
  display: flex;
  gap: 12rpx;
}

.bloodline-tabs .tab {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #475569;
  background-color: #F0F7FF;
  border-radius: 24rpx;
  transition: all 0.2s ease;
}

.bloodline-tabs .tab.active {
  color: #ffffff;
  background-color: var(--primary-color, #3A7CFF);
}

.bloodline-content {
  padding: 32rpx 0;
}

.empty-line {
  text-align: center;
  padding: 48rpx;
  color: #94A3B8;
  font-size: 28rpx;
}

.bloodline-chain {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.bloodline-node {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.node-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  width: 100%;
  padding: 20rpx 24rpx;
  background-color: #ffffff;
  border: 2rpx solid #EDF2F7;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(58, 124, 255, 0.04);
  position: relative;
  overflow: visible;
}

.node-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-light, #EDF2F7) 0%, #F0F7FF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.node-avatar .avatar-img {
  width: 100%;
  height: 100%;
}

.node-avatar .avatar-text {
  font-size: 36rpx;
  color: var(--primary-color, #3A7CFF);
}

.node-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.node-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
}

.node-category {
  font-size: 24rpx;
  color: #94A3B8;
}

.chain-arrow {
  font-size: 32rpx;
  color: var(--primary-color, #3A7CFF);
  padding: 8rpx 0;
}

/* 完整家谱树 */
.family-tree-section {
  margin-top: 32rpx;
}

.tree-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.tree-title .title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
}

.tree-title .tree-hint {
  font-size: 24rpx;
  color: #94A3B8;
}

.empty-tree {
  text-align: center;
  padding: 48rpx;
  color: #94A3B8;
  background-color: #FFFFFF;
  border-radius: 16rpx;
}

.family-tree-visual {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 24rpx 120rpx;
  background: linear-gradient(180deg, #F0F7FF 0%, #ffffff 100%);
  border-radius: 20rpx;
  border: 2rpx solid var(--primary-light, #EDF2F7);
}

/* 代数标签 */
.generation-label {
  font-size: 24rpx;
  color: var(--primary-color, #3A7CFF);
  font-weight: 600;
  padding: 8rpx 24rpx;
  background-color: var(--primary-light, #EDF2F7);
  border-radius: 20rpx;
  margin-bottom: 8rpx;
}

.tree-level {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  width: 100%;
}

.tree-level.level-2 {
  gap: 16rpx;
}

.tree-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.tree-node.ancestor {
  background-color: #ffffff;
  border: 2rpx solid #E6F0FF;
  min-width: 160rpx;
}

.tree-node.parent {
  background-color: #ffffff;
  border: 2rpx solid var(--primary-light, #EDF2F7);
  min-width: 200rpx;
}

.tree-node.current {
  background: linear-gradient(135deg, var(--primary-color, #3A7CFF) 0%, var(--primary-dark, #1A5CD6) 100%);
  border: 2rpx solid var(--primary-dark, #1A5CD6);
  min-width: 240rpx;
  padding: 20rpx;
  position: relative;
  margin-top: 60rpx;
  padding-top: 60rpx;
}

/* 卡片外部性别标签 - 相对于tree-node定位 */
.tree-node .node-gender-tag {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  min-width: 44rpx;
  height: 44rpx;
  padding: 0 10rpx;
  border-radius: 22rpx;
  font-size: 22rpx;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(58, 124, 255, 0.3);
  z-index: 1;
}

.tree-node .node-gender-tag.male {
  background: linear-gradient(135deg, #2A6F97 0%, #2A6F97 100%);
}

.tree-node .node-gender-tag.female {
  background: linear-gradient(135deg, #C77D5F 0%, #C77D5F 100%);
}

.tree-node.parent .node-gender-tag {
  min-width: 52rpx;
  height: 52rpx;
  font-size: 26rpx;
  border-radius: 26rpx;
  top: 12rpx;
  right: 12rpx;
}

.tree-node.current .node-gender-tag {
  min-width: 56rpx;
  height: 56rpx;
  font-size: 28rpx;
  border-radius: 28rpx;
  top: 16rpx;
  right: 16rpx;
}

/* 当前龟标识 */
.tree-node .current-badge {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  padding: 10rpx 28rpx;
  background: linear-gradient(135deg, var(--primary-color, #3A7CFF) 0%, var(--primary-dark, #1A5CD6) 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(58, 124, 255, 0.3);
  z-index: 1;
}

.tree-node .node-avatar-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 240rpx;
  height: 240rpx;
  background-color: #F0F7FF;
  border-radius: 24rpx;
  overflow: hidden;
}

.tree-node .node-gender-text {
  font-size: 26rpx;
  color: var(--primary-color, #3A7CFF);
  font-weight: 600;
  margin-top: 8rpx;
  padding: 4rpx 20rpx;
  background-color: var(--primary-light, #EDF2F7);
  border-radius: 16rpx;
}

.tree-node .node-img {
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
  object-fit: cover;
}

.tree-node .node-icon {
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
  background-color: #F0F7FF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  color: #94A3B8;
}

/* 名称和别名 */
.tree-node .node-name {
  font-size: 26rpx;
  color: #1E293B;
  font-weight: 600;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 8rpx;
}

.tree-node.parent .node-name {
  font-size: 28rpx;
  max-width: 140rpx;
}

.tree-node.current .node-name {
  font-size: 30rpx;
  color: #ffffff;
  max-width: 160rpx;
}

.tree-node .node-alias {
  font-size: 22rpx;
  color: #94A3B8;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 4rpx;
}

.tree-node.parent .node-alias {
  font-size: 24rpx;
  max-width: 140rpx;
}

.tree-node.current .node-alias {
  color: rgba(255, 255, 255, 0.8);
  max-width: 160rpx;
}

.tree-connections {
  display: flex;
  justify-content: center;
  gap: 120rpx;
  width: 100%;
}

.connection-line {
  width: 2rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--primary-color, #3A7CFF) 0%, var(--primary-light, #EDF2F7) 100%);
}

.connection-line.center {
  width: 2rpx;
  height: 40rpx;
}

/* ========== 事件Tab样式 ========== */
.event-tabs {
  display: flex;
  gap: 10rpx;
  margin-bottom: 24rpx;
}

.event-tab {
  flex: 1;
  padding: 14rpx 16rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #475569;
  background-color: #F0F7FF;
  transition: all 0.15s ease;
  -webkit-user-select: none;
  user-select: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.event-tab-icon {
  font-size: 26rpx;
  line-height: 1;
}

.event-tab-text {
  font-size: 22rpx;
  line-height: 1;
}

.event-tab.active {
  background-color: #3A7CFF;
  color: #ffffff;
  font-weight: 500;
}

/* ========== 骨架屏样式 ========== */
.skeleton-container {
  padding: 0;
  position: relative;
  overflow: hidden;
}

.skeleton-container::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 40%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent);
  animation: skeleton-sweep 1.8s ease-in-out infinite;
  z-index: 1;
  pointer-events: none;
  will-change: transform;
}

.skeleton-photo-banner {
  width: 100%;
  height: 500rpx;
  background: #F0F7FF;
}

.skeleton-photo {
  width: 100%;
  height: 100%;
  background: #EDF2F7;
}

.skeleton-info-card {
  margin: -40rpx 24rpx 24rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(58, 124, 255, 0.08);
  position: relative;
  z-index: 10;
}

.skeleton-pet-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.skeleton-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #EDF2F7;
  flex-shrink: 0;
}

.skeleton-pet-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.skeleton-pet-name {
  width: 60%;
  height: 40rpx;
  background: #EDF2F7;
  border-radius: 8rpx;
}

.skeleton-pet-tags {
  display: flex;
  gap: 12rpx;
}

.skeleton-tag {
  width: 80rpx;
  height: 36rpx;
  background: #EDF2F7;
  border-radius: 18rpx;
}

.skeleton-parents-row {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.skeleton-parent-box {
  flex: 1;
  height: 56rpx;
  background: #EDF2F7;
  border-radius: 12rpx;
}

.skeleton-parent-divider {
  width: 2rpx;
  height: 40rpx;
  background: #EDF2F7;
}

.skeleton-detail-card {
  margin: 0 24rpx 24rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 24rpx;
}

.skeleton-card-title {
  width: 160rpx;
  height: 36rpx;
  background: #EDF2F7;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
}

.skeleton-detail-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.skeleton-detail-item {
  height: 80rpx;
  background: #EDF2F7;
  border-radius: 12rpx;
}

.skeleton-events-card {
  margin: 0 24rpx 24rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 24rpx;
}

.skeleton-event-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.skeleton-event-tab {
  flex: 1;
  height: 64rpx;
  background: #EDF2F7;
  border-radius: 16rpx;
}

.skeleton-event-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.skeleton-event-card {
  height: 120rpx;
  background: #EDF2F7;
  border-radius: 16rpx;
}

.skeleton-qrcode-section {
  padding: 0 24rpx;
}

.skeleton-qrcode-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 24rpx;
}

.skeleton-qrcode-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.skeleton-qrcode-title {
  width: 70%;
  height: 36rpx;
  background: #EDF2F7;
  border-radius: 8rpx;
}

.skeleton-qrcode-subtitle {
  width: 50%;
  height: 24rpx;
  background: #EDF2F7;
  border-radius: 6rpx;
}

.skeleton-qrcode-right {
  width: 160rpx;
  height: 160rpx;
  background: #EDF2F7;
  border-radius: 16rpx;
}

@keyframes skeleton-sweep {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(450%); }
}

/* ====== 事件详情弹窗 ====== */
.event-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
  padding-top: calc(40rpx + env(safe-area-inset-top));
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.record-detail-modal {
  width: 100%;
  max-width: 600rpx;
  background-color: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.record-detail-header {
  display: flex;
  align-items: center;
  padding: 32rpx;
  padding-bottom: 24rpx;
  background: linear-gradient(135deg, #F0F7FF 0%, #ffffff 100%);
}

.record-type-badge {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: #EDF2F7;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.record-type-icon {
  font-size: 40rpx;
  color: #3A7CFF;
  font-weight: 700;
  font-family: monospace;
}

.record-badge-lay {
  background: #EDF2F7;
}

.record-badge-lay .record-type-icon {
  font-size: 52rpx;
}

.record-detail-title {
  flex: 1;
  font-size: 34rpx;
  font-weight: bold;
  color: #1E293B;
}

.modal-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #94A3B8;
}

.record-detail-content {
  padding: 32rpx;
  min-height: 160rpx;
  flex: 1;
  overflow-y: auto;
}

.record-detail-text {
  font-size: 30rpx;
  color: #1E293B;
  line-height: 1.7;
}

.record-detail-footer {
  padding: 0 32rpx 32rpx;
  flex-shrink: 0;
}

.record-detail-date {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.date-label {
  font-size: 26rpx;
  color: #94A3B8;
  margin-right: 16rpx;
}

.date-value {
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
}

.record-detail-actions {
  display: flex;
  gap: 20rpx;
  align-items: center;
  justify-content: center;
}

.record-detail-actions .btn-confirm {
  flex: 1;
  padding: 22rpx 40rpx;
  font-size: 28rpx;
  min-height: 76rpx;
  border-radius: 40rpx;
  font-weight: 500;
  background: linear-gradient(135deg, #3A7CFF 0%, #1A5CD6 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(58, 124, 255, 0.15);
  text-align: center;
}

