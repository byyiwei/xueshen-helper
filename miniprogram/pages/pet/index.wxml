<view class="page-pet-list">
  <view class="nav-bar" style="padding-top:{{statusBarHeight}}px">
    <text class="nav-title">宠物档案</text>
  </view>

  <view style="padding-top:{{totalNavHeight}}rpx">
    <!-- 刷新中提示 -->
    <view wx:if="{{refreshing}}" class="refreshing-bar">
      <view class="refreshing-spinner"></view>
      <text class="refreshing-text">刷新中...</text>
    </view>

    <!-- 未登录提示 -->
    <view wx:if="{{!isLoggedIn}}" class="login-bar" bindtap="goToLogin">
      <text class="login-bar-text">登录后可管理宠物资料、记录和打印标签</text>
      <view class="login-bar-btn"><text>立即登录 ›</text></view>
    </view>

    <!-- 筛选区 -->
    <view class="filter-bar">
      <view class="filter-left">
        <text class="filter-label">系列</text>
        <scroll-view scroll-x class="chip-scroll" show-scrollbar="{{false}}">
          <text class="chip {{filter.category==='全部'?'active':''}}" bindtap="setFilter" data-key="category" data-value="全部">全部</text>
          <block wx:for="{{categories}}" wx:key="*this">
            <text class="chip {{filter.category===item?'active':''}}" bindtap="setFilter" data-key="category" data-value="{{item}}">{{item}}</text>
          </block>
        </scroll-view>
      </view>
      <view class="filter-more press" bindtap="toggleFilters">
        <text>更多</text>
      </view>
    </view>

    <!-- 展开筛选 -->
    <view wx:if="{{showFilters}}" class="filter-expand card-flush">
      <view class="expand-row">
        <text class="expand-label">性别</text>
        <text class="chip-sm {{filter.gender==='全部'?'active':''}}" bindtap="setFilter" data-key="gender" data-value="全部">全部</text>
        <text class="chip-sm {{filter.gender==='公'?'active':''}}" bindtap="setFilter" data-key="gender" data-value="公">公</text>
        <text class="chip-sm {{filter.gender==='母'?'active':''}}" bindtap="setFilter" data-key="gender" data-value="母">母</text>
        <text class="chip-sm {{filter.gender==='未知'?'active':''}}" bindtap="setFilter" data-key="gender" data-value="未知">未知</text>
      </view>
      <view class="expand-row">
        <text class="expand-label">状态</text>
        <text class="chip-sm {{filter.status==='全部'?'active':''}}" bindtap="setFilter" data-key="status" data-value="全部">全部</text>
        <text class="chip-sm {{filter.status==='正常'?'active':''}}" bindtap="setFilter" data-key="status" data-value="正常">正常</text>
        <text class="chip-sm {{filter.status==='待配'?'active':''}}" bindtap="setFilter" data-key="status" data-value="待配">待配</text>
        <text class="chip-sm {{filter.status==='预警'?'active':''}}" bindtap="setFilter" data-key="status" data-value="预警">预警</text>
      </view>
      <!-- 搜索 -->
      <view class="search-row">
        <input class="search-input" placeholder="搜索名称别名/扫码搜索" value="{{searchText}}" bindinput="onSearchInput"/>
        <view class="scan-btn press" bindtap="scanQrCode">
          <view class="scan-icon">
            <view class="scan-frame"></view>
            <view class="scan-line"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 宠物网格 -->
    <view wx:if="{{filteredPets.length===0}}" class="empty-box">
      <text class="empty-icon">🐢</text>
      <text class="empty-text">还没有宠物档案</text>
      <text class="empty-hint">点击下方 + 添加你的第一只龟</text>
    </view>

    <view wx:else class="pet-grid">
      <view wx:for="{{filteredPets}}" wx:key="id" class="pet-card press" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="pet-img-wrap {{item.photos&&item.photos.length&&item.photos[0]?'':'pet-img-wrap-empty'}}">
          <image wx:if="{{item.photos&&item.photos.length&&item.photos[0]}}" src="{{item.photos[0]}}" mode="aspectFill" binderror="onImageError" data-index="{{index}}"/>
          <view wx:else class="pet-noimg"></view>
          <text class="overlay-gender" wx:if="{{item.gender==='公'}}">公</text>
          <text class="overlay-gender" wx:elif="{{item.gender==='母'}}">母</text>
          <text class="overlay-gender" wx:else>?</text>
          <!-- 图片内信息叠加层 -->
          <view class="pet-overlay-info">
            <text class="overlay-category">{{item.category||'宠物'}}</text>
          </view>
          <!-- 浮动记录按钮 -->
          <view class="pet-record-btn" catchtap="showRecordModal" data-pet="{{item}}" stop-propagation><text>记录</text></view>
        </view>
        <view class="pet-card-info">
          <text class="pet-card-name">{{item.alias||item.name}}</text>
        </view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view wx:if="{{loadingMore}}" class="load-more">
      <view class="load-more-spinner"></view>
      <text class="load-more-text">加载中...</text>
    </view>
    <view wx:elif="{{hasMore && filteredPets.length>0}}" class="load-more-btn-wrap">
      <view class="load-more-btn press" bindtap="loadMorePets">
        <text>加载更多</text>
      </view>
    </view>
    <view wx:elif="{{filteredPets.length>0 && !hasMore}}" class="load-all">
      <text>已加载全部 {{total}} 只宠物</text>
    </view>

    <view class="safe-bottom" style="height:120rpx"></view>
  </view>

  <!-- 悬浮新增按钮 -->
  <view class="fab-add press" bindtap="showAddModal">
    <text class="fab-add-icon">＋</text>
  </view>

  <!-- 新增宠物模态框 -->
  <view wx:if="{{showModal}}" class="modal-mask" bindtap="hideAddModal">
    <view class="modal-sheet" catchtap="stopPropagation">
      <view class="modal-head">
        <text class="modal-title">新增宠物</text>
        <text class="modal-close" bindtap="hideAddModal">×</text>
      </view>

      <scroll-view scroll-y class="modal-body">
        <!-- 照片选择 -->
        <view class="form-photos">
          <view wx:for="{{petForm.photos}}" wx:key="*this" class="form-photo-item">
            <image src="{{item}}" mode="aspectFill" class="form-photo-img"/>
            <view class="form-photo-del press" catchtap="deletePhoto" data-index="{{index}}"><text>×</text></view>
          </view>
          <view wx:if="{{petForm.photos.length<9}}" class="form-photo-add press" bindtap="chooseImage">
            <text>＋</text>
          </view>
        </view>

        <!-- 名称 -->
        <view class="form-field">
          <text class="form-label">名称</text>
          <input class="form-input" placeholder="请输入宠物名称" value="{{petForm.name}}" bindinput="onNameInput"/>
        </view>

        <!-- 别名 -->
        <view class="form-field">
          <text class="form-label">别名</text>
          <input class="form-input" placeholder="可选" value="{{petForm.alias}}" bindinput="onAliasInput"/>
        </view>

        <!-- 分类 -->
        <view class="form-field">
          <view class="form-label-row">
            <text class="form-label">分类</text>
            <text class="form-hint">点击分类选中，长按编辑名称</text>
          </view>
          <view class="form-chips">
            <view wx:for="{{categories}}" wx:key="*this" class="chip {{petForm.category===item?'active':''}}" bindtap="selectCategory" bindlongpress="editCategory" data-category="{{item}}">{{item}}</view>
            <view class="chip chip-add press" bindtap="addCategory">＋</view>
          </view>
        </view>

        <!-- 性别 -->
        <view class="form-field">
          <text class="form-label">性别</text>
          <view class="form-chips">
            <text class="chip {{petForm.gender==='公'?'active':''}}" bindtap="selectGender" data-gender="公">公</text>
            <text class="chip {{petForm.gender==='母'?'active':''}}" bindtap="selectGender" data-gender="母">母</text>
            <text class="chip {{petForm.gender==='未知'?'active':''}}" bindtap="selectGender" data-gender="未知">未知</text>
          </view>
        </view>

        <!-- 价格 -->
        <view class="form-field">
          <text class="form-label">价格</text>
          <input class="form-input" type="digit" placeholder="可选" value="{{petForm.price}}" bindinput="onPriceInput"/>
        </view>

        <!-- 状态 -->
        <view class="form-field">
          <text class="form-label">状态</text>
          <view class="form-chips">
            <text class="chip {{petForm.status==='正常'?'active':''}}" bindtap="selectStatus" data-status="正常">正常</text>
            <text class="chip {{petForm.status==='待配'?'active':''}}" bindtap="selectStatus" data-status="待配">待配</text>
            <text class="chip {{petForm.status==='预警'?'active':''}}" bindtap="selectStatus" data-status="预警">预警</text>
          </view>
        </view>

        <!-- 父本 -->
        <view class="form-field">
          <text class="form-label">父本</text>
          <view class="form-parent-row" bindtap="selectParent" data-parent="father">
            <text class="form-parent-value {{petForm.fatherName?'':'empty'}}">{{petForm.fatherName||'点击选择父本'}}</text>
            <text class="form-parent-arrow">›</text>
          </view>
        </view>

        <!-- 母本 -->
        <view class="form-field">
          <text class="form-label">母本</text>
          <view class="form-parent-row" bindtap="selectParent" data-parent="mother">
            <text class="form-parent-value {{petForm.motherName?'':'empty'}}">{{petForm.motherName||'点击选择母本'}}</text>
            <text class="form-parent-arrow">›</text>
          </view>
        </view>

        <!-- 配偶 -->
        <view class="form-field">
          <text class="form-label">配偶</text>
          <view class="form-parent-row" bindtap="selectParent" data-parent="partner">
            <text class="form-parent-value {{petForm.partnerName?'':'empty'}}">{{petForm.partnerName||'点击选择配偶'}}</text>
            <text class="form-parent-arrow">›</text>
          </view>
        </view>

        <!-- 公开展示 -->
        <view class="form-field form-switch-row">
          <view>
            <text class="form-label">公开展示</text>
            <text class="form-hint">允许通过分享页查看这只宠物</text>
          </view>
          <switch checked="{{petForm.isPublic}}" bindchange="onPublicSwitchChange" color="{{switchColor}}"/>
        </view>
      </scroll-view>

      <view class="modal-actions">
        <view class="modal-btn modal-cancel press" bindtap="hideAddModal">取消</view>
        <view class="modal-btn modal-confirm press" bindtap="confirmCreate">创建</view>
      </view>
    </view>
  </view>

  <!-- 父本选择弹窗 -->
  <view wx:if="{{showFatherModal}}" class="modal-mask" bindtap="hideFatherModal">
    <view class="modal-sheet modal-sheet-sm" catchtap="stopPropagation">
      <view class="modal-head">
        <text class="modal-title">选择父本</text>
        <text class="modal-close" bindtap="hideFatherModal">×</text>
      </view>
      <view class="modal-body-sm">
        <input class="form-input" placeholder="搜索名称" value="{{fatherSearchText}}" bindinput="onFatherSearch"/>
        <scroll-view scroll-y class="parent-list">
          <view wx:for="{{fatherList}}" wx:key="id" class="parent-item press" catchtap="selectFather" data-id="{{item.id||item._id}}">
            <image wx:if="{{item.photos&&item.photos[0]}}" src="{{item.photos[0]}}" mode="aspectFill" class="parent-avatar"/>
            <view wx:else class="parent-avatar parent-avatar-placeholder"></view>
            <text class="parent-name">{{item.alias||item.name}}</text>
          </view>
          <view wx:if="{{fatherList.length===0}}" class="parent-empty">暂无可选父本</view>
        </scroll-view>
      </view>
      <view class="modal-actions">
        <view class="modal-btn modal-cancel press" bindtap="hideFatherModal">取消</view>
        <view wx:if="{{petForm.fatherName}}" class="modal-btn modal-confirm press" bindtap="clearFather">清除选择</view>
      </view>
    </view>
  </view>

  <!-- 母本选择弹窗 -->
  <view wx:if="{{showMotherModal}}" class="modal-mask" bindtap="hideMotherModal">
    <view class="modal-sheet modal-sheet-sm" catchtap="stopPropagation">
      <view class="modal-head">
        <text class="modal-title">选择母本</text>
        <text class="modal-close" bindtap="hideMotherModal">×</text>
      </view>
      <view class="modal-body-sm">
        <input class="form-input" placeholder="搜索名称" value="{{motherSearchText}}" bindinput="onMotherSearch"/>
        <scroll-view scroll-y class="parent-list">
          <view wx:for="{{motherList}}" wx:key="id" class="parent-item press" catchtap="selectMother" data-id="{{item.id||item._id}}">
            <image wx:if="{{item.photos&&item.photos[0]}}" src="{{item.photos[0]}}" mode="aspectFill" class="parent-avatar"/>
            <view wx:else class="parent-avatar parent-avatar-placeholder"></view>
            <text class="parent-name">{{item.alias||item.name}}</text>
          </view>
          <view wx:if="{{motherList.length===0}}" class="parent-empty">暂无可选母本</view>
        </scroll-view>
      </view>
      <view class="modal-actions">
        <view class="modal-btn modal-cancel press" bindtap="hideMotherModal">取消</view>
        <view wx:if="{{petForm.motherName}}" class="modal-btn modal-confirm press" bindtap="clearMother">清除选择</view>
      </view>
    </view>
  </view>

  <!-- 配偶选择弹窗 -->
  <view wx:if="{{showPartnerModal}}" class="modal-mask" bindtap="hidePartnerModal">
    <view class="modal-sheet modal-sheet-sm" catchtap="stopPropagation">
      <view class="modal-head">
        <text class="modal-title">选择配偶</text>
        <text class="modal-close" bindtap="hidePartnerModal">×</text>
      </view>
      <view class="modal-body-sm">
        <input class="form-input" placeholder="搜索名称" value="{{partnerSearchText}}" bindinput="onPartnerSearch"/>
        <scroll-view scroll-y class="parent-list">
          <view wx:for="{{partnerList}}" wx:key="id" class="parent-item press" catchtap="selectPartner" data-id="{{item.id||item._id}}">
            <image wx:if="{{item.photos&&item.photos[0]}}" src="{{item.photos[0]}}" mode="aspectFill" class="parent-avatar"/>
            <view wx:else class="parent-avatar parent-avatar-placeholder"></view>
            <text class="parent-name">{{item.alias||item.name}}</text>
          </view>
          <view wx:if="{{partnerList.length===0}}" class="parent-empty">暂无可选宠物</view>
        </scroll-view>
      </view>
      <view class="modal-actions">
        <view class="modal-btn modal-cancel press" bindtap="hidePartnerModal">取消</view>
        <view wx:if="{{petForm.partnerName}}" class="modal-btn modal-confirm press" bindtap="clearPartner">清除选择</view>
      </view>
    </view>
  </view>

  <!-- 添加分类模态框 -->
  <view wx:if="{{showAddCategoryModal}}" class="modal-mask" bindtap="hideAddCategoryModal">
    <view class="modal-sheet modal-sheet-sm" catchtap="stopPropagation">
      <view class="modal-head">
        <text class="modal-title">新增分类</text>
        <text class="modal-close" bindtap="hideAddCategoryModal">×</text>
      </view>
      <view class="modal-body-sm">
        <input class="form-input" placeholder="输入分类名称" value="{{newCategoryName}}" bindinput="onCategoryInput"/>
      </view>
      <view class="modal-actions">
        <view class="modal-btn modal-cancel press" bindtap="hideAddCategoryModal">取消</view>
        <view class="modal-btn modal-confirm press" bindtap="confirmAddCategory">添加</view>
      </view>
    </view>
  </view>

  <!-- 编辑分类模态框 -->
  <view wx:if="{{showEditCategoryModal}}" class="modal-mask" bindtap="hideEditCategoryModal">
    <view class="modal-sheet modal-sheet-sm" catchtap="stopPropagation">
      <view class="modal-head">
        <text class="modal-title">编辑分类</text>
        <text class="modal-close" bindtap="hideEditCategoryModal">×</text>
      </view>
      <view class="modal-body-sm">
        <input class="form-input" placeholder="输入新名称" value="{{editCategoryNewName}}" bindinput="onEditCategoryInput"/>
      </view>
      <view class="modal-actions">
        <view class="modal-btn modal-cancel press" bindtap="hideEditCategoryModal">取消</view>
        <view class="modal-btn modal-danger press" bindtap="deleteCategory" data-category="{{editCategoryOldName}}">删除</view>
        <view class="modal-btn modal-confirm press" bindtap="confirmEditCategory">保存</view>
      </view>
    </view>
  </view>

</view>
