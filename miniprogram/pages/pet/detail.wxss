  max-width: 400rpx;
}

.tree-node .node-alias {
  font-size: 22rpx;
  color: #94A3B8;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 4rpx;
}

.tree-node.parent .node-alias {
  font-size: 24rpx;
