  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
  min-width: 48rpx;
  height: 48rpx;
  padding: 0 12rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  box-shadow: 0 4rpx 8rpx rgba(58, 124, 255, 0.3);
}

.tree-node .node-gender-badge.male {
  background-color: #2A6F97;
}

.tree-node .node-gender-badge.female {
  background-color: #C77D5F;
}

.tree-node.parent .node-gender-badge {
