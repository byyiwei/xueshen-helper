  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3A7CFF 0%, #1A5CD6 100%);
  box-shadow: 0 4rpx 16rpx rgba(58, 124, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.voice-btn-inline:active,
.voice-btn-inline.recording {
  transform: scale(0.95);
  background: linear-gradient(135deg, #E76F51 0%, #C77D5F 100%);
  box-shadow: 0 4rpx 16rpx rgba(199, 125, 95, 0.4);
}

.voice-btn-inline-icon {
  font-size: 28rpx;
  color: #ffffff;
  line-height: 1;
}

.form-input {
  flex: 1;
  height: 88rpx;
  box-sizing: border-box;
  padding: 0 24rpx;
  border: 2rpx solid #E6F0FF;
  border-radius: 16rpx;
  font-size: 28rpx;
  background-color: #FFFFFF;
  line-height: 88rpx;
  min-width: 0;
}

.voice-btn {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: #F0F7FF;
  border: 2rpx solid #E6F0FF;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.voice-btn:active {
  background-color: #E6F0FF;
  transform: scale(0.9);
}

.voice-btn.recording {
  background: linear-gradient(135deg, #E76F51 0%, #C77D5F 100%);
  border-color: #E76F51;
  animation: voice-pulse 1s infinite;
}

.voice-btn.recording .voice-btn-icon {
  color: #fff;
}

.voice-cancel-btn {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #E53E3E;
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.voice-cancel-inline {
  font-size: 24rpx;
  color: #E53E3E;
  padding: 8rpx 20rpx;
  border: 2rpx solid #E53E3E;
  border-radius: 24rpx;
}

.voice-btn-icon {
  font-size: 28rpx;
  color: #94A3B8;
  line-height: 1;
}

.input-with-voice {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%;
}

.form-textarea {
  width: 100%;
  min-height: 220rpx;
  padding: 28rpx;
  border: 3rpx dashed var(--primary-color);
  border-radius: 20rpx;
  font-size: 28rpx;
  background-color: rgba(58, 124, 255, 0.03);
  box-sizing: border-box;
}

.form-textarea:focus {
  border-style: solid;
  border-color: var(--primary-color);
  background-color: #ffffff;
}

.form-options {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.form-switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.switch-hint {
  font-size: 26rpx;
  color: #475569;
  flex: 1;
}

.option {
  padding: 16rpx 32rpx;
  background-color: #F0F7FF;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #475569;
}

.option.active {
  background-color: #3A7CFF;
  color: #ffffff;
}

.confirm-modal {
  width: 100%;
  max-width: 560rpx;
  background-color: #ffffff;
  border-radius: 28rpx;
  padding: 40rpx 32rpx 32rpx;
}

.confirm-content {
  text-align: center;
}

.confirm-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  background: #FDECE8;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
}

.confirm-icon {
  font-size: 48rpx;
  line-height: 1;
}

.confirm-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1E293B;
  margin-bottom: 16rpx;
}

.confirm-text {
  display: block;
  font-size: 28rpx;
  color: #475569;
  line-height: 1.6;
  margin-bottom: 0;
}

.confirm-divider {
  height: 1rpx;
  background: #EDF2F7;
  margin: 32rpx 0;
}

.confirm-buttons {
  display: flex;
  gap: 20rpx;
}

.record-type-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.record-type-item {
  padding: 16rpx 24rpx;
  background-color: #ffffff;
  border: 2rpx solid #E6F0FF;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #475569;
  transition: all 0.2s ease;
  min-width: 90rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.record-type-icon {
  font-size: 24rpx;
  line-height: 1;
}

.record-type-text {
  font-size: 22rpx;
  line-height: 1;
}

.record-type-item.active {
  background-color: #3A7CFF;
  color: #ffffff;
  border-color: #3A7CFF;
  box-shadow: 0 4rpx 12rpx rgba(58, 124, 255, 0.25);
  font-weight: 500;
}

.record-type-item:not(.active):active {
  border-color: var(--primary-color);
  color: var(--primary-color);
  transform: scale(0.98);
}

/* ===== 图片轮播（详情页顶部） ===== */
.photo-banner {
  width: 100%;
  margin-bottom: 0;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(58, 124, 255, 0.06);
}

.photo-swiper {
  width: 100%;
  height: 610rpx;
}

.photo-swiper-img {
  width: 100%;
  height: 100%;
}

/* ===== 图片管理（编辑弹窗） ===== */
.photo-manager {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 0;
}

.photo-thumb-wrap {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}

.photo-thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  border: 2rpx solid #E6F0FF;
}

.photo-del {
  position: absolute;
  top: -14rpx;
  right: -14rpx;
  width: 36rpx;
  height: 36rpx;
  background-color: rgba(58, 124, 255, 0.6);
  border-radius: 18rpx;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 34rpx;
  text-align: center;
}

.photo-add-btn {
  width: 140rpx;
  height: 140rpx;
  border: 2rpx dashed #CBD5E1;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.photo-add-icon {
  font-size: 56rpx;
  color: #CBD5E1;
  line-height: 1;
}

/* ============================================================
   提醒事件 — 详情页中部提醒展示区
   ============================================================ */

.reminder-section {
  background: #ffffff;
  border-radius: 24rpx;
  margin: 24rpx 0;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(58, 124, 255, 0.04);
  border: 2rpx solid #EDF2F7;
}

.reminder-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.reminder-header-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1E293B;
}

.reminder-header-count {
  font-size: 24rpx;
  color: #94A3B8;
}

.reminder-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* 详情页提醒卡片：图标+类型+状态胶囊在顶部，元信息在底部 */
.reminder-card {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  gap: 16rpx;
}

.reminder-icon-box {
  width: 64rpx;
  height: 64rpx;
  background: #ffffff;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 2rpx solid #EDF2F7;
}

.reminder-icon {
  font-size: 28rpx;
  line-height: 1;
}

.reminder-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.reminder-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.reminder-type {
  font-size: 28rpx;
  font-weight: 700;
  color: #1E293B;
}

.reminder-status {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  background: #EDF2F7;
  color: #475569;
  white-space: nowrap;
  flex-shrink: 0;
}

.reminder-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.reminder-meta {
  font-size: 22rpx;
  color: #94A3B8;
}

.reminder-action {
  padding: 8rpx 20rpx;
  background: #3A7CFF;
  border-radius: 20rpx;
  flex-shrink: 0;
  transition: transform 0.15s;
}

.reminder-action-text {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 600;
}

.reminder-action:active {
  transform: scale(0.95);
}

.reminder-action.done {
  background: #EDF2F7;
}

.reminder-action.done .reminder-action-text {
  color: #3A7CFF;
}

/* 状态强调色（详情页） */
.reminder-card.reminder-overdue {
  background: #FDE8E0;
  border: 2rpx solid #EDD8D0;
}
.reminder-card.reminder-overdue .reminder-status {
  background: #FDECE8;
  color: #E76F51;
}

.reminder-card.reminder-today {
  background: #FDE8E0;
  border: 2rpx solid #EDD0C0;
}
.reminder-card.reminder-today .reminder-status {
  background: #FDE8E0;
  color: #E76F51;
}

.reminder-card.reminder-tomorrow {
  background: #F9F3D8;
  border: 2rpx solid #F0E8D0;
}
.reminder-card.reminder-tomorrow .reminder-status {
  background: #F9F3D8;
  color: #64748B;
}

.reminder-card.reminder-normal {
  background: #FFFFFF;
  border: 2rpx solid #EDF2F7;
}
.reminder-card.reminder-normal .reminder-status {
  background: #EDF2F7;
  color: #3A7CFF;
}

.reminder-card.reminder-pending {
  background: #FFFFFF;
  border: 2rpx solid #EDF2F7;
}
.reminder-card.reminder-pending .reminder-status {
  background: #EDF2F7;
  color: #94A3B8;
}

/* ============================================================
   提醒事件管理弹窗
   ============================================================ */

.safe-area-top {
  height: 20rpx;
  flex-shrink: 0;
}

.reminder-modal {
  background: #ffffff;
  width: 100%;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  max-height: 85vh;
}

.reminder-modal-empty {
  padding: 60rpx 32rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.reminder-empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.reminder-empty-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #3A7CFF;
  margin-bottom: 12rpx;
}

.reminder-empty-hint {
  font-size: 24rpx;
  color: #94A3B8;
  line-height: 1.6;
}

/* 列表区：允许滚动，占满剩余空间 */
.reminder-modal-list {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding: 0 32rpx;
  box-sizing: border-box;
  -webkit-overflow-scrolling: touch;
}

/* 列表项：图标 + 内容区，按钮在下方 */
.reminder-modal-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  box-sizing: border-box;
}

.reminder-modal-icon {
  width: 72rpx;
  height: 72rpx;
  background: #ffffff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
  border: 2rpx solid #EDF2F7;
}

.reminder-modal-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.reminder-modal-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.reminder-modal-type {
  font-size: 30rpx;
  font-weight: 700;
  color: #3A7CFF;
}

.reminder-modal-status {
  font-size: 24rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  background: #EDF2F7;
  color: #475569;
  white-space: nowrap;
  flex-shrink: 0;
}

/* 状态强调色 */
.reminder-modal-status.reminder-status-overdue {
  background: #FDECE8;
  color: #E76F51;
}

.reminder-modal-status.reminder-status-today {
  background: #FDE8E0;
  color: #E76F51;
}

.reminder-modal-status.reminder-status-tomorrow {
  background: #F9F3D8;
  color: #64748B;
}

.reminder-modal-status.reminder-status-normal {
  background: #EDF2F7;
  color: #3A7CFF;
}

.reminder-modal-status.reminder-status-pending {
  background: #EDF2F7;
  color: #94A3B8;
}

.reminder-modal-sub {
  font-size: 24rpx;
  color: #475569;
  line-height: 1.5;
}

.reminder-modal-sub-dim .reminder-modal-meta,
.reminder-modal-sub-dim {
  color: #CBD5E1;
  font-size: 22rpx;
}

.reminder-modal-meta {
  font-size: 24rpx;
  line-height: 1.5;
  word-break: break-all;
}

/* 按钮区：内容下方一行，紧凑胶囊按钮 */
.reminder-modal-btns {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  margin-top: 12rpx;
}

.reminder-modal-btn {
  flex: 1;
  padding: 14rpx 0;
  border-radius: 14rpx;
  font-size: 24rpx;
  text-align: center;
  font-weight: 600;
  transition: all 0.15s;
}

.reminder-modal-btn.done {
  background: #3A7CFF;
  color: #ffffff;
}

.reminder-modal-btn.edit {
  background: #ffffff;
  color: #3A7CFF;
  border: 2rpx solid #3A7CFF;
}

.reminder-modal-btn.delete {
  background: #ffffff;
  color: #94A3B8;
  border: 2rpx solid #E6F0FF;
}

.reminder-modal-item.reminder-overdue {
  background: #FDE8E0;
  border: 2rpx solid #EDD8D0;
}

.reminder-modal-item.reminder-today {
  background: #FDE8E0;
  border: 2rpx solid #EDD0C0;
}

.reminder-modal-item.reminder-tomorrow {
  background: #F9F3D8;
  border: 2rpx solid #F0E8D0;
}

.reminder-modal-item.reminder-normal {
  background: #FFFFFF;
  border: 2rpx solid #EDF2F7;
}

.reminder-modal-item.reminder-pending {
  background: #FFFFFF;
  border: 2rpx solid #EDF2F7;
}

.reminder-modal-footer {
  padding: 20rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid #F0F7FF;
  flex-shrink: 0;
}

.reminder-modal-add-btn {
  background: #3A7CFF;
  padding: 22rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.reminder-modal-add-icon {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: 700;
}

.reminder-modal-add-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
}

/* ============================================================
   新增/编辑提醒弹窗
   ============================================================ */

.reminder-edit-modal {
  width: 100%;
  background: linear-gradient(180deg, #ffffff 0%, #F0F7FF 100%);
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx 36rpx;
  padding-bottom: calc(36rpx + env(safe-area-inset-bottom));
  max-height: 75vh;
  overflow-y: auto;
  box-shadow: 0 -8rpx 40rpx rgba(58, 124, 255, 0.08);
}

.reminder-edit-form {
  margin-top: 20rpx;
}

.reminder-edit-row {
  margin-bottom: 32rpx;
}

.reminder-edit-label {
  font-size: 28rpx;
  color: #475569;
  display: block;
  margin-bottom: 16rpx;
}

.reminder-edit-type-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.reminder-edit-type-chip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: linear-gradient(135deg, rgba(240, 247, 255, 0.9) 0%, rgba(58, 124, 255, 0.04) 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(58, 124, 255, 0.06);
  transition: all 0.2s;
}

.reminder-edit-type-chip.active {
  background: linear-gradient(135deg, #3A7CFF 0%, #1A5CD6 100%);
  border-color: #3A7CFF;
  box-shadow: 0 4rpx 16rpx rgba(58, 124, 255, 0.25);
}

.type-chip-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.type-chip-text {
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
}

.reminder-edit-type-chip.active .type-chip-text {
  color: #ffffff;
}

.reminder-edit-input-wrap {
  display: flex;
  align-items: center;
  background-color: rgba(240, 247, 255, 0.8);
  border-radius: 28rpx;
  padding: 0 28rpx;
  border: 1rpx solid rgba(58, 124, 255, 0.06);
  box-shadow: inset 0 2rpx 4rpx rgba(58, 124, 255, 0.04);
}

.reminder-edit-input {
  flex: 1;
  height: 96rpx;
  font-size: 30rpx;
  color: #1E293B;
  background: transparent;
  line-height: 96rpx;
}

.reminder-edit-unit {
  font-size: 24rpx;
  color: #94A3B8;
  margin-left: 8rpx;
}

.reminder-edit-date {
  background-color: rgba(240, 247, 255, 0.8);
  border-radius: 28rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(58, 124, 255, 0.06);
  box-shadow: inset 0 2rpx 4rpx rgba(58, 124, 255, 0.04);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.reminder-edit-date-text {
  font-size: 30rpx;
  color: #1E293B;
}

.reminder-edit-date-icon {
  font-size: 22rpx;
  color: #94A3B8;
}

.reminder-edit-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #94A3B8;
}

/* 通用按钮样式补充 */
.btn-full {
  flex: 1;
  padding: 20rpx;
  border-radius: 20rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  transition: all 0.15s;
}

.btn-cancel {
  background: #F0F7FF;
  color: #475569;
}

.btn-confirm {
  background: #3A7CFF;
  color: #ffffff;
}

.btn-full:active {
  transform: scale(0.98);
}

/* ===== 父本/母本选择器 ===== */
.family-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #F0F7FF;
  border-radius: 24rpx;
  padding: 24rpx;
  border: 2rpx dashed #E6F0FF;
}

.family-placeholder {
  font-size: 28rpx;
  color: #94A3B8;
}

.family-selected {
  display: flex;
  align-items: center;
  gap: 20rpx;
  width: 100%;
}

.family-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
}

.family-info {
  flex: 1;
}

.family-name {
  display: block;
  font-size: 30rpx;
  color: #3A7CFF;
