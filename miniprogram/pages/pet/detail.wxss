  border-radius: 32rpx;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(58, 124, 255, 0.15);
  box-sizing: border-box;
}

.family-modal-bottom {
  width: 100%;
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 -8rpx 40rpx rgba(58, 124, 255, 0.08);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.family-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0F7FF;
  background: linear-gradient(135deg, var(--bg-light) 0%, #ffffff 100%);
}

.family-modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1E293B;
}

.family-modal-desc {
  font-size: 24rpx;
  color: #94A3B8;
  margin-top: 8rpx;
}

.family-search {
  padding: 24rpx;
}

.family-search-input {
  width: 100%;
  height: 80rpx;
  box-sizing: border-box;
  padding: 0 32rpx;
  border: 2rpx solid #EDF2F7;
  border-radius: 40rpx;
  font-size: 28rpx;
  background-color: #FFFFFF;
}

.family-list {
  flex: 1;
  padding: 0 12rpx 12rpx;
  max-height: 50vh;
  box-sizing: border-box;
}

.family-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  margin-bottom: 8rpx;
  margin-left: 4rpx;
  margin-right: 4rpx;
  border-radius: 16rpx;
  background-color: #FFFFFF;
  box-sizing: border-box;
}

.family-item:active {
  background-color: #EDF2F7;
}

.family-item-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.family-item-placeholder {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, var(--bg-light) 0%, var(--primary-light) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--primary-color);
  flex-shrink: 0;
}

.family-item-info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.family-item-name {
  display: block;
  font-size: 30rpx;
  color: #1E293B;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.family-item-desc {
  display: block;
  font-size: 24rpx;
  color: #94A3B8;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.family-item-select {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 500;
  padding: 12rpx 24rpx;
  background-color: var(--primary-light);
  border-radius: 24rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 时间线弹窗 */
.timeline-modal {
  width: 100%;
  background: linear-gradient(180deg, #ffffff 0%, #F0F7FF 100%);
  border-radius: 40rpx 40rpx 0 0;
  max-height: 92vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 -8rpx 40rpx rgba(58, 124, 255, 0.08);
}

.safe-area-top {
  height: env(safe-area-inset-top);
}

.timeline-content {
  flex: 1;
  padding: 0 36rpx;
  padding-bottom: calc(36rpx + env(safe-area-inset-bottom));
  max-height: 75vh;
  box-sizing: border-box;
}

.empty-timeline {
  padding: 80rpx 0;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #64748B;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #94A3B8;
}

.timeline-list {
  padding-top: 24rpx;
}

.timeline-date-group {
  margin-bottom: 40rpx;
}

.timeline-date-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding-left: 48rpx;
}

.timeline-date {
  font-size: 32rpx;
  font-weight: 700;
  color: #3A7CFF;
}

.timeline-count {
  font-size: 24rpx;
  color: #94A3B8;
  padding: 6rpx 18rpx;
  background-color: #F0F7FF;
  border-radius: 20rpx;
}

.timeline-item {
  display: flex;
  padding-left: 24rpx;
  margin-bottom: 24rpx;
}

.timeline-dot-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 32rpx;
  flex-shrink: 0;
}

.timeline-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3A7CFF 0%, #5B9FFF 100%);
  margin-right: 20rpx;
  margin-top: 14rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(58, 124, 255, 0.3);
}

.timeline-line {
  width: 4rpx;
  background: linear-gradient(180deg, #E6F0FF 0%, #C7DFFF 100%);
  margin-left: 10rpx;
  flex-shrink: 0;
  flex: 1;
  min-height: 40rpx;
}

.timeline-item:last-child .timeline-line {
  height: 0;
}

.timeline-card {
  flex: 1;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  transition: all 0.2s ease;
  box-sizing: border-box;
  overflow: hidden;
  margin-left: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.timeline-card:active {
  background-color: #F8FAFC;
  transform: scale(0.99);
}

.timeline-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  width: 100%;
}

.timeline-type-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.timeline-type-icon {
  font-size: 32rpx;
}

.timeline-type {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.timeline-time {
  font-size: 24rpx;
  color: #94A3B8;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.timeline-text {
  font-size: 26rpx;
  color: #64748B;
  line-height: 1.6;
}

.timeline-card-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.timeline-delete-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background-color: #FDECE8;
  transition: all 0.2s ease;
}

.timeline-delete-btn:active {
  background-color: #F8D4CD;
  transform: scale(0.95);
}

.delete-icon {
  font-size: 28rpx;
}

.timeline-egg-info {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F1F5F9;
}

.egg-info-text {
  font-size: 24rpx;
  color: #059669;
  font-weight: 500;
}

/* ========== 骨架屏样式 ========== */
.skeleton-container {
  padding: 0;
  position: relative;
  overflow: hidden;
}

.skeleton-container::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 40%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent);
  animation: skeleton-sweep 1.8s ease-in-out infinite;
  z-index: 1;
  pointer-events: none;
  will-change: transform;
}

.skeleton-header {
  height: 88rpx;
  background: #EDF2F7;
}

.skeleton-photo-banner {
  width: 100%;
  height: 610rpx;
  background: #F0F7FF;
}

.skeleton-photo {
  width: 100%;
  height: 100%;
  background: #EDF2F7;
}

.skeleton-pet-info {
  padding: 32rpx;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.skeleton-info-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.skeleton-pet-name {
  width: 200rpx;
  height: 48rpx;
  background: #EDF2F7;
  border-radius: 10rpx;
}

.skeleton-gender-badge {
  width: 60rpx;
  height: 40rpx;
  background: #EDF2F7;
  border-radius: 20rpx;
}

.skeleton-info-tags {
  display: flex;
  gap: 16rpx;
}

.skeleton-info-tag {
  width: 100rpx;
  height: 40rpx;
  background: #EDF2F7;
  border-radius: 20rpx;
}

.skeleton-relation-row {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.skeleton-relation-item {
  flex: 1;
  height: 60rpx;
  background: #EDF2F7;
  border-radius: 12rpx;
}

.skeleton-relation-divider {
  width: 2rpx;
  height: 40rpx;
  background: #EDF2F7;
}

.skeleton-section {
  padding: 32rpx;
}

.skeleton-section-title {
  width: 160rpx;
  height: 40rpx;
  background: #EDF2F7;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
}

.skeleton-event-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.skeleton-event-tab {
  flex: 1;
  height: 72rpx;
  background: #EDF2F7;
  border-radius: 16rpx;
}

.skeleton-event-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.skeleton-event-card {
  display: flex;
  gap: 20rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(58, 124, 255, 0.04);
}

.skeleton-event-icon {
  width: 72rpx;
  height: 72rpx;
  background: #EDF2F7;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.skeleton-event-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  justify-content: center;
}

.skeleton-event-title {
  width: 50%;
  height: 32rpx;
  background: #EDF2F7;
  border-radius: 6rpx;
}

.skeleton-event-date {
  width: 70%;
  height: 24rpx;
  background: #EDF2F7;
  border-radius: 6rpx;
}

@keyframes skeleton-sweep {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(450%); }
}

/* 编辑弹窗展开收起样式 */
.edit-form .section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #EDF2F7;
}

.edit-form .section-title text:first-child {
  font-size: 32rpx;
  color: #1E293B;
  font-weight: 600;
}

.edit-form .toggle-btn {
  font-size: 26rpx;
  color: #3A7CFF;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  background-color: rgba(58, 124, 255, 0.05);
}

.edit-form .toggle-btn:active {
  background-color: rgba(58, 124, 255, 0.08);
}

.edit-form .manual-section {
  margin-bottom: 32rpx;
}

/* ===== 录音状态提示条 ===== */
.voice-status-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  background: rgba(231, 111, 81, 0.95);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  z-index: 9999;
}

.voice-status-text {
  font-size: 28rpx;
  color: #fff;
}

.voice-status-cancel {
  font-size: 28rpx;
  color: #fff;
  padding: 8rpx 24rpx;
  border: 2rpx solid rgba(255,255,255,0.6);
  border-radius: 24rpx;
}

@keyframes voice-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}
