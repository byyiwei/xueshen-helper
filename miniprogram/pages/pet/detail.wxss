.page {
  width: 100%;
  max-width: 750rpx;
  margin: 0 auto;
  box-sizing: border-box;
  min-height: 100vh;
  background-color: #F0F7FF;
  --primary-color: #3A7CFF;
  --primary-light: #EDF2F7;
  --primary-dark: #1A5CD6;
  --bg-color: #F0F7FF;
  --bg-light: #FFFFFF;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #EDF2F7;
  border-top: 6rpx solid #3A7CFF;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #94A3B8;
}

.content {
  padding: 32rpx;
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

.pet-info {
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  margin-top: 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(58, 124, 255, 0.06);
}

.pet-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.pet-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #1E293B;
}

.gender-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #ffffff;
}

.gender-tag.gender-male {
  background-color: rgba(58, 124, 255, 0.55);
}

.gender-tag.gender-female {
  background-color: rgba(236, 72, 153, 0.55);
}

.gender-tag.gender-unknown {
  background-color: rgba(148, 163, 184, 0.55);
}

.gender-text {
  font-size: 28rpx;
  color: #ffffff;
}

.gender-icon {
  font-size: 28rpx;
  color: #2A6F97;
}

.gender-text {
  font-size: 28rpx;
  color: #2A6F97;
}

.relation-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-top: 2rpx solid #F0F7FF;
}

.relation-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.relation-label {
  font-size: 24rpx;
  color: #94A3B8;
  margin-bottom: 8rpx;
}

.relation-value {
  font-size: 28rpx;
}

.relation-value.unlinked {
  color: #2A6F97;
}

.relation-value.unlinked-red {
  color: #E76F51;
}

.relation-value.unlinked-orange {
  color: #64748B;
}

.relation-value.gender-male {
  color: #2A6F97;
}

.relation-value.gender-partner {
  color: #C026D3;
}

.relation-value.gender-female {
  color: #C77D5F;
}

.relation-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: #EDF2F7;
}

.section {
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  position: relative;
  overflow: visible;
}

/* 家族谱系区块添加额外底部间距 */
.section-pedigree {
  padding-bottom: 24rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title-row .section-title {
  margin-bottom: 0;
}

.report-entries {
  display: flex;
  gap: 12rpx;
}

.report-entry {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  background: #E6F0FF;
  border-radius: 24rpx;
}

.report-entry-icon {
  font-size: 24rpx;
}

.report-entry-text {
  font-size: 24rpx;
  color: #3A7CFF;
  font-weight: 500;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1E293B;
  margin-bottom: 24rpx;
}

/* 日期筛选栏 */
.date-filter-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 0;
  margin-bottom: 12rpx;
}

.date-filter-picker {
  flex: 1;
}

.date-filter-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 16rpx;
  background-color: #F0F7FF;
  border-radius: 16rpx;
  border: 1rpx solid #E2E8F0;
}

.date-filter-btn.active {
  border-color: #3A7CFF;
  background-color: #EBF4FF;
}

.date-filter-label {
  font-size: 22rpx;
  color: #94A3B8;
  flex-shrink: 0;
}

.date-filter-value {
  font-size: 24rpx;
  color: #1E293B;
  flex: 1;
}

.date-filter-arrow {
  font-size: 20rpx;
  color: #94A3B8;
  flex-shrink: 0;
}

.date-filter-sep {
  font-size: 24rpx;
  color: #94A3B8;
  flex-shrink: 0;
}

.date-filter-clear {
  padding: 10rpx 16rpx;
  background-color: #FEE2E2;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.date-filter-clear text {
  font-size: 22rpx;
  color: #EF4444;
}

.event-tabs {
  display: flex;
  gap: 10rpx;
  margin-bottom: 24rpx;
}

.event-tab {
  flex: 1;
  padding: 14rpx 16rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #475569;
  background-color: #F0F7FF;
  transition: all 0.15s ease;
  -webkit-user-select: none;
  user-select: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.event-tab-icon {
  font-size: 26rpx;
  line-height: 1;
}

.event-tab-text {
  font-size: 22rpx;
  line-height: 1;
}

.event-tab.active {
  background-color: #3A7CFF;
  color: #ffffff;
  font-weight: 500;
}

.event-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.event-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  width: calc(25% - 9rpx);
  box-sizing: border-box;
  transition: all 0.2s ease;
  box-shadow: 0 4rpx 16rpx rgba(58, 124, 255, 0.04);
  border: 1rpx solid #EDF2F7;
}

.event-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(58, 124, 255, 0.06);
}

.event-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  background: #EDF2F7;
}

.icon-text {
  font-size: 32rpx;
  color: #1E293B;
  font-weight: 700;
}

.icon-emoji {
  font-size: 36rpx;
  line-height: 1;
  font-weight: bold;
}

.event-icon-lay {
  background: #EDF2F7;
}

.event-icon-lay .icon-emoji {
  font-size: 40rpx;
}

.event-icon-hatch {
  background: #FFF7ED;
}

.event-icon-hatch .icon-emoji {
  font-size: 40rpx;
}

.event-info {
  width: 100%;
  text-align: center;
}

.event-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 4rpx;
}

.event-content {
  font-size: 18rpx;
  color: #475569;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.3;
}

.event-date {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 18rpx;
  color: #94A3B8;
}
.event-photo-hint {
  font-size: 18rpx;
  color: #64748B;
}

.event-date .date {
  margin-right: 4rpx;
}

.event-date .time {
  opacity: 0.8;
}

.event-arrow {
  font-size: 28rpx;
  color: #CBD5E1;
  position: absolute;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
}

.empty-events {
  padding: 24rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #94A3B8;
}

.timeline-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx dashed #EDF2F7;
}

.timeline-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
  gap: 12rpx;
}

.timeline-title {
  font-size: 28rpx;
  color: #1E293B;
  flex-shrink: 0;
}

.timeline-actions {
  display: flex;
  gap: 12rpx;
  align-items: center;
  flex-wrap: wrap;
}

.timeline-btn {
  padding: 10rpx 18rpx;
  background-color: #F0F7FF;
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #475569;
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
}

.timeline-btn:active {
  transform: scale(0.95);
  background-color: #E6F0FF;
}

.timeline-btn-text {
  font-size: 22rpx;
  color: #475569;
}

.timeline-btn-icon {
  font-size: 18rpx;
  color: #94A3B8;
  margin-left: 6rpx;
}

.timeline-btn-clear {
  background-color: #FDECE8;
  padding: 10rpx 14rpx;
}

.timeline-btn-clear .timeline-btn-text {
  color: #E76F51;
}

.timeline-btn-expand {
  padding: 10rpx 16rpx;
}

.timeline-date-picker {
  flex: 0 0 auto;
}

.timeline-date-range {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.range-separator {
  font-size: 20rpx;
  color: #94A3B8;
  flex-shrink: 0;
  padding: 0 2rpx;
}

.timeline-btn.active {
  background-color: var(--primary-light);
  border: 2rpx solid var(--primary-color);
}

.timeline-btn.active .timeline-btn-text {
  color: var(--primary-color);
  font-weight: 600;
}

.timeline-btn.active .timeline-btn-icon {
  color: var(--primary-color);
}

.timeline-hint {
  font-size: 24rpx;
  color: #94A3B8;
}

/* 记录详情弹窗 */
.record-detail-modal {
  width: 100%;
  max-width: 600rpx;
  background-color: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.record-detail-header {
  display: flex;
  align-items: center;
  padding: 32rpx;
  padding-bottom: 24rpx;
  background: linear-gradient(135deg, #F0F7FF 0%, #ffffff 100%);
}

.record-type-badge {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: #EDF2F7;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.record-type-icon {
  font-size: 40rpx;
  color: #3A7CFF;
  font-weight: 700;
  font-family: monospace;
}

.record-badge-lay {
  background: #EDF2F7;
}

.record-badge-lay .record-type-icon {
  font-size: 52rpx;
}

.record-badge-hatch {
  background: #FFF7ED;
}

.record-badge-hatch .record-type-icon {
  font-size: 52rpx;
}

.record-detail-title {
  flex: 1;
  font-size: 34rpx;
  font-weight: bold;
  color: #1E293B;
}

.record-detail-content {
  padding: 32rpx;
  min-height: 160rpx;
  flex: 1;
  overflow-y: auto;
}

.record-detail-text {
  font-size: 30rpx;
  color: #1E293B;
  line-height: 1.7;
}

/* 记录详情弹窗照片 */
.record-detail-photos {
  padding: 0 32rpx 24rpx;
}
.record-photos-title {
  font-size: 26rpx;
  color: #64748B;
  margin-bottom: 16rpx;
  display: block;
}
.record-photos-scroll {
  width: 100%;
  white-space: nowrap;
}
.record-photos-list {
  display: flex;
  gap: 16rpx;
}
.record-photo-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #EDF2F7;
}

.record-detail-footer {
  padding: 0 32rpx 32rpx;
  flex-shrink: 0;
}

.record-detail-date {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.date-label {
  font-size: 26rpx;
  color: #94A3B8;
  margin-right: 16rpx;
}

.date-value {
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
}

.record-detail-actions {
  display: flex;
  gap: 20rpx;
  align-items: center;
  justify-content: center;
}

.record-detail-actions .btn-print {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 22rpx 36rpx;
  background: #ffffff;
  border: 2rpx solid #E6F0FF;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #3A7CFF;
  transition: all 0.2s ease;
  flex-shrink: 0;
  min-height: 76rpx;
}

.record-detail-actions .btn-print:active {
  transform: scale(0.95);
  background: #F0F7FF;
  border-color: #CBD5E1;
}

.record-detail-actions .btn-print-icon {
  font-size: 26rpx;
}

.record-detail-actions .btn-print-text {
  font-size: 26rpx;
  font-weight: 500;
}

.record-detail-actions .btn-confirm {
  flex: 1;
  padding: 22rpx 40rpx;
  font-size: 28rpx;
  min-height: 76rpx;
  border-radius: 40rpx;
  font-weight: 500;
}

.family-tree {
  border: 2rpx dashed #E6F0FF;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  background-color: #FFFFFF;
}

.family-status {
  display: inline-block;
  padding: 8rpx 24rpx;
  background-color: #EDF2F7;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #64748B;
  margin-bottom: 24rpx;
}

.family-title {
  font-size: 32rpx;
  color: #1E293B;
  display: block;
  margin-bottom: 16rpx;
}

.family-hint {
  font-size: 26rpx;
  color: #94A3B8;
  display: block;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.family-btn {
  display: inline-block;
  padding: 24rpx 80rpx;
  background: linear-gradient(135deg, #3A7CFF 0%, #1A5CD6 100%);
  border-radius: 40rpx;
  font-size: 30rpx;
  color: #ffffff;
  font-weight: bold;
}

/* ========== 家族谱系样式 ========== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
}

.section-title-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.pedigree-badge {
  background: linear-gradient(135deg, var(--primary-color, #3A7CFF) 0%, var(--primary-dark, #1A5CD6) 100%);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  vertical-align: middle;
}

.pedigree-count {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 500;
  line-height: 1.2;
}

/* 收起状态 - 谱系卡片 */
.pedigree-cards {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: stretch;
  gap: 40rpx;
  padding: 24rpx 0 32rpx;
}

.pedigree-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 0;
  min-width: 240rpx;
  position: relative;
  overflow: visible;
}

.card-gender-tag {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 52rpx;
  height: 52rpx;
  padding: 0 14rpx;
  border-radius: 26rpx;
  font-size: 24rpx;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(58, 124, 255, 0.3);
  z-index: 2;
}

.card-gender-tag.male {
  background: linear-gradient(135deg, #2A6F97 0%, #3A7CFF 100%);
}

.card-gender-tag.female {
  background: linear-gradient(135deg, #C77D5F 0%, #E76F51 100%);
}

.card-avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 28rpx;
  background: #F0F7FF;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 4rpx solid #E2E8F0;
  box-shadow: 0 6rpx 20rpx rgba(58, 124, 255, 0.10);
}

.card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.card-icon {
  font-size: 80rpx;
  color: #CBD5E1;
}

.card-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.card-label {
  font-size: 28rpx;
  color: var(--primary-color, #3A7CFF);
  font-weight: 600;
  padding: 8rpx 24rpx;
  background-color: rgba(58, 124, 255, 0.08);
  border-radius: 14rpx;
}

.card-name {
  font-size: 36rpx;
  color: #1E293B;
  font-weight: 700;
  max-width: 240rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-more {
  font-size: 24rpx;
  color: #64748B;
  padding: 6rpx 20rpx;
  background-color: #F0F7FF;
  border-radius: 12rpx;
}

.expand-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background-color: #F0F7FF;
  border-radius: 24rpx;
  transition: all 0.3s ease;
}

.expand-btn.expanded {
  background-color: var(--primary-light, #EDF2F7);
}

.expand-text {
  font-size: 26rpx;
  color: #475569;
}

.expand-icon {
  font-size: 24rpx;
  color: #94A3B8;
  transition: transform 0.3s ease;
}

.expand-btn.expanded .expand-icon {
  transform: rotate(180deg);
}

/* 收起状态 - 简洁预览 */
.pedigree-preview {
  padding: 8rpx 0;
  position: relative;
  overflow: visible;
}

.family-tree-empty {
  border: 2rpx dashed #E6F0FF;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  background-color: #FFFFFF;
}

.pedigree-lines {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.line-preview {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
}

.line-label {
  font-size: 24rpx;
  color: var(--primary-color, #3A7CFF);
  font-weight: 600;
  padding: 4rpx 16rpx;
  background-color: var(--primary-light, #EDF2F7);
  border-radius: 12rpx;
  flex-shrink: 0;
}

.line-chain {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  flex: 1;
}

.line-item {
  font-size: 26rpx;
  color: #1E293B;
}

.line-item:not(:last-child)::after {
  content: ' → ';
  color: #94A3B8;
}

/* 展开状态 - 完整族谱 */
.pedigree-full {
  padding: 16rpx 0;
  animation: fadeIn 0.3s ease;
  position: relative;
  overflow: visible;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 统计信息 */
.pedigree-stats {
  display: flex;
  justify-content: space-around;
  padding: 16rpx;
  background: #F0F7FF;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.pedigree-stats .stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.pedigree-stats .stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--primary-color, #3A7CFF);
}

.pedigree-stats .stat-label {
  font-size: 24rpx;
  color: #94A3B8;
}

/* 血缘主线 */
.bloodline-section {
  margin-bottom: 32rpx;
}

.bloodline-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.bloodline-title .title-text {
  font-size: 30rpx;
