.page {
  width: 100%;
  max-width: 750rpx;
  margin: 0 auto;
  box-sizing: border-box;
  min-height: 100vh;
  background-color: #faf8f3;
  --primary-color: #B8860B;
  --primary-light: #f5e6c8;
  --primary-dark: #8B6914;
  --bg-color: #f5f0e6;
  --bg-light: #faf8f3;
}

.page.theme-mocha {
  background-color: #f5f5f0;
  --primary-color: #8B7765;
  --primary-light: #d4cfc4;
  --primary-dark: #6B5744;
  --bg-color: #faf8f3;
  --bg-light: #f5f5f0;
}

.page.theme-olive {
  background-color: #e8ede4;
  --primary-color: #556B2F;
  --primary-light: #b8c9b8;
  --primary-dark: #3d5020;
  --bg-color: #f0f3ef;
  --bg-light: #e8ede4;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #B8860B;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999999;
}

.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  padding-top: 80rpx;
  padding-top: calc(80rpx + env(safe-area-inset-top));
  background-color: #faf8f3;
  box-sizing: border-box;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.header-inner {
  width: 100%;
  max-width: 686rpx;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.back-btn:active {
  transform: scale(0.9);
  opacity: 0.7;
}

.back-icon {
  font-size: 48rpx;
  color: #333333;
}

.header-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.header-actions {
  display: flex;
  width: 200rpx;
  justify-content: flex-end;
  gap: 16rpx;
}

.action-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #666666;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.9);
  opacity: 0.7;
}

.content {
  padding: 176rpx 32rpx 0;
  padding-top: calc(200rpx + env(safe-area-inset-top));
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

.pet-info {
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.pet-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.pet-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #333333;
}

.gender-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background-color: #e6f7ff;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
}

.gender-icon {
  font-size: 28rpx;
  color: #1890ff;
}

.gender-text {
  font-size: 28rpx;
  color: #1890ff;
}

.relation-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-top: 2rpx solid #f5f5f5;
}

.relation-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.relation-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.relation-value {
  font-size: 28rpx;
}

.relation-value.unlinked {
  color: #1890ff;
}

.relation-value.unlinked-red {
  color: #f5222d;
}

.relation-value.unlinked-orange {
  color: #fa8c16;
}

.relation-value.gender-male {
  color: #1890ff;
}

.relation-value.gender-female {
  color: #f5222d;
}

.relation-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: #f0f0f0;
}

.section {
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  position: relative;
  overflow: visible;
}

/* 家族谱系区块添加额外底部间距 */
.section-pedigree {
  padding-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
}

.event-tabs {
  display: flex;
  gap: 10rpx;
  margin-bottom: 24rpx;
}

.event-tab {
  flex: 1;
  padding: 14rpx 16rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #666666;
  background-color: #f5f5f5;
  transition: all 0.15s ease;
  -webkit-user-select: none;
  user-select: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.event-tab-icon {
  font-size: 26rpx;
  line-height: 1;
}

.event-tab-text {
  font-size: 22rpx;
  line-height: 1;
}

.event-tab.active {
  background-color: #1a1a1a;
  color: #ffffff;
  font-weight: 500;
}

.theme-gold .page {
  background-color: #faf8f3;
}
.theme-gold .header {
  background-color: #faf8f3;
}
.theme-gold .loading-spinner {
  border-top-color: #B8860B;
}
.theme-gold .icon-bg {
  background-color: #f5e6c8;
}
.theme-gold .icon-text {
  color: #B8860B;
}
.theme-gold .event-card:active {
  background-color: #f5f0e6;
}
.theme-gold .bar-btn.primary {
  background: linear-gradient(135deg, #ffc53d 0%, #B8860B 100%);
}
.theme-gold .family-btn {
  background: linear-gradient(135deg, #ffc53d 0%, #B8860B 100%);
}
.theme-gold .btn-confirm {
  background: linear-gradient(135deg, #ffc53d 0%, #B8860B 100%);
}
.theme-gold .family-status {
  background-color: #fff7e6;
  color: #fa8c16;
}

.theme-mocha .page {
  background-color: #f5f5f0;
}
.theme-mocha .header {
  background-color: #f5f5f0;
}
.theme-mocha .loading-spinner {
  border-top-color: #8B7765;
}
.theme-mocha .icon-bg {
  background-color: #d4cfc4;
}
.theme-mocha .icon-text {
  color: #8B7765;
}
.theme-mocha .event-card:active {
  background-color: #e8e4dc;
}
.theme-mocha .bar-btn.primary {
  background: linear-gradient(135deg, #c4b8a8 0%, #8B7765 100%);
}
.theme-mocha .family-btn {
  background: linear-gradient(135deg, #c4b8a8 0%, #8B7765 100%);
}
.theme-mocha .btn-confirm {
  background: linear-gradient(135deg, #c4b8a8 0%, #8B7765 100%);
}
.theme-mocha .family-status {
  background-color: #e8e4dc;
  color: #6B5744;
}

.theme-olive .page {
  background-color: #e8ede4;
}
.theme-olive .header {
  background-color: #e8ede4;
}
.theme-olive .loading-spinner {
  border-top-color: #556B2F;
}
.theme-olive .icon-bg {
  background-color: #b8c9b8;
}
.theme-olive .icon-text {
  color: #556B2F;
}
.theme-olive .event-card:active {
  background-color: #d4e0d4;
}
.theme-olive .bar-btn.primary {
  background: linear-gradient(135deg, #a8c2a8 0%, #556B2F 100%);
}
.theme-olive .family-btn {
  background: linear-gradient(135deg, #a8c2a8 0%, #556B2F 100%);
}
.theme-olive .btn-confirm {
  background: linear-gradient(135deg, #a8c2a8 0%, #556B2F 100%);
}
.theme-olive .family-status {
  background-color: #d4e0d4;
  color: #3d5020;
}

.event-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.event-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 24rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  width: calc(50% - 10rpx);
  box-sizing: border-box;
  transition: all 0.2s ease;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #f0f0f0;
}

.event-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.event-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #f5e6c8 0%, #fff7e6 100%);
}

.theme-mocha .event-icon {
  background: linear-gradient(135deg, #d4cfc4 0%, #e8e4dc 100%);
}

.theme-olive .event-icon {
  background: linear-gradient(135deg, #b8c9b8 0%, #d4e0d4 100%);
}

.icon-text {
  font-size: 48rpx;
  color: #B8860B;
  font-weight: 700;
}

.icon-emoji {
  font-size: 52rpx;
  line-height: 1;
  font-weight: bold;
}

.event-icon-lay {
  background: linear-gradient(135deg, #fff7e6 0%, #ffe8b0 100%);
}

.event-icon-lay .icon-emoji {
  font-size: 60rpx;
}

.theme-mocha .event-icon-lay {
  background: linear-gradient(135deg, #e8e4dc 0%, #d4cfc4 100%);
}

.theme-olive .event-icon-lay {
  background: linear-gradient(135deg, #d4e0d4 0%, #b8c9b8 100%);
}

.theme-mocha .icon-text,
.theme-mocha .icon-emoji {
  color: #8B7765;
}

.theme-olive .icon-text,
.theme-olive .icon-emoji {
  color: #556B2F;
}

.event-info {
  width: 100%;
  text-align: center;
}

.event-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.event-content {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
}

.event-date {
  font-size: 22rpx;
  color: #999999;
}

.event-date .date {
  margin-right: 8rpx;
}

.event-date .time {
  opacity: 0.8;
}

.event-arrow {
  font-size: 28rpx;
  color: #cccccc;
  position: absolute;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
}

.empty-events {
  padding: 24rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #999999;
}

.timeline-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx dashed #f0f0f0;
}

.timeline-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
  gap: 12rpx;
}

.timeline-title {
  font-size: 28rpx;
  color: #333333;
  flex-shrink: 0;
}

.timeline-actions {
  display: flex;
  gap: 12rpx;
  align-items: center;
  flex-wrap: wrap;
}

.timeline-btn {
  padding: 10rpx 18rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #666666;
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
}

.timeline-btn:active {
  transform: scale(0.95);
  background-color: #e8e8e8;
}

.timeline-btn-text {
  font-size: 22rpx;
  color: #666666;
}

.timeline-btn-icon {
  font-size: 18rpx;
  color: #999999;
  margin-left: 6rpx;
}

.timeline-btn-clear {
  background-color: #fff0f0;
  padding: 10rpx 14rpx;
}

.timeline-btn-clear .timeline-btn-text {
  color: #f5222d;
}

.timeline-btn-expand {
  padding: 10rpx 16rpx;
}

.timeline-date-picker {
  flex: 0 0 auto;
}

.timeline-date-range {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.range-separator {
  font-size: 20rpx;
  color: #999999;
  flex-shrink: 0;
  padding: 0 2rpx;
}

.timeline-btn.active {
  background-color: var(--primary-light);
  border: 2rpx solid var(--primary-color);
}

.timeline-btn.active .timeline-btn-text {
  color: var(--primary-color);
  font-weight: 600;
}

.timeline-btn.active .timeline-btn-icon {
  color: var(--primary-color);
}

.theme-mocha .timeline-btn.active {
  background-color: rgba(139, 119, 101, 0.1);
  border-color: #8B7765;
}

.theme-mocha .timeline-btn.active .timeline-btn-text,
.theme-mocha .timeline-btn.active .timeline-btn-icon {
  color: #8B7765;
}

.theme-olive .timeline-btn.active {
  background-color: rgba(85, 107, 47, 0.1);
  border-color: #556B2F;
}

.theme-olive .timeline-btn.active .timeline-btn-text,
.theme-olive .timeline-btn.active .timeline-btn-icon {
  color: #556B2F;
}

.timeline-hint {
  font-size: 24rpx;
  color: #999999;
}

/* 记录详情弹窗 */
.record-detail-modal {
  width: calc(100% - 64rpx);
  max-width: 600rpx;
  background-color: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
}

.record-detail-header {
  display: flex;
  align-items: center;
  padding: 32rpx;
  padding-bottom: 24rpx;
  background: linear-gradient(135deg, #faf8f3 0%, #ffffff 100%);
}

.record-type-badge {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #f5e6c8 0%, #fff7e6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.theme-mocha .record-type-badge {
  background: linear-gradient(135deg, #d4cfc4 0%, #e8e4dc 100%);
}

.theme-olive .record-type-badge {
  background: linear-gradient(135deg, #b8c9b8 0%, #d4e0d4 100%);
}

.record-type-icon {
  font-size: 40rpx;
  color: #B8860B;
  font-weight: 700;
  font-family: monospace;
}

.theme-mocha .record-type-icon {
  color: #8B7765;
}

.theme-olive .record-type-icon {
  color: #556B2F;
}

.record-badge-lay {
  background: linear-gradient(135deg, #fff7e6 0%, #ffe8b0 100%);
}

.record-badge-lay .record-type-icon {
  font-size: 52rpx;
}

.theme-mocha .record-badge-lay {
  background: linear-gradient(135deg, #e8e4dc 0%, #d4cfc4 100%);
}

.theme-olive .record-badge-lay {
  background: linear-gradient(135deg, #d4e0d4 0%, #b8c9b8 100%);
}

.record-detail-title {
  flex: 1;
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.record-detail-content {
  padding: 32rpx;
  min-height: 160rpx;
}

.record-detail-text {
  font-size: 30rpx;
  color: #333333;
  line-height: 1.7;
}

.record-detail-footer {
  padding: 0 32rpx 32rpx;
}

.record-detail-date {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: #fafafa;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.date-label {
  font-size: 26rpx;
  color: #999999;
  margin-right: 16rpx;
}

.date-value {
  font-size: 26rpx;
  color: #666666;
  font-weight: 500;
}

.record-detail-actions {
  display: flex;
  gap: 20rpx;
  align-items: center;
  justify-content: center;
}

.record-detail-actions .btn-print {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 22rpx 36rpx;
  background: #ffffff;
  border: 2rpx solid #e0e0e0;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #333;
  transition: all 0.2s ease;
  flex-shrink: 0;
  min-height: 76rpx;
}

.record-detail-actions .btn-print:active {
  transform: scale(0.95);
  background: #f5f5f5;
  border-color: #d0d0d0;
}

.record-detail-actions .btn-print-icon {
  font-size: 26rpx;
}

.record-detail-actions .btn-print-text {
  font-size: 26rpx;
  font-weight: 500;
}

.record-detail-actions .btn-confirm {
  flex: 1;
  padding: 22rpx 40rpx;
  font-size: 28rpx;
  min-height: 76rpx;
  border-radius: 40rpx;
  font-weight: 500;
}

.family-tree {
  border: 2rpx dashed #d4d4d4;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  background-color: #fafafa;
}

.family-status {
  display: inline-block;
  padding: 8rpx 24rpx;
  background-color: #fff7e6;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #fa8c16;
  margin-bottom: 24rpx;
}

.family-title {
  font-size: 32rpx;
  color: #333333;
  display: block;
  margin-bottom: 16rpx;
}

.family-hint {
  font-size: 26rpx;
  color: #999999;
  display: block;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.family-btn {
  display: inline-block;
  padding: 24rpx 80rpx;
  background: linear-gradient(135deg, #ffc53d 0%, #ffa940 100%);
  border-radius: 40rpx;
  font-size: 30rpx;
  color: #ffffff;
  font-weight: bold;
}

/* ========== 家族谱系样式 ========== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
}

.section-title-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.pedigree-badge {
  background: linear-gradient(135deg, var(--primary-color, #B8860B) 0%, var(--primary-dark, #8B6914) 100%);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  vertical-align: middle;
}

.pedigree-count {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 500;
  line-height: 1.2;
}

/* 收起状态 - 谱系卡片 */
.pedigree-cards {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: stretch;
  gap: 24rpx;
  padding: 16rpx 0 24rpx;
}

.pedigree-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 28rpx 12rpx;
  background-color: #ffffff;
  border: 2rpx solid var(--primary-light, #f5e6c8);
  border-radius: 24rpx;
  min-width: 200rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
  overflow: visible;
}

.card-gender-tag {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  min-width: 44rpx;
  height: 44rpx;
  padding: 0 10rpx;
  border-radius: 22rpx;
  font-size: 22rpx;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
  z-index: 1;
}

.card-gender-tag.male {
  background: linear-gradient(135deg, var(--primary-color, #B8860B) 0%, var(--primary-dark, #8B6914) 100%);
}

.card-gender-tag.female {
  background: linear-gradient(135deg, var(--primary-color, #B8860B) 0%, var(--primary-dark, #8B6914) 100%);
}

.card-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.card-icon {
  font-size: 60rpx;
  color: #cccccc;
}

.card-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.card-label {
  font-size: 24rpx;
  color: var(--primary-color, #B8860B);
  font-weight: 600;
  padding: 6rpx 20rpx;
  background-color: var(--primary-light, #f5e6c8);
  border-radius: 12rpx;
}

.card-name {
  font-size: 32rpx;
