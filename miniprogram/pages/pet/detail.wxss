}

.tree-node.parent .node-avatar-wrapper {
  width: 260rpx;
  height: 260rpx;
  border-color: #2A6F97;
}

.tree-node.ancestor .node-avatar-wrapper {
  width: 155rpx;
  height: 155rpx;
  border-color: #94A3B8;
}

.tree-level.level-3 .tree-node.ancestor .node-avatar-wrapper {
  width: 120rpx;
  height: 120rpx;
}

.tree-level.level-3 .tree-node {
  min-width: 120rpx;
  gap: 8rpx;
  padding: 4rpx;
}

.tree-level.level-3 .node-name {
  font-size: 20rpx;
  max-width: 100rpx;
}

.tree-level.level-3 .node-alias {
  font-size: 18rpx;
  max-width: 100rpx;
}

.tree-level.level-3 .node-gender-tag {
