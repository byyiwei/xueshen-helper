}

.info-tag.status-normal {
  background-color: #DCFCE7;
  color: #16A34A;
}

.info-tag.status-pending {
  background-color: #FFF7ED;
  color: #EA580C;
}

.info-tag.status-warning {
  background-color: #FEE2E2;
