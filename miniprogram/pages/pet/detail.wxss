  border-radius: 16rpx;
  font-size: 28rpx;
  background-color: #fafafa;
  line-height: 88rpx;
}

.voice-btn {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  border: 2rpx solid #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.voice-btn:active {
  background-color: #e8e8e8;
  transform: translateY(-50%) scale(0.9);
}

.voice-btn-icon {
  font-size: 20rpx;
  color: #999;
  line-height: 1;
}

.input-with-voice {
  position: relative;
  width: 100%;
}

.form-textarea {
  width: 100%;
  min-height: 220rpx;
  padding: 28rpx;
  border: 3rpx dashed var(--primary-color);
  border-radius: 20rpx;
  font-size: 28rpx;
  background-color: rgba(184, 134, 11, 0.05);
  box-sizing: border-box;
}

.theme-mocha .form-textarea {
  background-color: rgba(139, 119, 101, 0.05);
}

.theme-olive .form-textarea {
  background-color: rgba(85, 107, 47, 0.05);
  transition: all 0.3s ease;
}

.form-textarea:focus {
  border-style: solid;
  border-color: var(--primary-color);
  background-color: #ffffff;
}

.form-options {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.form-switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.switch-hint {
  font-size: 26rpx;
  color: #666666;
  flex: 1;
}

.option {
  padding: 16rpx 32rpx;
  background-color: #f5f5f5;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666666;
}

.option.active {
  background-color: #1a1a1a;
  color: #ffffff;
}

.confirm-modal {
  width: 100%;
  max-width: 600rpx;
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 48rpx 32rpx;
}

.confirm-content {
  text-align: center;
}

.confirm-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
}

.confirm-text {
  display: block;
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 48rpx;
}

.confirm-buttons {
  display: flex;
  gap: 24rpx;
}

.record-type-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.record-type-item {
  padding: 16rpx 24rpx;
  background-color: #ffffff;
  border: 2rpx solid #dddddd;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666666;
  transition: all 0.2s ease;
  min-width: 90rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.record-type-icon {
  font-size: 24rpx;
  line-height: 1;
}

.record-type-text {
  font-size: 22rpx;
  line-height: 1;
}

.record-type-item.active {
  background-color: #1a1a1a;
  color: #ffffff;
  border-color: #1a1a1a;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.25);
  font-weight: 500;
}

.record-type-item:not(.active):active {
  border-color: var(--primary-color);
  color: var(--primary-color);
  transform: scale(0.98);
}

/* ===== 图片轮播（详情页顶部） ===== */
.photo-banner {
  width: 100%;
  margin-bottom: 0;
}

.photo-swiper {
  width: 100%;
  height: 420rpx;
}

.photo-swiper-img {
  width: 100%;
  height: 100%;
}

/* ===== 图片管理（编辑弹窗） ===== */
.photo-manager {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 0;
}

.photo-thumb-wrap {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}

.photo-thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e8e8e8;
}

.photo-del {
  position: absolute;
  top: -14rpx;
  right: -14rpx;
  width: 36rpx;
  height: 36rpx;
  background-color: rgba(0, 0, 0, 0.6);
  border-radius: 18rpx;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 34rpx;
  text-align: center;
}

.photo-add-btn {
  width: 140rpx;
  height: 140rpx;
  border: 2rpx dashed #cccccc;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.photo-add-icon {
  font-size: 56rpx;
  color: #cccccc;
  line-height: 1;
}

/* ===== 父本/母本选择器 ===== */
.family-selector {
  background-color: #faf8f3;
  border-radius: 24rpx;
  padding: 24rpx;
  border: 2rpx dashed #d4d4d4;
}

.family-placeholder {
  font-size: 28rpx;
  color: #999999;
}

.family-selected {
  display: flex;
  align-items: center;
  gap: 20rpx;
  width: 100%;
}

.family-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
}

.family-info {
  flex: 1;
}

.family-name {
  display: block;
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.family-desc {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
}

.family-clear {
  font-size: 26rpx;
  color: var(--primary-color);
  margin-top: 12rpx;
  text-align: right;
}

/* ===== 选择父本/母本弹窗 ===== */
.family-modal {
  width: calc(100% - 64rpx);
  max-width: 650rpx;
  background-color: #ffffff;
  border-radius: 32rpx;
  max-height: 65vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
  box-sizing: border-box;
}

.family-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
  background: linear-gradient(135deg, var(--bg-light) 0%, #fff 100%);
}

.family-modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.family-modal-desc {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.family-search {
  padding: 24rpx;
}

.family-search-input {
  width: 100%;
  height: 80rpx;
  box-sizing: border-box;
  padding: 0 32rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 40rpx;
  font-size: 28rpx;
  background-color: #fafafa;
}

.family-list {
  flex: 1;
  padding: 0 12rpx 12rpx;
  max-height: 50vh;
  box-sizing: border-box;
}

.family-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  margin-bottom: 8rpx;
  margin-left: 4rpx;
  margin-right: 4rpx;
  border-radius: 16rpx;
  background-color: #fafafa;
  box-sizing: border-box;
}

.family-item:active {
  background-color: #f0f0f0;
}

.family-item-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.family-item-placeholder {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, var(--bg-light) 0%, var(--primary-light) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--primary-color);
  flex-shrink: 0;
}

.family-item-info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.family-item-name {
  display: block;
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.family-item-desc {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.family-item-select {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 500;
  padding: 12rpx 24rpx;
  background-color: var(--primary-light);
  border-radius: 24rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 时间线弹窗 */
.timeline-modal {
  width: calc(100% - 64rpx);
  max-width: 680rpx;
  background-color: #ffffff;
  border-radius: 32rpx;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.timeline-content {
  flex: 1;
  padding: 0 32rpx 32rpx;
  max-height: 60vh;
  box-sizing: border-box;
}

.empty-timeline {
  padding: 60rpx 0;
  text-align: center;
}

.timeline-list {
  padding-top: 16rpx;
}

.timeline-date-group {
  margin-bottom: 32rpx;
}

.timeline-date-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding-left: 40rpx;
}

.timeline-date {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.timeline-count {
  font-size: 24rpx;
  color: #999999;
  padding: 4rpx 16rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
}

.timeline-item {
  display: flex;
  padding-left: 24rpx;
  margin-bottom: 20rpx;
}

.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background-color: var(--primary-color);
  margin-right: 20rpx;
  margin-top: 12rpx;
  flex-shrink: 0;
}

.timeline-line {
  width: 4rpx;
  background-color: #eeeeee;
  margin-left: 8rpx;
  margin-right: 36rpx;
  flex-shrink: 0;
}

.timeline-item:last-child .timeline-line {
  height: 0;
}

.timeline-card {
  flex: 1;
  background-color: #fafafa;
  border-radius: 20rpx;
  padding: 24rpx;
  transition: all 0.2s ease;
  box-sizing: border-box;
  overflow: hidden;
}

.timeline-card:active {
  background-color: #f0f0f0;
  transform: scale(0.98);
}

.timeline-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  width: 100%;
}

.timeline-type {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.timeline-time {
  font-size: 24rpx;
  color: #999999;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.timeline-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}
