  white-space: nowrap;
}

.tree-node.parent .node-label {
  font-size: 26rpx;
  color: #1E293B;
  max-width: 220rpx;
}

.tree-node.current .node-label {
  font-size: 28rpx;
  color: #1E293B;
  font-weight: 600;
