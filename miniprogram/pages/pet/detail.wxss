  height: 36rpx;
  font-size: 18rpx;
  padding: 0 6rpx;
}

/* 卡片外部性别标签 - 相对于tree-node定位 */
.tree-node .node-gender-tag {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  min-width: 44rpx;
  height: 44rpx;
  padding: 0 10rpx;
  border-radius: 22rpx;
  font-size: 22rpx;
  color: #ffffff;
