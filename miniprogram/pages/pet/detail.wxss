@import "/styles/design.wxss";

.page-detail {
  min-height: 100vh;
  background: var(--c-bg);
}

.scroll-main {
  height: 100vh;
}

.detail-inner {
  padding: 0 0 calc(210rpx + env(safe-area-inset-bottom));
}

.nav-bar-detail {
  justify-content: center;
  padding-left: 0;
}

.nav-bar-detail .nav-back {
  position: absolute;
  left: var(--s-md);
}

/* 返回图标 */
.nav-back-icon {
  width: 40rpx;
  height: 40rpx;
}

/* 分享按钮重置button默认样式 */
.share-btn {
  padding: 0;
  margin: 0;
  line-height: inherit;
  background: transparent;
  border: none;
  font-size: inherit;
  font-weight: inherit;
  color: inherit;
  text-align: inherit;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}
.share-btn::after {
  border: none;
}

.photo-swiper {
  margin: 20rpx 28rpx 0;
  border-radius: 34rpx;
  overflow: hidden;
  background: var(--c-primary-light);
  box-shadow: var(--shadow-sm);
  position: relative;
}

.photo-swiper-inner {
  height: 520rpx;
}

/* 名字标签浮在图片左下角 */
.photo-name-badge,
.photo-name-badge-static {
  position: absolute;
  left: 20rpx;
  bottom: 20rpx;
  z-index: 10;
  display: inline-flex;
  align-items: center;
  padding: 10rpx 24rpx;
  border-radius: var(--r-full);
  background: rgba(0, 0, 0, 0.55);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
  letter-spacing: 1rpx;
}

.photo-name-badge-static {
  position: static;
  margin-top: 16rpx;
}

.photo-empty {
  height: 420rpx;
  margin: 24rpx 28rpx 0;
  border-radius: 34rpx;
  background: var(--c-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--c-primary);
  font-size: 112rpx;
}

.section-card {
  margin: 20rpx 28rpx 0;
  padding: 28rpx;
  border-radius: var(--r-xl);
  border: 1.5rpx solid var(--c-border-light);
  background: var(--c-surface);
  box-shadow: var(--shadow-sm);
}

/* ═─ 名片卡片 ─═ */
.profile-card {
  margin-top: 20rpx;
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 26rpx;
}

.profile-title-col {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.profile-name-line {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.profile-name {
  color: var(--c-text);
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.2;
}

.profile-gender-tag {
  margin-left: auto;
}

.profile-info-line {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 10rpx;
}

.profile-offspring-price {
  margin-left: auto;
  display: inline-flex;
  align-items: center;
  padding: 10rpx 28rpx;
  border-radius: var(--r-full);
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.2;
  background: linear-gradient(135deg, #E8A400 0%, #C98D00 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(232, 164, 0, 0.25);
}

.profile-category {
  color: var(--c-primary);
  font-size: var(--fs-small);
  font-weight: 700;
}

.profile-dot {
  color: var(--c-text3);
  font-size: var(--fs-small);
}

.profile-status-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--r-full);
  font-size: var(--fs-mini);
  font-weight: 700;
  line-height: 1.3;
}

.profile-status-tag.status-normal {
  color: var(--c-success);
  background: var(--c-success-bg);
}

.profile-status-tag.status-pending {
  color: var(--c-warning);
  background: var(--c-warning-bg);
}

.profile-status-tag.status-warning {
  color: var(--c-danger);
  background: var(--c-danger-bg);
}

.profile-footer {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid var(--c-border-light);
}

.profile-alias-name {
  color: var(--c-text3);
  font-size: var(--fs-mini);
  font-weight: 500;
}

.profile-tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 22rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--c-border-light);
}

.profile-big-tag {
  flex: 1;
  min-width: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 16rpx 12rpx;
  border-radius: var(--r-lg);
  text-align: center;
}

.big-tag-label {
  font-size: var(--fs-small);
  font-weight: 700;
  line-height: 1.3;
}

.big-tag-value {
  font-size: var(--fs-base);
  font-weight: 800;
  line-height: 1.3;
}

.profile-big-tag.tag-father {
  background: var(--c-male-bg);
}
.profile-big-tag.tag-father .big-tag-label,
.profile-big-tag.tag-father .big-tag-value {
  color: var(--c-male);
}

.profile-big-tag.tag-mother {
  background: var(--c-female-bg);
}
.profile-big-tag.tag-mother .big-tag-label,
.profile-big-tag.tag-mother .big-tag-value {
  color: var(--c-female);
}

.profile-big-tag.tag-partner {
  background: #FFF0F3;
}
.profile-big-tag.tag-partner .big-tag-label,
.profile-big-tag.tag-partner .big-tag-value {
  color: #D4506B;
}

.profile-big-tag.tag-offspring {
  background: var(--c-primary-light);
}
.profile-big-tag.tag-offspring .big-tag-label,
.profile-big-tag.tag-offspring .big-tag-value {
  color: var(--c-primary);
}

.section-heading {
  margin-bottom: 36rpx;
}

.section-title {
  display: block;
  margin: 0;
  color: var(--c-text);
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.25;
}

.section-sub {
  display: block;
  margin-top: 8rpx;
  color: var(--c-text2);
  font-size: var(--fs-mini);
  line-height: 1.45;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.section-badge {
  margin-left: 14rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--r-full);
  color: var(--c-primary);
  background: var(--c-primary-light);
  font-size: var(--fs-mini);
  font-weight: 700;
}

.family-tree {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0 16rpx;
  border-radius: 34rpx;
  background: linear-gradient(180deg, #FFFEFA 0%, #FFFFFF 100%);
  overflow: hidden;
}

.tree-current-row {
  display: flex;
  align-items: center;
  width: 100%;
  min-height: 462rpx;
}

.tree-spacer {
  width: 116rpx;
  height: 1rpx;
  flex-shrink: 0;
}

.tree-current-node,
.tree-partner-node,
.tree-node,
.tree-parent-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}

.tree-current-node {
  flex: 1;
  justify-content: center;
}

.tree-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  max-width: 100%;
  min-height: 44rpx;
  padding: 8rpx 24rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.1;
  white-space: nowrap;
}

.tree-badge-current {
  margin-bottom: 24rpx;
  color: #FFFFFF;
  background: #90B866;
  box-shadow: 0 10rpx 24rpx rgba(144,184,102,.25);
}

.tree-node {
  width: 230rpx;
  position: relative;
}

.tree-avatar {
  width: 190rpx;
  height: 190rpx;
  border-radius: 28rpx;
  margin: 12rpx 0 16rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8E6F3A;
  background: #F8F3E8;
  border: 2rpx solid rgba(144,184,102,.2);
  box-shadow: 0 12rpx 28rpx rgba(66,50,30,.08);
  font-size: 44rpx;
  font-weight: 700;
}

.tree-avatar image,
.tree-avatar-hero image {
  width: 100%;
  height: 100%;
}

.tree-avatar.tree-empty {
  border-style: dashed;
  opacity: .72;
}

.tree-avatar-hero {
  width: 330rpx;
  height: 330rpx;
  border-radius: 44rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #90B866;
  background: #F8F8F0;
  border: 8rpx solid rgba(223,243,194,.95);
  box-shadow: 0 18rpx 42rpx rgba(143,181,88,.24);
  font-size: 86rpx;
}

.tree-avatar-partner {
  width: 132rpx;
  height: 132rpx;
  border-radius: 24rpx;
  margin: 10rpx 0 14rpx;
  font-size: 34rpx;
}

.tree-name {
  display: block;
  max-width: 220rpx;
  color: var(--c-text);
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.25;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tree-current-name {
  display: block;
  max-width: 360rpx;
  margin-top: 24rpx;
  color: var(--c-text);
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.15;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tree-role {
  color: #766A5B;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.2;
}

.tree-partner-node {
  align-self: center;
  width: 150rpx;
  flex-shrink: 0;
  padding-top: 78rpx;
  position: relative;
}

.tree-partner-label {
  color: #766A5B;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.2;
  white-space: nowrap;
}

.tree-arrow {
  margin-top: 2rpx;
  color: #BDAF98;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1;
}

.tree-down-line {
  width: 3rpx;
  height: 76rpx;
  margin: 2rpx 0 18rpx;
  background: linear-gradient(180deg, rgba(144,184,102,.05), rgba(144,184,102,.75), rgba(144,184,102,.05));
}

.tree-parent-section {
  width: 100%;
}

.tree-badge-parent {
  color: #9F7A34;
  background: #FFF8E7;
}

.tree-parent-desc {
  display: block;
  margin-top: 14rpx;
  color: #8A8176;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.35;
  text-align: center;
}

.tree-parent-grid {
  display: flex;
  justify-content: center;
  gap: 36rpx;
  width: 100%;
  margin-top: 26rpx;
}

.tree-ancestor-section {
  padding-bottom: 8rpx;
}

.tree-badge-ancestor {
  color: #6B7F96;
  background: #EEF3F8;
}

.tree-ancestor-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20rpx 24rpx;
  width: 100%;
  margin-top: 26rpx;
  padding: 0 12rpx;
  box-sizing: border-box;
}

.tree-node-ancestor {
  width: 156rpx;
}

.tree-avatar-ancestor {
  width: 120rpx;
  height: 120rpx;
  border-radius: 22rpx;
  margin: 10rpx 0 12rpx;
  font-size: 32rpx;
}

.tree-node-ancestor .tree-name {
  max-width: 150rpx;
  font-size: 22rpx;
}

.tree-node-ancestor .tree-role {
  font-size: 22rpx;
}

@media (max-width: 360px) {
  .tree-spacer {
    width: 84rpx;
  }

  .tree-avatar-hero {
    width: 292rpx;
    height: 292rpx;
  }

  .tree-avatar {
    width: 166rpx;
    height: 166rpx;
  }

  .tree-avatar-partner {
    width: 112rpx;
    height: 112rpx;
  }

  .tree-partner-node {
    width: 126rpx;
  }

  .tree-parent-grid {
    gap: 18rpx;
  }

  .tree-node {
    width: 200rpx;
  }
}

.reminder-section-card {
  background: var(--c-surface);
  border-color: var(--c-border-light);
}

.reminder-card-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.reminder-section-card .reminder-item {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  min-height: 260rpx;
  padding: 24rpx;
  border-radius: var(--r-xl);
  border: 1.5rpx solid #F0EDE8;
  background: #FFFFFF;
  box-shadow: 0 4rpx 18rpx rgba(0,0,0,.05);
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.reminder-section-card .reminder-item:nth-child(odd) {
  background: var(--c-primary-bg);
  border-color: rgba(232,164,0,.42);
}

.rem-icon {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  margin: 0 0 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--c-primary-light);
  font-size: 30rpx;
}

.rem-info {
  width: 100%;
  min-width: 0;
  padding: 0 0 58rpx;
  box-sizing: border-box;
}

.rem-type {
  display: block;
  color: var(--c-text);
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.25;
}

.rem-date {
  display: block;
  margin-top: 12rpx;
  color: var(--c-text3);
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.45;
}

.rem-done {
  position: absolute;
  right: 20rpx;
  bottom: 22rpx;
  flex-shrink: 0;
  margin: 0;
  padding: 8rpx 18rpx;
  border-radius: var(--r-full);
  color: var(--c-primary);
  background: var(--c-primary-light);
  font-size: var(--fs-mini);
  font-weight: 700;
}

.rem-done.done {
  color: var(--c-success);
  background: var(--c-success-bg);
}

.event-section {
  background: #fff;
}

.pet-event-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.pet-event-title {
  font-size: 36rpx;
}

.report-entries {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.report-entry {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  border-radius: var(--r-full);
  background: var(--c-primary-light);
}

.report-entry-icon {
  font-size: 24rpx;
  line-height: 1;
}

.report-entry-text {
  color: var(--c-primary);
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1;
}

.date-filter-bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin: -4rpx 0 24rpx;
  padding: 12rpx 0;
  box-sizing: border-box;
}

.date-filter-picker {
  flex: 1;
  min-width: 0;
}

.date-filter-btn {
  height: 74rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
  padding: 0 16rpx;
  border-radius: 16rpx;
  border: 1.5rpx solid var(--c-border);
  background: #fff;
  box-sizing: border-box;
}

.date-filter-btn.active {
  border-color: var(--c-primary);
  background: var(--c-primary-light);
}

.date-filter-value {
  color: var(--c-text);
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.date-filter-arrow {
  margin-left: auto;
  color: var(--c-primary);
  font-size: 18rpx;
  line-height: 1;
  flex-shrink: 0;
}

.date-filter-sep {
  width: 16rpx;
  height: 2rpx;
  border-radius: var(--r-full);
  background: var(--c-border);
  flex-shrink: 0;
}

.date-filter-clear {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--r-full);
  color: var(--c-danger);
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1;
  flex-shrink: 0;
}

.pet-event-tabs {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-bottom: 26rpx;
}

.pet-event-tab {
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border-radius: 14rpx;
  background: var(--c-bg);
  color: var(--c-text2);
  font-weight: 800;
  box-sizing: border-box;
}

.pet-event-tab.active {
  background: var(--c-primary);
  color: #fff;
}

.pet-event-tab-icon {
  font-size: 22rpx;
  line-height: 1;
}

.pet-event-tab-text {
  font-size: 24rpx;
  line-height: 1;
}

.pet-event-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-bottom: 28rpx;
}

/* 换公记录卡片 */
.mate-male-card {
  margin-top: 20rpx;
  padding: 24rpx;
}

.mate-male-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.mate-male-title {
  color: var(--c-text);
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.25;
}

.mate-male-count {
  color: var(--c-text3);
  font-size: var(--fs-mini);
  font-weight: 600;
}

.mate-male-scroll {
  width: 100%;
  white-space: nowrap;
}

.mate-male-list {
  display: inline-flex;
  flex-direction: row;
  gap: 20rpx;
  padding: 4rpx 0;
}

.mate-male-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  min-width: 180rpx;
  vertical-align: top;
}

.mate-male-photo-wrap {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--r-lg);
  overflow: hidden;
  border: 3rpx solid transparent;
  background: var(--c-bg);
}

.mate-male-item.latest .mate-male-photo-wrap {
  border-color: var(--c-primary);
}

.mate-male-photo {
  width: 100%;
  height: 100%;
}

.mate-male-photo-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  background: var(--c-bg);
}

.mate-male-latest-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  padding: 2rpx 14rpx;
  border-radius: var(--r-full);
  background: var(--c-primary);
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.4;
}

.mate-male-name {
  max-width: 180rpx;
  color: var(--c-text);
  font-size: var(--fs-small);
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pet-event-card {
  min-height: 174rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 10rpx;
  border-radius: 14rpx;
  border: 1.5rpx solid var(--c-border-light);
  background: #fff;
  box-sizing: border-box;
}

.pet-event-icon {
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
  background: var(--c-bg);
  font-size: 34rpx;
  line-height: 1;
}

.pet-event-name {
  display: block;
  max-width: 100%;
  color: var(--c-text);
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pet-event-date {
  display: block;
  margin-top: 10rpx;
  color: var(--c-text3);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
}

.pet-event-empty {
  padding: 28rpx 0 34rpx;
}

.event-divider {
  height: 1.5rpx;
  margin: 0 0 22rpx;
  border-top: 1.5rpx dashed var(--c-border-light);
}

.event-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.event-collapse {
  padding: 12rpx 26rpx;
  border-radius: var(--r-full);
  border: 1.5rpx solid var(--c-border);
  color: var(--c-text2);
  font-size: var(--fs-small);
  font-weight: 600;
  flex-shrink: 0;
}

.event-tabs {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 18rpx;
}

.event-tabs .chip {
  background: transparent;
  border: 1.5rpx solid var(--c-border);
  color: var(--c-text2);
}

.event-tabs .chip.active {
  background: var(--c-primary-light);
  color: var(--c-primary);
  border-color: var(--c-primary);
}

.timeline {
  position: relative;
}

.timeline-item {
  position: relative;
}

.tl-year-row {
  display: flex;
  align-items: center;
  margin: 26rpx 0 22rpx;
}

.timeline-item:first-child .tl-year-row {
  margin-top: 0;
}

.tl-year {
  width: 74rpx;
  color: var(--c-text);
  font-size: var(--fs-small);
  font-weight: 800;
}

.tl-year-line {
  flex: 1;
  height: 1.5rpx;
  background: var(--c-border-light);
}

.tl-body {
  display: flex;
  align-items: stretch;
  min-height: 182rpx;
}

.tl-rail {
  width: 34rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.tl-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  border: 7rpx solid #fff;
  background: var(--c-primary);
  box-shadow: 0 0 0 5rpx var(--c-primary-light);
  box-sizing: border-box;
  flex-shrink: 0;
}

.tl-dot.dot-love {
  background: #E87DA0;
  box-shadow: 0 0 0 5rpx var(--c-female-bg);
}

.tl-dot.dot-egg {
  background: var(--c-primary);
}

.tl-dot.dot-hatch {
  background: #5B8DEF;
  box-shadow: 0 0 0 5rpx var(--c-male-bg);
}

.tl-dot.dot-health {
  background: var(--c-success);
  box-shadow: 0 0 0 5rpx var(--c-success-bg);
}

.tl-dot.dot-default {
  background: var(--c-primary);
}

.tl-line {
  width: 2rpx;
  flex: 1;
  margin-top: 8rpx;
  background: var(--c-border);
}

.timeline-item:last-child .tl-line {
  opacity: 0;
}

.tl-card {
  flex: 1;
  min-width: 0;
  padding: 8rpx 0 42rpx 28rpx;
}

.tl-icon {
  display: block;
  color: var(--c-primary);
  font-size: 44rpx;
  line-height: 1;
  margin-bottom: 30rpx;
}

.tl-text {
  display: block;
  color: var(--c-text);
  font-size: 32rpx;
  line-height: 1.45;
  margin-bottom: 24rpx;
}

.tl-image {
  width: 190rpx;
  height: 190rpx;
  display: block;
  border-radius: 26rpx;
  background: var(--c-bg);
  box-shadow: var(--shadow-sm);
}

.tl-date {
  display: block;
  margin-top: 10rpx;
  color: var(--c-text);
  font-size: 34rpx;
  line-height: 1;
}

.detail-action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 120;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255,255,255,.92);
  border-top: 1rpx solid var(--c-border-light);
  box-shadow: 0 -8rpx 28rpx rgba(0,0,0,.04);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  box-sizing: border-box;
}

.detail-action {
  height: 82rpx;
  border-radius: var(--r-full);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: var(--fs-small);
  font-weight: 800;
  box-sizing: border-box;
}

.detail-action.secondary {
  width: 150rpx;
  color: var(--c-text);
  background: var(--c-bg);
  border: 1.5rpx solid var(--c-border);
}

.detail-action.primary {
  flex: 1;
  color: #fff;
  background: var(--c-primary);
  box-shadow: var(--shadow-btn);
}

.action-icon {
  font-size: 30rpx;
  line-height: 1;
}

.action-icon-img {
  width: 36rpx;
  height: 36rpx;
}

.action-text {
  font-size: var(--fs-small);
  white-space: nowrap;
}

.record-modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 300;
  display: flex;
  align-items: flex-end;
  background: rgba(0,0,0,.32);
}

.record-modal {
  width: 100%;
  padding: 30rpx 28rpx calc(32rpx + env(safe-area-inset-bottom));
  border-radius: 34rpx 34rpx 0 0;
  background: var(--c-surface);
  box-sizing: border-box;
}

.edit-pet-modal,
.reminder-edit-modal {
  max-height: 82vh;
  display: flex;
  flex-direction: column;
}

.record-modal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.record-modal-title {
  color: var(--c-text);
  font-size: 34rpx;
  font-weight: 800;
}

.record-modal-close {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--c-text2);
  background: var(--c-bg);
  font-size: 42rpx;
  line-height: 1;
}

.record-type-row {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

.record-field-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-bottom: 18rpx;
}

/* 交配记录配对对象选择 */
.record-partner-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 18rpx;
  padding: 16rpx 22rpx;
  border-radius: var(--r-lg);
  background: var(--c-bg);
}

.record-partner-label {
  color: var(--c-text2);
  font-size: var(--fs-small);
  font-weight: 700;
  flex-shrink: 0;
}

.record-partner-selected {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-width: 0;
}

.record-partner-name {
  color: var(--c-primary);
  font-size: var(--fs-small);
  font-weight: 800;
}

.record-partner-change {
  color: var(--c-text3);
  font-size: var(--fs-mini);
  margin-left: 12rpx;
}

.record-partner-select {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-width: 0;
}

.record-partner-placeholder {
  color: var(--c-text3);
  font-size: var(--fs-small);
}

.record-partner-arrow {
  color: var(--c-text3);
  font-size: var(--fs-small);
}

.record-input {
  height: 78rpx;
  padding: 0 22rpx;
  border-radius: var(--r-lg);
  background: var(--c-bg);
  color: var(--c-text);
  font-size: var(--fs-small);
  box-sizing: border-box;
}

.record-textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 22rpx;
  border-radius: var(--r-lg);
  background: var(--c-bg);
  color: var(--c-text);
  font-size: var(--fs-small);
  line-height: 1.5;
  box-sizing: border-box;
}

.record-modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.edit-pet-body,
.reminder-edit-body {
  height: 56vh;
  max-height: 56vh;
  min-height: 0;
  box-sizing: border-box;
}

.edit-pet-field {
  margin-bottom: 24rpx;
}

.edit-pet-label {
  display: block;
  margin-bottom: 12rpx;
  color: var(--c-text);
  font-size: var(--fs-small);
  font-weight: 800;
  line-height: 1.25;
}

.edit-pet-label-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.edit-pet-label-row .edit-pet-label {
  margin-bottom: 0;
}

.edit-pet-hint {
  display: block;
  color: var(--c-text3);
  font-size: var(--fs-mini);
  line-height: 1.35;
}

.edit-pet-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.edit-pet-chip-row .chip-add {
  color: var(--c-primary);
  border-color: var(--c-primary);
  font-weight: 700;
}

.edit-pet-switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 22rpx;
  border-radius: var(--r-lg);
  background: var(--c-bg);
}

.edit-pet-switch-row .edit-pet-label {
  margin-bottom: 0;
}

.reminder-type-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.reminder-type-chip {
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border-radius: var(--r-lg);
  border: 1.5rpx solid var(--c-border-light);
  background: var(--c-bg);
  color: var(--c-text2);
  font-size: var(--fs-small);
  font-weight: 800;
  box-sizing: border-box;
}

.reminder-type-chip.active {
  border-color: rgba(232,164,0,.38);
  background: var(--c-primary-light);
  color: var(--c-primary);
}

.reminder-type-icon {
  font-size: 28rpx;
  line-height: 1;
}

.reminder-type-text {
  font-size: var(--fs-small);
  line-height: 1;
}

.reminder-input-wrap {
  position: relative;
}

.reminder-days-input {
  padding-right: 76rpx;
}

.reminder-unit {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  color: var(--c-text3);
  font-size: var(--fs-small);
  font-weight: 800;
}

.reminder-date-picker {
  height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 0 22rpx;
  border-radius: var(--r-lg);
  background: var(--c-bg);
  color: var(--c-text);
  font-size: var(--fs-small);
  font-weight: 700;
  box-sizing: border-box;
}

.record-cancel,
.record-confirm {
  height: 82rpx;
  border-radius: var(--r-full);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-small);
  font-weight: 800;
  transition: all .15s;
}

.record-cancel:active,
.record-confirm:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.record-cancel {
  width: 180rpx;
  color: var(--c-text2);
  background: var(--c-bg);
}

.record-confirm {
  flex: 1;
  color: #fff;
  background: var(--c-primary);
  box-shadow: var(--shadow-btn);
}

/* 删除按钮样式 */
.record-delete-btn {
  width: 160rpx;
  height: 82rpx;
  border-radius: var(--r-full);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-small);
  font-weight: 800;
  color: #fff;
  background: #FF4D4F;
  box-shadow: 0 2rpx 8rpx rgba(255, 77, 79, 0.2);
  transition: all .15s;
}

.record-delete-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.record-detail-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 320;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 44rpx;
  background: rgba(20, 20, 20, .38);
  box-sizing: border-box;
}

.record-detail-modal {
  width: 100%;
  max-width: 640rpx;
  max-height: 78vh;
  display: flex;
  flex-direction: column;
  border-radius: var(--r-xl);
  background: var(--c-surface);
  overflow: hidden;
  box-shadow: var(--shadow-lg);
}

.record-detail-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 28rpx;
  border-bottom: 1.5rpx solid var(--c-border-light);
}

.record-detail-badge {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: var(--c-bg);
  font-size: 34rpx;
  flex-shrink: 0;
}

.record-detail-badge.egg {
  background: var(--c-warning-bg);
}

.record-detail-badge.hatch {
  background: var(--c-male-bg);
}

.record-detail-badge.mate {
  background: var(--c-female-bg);
}

.record-detail-title-wrap {
  flex: 1;
  min-width: 0;
}

.record-detail-title {
  display: block;
  color: var(--c-text);
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.25;
}

.record-detail-subtitle {
  display: block;
  margin-top: 4rpx;
  color: var(--c-text3);
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.3;
}

.record-detail-close {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--c-bg);
  color: var(--c-text2);
  font-size: 42rpx;
  line-height: 1;
  flex-shrink: 0;
}

.record-detail-body {
  flex: 1;
  min-height: 0;
  padding: 28rpx;
  overflow-y: auto;
  box-sizing: border-box;
}

.record-detail-text {
  display: block;
  color: var(--c-text);
  font-size: var(--fs-body);
  font-weight: 600;
  line-height: 1.55;
}

.record-detail-metrics {
  margin-top: 22rpx;
  padding: 18rpx 22rpx;
  border-radius: var(--r-lg);
  background: var(--c-bg);
}

.record-detail-metric {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 10rpx 0;
}

.metric-label {
  color: var(--c-text3);
  font-size: var(--fs-small);
  font-weight: 700;
}

.metric-value {
  color: var(--c-text);
  font-size: var(--fs-small);
  font-weight: 800;
  text-align: right;
}

.metric-value.low {
  color: var(--c-danger);
}

.record-detail-photos {
  margin-top: 24rpx;
}

.record-detail-photo-title {
  display: block;
  margin-bottom: 12rpx;
  color: var(--c-text2);
  font-size: var(--fs-small);
  font-weight: 800;
}

.record-detail-photo-scroll {
  width: 100%;
  white-space: nowrap;
}

.record-detail-photo-list {
  display: flex;
  gap: 14rpx;
}

.record-detail-photo {
  width: 154rpx;
  height: 154rpx;
  border-radius: var(--r-md);
  background: var(--c-bg);
  flex-shrink: 0;
}

.record-detail-actions {
  display: flex;
  gap: 16rpx;
  padding: 22rpx 28rpx calc(22rpx + env(safe-area-inset-bottom));
  border-top: 1.5rpx solid var(--c-border-light);
}

.record-detail-print,
.record-detail-ok {
  height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--r-full);
  font-size: var(--fs-small);
  font-weight: 800;
}

.record-detail-print {
  width: 170rpx;
  gap: 8rpx;
  background: var(--c-bg);
  color: var(--c-text2);
}

.record-detail-ok {
  flex: 1;
  background: var(--c-primary);
  color: #fff;
  box-shadow: var(--shadow-btn);
}

/* ═─ 编辑弹窗·更多设置 ─═ */
.edit-pet-more-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 22rpx;
  border-radius: var(--r-lg);
  background: var(--c-bg);
}

.edit-pet-more-arrow {
  color: var(--c-text3);
  font-size: 32rpx;
  transition: transform .2s;
}

.edit-pet-more-arrow.open {
  transform: rotate(180deg);
}

.edit-pet-more-body {
  margin-top: 16rpx;
  padding-left: 8rpx;
}

/* ═─ 编辑弹窗·照片选择 ─═ */
.edit-photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.edit-photo-item {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  border-radius: var(--r-md);
  overflow: hidden;
}

.edit-photo-img {
  width: 100%;
  height: 100%;
}

.edit-photo-del {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  border-radius: 0 0 0 16rpx;
  background: rgba(0,0,0,.5);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.edit-photo-add {
  width: 150rpx;
  height: 150rpx;
  border-radius: var(--r-md);
  border: 2rpx dashed var(--c-border);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--c-text3);
  font-size: 52rpx;
  background: var(--c-bg);
}

/* ═─ 编辑弹窗·父本/母本/配偶选择行 ─═ */
.edit-parent-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 22rpx;
  border-radius: var(--r-lg);
  background: var(--c-bg);
}

.edit-parent-value {
  color: var(--c-text);
  font-size: var(--fs-small);
  font-weight: 700;
}

.edit-parent-value.empty {
  color: var(--c-text3);
  font-weight: 500;
}

.edit-parent-arrow {
  color: var(--c-text3);
  font-size: 36rpx;
}

.edit-parent-clear {
  display: inline-block;
  margin-top: 10rpx;
  color: var(--c-warning);
  font-size: var(--fs-mini);
  font-weight: 700;
}

/* ═─ 编辑弹窗·选择列表 ─═ */
.edit-empty-hint {
  text-align: center;
  padding: 60rpx 0;
  color: var(--c-text3);
  font-size: var(--fs-small);
}

.edit-pet-pick {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 16rpx;
  border-radius: var(--r-md);
}

.edit-pet-pick:active {
  background: var(--c-bg);
}

.edit-pet-pick-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.edit-pet-pick-emoji {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--c-primary-light);
  font-size: 32rpx;
}

.edit-pet-pick-name {
  color: var(--c-text);
  font-size: var(--fs-small);
  font-weight: 600;
}
