  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 22rpx 16rpx;
  border-radius: 40rpx;
  background-color: #F0F7FF;
  transition: all 0.2s ease;
}

.bar-btn:active {
  transform: scale(0.95);
}

/* 记录按钮 - 蓝色主按钮 */
