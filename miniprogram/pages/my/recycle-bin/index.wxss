@import "/styles/design.wxss";

.page-recycle-bin {
  min-height: 100vh;
  background: var(--c-bg);
}

.scroll-main {
  height: 100vh;
}

.recycle-content {
  padding: 0 0 calc(40rpx + env(safe-area-inset-bottom));
}

/* 导航栏 - 复用全局 nav-bar，只覆盖需要的属性 */
.nav-bar-detail {
  justify-content: center;
  padding-left: 0;
}

.nav-bar-detail .nav-back {
  position: absolute;
  left: var(--s-md);
}

.nav-bar-detail .nav-action {
  position: absolute;
  right: var(--s-md);
}

/* 返回图标 */
.nav-back-icon {
  width: 40rpx;
  height: 40rpx;
}

.nav-action .action-text {
  font-size: var(--fs-small);
  color: var(--c-primary);
  font-weight: 600;
  white-space: nowrap;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: var(--fs-subtitle);
  font-weight: 700;
  color: var(--c-text);
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: var(--fs-small);
  color: var(--c-text2);
}

/* 宠物列表 */
.pet-list {
  padding: 20rpx 28rpx;
}

.pet-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--c-surface);
  border-radius: var(--r-xl);
  border: 1.5rpx solid var(--c-border-light);
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}

.pet-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  background: var(--c-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
}

.pet-avatar image {
  width: 100%;
  height: 100%;
}

.pet-avatar-text {
  font-size: 48rpx;
}

.pet-info {
  flex: 1;
  padding: 0 20rpx;
  min-width: 0;
}

.pet-name {
  display: block;
  font-size: var(--fs-body);
  font-weight: 700;
  color: var(--c-text);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pet-breed {
  display: block;
  font-size: var(--fs-small);
  color: var(--c-text2);
  margin-bottom: 6rpx;
}

.pet-delete-time {
  display: block;
  font-size: 22rpx;
  color: var(--c-text3);
}

.pet-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex-shrink: 0;
}

.action-btn {
  padding: 10rpx 28rpx;
  border-radius: var(--r-full);
  font-size: 24rpx;
  font-weight: 600;
}

.restore-btn {
  background: var(--c-primary-light);
  color: var(--c-primary);
}

.delete-btn {
  background: var(--c-danger-bg);
  color: var(--c-danger);
}
