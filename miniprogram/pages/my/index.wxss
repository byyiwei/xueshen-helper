}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 88rpx;
  box-sizing: border-box;
  background-color: #faf8f3;
  border-radius: 24rpx;
  padding: 0 100rpx 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 88rpx;
}

.switch-wrapper {
  display: flex;
  justify-content: flex-end;
}

.modal-overlay-center {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 32rpx;
}

.input-with-voice {
  position: relative;
}

.voice-btn {
  position: absolute;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 56rpx;
  height: 56rpx;
  background-color: #999999;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.voice-btn.recording {
  background-color: #ff3b30;
}

.voice-btn.recording .voice-btn-icon {
  color: #ffffff;
  animation: breathe 1s ease-in-out infinite;
}

.voice-btn-icon {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: bold;
}

@keyframes breathe {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.15);
  }
}

.scanning-indicator {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.scan-dots {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #B8860B;
  animation: dotPulse 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }
.dot:nth-child(3) { animation-delay: 0s; }

@keyframes dotPulse {
  0%, 80%, 100% {
    transform: scale(0);
    opacity: 0.5;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

.scanning-text {
  font-size: 28rpx;
  color: #999999;
}

.device-list {
  padding: 16rpx 0;
}

.device-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.device-item:last-child {
  border-bottom: none;
}

.device-icon {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #4CAF50;
  margin-right: 20rpx;
}

.device-info {
