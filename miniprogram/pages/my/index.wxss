.page {
  position: relative;
  min-height: 100vh;
  background-color: #F0F7FF;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* ====== 自定义导航栏 ====== */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: #F0F7FF;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #1E293B;
  text-align: center;
}

.custom-nav.is-refreshing {
  flex-direction: column;
  height: auto;
  padding: 12rpx 0;
}

.nav-refresh-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #E6F0FF;
  border-top-color: #3A7CFF;
  border-radius: 50%;
  animation: navSpin 0.8s linear infinite;
}

@keyframes navSpin {
  to { transform: rotate(360deg); }
}

.nav-refresh-text {
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 4rpx;
}

.header-bg {
  height: 0;
  background: #F0F7FF;
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
}

.profile-card {
  position: relative;
  margin: 32rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  z-index: 1;
  box-shadow: 0 4rpx 24rpx rgba(58, 124, 255, 0.06), 0 0 0 1rpx rgba(58, 124, 255, 0.04);
}

.avatar-section {
  flex-shrink: 0;
  position: relative;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #F0F7FF;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(58, 124, 255, 0.06);
  overflow: hidden;
  border: 4rpx solid #ffffff;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-text {
  font-size: 50rpx;
  color: #1E293B;
  font-weight: bold;
}

.avatar-btn {
  position: absolute;
  bottom: -14rpx;
  left: 50%;
  transform: translateX(-50%);
  background-color: #475569;
  color: #ffffff;
  padding: 10rpx 24rpx;
  border-radius: 18rpx;
  font-size: 22rpx;
  white-space: nowrap;
}

.profile-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  margin-left: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  transition: background 0.15s;
}

.profile-info:active {
  background: #F0F7FF;
}

.username-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.username {
  font-size: 34rpx;
  font-weight: 700;
  color: #1E293B;
}

.edit-hint-row {
  display: inline-flex;
  align-items: center;
  background: #F0F7FF;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  align-self: flex-start;
}

.edit-hint-icon {
  font-size: 20rpx;
  color: #94A3B8;
  margin-right: 8rpx;
}

.edit-hint-text {
  font-size: 22rpx;
  color: #475569;
}

.logout-btn {
  flex-shrink: 0;
  padding: 16rpx 28rpx;
  background-color: rgba(58, 124, 255, 0.05);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.logout-btn:active {
  background-color: rgba(58, 124, 255, 0.1);
  transform: scale(0.95);
}

.logout-icon {
  font-size: 24rpx;
  color: #475569;
  font-weight: 500;
}

.tabs {
  display: flex;
  padding: 0 32rpx;
  margin-top: -16rpx;
  position: relative;
  z-index: 1;
}

.tab {
  flex: 1;
  background-color: #ffffff;
  color: #475569;
  padding: 24rpx 16rpx;
  text-align: center;
  border-radius: 20rpx;
  font-size: 28rpx;
  margin-right: 16rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 12rpx rgba(58, 124, 255, 0.04), 0 0 0 1rpx rgba(58, 124, 255, 0.03);
  transition: all 0.2s ease;
}

.tab:last-child {
  margin-right: 0;
}

.tab.active {
  background-color: #3A7CFF;
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(58, 124, 255, 0.12);
}

.content {
  padding: 24rpx 32rpx;
  padding-bottom: 140rpx;
  position: relative;
  z-index: 1;
}

.tab-content {
  display: block;
}

.section {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(58, 124, 255, 0.04), 0 0 0 1rpx rgba(58, 124, 255, 0.03);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 20rpx;
}

.section-desc {
  font-size: 26rpx;
  color: #475569;
  display: block;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.section-items {
  display: flex;
  flex-direction: column;
}

.item {
  display: flex;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 2rpx solid #F0F7FF;
  transition: all 0.2s ease;
  gap: 20rpx;
}

.item:active {
  background-color: #F0F7FF;
  padding-left: 16rpx;
}

.item:last-child {
  border-bottom: none;
}

.item-left {
  flex-shrink: 0;
}

.input-with-voice {
  flex: 1;
  position: relative;
  display: flex;
  align-items: center;
}

.item-value {
  font-size: 30rpx;
  color: #1E293B;
}

.item-value-input {
  width: 100%;
  height: 88rpx;
  box-sizing: border-box;
  background-color: #F0F7FF;
  border-radius: 24rpx;
  padding: 0 100rpx 0 24rpx;
  font-size: 28rpx;
  color: #1E293B;
  line-height: 88rpx;
}

.voice-btn {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: #F0F7FF;
  border: 2rpx solid #E6F0FF;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background-color 0.2s ease, border-color 0.2s ease;
}

.voice-btn:active {
  background-color: #E6F0FF;
}

.voice-btn.recording {
  background-color: #E76F51;
  border-color: #E76F51;
}

.voice-btn.recording .voice-btn-icon {
  animation: breathe 0.8s ease-in-out infinite;
}

.voice-btn-icon {
  font-size: 20rpx;
  color: #94A3B8;
  line-height: 1;
}

.voice-btn.recording .voice-btn-icon {
  color: #ffffff;
}

@keyframes breathe {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.2);
  }
  100% {
    transform: scale(1);
  }
}

.item-label {
  font-size: 26rpx;
  color: #475569;
  display: block;
  margin-bottom: 6rpx;
}

.item-value {
  font-size: 30rpx;
  color: #1E293B;
}

.item-tag {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  margin-right: 16rpx;
}

.item-tag.valid {
  background-color: #EDF2F7;
  color: #1E293B;
}

.item-tag.editable {
  background-color: #EDF2F7;
  color: #1E293B;
}

.item-tag.warning {
  background-color: #FDF3E0;
  color: #64748B;
}

.item-arrow {
  font-size: 32rpx;
  color: #CBD5E1;
}







/* ========== 数据页面统计卡片（居中） ========== */
.tab-content {
  min-height: 60vh;
}

.stats-grid {
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.stats-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
  width: 100%;
  max-width: 686rpx;
  justify-content: center;
}

.stat-card {
  flex: 1;
  max-width: 333rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(58, 124, 255, 0.04), 0 0 0 1rpx rgba(58, 124, 255, 0.03);
}

.stat-label {
  font-size: 24rpx;
  color: #475569;
  display: block;
  margin-bottom: 12rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #3A7CFF;
  display: block;
  line-height: 1.2;
}

.stat-sub {
  font-size: 22rpx;
  color: #94A3B8;
  display: block;
  margin-top: 8rpx;
}

/* ========== 龟友名片卡片 ========== */
.shop-card {
  background: #ffffff;
  border-radius: 28rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(58, 124, 255, 0.06);
  border: 2rpx solid #EDF2F7;
}

/* 顶部封面 */
.shop-banner {
  position: relative;
  width: 100%;
  height: 360rpx;
  background: linear-gradient(180deg, #FFFFFF 0%, #EDF2F7 100%);
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-hint {
  font-size: 26rpx;
  color: #94A3B8;
  letter-spacing: 2rpx;
  padding: 16rpx 32rpx;
  background: #ffffff;
  border-radius: 999rpx;
  border: 2rpx dashed #E6F0FF;
}

.banner-watermark {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  font-size: 22rpx;
  color: rgba(58, 124, 255, 0.3);
  letter-spacing: 2rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.85);
  border-radius: 999rpx;
  backdrop-filter: blur(10px);
}

/* 店名 */
.shop-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 32rpx 16rpx;
  text-align: center;
}

.shop-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #1E293B;
  line-height: 1.3;
  letter-spacing: 1rpx;
}

/* 主玩品种标签 —— 胶囊高亮 */
.shop-specialty {
  padding: 0 32rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.specialty-tag {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  border: 2rpx solid #EDF2F7;
  gap: 12rpx;
}

.specialty-tag-label {
  font-size: 22rpx;
  color: #3A7CFF;
  font-weight: 700;
  background: #3A7CFF;
  color: #ffffff;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  letter-spacing: 1rpx;
}

.specialty-tag-divider {
  font-size: 24rpx;
  color: #E6F0FF;
  font-weight: 300;
}

.specialty-tag-text {
  font-size: 24rpx;
  color: #1E293B;
  font-weight: 600;
  line-height: 1.4;
}

/* ========== 信息卡片网格 ========== */
.shop-info-grid {
  padding: 0 32rpx 28rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.info-card {
  flex: 1;
  min-width: calc(50% - 8rpx);
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: flex-start;
  border: 2rpx solid #EDF2F7;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.info-card:active {
  background: #F0F7FF;
}

.info-card-full {
  min-width: 100%;
  flex: 0 0 100%;
}

.info-card-icon {
  width: 56rpx;
  height: 56rpx;
  background: #ffffff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
  border: 2rpx solid #EDF2F7;
}

.info-card-body {
  flex: 1;
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.info-card-label {
  font-size: 22rpx;
  color: #94A3B8;
  font-weight: 500;
  margin-bottom: 8rpx;
  display: block;
  letter-spacing: 1rpx;
}

.info-card-text {
  font-size: 26rpx;
  color: #1E293B;
  font-weight: 600;
  line-height: 1.4;
  word-break: break-all;
}

.info-card-text-empty {
  color: #94A3B8;
  font-weight: 500;
}

.info-card-text-wechat {
  letter-spacing: 0.5rpx;
}

/* 状态徽章 */
.info-card-badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  align-self: flex-start;
  margin-top: 2rpx;
}

.badge-active {
  background: #EDF2F7;
}

.badge-active .info-card-badge-text {
  color: #1E293B;
}

.badge-muted {
  background: #EDF2F7;
}

.badge-muted .info-card-badge-text {
  color: #94A3B8;
}

.info-card-badge-text {
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* 微信行 */
.info-card-wechat-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.info-card-copy-btn {
  background: #3A7CFF;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}

.info-card-copy-text {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.info-card-status {
  flex-shrink: 0;
}

/* ========== 营业执照图片展示区 ========== */
.shop-license-section {
  padding: 4rpx 32rpx 28rpx;
}

.license-card {
  background: linear-gradient(135deg, #FFFFFF 0%, #F0F7FF 100%);
  border-radius: 20rpx;
  overflow: hidden;
  border: 2rpx solid #E6F0FF;
}

.license-image-wrap {
  width: 100%;
  padding: 24rpx;
  box-sizing: border-box;
}

.license-image {
  width: 100%;
  height: 380rpx;
  background: #ffffff;
  border-radius: 16rpx;
  display: block;
}

.license-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 32rpx;
  background: #3A7CFF;
}

.license-icon {
  font-size: 24rpx;
  color: #ffffff;
  margin-right: 12rpx;
  background: #3A7CFF;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
}

.license-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* ========== 特色标签区 ========== */
.shop-tags-section {
  padding: 8rpx 32rpx 28rpx;
}

.shop-tags-title {
  display: block;
  font-size: 24rpx;
  color: #94A3B8;
  font-weight: 600;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

.shop-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.shop-tag {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.shop-tag-0 {
  background: #3A7CFF;
  color: #ffffff;
}

.shop-tag-1 {
  background: #F0F7FF;
  color: #3A7CFF;
  border: 2rpx solid #E6F0FF;
}

.shop-tag-2 {
  background: #FFFFFF;
  color: #475569;
  border: 2rpx solid #EDF2F7;
}

.shop-tag-3 {
  background: #EDF2F7;
  color: #3A7CFF;
}

/* 龟友有话说 —— 引用卡片样式 */
.shop-intro-section {
  margin: 8rpx 32rpx 28rpx;
  padding: 32rpx 32rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #F0F7FF 100%);
  border-radius: 20rpx;
  position: relative;
  border-left: 6rpx solid #3A7CFF;
}

.shop-intro-quote {
  font-size: 80rpx;
  color: #E6F0FF;
  font-family: Georgia, serif;
  line-height: 0.8;
  margin-bottom: -20rpx;
  font-weight: 700;
}

.shop-intro-text {
  font-size: 26rpx;
  color: #1E293B;
  line-height: 1.8;
  font-weight: 500;
  display: block;
  padding-top: 8rpx;
}

/* 区块标题行（种群、环境共用） */
.section-title-row {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx 20rpx;
}

.section-title-bar {
  width: 8rpx;
  height: 32rpx;
  background: #3A7CFF;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.section-title-text {
  font-size: 30rpx;
  font-weight: 800;
  color: #1E293B;
  letter-spacing: 1rpx;
}

.section-title-count {
  margin-left: auto;
  font-size: 22rpx;
  color: #94A3B8;
  font-weight: 500;
  padding: 6rpx 16rpx;
  background: #F0F7FF;
  border-radius: 999rpx;
}

/* 种群展示 */
.species-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 32rpx 24rpx;
  gap: 16rpx;
}

.species-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #F0FDF4 0%, #EDF2F7 100%);
  border-radius: 16rpx;
  border: 2rpx solid #C8E6D5;
  min-width: 160rpx;
}

.species-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
}

/* 养殖环境展示 */
.env-section {
  padding-bottom: 24rpx;
}

.env-image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  padding: 8rpx 32rpx 16rpx;
}

.env-image-item {
  aspect-ratio: 1;
  border-radius: 20rpx;
  overflow: hidden;
  background: #F0F7FF;
  border: 2rpx solid #EDF2F7;
}

.env-image {
  width: 100%;
  height: 100%;
}

.env-placeholder {
  margin: 8rpx 32rpx 16rpx;
  width: 200rpx;
  height: 200rpx;
  background: #FFFFFF;
  border: 2rpx dashed #E6F0FF;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.env-placeholder-text {
  font-size: 26rpx;
  color: #94A3B8;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.env-desc {
  display: block;
  padding: 8rpx 32rpx 24rpx;
  font-size: 26rpx;
  color: #475569;
  line-height: 1.8;
  font-weight: 500;
}

/* ========== 小程序二维码卡片 ========== */
.qr-card {
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(58, 124, 255, 0.04);
  border: 2rpx solid #EDF2F7;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.qr-card-text {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.qr-card-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #1E293B;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.qr-card-sub {
  font-size: 24rpx;
  color: #94A3B8;
  font-weight: 500;
}

.qr-card-image {
  width: 140rpx;
  height: 140rpx;
  flex-shrink: 0;
  margin-left: 24rpx;
  background: #ffffff;
  border: 2rpx solid #EDF2F7;
  border-radius: 16rpx;
  padding: 12rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qr-card-qr {
  width: 100%;
  height: 100%;
  display: block;
}

.qr-card-qr-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  border-radius: 8rpx;
}

.qr-card-qr-icon {
  font-size: 52rpx;
  color: #CBD5E1;
}

/* ===== 数据 Tab：跨宠物提醒汇总 ===== */
.reminder-summary-wrap {
  padding: 0 32rpx;
  margin-top: 16rpx;
  margin-bottom: 16rpx;
}

.reminder-summary-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0 16rpx;
}

.reminder-summary-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1E293B;
}

.reminder-summary-count {
  font-size: 24rpx;
  color: #94A3B8;
  font-weight: 500;
}

.reminder-summary-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(58, 124, 255, 0.03);
  border: 2rpx solid #EDF2F7;
  transition: all 0.15s;
  gap: 16rpx;
}

.reminder-summary-card:active {
  background: #FFFFFF;
  transform: scale(0.99);
}

.reminder-summary-icon {
  width: 72rpx;
  height: 72rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
  border: 2rpx solid #EDF2F7;
}

.reminder-summary-main {
  flex: 1;
  min-width: 0;
}

.reminder-summary-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.reminder-summary-type {
  font-size: 28rpx;
  font-weight: 700;
  color: #1E293B;
}

.reminder-summary-status {
  font-size: 22rpx;
  color: #475569;
  font-weight: 500;
}

.reminder-summary-bottom {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.reminder-summary-name {
  font-size: 24rpx;
  color: #1E293B;
  font-weight: 600;
}

.reminder-summary-category {
  font-size: 24rpx;
  color: #475569;
}

.reminder-summary-meta {
  font-size: 22rpx;
  color: #94A3B8;
}

.reminder-summary-done-btn {
  flex-shrink: 0;
  align-self: center;
  padding: 12rpx 22rpx;
  border-radius: 28rpx;
  background: #3A7CFF;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1;
}

/* 状态强调色 */
.reminder-summary-card.reminder-overdue {
  background: #FDF3E0;
  border-color: #F5E0D0;
}
.reminder-summary-card.reminder-overdue .reminder-summary-status {
  color: #E76F51;
  font-weight: 700;
}

.reminder-summary-card.reminder-today {
  background: #FDF3E0;
  border-color: #F5D0D0;
}
.reminder-summary-card.reminder-today .reminder-summary-status {
  color: #E76F51;
  font-weight: 700;
}

.reminder-summary-card.reminder-tomorrow {
  background: #FDFBF5;
  border-color: #F0E8C0;
}
.reminder-summary-card.reminder-tomorrow .reminder-summary-status {
  color: #64748B;
  font-weight: 700;
}

/* 空状态 */
.reminder-summary-empty {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 60rpx 32rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid #EDF2F7;
  box-shadow: 0 2rpx 12rpx rgba(58, 124, 255, 0.03);
}

.reminder-summary-empty .reminder-empty-icon {
  font-size: 72rpx;
  opacity: 0.6;
  margin-bottom: 16rpx;
}

.reminder-summary-empty .reminder-empty-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 8rpx;
}

.reminder-summary-empty .reminder-empty-hint {
  font-size: 22rpx;
  color: #94A3B8;
  line-height: 1.6;
  max-width: 560rpx;
}

/* 分享按钮 */
.share-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
  padding: 0 32rpx;
}

.share-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  transition: all 0.2s ease;
}

.share-btn.outline {
  background-color: #ffffff;
  border: 2rpx solid #3A7CFF;
  color: #3A7CFF;
}

.share-btn.primary {
  background: #3A7CFF;
  color: #ffffff;
}

.share-btn:active {
  transform: scale(0.98);
}

/* ========== 种群卡片（带图片） ========== */
.species-section {
  padding-bottom: 16rpx;
}

.species-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  padding: 4rpx 32rpx 24rpx;
}

.species-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  border: 2rpx solid #EDF2F7;
}

.species-photo {
  width: 100%;
  height: 180rpx;
  background: #EDF2F7;
}

.species-photo.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F0F7FF;
}

.species-photo-text {
  font-size: 24rpx;
  color: #475569;
  font-weight: 600;
}

.species-info {
  padding: 16rpx;
  text-align: center;
}

.species-name {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #1E293B;
  letter-spacing: 1rpx;
  margin-bottom: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ========== 编辑名片弹窗（底部弹出样式） ========== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 99999;
  animation: overlayFadeIn 0.2s ease-out;
}

@keyframes overlayFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-content {
  width: 100%;
  background: linear-gradient(180deg, #ffffff 0%, #F0F7FF 100%);
  border-radius: 40rpx 40rpx 0 0;
  padding: calc(60rpx + env(safe-area-inset-top)) 36rpx calc(40rpx + env(safe-area-inset-bottom));
  max-height: 92vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 -8rpx 40rpx rgba(58, 124, 255, 0.08);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid #EDF2F7;
  flex-shrink: 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1E293B;
  letter-spacing: 1rpx;
}

.modal-close {
  font-size: 48rpx;
  color: #94A3B8;
  line-height: 1;
  padding: 0 8rpx;
}

.modal-scroll {
  flex: 1;
  overflow: hidden;
}

.edit-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid #EDF2F7;
}

.edit-item:last-child {
  border-bottom: none;
}

.edit-label {
  font-size: 28rpx;
  color: #3A7CFF;
  font-weight: 600;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.edit-item-switch {
  cursor: default;
}

.edit-item-switch .edit-label {
  font-size: 28rpx;
  color: #3A7CFF;
  font-weight: 600;
  min-width: 160rpx;
  max-width: 280rpx;
  flex-shrink: 0;
  word-break: keep-all;
}

.edit-value {
  flex: 1;
  font-size: 28rpx;
  color: #94A3B8;
  text-align: right;
  margin-right: 16rpx;
  font-weight: 500;
  min-width: 0;
  line-height: 1.4;
}

.edit-arrow {
  font-size: 32rpx;
  color: #CBD5E1;
}

.modal-footer {
  padding: 24rpx 32rpx;
  border-top: 2rpx solid #EDF2F7;
  flex-shrink: 0;
}

.btn-confirm {
  width: 100%;
  height: 88rpx;
  background-color: #3A7CFF;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 2rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 26rpx;
  color: #94A3B8;
}

.empty-hint {
  font-size: 22rpx;
  color: #CBD5E1;
  margin-top: 16rpx;
  text-align: center;
  padding: 0 40rpx;
}

.contact-modal {
  width: calc(100% - 64rpx);
  max-width: 650rpx;
  background-color: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
}

.modal-header {
  padding: 32rpx;
  border-bottom: 2rpx solid #EDF2F7;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1E293B;
}

.modal-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #94A3B8;
  line-height: 1;
}

.modal-body {
  padding: 32rpx;
}

.modal-footer {
  padding: 24rpx 32rpx;
  border-top: 2rpx solid #EDF2F7;
  display: flex;
  gap: 24rpx;
}

.btn-cancel {
  flex: 1;
  height: 88rpx;
  background-color: #F0F7FF;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #475569;
}

.btn-confirm {
  flex: 1;
  height: 88rpx;
  background-color: #3A7CFF;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #ffffff;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: #475569;
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 88rpx;
  box-sizing: border-box;
  background-color: #F0F7FF;
  border-radius: 24rpx;
  padding: 0 100rpx 0 24rpx;
  font-size: 28rpx;
  color: #3A7CFF;
  line-height: 88rpx;
}

.switch-wrapper {
  display: flex;
  justify-content: flex-end;
}

.modal-overlay-center {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99999;
  padding: 32rpx;
  box-sizing: border-box;
}

.input-with-voice {
  position: relative;
}

.voice-btn {
  position: absolute;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 56rpx;
  height: 56rpx;
  background-color: #94A3B8;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.voice-btn.recording {
  background-color: #E76F51;
}

.voice-btn.recording .voice-btn-icon {
  color: #ffffff;
  animation: breathe 1s ease-in-out infinite;
}

.voice-btn-icon {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: bold;
}

@keyframes breathe {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.15);
  }
}

.scanning-indicator {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.scan-dots {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #3A7CFF;
  animation: dotPulse 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }
.dot:nth-child(3) { animation-delay: 0s; }

@keyframes dotPulse {
  0%, 80%, 100% {
    transform: scale(0);
    opacity: 0.5;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

.scanning-text {
  font-size: 28rpx;
  color: #94A3B8;
}

.device-list {
  padding: 16rpx 0;
}

.device-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #EDF2F7;
}

.device-item:last-child {
  border-bottom: none;
}

.device-icon {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #3A7CFF;
  margin-right: 20rpx;
}

.device-info {
  flex: 1;
}

.device-name {
  font-size: 30rpx;
  color: #3A7CFF;
  display: block;
}

.device-id {
  font-size: 24rpx;
  color: #94A3B8;
  margin-top: 8rpx;
  display: block;
}

.device-arrow {
  font-size: 32rpx;
  color: #CBD5E1;
}

.action-item {
  padding: 28rpx;
  background-color: #F0F7FF;
  border-radius: 24rpx;
  text-align: center;
  margin-bottom: 16rpx;
}

.action-item:last-child {
  margin-bottom: 0;
}

.action-text {
  font-size: 30rpx;
  color: #3A7CFF;
}

.action-text.danger {
  color: #E76F51;
}

/* ========== 骨架屏样式 ========== */
.skeleton-container {
  padding: 0 32rpx;
  position: relative;
  overflow: hidden;
}

/* GPU加速闪光扫描条 - 仅1个动画元素 */
.skeleton-container::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 40%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent);
  animation: skeleton-sweep 1.8s ease-in-out infinite;
  z-index: 1;
  pointer-events: none;
  will-change: transform;
}

.skeleton-profile-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.skeleton-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #EDF2F7;
  flex-shrink: 0;
}

.skeleton-profile-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.skeleton-username {
  width: 60%;
  height: 40rpx;
  background: #EDF2F7;
  border-radius: 8rpx;
}

.skeleton-edit-hint {
  width: 40%;
  height: 24rpx;
  background: #EDF2F7;
  border-radius: 6rpx;
}

.skeleton-tabs {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.skeleton-tab {
  flex: 1;
  height: 72rpx;
  background: #EDF2F7;
  border-radius: 16rpx;
}

.skeleton-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.skeleton-stats-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.skeleton-stats-row {
  display: flex;
  gap: 20rpx;
}

.skeleton-stat-card {
  flex: 1;
  height: 180rpx;
  background: #EDF2F7;
  border-radius: 24rpx;
}

@keyframes skeleton-sweep {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(450%); }
}
