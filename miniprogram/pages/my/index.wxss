.contact-modal {
  width: calc(100% - 64rpx);
  max-width: 650rpx;
  background-color: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
}

.modal-header {
  padding: 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
