@import "/styles/design.wxss";

.page-my {
  min-height: 100vh;
  background: var(--c-bg);
}

.scroll-main {
  height: 100vh;
}

.my-inner {
  padding: 0 0 calc(190rpx + env(safe-area-inset-bottom));
}

.login-bar {
  margin-top: 20rpx;
}

.hero-panel {
  display: flex;
  align-items: center;
  margin: 24rpx 28rpx 0;
  padding: 30rpx;
  background: var(--c-surface);
  border: 1.5rpx solid var(--c-border-light);
  border-radius: var(--r-xl);
  box-shadow: var(--shadow-sm);
}

.profile-avatar {
  width: 116rpx;
  height: 116rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  color: var(--c-primary);
  font-size: 34rpx;
  font-weight: 800;
  background: var(--c-primary-light);
  border: 2rpx solid var(--c-primary);
}

.profile-avatar image {
  width: 100%;
  height: 100%;
}

.hero-copy {
  flex: 1;
  min-width: 0;
  padding: 0 20rpx;
}

.hero-chip {
  margin-bottom: 14rpx;
}

.hero-title {
  display: block;
  color: var(--c-text);
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.18;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-desc {
  display: block;
  margin-top: 10rpx;
  color: var(--c-text2);
  font-size: var(--fs-mini);
  line-height: 1.4;
}

.logout-btn {
  flex-shrink: 0;
  padding: 10rpx 22rpx;
  border-radius: var(--r-full);
  background: var(--c-danger-bg);
  color: var(--c-danger);
  font-size: var(--fs-mini);
  font-weight: 700;
}

.my-tabs {
  display: flex;
  gap: 12rpx;
  margin: 20rpx 28rpx 0;
  padding: 8rpx;
  background: var(--c-surface);
  border: 1.5rpx solid var(--c-border-light);
  border-radius: var(--r-xl);
  box-shadow: var(--shadow-sm);
}

.my-tab {
  flex: 1;
  height: 64rpx;
  border-radius: var(--r-full);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--c-text2);
  font-size: var(--fs-small);
  font-weight: 600;
}

.my-tab.active {
  color: var(--c-primary);
  background: var(--c-primary-light);
  border: 1.5rpx solid var(--c-primary);
}

.section-card {
  margin: 20rpx 28rpx 0;
  padding: 28rpx;
  border-radius: var(--r-xl);
  border: 1.5rpx solid var(--c-border-light);
  background: var(--c-surface);
  box-shadow: var(--shadow-sm);
}

.section-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 22rpx;
}

.section-header.compact {
  margin-bottom: 18rpx;
}

.section-title {
  display: block;
  margin: 0;
  color: var(--c-text);
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.25;
}

.section-sub {
  display: block;
  margin-top: 8rpx;
  color: var(--c-text2);
  font-size: var(--fs-mini);
  line-height: 1.35;
}

.count-chip {
  margin: 0;
  flex-shrink: 0;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.stat-card {
  width: 100%;
  min-height: 148rpx;
  padding: 24rpx 16rpx;
  border-radius: var(--r-lg);
  background: var(--c-bg);
  border: 1.5rpx solid var(--c-border-light);
  box-sizing: border-box;
  text-align: center;
}

.stat-card.warning {
  background: var(--c-primary-light);
  border-color: rgba(232,164,0,.32);
}

.stat-card-num {
  display: block;
  color: var(--c-text);
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1;
}

.stat-card-label {
  display: block;
  margin-top: 12rpx;
  color: var(--c-text2);
  font-size: var(--fs-mini);
}

.menu-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.menu-grid-3 .menu-item {
  width: calc((100% - 28rpx) / 3);
}

.menu-item {
  width: calc(25% - 11rpx);
  min-height: 128rpx;
  padding: 16rpx 6rpx;
  border-radius: var(--r-lg);
  background: var(--c-bg);
  border: 1.5rpx solid var(--c-border-light);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.menu-icon {
  display: block;
  margin-bottom: 10rpx;
  font-size: 36rpx;
  line-height: 1;
}

.menu-name {
  display: block;
  max-width: 100%;
  color: var(--c-text2);
  font-size: 20rpx;
  line-height: 1.2;
  text-align: center;
}

/* 客服按钮 - 使用透明 button 覆盖在 menu-item 上，保持布局与回收站一致 */
.menu-contact-wrap {
  position: relative;
}
.menu-contact-btn {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  margin: 0;
  padding: 0;
  border: none;
  border-radius: var(--r-lg);
  background: transparent;
  opacity: 0;
}
.menu-contact-btn::after {
  border: none;
}

.recent-scroll {
  white-space: nowrap;
}

.recent-card {
  display: inline-block;
  width: 150rpx;
  margin-right: 16rpx;
  vertical-align: top;
}

.recent-card image {
  width: 150rpx;
  height: 150rpx;
  display: block;
  border-radius: var(--r-lg);
  background: var(--c-bg);
}

.recent-card text {
  display: block;
  margin-top: 10rpx;
  color: var(--c-text2);
  font-size: var(--fs-mini);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

.shop-banner {
  width: 100%;
  height: 300rpx;
  border-radius: var(--r-lg);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--c-primary-light);
  border: 1.5rpx dashed rgba(232,164,0,.42);
  box-sizing: border-box;
}

.shop-banner image {
  width: 100%;
  height: 100%;
}

.shop-banner-hint {
  color: var(--c-primary);
  font-size: var(--fs-small);
  font-weight: 600;
}

.shop-name-row {
  margin: 22rpx 0 18rpx;
}

.shop-name {
  display: block;
  margin-bottom: 12rpx;
  color: var(--c-text);
  font-size: 34rpx;
  font-weight: 800;
}

.shop-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
}

.shop-item {
  padding: 20rpx;
  border-radius: var(--r-lg);
  background: var(--c-bg);
  border: 1.5rpx solid var(--c-border-light);
  box-sizing: border-box;
}

.shop-item-full {
  grid-column: 1 / -1;
}

.shop-item-label {
  display: block;
  color: var(--c-text3);
  font-size: var(--fs-mini);
}

.shop-item-val {
  display: block;
  margin-top: 8rpx;
  color: var(--c-text);
  font-size: var(--fs-small);
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.shop-item-val.success {
  color: var(--c-success);
}

.shop-item-val.danger {
  color: var(--c-danger);
}

/* ═─ 分享·养殖环境 ─═ */
.share-env-section {
  margin-top: 28rpx;
}

.share-sub-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.share-sub-title {
  color: var(--c-text);
  font-size: var(--fs-small);
  font-weight: 800;
}

.share-sub-hint {
  color: var(--c-primary);
  font-size: var(--fs-mini);
  font-weight: 600;
}

.env-photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.env-photo-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--r-md);
  overflow: hidden;
}

.env-photo-img {
  width: 100%;
  height: 100%;
}

.env-photo-del {
  position: absolute;
  top: 0;
  right: 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: 0 0 0 16rpx;
  background: rgba(0,0,0,.5);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.env-photo-add {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--r-md);
  border: 2rpx dashed var(--c-border);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--c-text3);
  font-size: 56rpx;
  background: var(--c-bg);
}

/* ═─ 分享·小程序码 ─═ */
.share-qrcode-section {
  margin-top: 28rpx;
}

.qrcode-box {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 300rpx;
  height: 300rpx;
  margin: 0 auto;
  border-radius: var(--r-lg);
  border: 1.5rpx solid var(--c-border-light);
  background: var(--c-bg);
}

.qrcode-img {
  width: 260rpx;
  height: 260rpx;
}

.qrcode-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.qrcode-placeholder-icon {
  font-size: 60rpx;
}

.qrcode-placeholder-text {
  color: var(--c-text3);
  font-size: var(--fs-mini);
  font-weight: 600;
}

.config-item {
  display: flex;
  align-items: center;
  min-height: 86rpx;
  padding: 0 6rpx;
  border-bottom: 1rpx solid var(--c-border-light);
}

.config-item:last-child {
  border-bottom: none;
}

.config-icon {
  width: 58rpx;
  height: 58rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--c-primary-light);
  color: var(--c-primary);
  font-size: 28rpx;
}

.config-name {
  flex: 1;
  color: var(--c-text);
  font-size: var(--fs-body);
  font-weight: 600;
}

.config-arrow {
  color: var(--c-text3);
  font-size: 38rpx;
}

/* ═─ 分享·编辑名片按钮 ─═ */
.share-edit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 28rpx;
  height: 82rpx;
  border-radius: var(--r-full);
  background: var(--c-primary);
  color: #fff;
  box-shadow: var(--shadow-btn);
}

.share-edit-icon {
  font-size: 30rpx;
  line-height: 1;
}

.share-edit-text {
  font-size: var(--fs-small);
  font-weight: 800;
}

/* ═─ 配置·打印开关行 ─═ */
.config-switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--c-border-light);
}

.config-switch-row:last-of-type {
  border-bottom: none;
}

.config-switch-info {
  flex: 1;
  min-width: 0;
}

.config-switch-label {
  display: block;
  color: var(--c-text);
  font-size: var(--fs-body);
  font-weight: 700;
}

.config-switch-hint {
  display: block;
  margin-top: 6rpx;
  color: var(--c-text3);
  font-size: var(--fs-mini);
  line-height: 1.35;
}

/* ═─ 配置·打印机状态 ─═ */
.printer-status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 20rpx;
  padding: 20rpx 22rpx;
  border-radius: var(--r-lg);
  background: var(--c-success-bg);
  border: 1.5rpx solid rgba(76,175,80,.2);
}

.printer-status-info {
  flex: 1;
  min-width: 0;
}

.printer-status-name {
  display: block;
  color: var(--c-text);
  font-size: var(--fs-small);
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.printer-status-badge {
  display: inline-block;
  margin-top: 6rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--r-full);
  font-size: var(--fs-mini);
  font-weight: 700;
}

.printer-status-badge.connected {
  color: var(--c-success);
  background: #fff;
}

.printer-disconnect-btn {
  flex-shrink: 0;
  padding: 10rpx 24rpx;
  border-radius: var(--r-full);
  background: var(--c-danger-bg);
  color: var(--c-danger);
  font-size: var(--fs-mini);
  font-weight: 700;
}

/* ═─ 配置·扫描按钮 ─═ */
.printer-scan-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 20rpx;
  height: 82rpx;
  border-radius: var(--r-full);
  background: var(--c-primary-light);
  color: var(--c-primary);
  font-size: var(--fs-small);
  font-weight: 800;
}

.printer-scan-icon {
  width: 32rpx;
  height: 32rpx;
  filter: brightness(0) saturate(100%) invert(48%) sepia(82%) saturate(2000%) hue-rotate(10deg);
}

/* ═─ 配置·二维码打印类型卡片 ─═ */
.qr-print-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.qr-print-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx 16rpx;
  border-radius: var(--r-lg);
  border: 1.5rpx solid var(--c-border-light);
  background: var(--c-bg);
  box-sizing: border-box;
  position: relative;
}

.qr-print-card.active {
  border-color: var(--c-primary);
  background: var(--c-primary-light);
}

.qr-print-icon {
  font-size: 40rpx;
  line-height: 1;
}

.qr-print-name {
  color: var(--c-text);
  font-size: var(--fs-small);
  font-weight: 800;
}

.qr-print-status {
  font-size: var(--fs-mini);
  font-weight: 600;
}

.qr-print-status.on {
  color: var(--c-success);
}

.qr-print-status.off {
  color: var(--c-text3);
}

/* ═─ 编辑名片弹窗 ─═ */
.share-edit-scroll {
  max-height: 56vh;
}

.edit-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 4rpx;
  border-bottom: 1rpx solid var(--c-border-light);
}

.edit-item-switch {
  justify-content: space-between;
}

.edit-label {
  flex-shrink: 0;
  width: 180rpx;
  color: var(--c-text);
  font-size: var(--fs-body);
  font-weight: 700;
}

.edit-value {
  flex: 1;
  min-width: 0;
  color: var(--c-text3);
  font-size: var(--fs-small);
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.edit-arrow {
  flex-shrink: 0;
  color: var(--c-text3);
  font-size: 38rpx;
  line-height: 1;
}

/* ═─ 蓝牙设备选择弹窗 ─═ */
.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 10000;
  display: flex;
  align-items: flex-end;
  background: rgba(0,0,0,.32);
}

.modal-sheet {
  width: 100%;
  padding: 30rpx 28rpx calc(32rpx + env(safe-area-inset-bottom));
  border-radius: 34rpx 34rpx 0 0;
  background: var(--c-surface);
  box-sizing: border-box;
}

.modal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.modal-title {
  color: var(--c-text);
  font-size: 34rpx;
  font-weight: 800;
}

.modal-close {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--c-text2);
  background: var(--c-bg);
  font-size: 42rpx;
  line-height: 1;
}

.modal-body {
  max-height: 60vh;
  min-height: 200rpx;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.modal-btn {
  height: 82rpx;
  border-radius: var(--r-full);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-small);
  font-weight: 800;
}

.modal-cancel {
  flex: 1;
  color: var(--c-text2);
  background: var(--c-bg);
}

.modal-confirm {
  flex: 1;
  color: #fff;
  background: var(--c-primary);
  box-shadow: var(--shadow-btn);
}

.bt-scanning-hint {
  text-align: center;
  padding: 30rpx 0;
  color: var(--c-text3);
  font-size: var(--fs-small);
}

.bt-device-list {
  max-height: 50vh;
}

.bt-device-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 16rpx;
  border-bottom: 1rpx solid var(--c-border-light);
}

.bt-device-item:last-child {
  border-bottom: none;
}

.bt-device-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--c-primary-light);
  font-size: 32rpx;
  flex-shrink: 0;
}

.bt-device-info {
  flex: 1;
  min-width: 0;
}

.bt-device-name {
  display: block;
  color: var(--c-text);
  font-size: var(--fs-small);
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bt-device-id {
  display: block;
  margin-top: 4rpx;
  color: var(--c-text3);
  font-size: var(--fs-mini);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bt-device-arrow {
  color: var(--c-text3);
  font-size: 38rpx;
  flex-shrink: 0;
}

.bt-empty {
  text-align: center;
  padding: 60rpx 0;
  color: var(--c-text3);
  font-size: var(--fs-small);
}
