<view class="page-my">
  <view class="nav-bar" style="padding-top:{{statusBarHeight}}px">
    <text class="nav-title">我的</text>
  </view>

  <scroll-view style="padding-top:{{totalNavHeight}}rpx" scroll-y class="scroll-main">
    <view class="my-inner">
      <view wx:if="{{!isLoggedIn}}" class="login-bar" bindtap="goToLogin">
        <text class="login-bar-text">登录后可管理宠物资料、记录和打印标签</text>
        <view class="login-bar-btn"><text>立即登录 ›</text></view>
      </view>

      <view class="hero-panel">
        <view class="profile-avatar" bindtap="chooseAvatar" bindlongpress="onAvatarLongPress">
          <image wx:if="{{userInfo.avatar}}" src="{{userInfo.avatar}}" mode="aspectFill"/>
          <text wx:else>龟</text>
        </view>
        <view class="hero-copy">
          <text class="chip active hero-chip">个人中心</text>
          <text class="hero-title">{{userInfo.nickname||'养龟档案'}}</text>
          <text class="hero-desc">本月昵称还可修改 {{nicknameRemaining}} 次</text>
        </view>
        <view wx:if="{{isLoggedIn}}" class="logout-btn press" bindtap="handleLogout">
          <text>退出</text>
        </view>
      </view>

      <view class="my-tabs">
        <view class="my-tab {{activeTab==='data'?'active':''}}" bindtap="switchTab" data-tab="data">数据</view>
        <view class="my-tab {{activeTab==='share'?'active':''}}" bindtap="switchTab" data-tab="share">分享</view>
        <view class="my-tab {{activeTab==='config'?'active':''}}" bindtap="switchTab" data-tab="config">配置</view>
      </view>

      <view wx:if="{{activeTab==='data'}}">
        <view class="section-card">
          <view class="section-header">
            <view>
              <text class="section-title">统计数据</text>
              <text class="section-sub">档案、繁育与提醒概览</text>
            </view>
          </view>
          <view class="stats-grid">
            <view class="stat-card">
              <text class="stat-card-num">{{stats.petCount}}</text>
              <text class="stat-card-label">龟档案</text>
            </view>
            <view class="stat-card">
              <text class="stat-card-num">{{stats.eggEvents}}</text>
              <text class="stat-card-label">产蛋记录</text>
            </view>
            <view class="stat-card">
              <text class="stat-card-num">{{stats.pairEvents}}</text>
              <text class="stat-card-label">配对记录</text>
            </view>
            <view class="stat-card warning">
              <text class="stat-card-num">{{stats.warningCount}}</text>
              <text class="stat-card-label">预警档案</text>
            </view>
          </view>
        </view>

        <view class="section-card">
          <view class="section-header compact">
            <view>
              <text class="section-title">常用功能</text>
              <text class="section-sub">个人资料与服务入口</text>
            </view>
          </view>
          <view class="menu-grid">
            <view class="menu-item press" bindtap="goToRecycleBin">
              <text class="menu-icon">🗑</text>
              <text class="menu-name">回收站</text>
            </view>
            <view class="menu-item press" bindtap="goToRecentView">
              <text class="menu-icon">👁</text>
              <text class="menu-name">最近浏览</text>
            </view>
            <view class="menu-item press menu-contact-wrap">
              <text class="menu-icon">🎧</text>
              <text class="menu-name">客服帮助</text>
              <button open-type="contact" class="menu-contact-btn"></button>
            </view>
          </view>
        </view>

      </view>

      <view wx:if="{{activeTab==='share'}}" class="section-card share-card">
        <view class="section-header">
          <view>
            <text class="section-title">分享名片</text>
            <text class="section-sub">用于公开档案展示的信息</text>
          </view>
        </view>
        <view class="shop-banner press" bindtap="chooseCover">
          <image wx:if="{{shareInfo.cover}}" src="{{shareInfo.cover}}" mode="aspectFill"/>
          <text wx:else class="shop-banner-hint">点击添加封面照片</text>
        </view>
        <view class="shop-name-row">
          <text class="shop-name">{{userInfo.nickname||'养龟档案'}}</text>
          <text class="tag tag-primary">主玩 · {{shareInfo.specialty||'记录、档案、繁育'}}</text>
        </view>
        <view class="shop-grid">
          <view class="shop-item">
            <text class="shop-item-label">营业执照</text>
            <text class="shop-item-val {{shareInfo.hasLicense?'success':'danger'}}">{{shareInfo.hasLicense?'已持有':'未持有'}}</text>
          </view>
          <view class="shop-item">
            <text class="shop-item-label">所在地区</text>
            <text class="shop-item-val">{{shareInfo.region||'未设置'}}</text>
          </view>
          <view class="shop-item shop-item-full">
            <text class="shop-item-label">微信联系</text>
            <text class="shop-item-val">{{shareInfo.wechatId||'未填写'}}</text>
          </view>
        </view>

        <!-- 养殖环境 -->
        <view class="share-env-section">
          <view class="share-sub-header">
            <text class="share-sub-title">养殖环境</text>
            <text class="share-sub-hint">最多3张</text>
          </view>
          <view class="env-photo-grid">
            <view wx:for="{{shareInfo.envImages}}" wx:key="*this" class="env-photo-item press" bindtap="previewEnvImage" data-index="{{index}}">
              <image src="{{item}}" mode="aspectFill" class="env-photo-img"/>
              <view class="env-photo-del" catchtap="removeEnvImage" data-index="{{index}}">×</view>
            </view>
            <view wx:if="{{(!shareInfo.envImages||shareInfo.envImages.length<3)}}" class="env-photo-add press" bindtap="chooseEnvImages">
              <text>+</text>
            </view>
          </view>
        </view>

        <!-- 扫一扫进入小程序 -->
        <view class="share-qrcode-section">
          <view class="share-sub-header">
            <text class="share-sub-title">扫一扫进入小程序</text>
            <text class="share-sub-hint" bindtap="saveQrcodeToAlbum">保存到相册</text>
          </view>
          <view class="qrcode-box press" bindtap="previewQrcode">
            <image wx:if="{{qrcodeImage}}" src="{{qrcodeImage}}" mode="aspectFit" class="qrcode-img"/>
            <view wx:else class="qrcode-placeholder">
              <text class="qrcode-placeholder-icon">QR</text>
              <text class="qrcode-placeholder-text">小程序码生成中…</text>
            </view>
          </view>
        </view>

        <!-- 编辑名片按钮 -->
        <view class="share-edit-btn press" bindtap="showEditShareModal">
          <text class="share-edit-icon">✎</text>
          <text class="share-edit-text">编辑名片</text>
        </view>
      </view>

      <view wx:if="{{activeTab==='config'}}">
        <!-- 打印机配置 -->
        <view class="section-card">
          <view class="section-header">
            <view>
              <text class="section-title">标签打印</text>
              <text class="section-sub">连接蓝牙打印机，管理标签打印</text>
            </view>
            <text class="chip {{printerConfig.connected?'active':''}}">{{printerConfig.connected?'已连接':'未连接'}}</text>
          </view>

          <!-- 启用打印 -->
          <view class="config-switch-row">
            <view class="config-switch-info">
              <text class="config-switch-label">启用打印</text>
              <text class="config-switch-hint">开启后可连接打印机打印标签</text>
            </view>
            <switch checked="{{printerConfig.enabled}}" bindchange="onPrinterSwitchChange" color="{{switchColor}}"/>
          </view>

          <!-- 自动连接 -->
          <view class="config-switch-row">
            <view class="config-switch-info">
              <text class="config-switch-label">自动连接</text>
              <text class="config-switch-hint">进入页面时自动连接已配对的打印机</text>
            </view>
            <switch checked="{{printerConfig.autoConnect}}" bindchange="onAutoConnectSwitchChange" color="{{switchColor}}"/>
          </view>

          <!-- 打印机状态 -->
          <view wx:if="{{printerConfig.connected}}" class="printer-status-row">
            <view class="printer-status-info">
              <text class="printer-status-name">{{printerConfig.deviceName||'打印机'}}</text>
              <text class="printer-status-badge connected">已连接</text>
            </view>
            <view class="printer-disconnect-btn press" bindtap="disconnectPrinter">
              <text>断开</text>
            </view>
          </view>

          <!-- 扫描连接按钮 -->
          <view wx:if="{{!printerConfig.connected}}" class="printer-scan-btn press" bindtap="scanBluetooth">
            <image class="printer-scan-icon" src="/icons/搜索.png" mode="aspectFit"/>
            <text>搜索蓝牙打印机</text>
          </view>
        </view>

        <!-- 二维码打印类型 -->
        <view class="section-card">
          <view class="section-header compact">
            <view>
              <text class="section-title">二维码打印类型</text>
              <text class="section-sub">选择需要自动打印二维码的记录类型</text>
            </view>
          </view>
          <view class="qr-print-grid">
            <view class="qr-print-card {{printerConfig.qrPrintTypes.jiaopei?'active':''}} press" bindtap="toggleQrPrintType" data-type="jiaopei">
              <text class="qr-print-icon">💕</text>
              <text class="qr-print-name">交配</text>
              <text class="qr-print-status {{printerConfig.qrPrintTypes.jiaopei?'on':'off'}}">{{printerConfig.qrPrintTypes.jiaopei?'已开启':'已关闭'}}</text>
            </view>
            <view class="qr-print-card {{printerConfig.qrPrintTypes.chandan?'active':''}} press" bindtap="toggleQrPrintType" data-type="chandan">
              <text class="qr-print-icon">🥚</text>
              <text class="qr-print-name">产蛋</text>
              <text class="qr-print-status {{printerConfig.qrPrintTypes.chandan?'on':'off'}}">{{printerConfig.qrPrintTypes.chandan?'已开启':'已关闭'}}</text>
            </view>
            <view class="qr-print-card {{printerConfig.qrPrintTypes.chumiao?'active':''}} press" bindtap="toggleQrPrintType" data-type="chumiao">
              <text class="qr-print-icon">🐣</text>
              <text class="qr-print-name">出苗</text>
              <text class="qr-print-status {{printerConfig.qrPrintTypes.chumiao?'on':'off'}}">{{printerConfig.qrPrintTypes.chumiao?'已开启':'已关闭'}}</text>
            </view>
            <view class="qr-print-card {{printerConfig.qrPrintTypes.jiankang?'active':''}} press" bindtap="toggleQrPrintType" data-type="jiankang">
              <text class="qr-print-icon">🏥</text>
              <text class="qr-print-name">健康</text>
              <text class="qr-print-status {{printerConfig.qrPrintTypes.jiankang?'on':'off'}}">{{printerConfig.qrPrintTypes.jiankang?'已开启':'已关闭'}}</text>
            </view>
          </view>
        </view>

        <!-- 通用配置 -->
        <view class="section-card">
          <view class="section-header compact">
            <view>
              <text class="section-title">通用</text>
              <text class="section-sub">账户与本地数据管理</text>
            </view>
          </view>
          <view class="config-item press" bindtap="clearCache">
            <text class="config-icon">🗑</text>
            <text class="config-name">清除缓存</text>
            <text class="config-arrow">›</text>
          </view>
        </view>
      </view>

      <view class="safe-bottom"></view>
    </view>
  </scroll-view>

  <!-- 编辑名片弹窗 -->
  <view wx:if="{{showEditShareModal}}" class="modal-mask" bindtap="hideEditShareModal">
    <view class="modal-sheet" catchtap="stopPropagation">
      <view class="modal-head">
        <text class="modal-title">编辑分享名片</text>
        <text class="modal-close" bindtap="hideEditShareModal">×</text>
      </view>
      <scroll-view scroll-y class="share-edit-scroll" enhanced show-scrollbar="{{false}}">
        <view class="edit-item press" bindtap="chooseCover">
          <text class="edit-label">更换封面图</text>
          <text class="edit-value">{{shareInfo.cover ? '已设置，点击更换' : '未设置'}}</text>
          <text class="edit-arrow">›</text>
        </view>
        <view class="edit-item press" bindtap="editField" data-field="specialty" data-title="主玩品种" data-placeholder="如：巨头、东方、头盔、佛泥、窄桥">
          <text class="edit-label">主玩品种</text>
          <text class="edit-value">{{shareInfo.specialty || '未设置'}}</text>
          <text class="edit-arrow">›</text>
        </view>
        <view class="edit-item press" bindtap="editField" data-field="wechatId" data-title="微信号" data-placeholder="请输入微信号">
          <text class="edit-label">微信号</text>
          <text class="edit-value">{{shareInfo.wechatId || '未设置'}}</text>
          <text class="edit-arrow">›</text>
        </view>
        <view class="edit-item edit-item-switch">
          <text class="edit-label">公开微信号</text>
          <switch checked="{{shareInfo.wechatPublic}}" bindchange="toggleWechatPublic" color="{{switchColor}}"/>
        </view>
        <picker mode="region" bindchange="chooseRegion" custom-item="{{provinceCityAreaCustomItem}}">
          <view class="edit-item press">
            <text class="edit-label">所在地区</text>
            <text class="edit-value">{{shareInfo.region || '点击选择省/市/区'}}</text>
            <text class="edit-arrow">›</text>
          </view>
        </picker>
        <view class="edit-item edit-item-switch">
          <text class="edit-label">营业执照</text>
          <switch checked="{{shareInfo.hasLicense}}" bindchange="toggleLicense" color="{{switchColor}}"/>
        </view>
        <view wx:if="{{shareInfo.hasLicense}}" class="edit-item press" bindtap="chooseLicenseImage">
          <text class="edit-label">执照图片</text>
          <text class="edit-value">{{shareInfo.licenseImage ? '已上传，点击更换' : '点击上传营业执照照片'}}</text>
          <text class="edit-arrow">›</text>
        </view>
        <view class="edit-item press" bindtap="editField" data-field="intro" data-title="龟友有话说" data-placeholder="介绍一下自己和你的宠物...">
          <text class="edit-label">简介</text>
          <text class="edit-value">{{shareInfo.intro || '未设置'}}</text>
          <text class="edit-arrow">›</text>
        </view>
        <view class="edit-item press" bindtap="editField" data-field="tags" data-title="标签" data-placeholder="用逗号分隔，如：接受平台交易,有待售龟苗">
          <text class="edit-label">标签</text>
          <text class="edit-value">{{shareInfo.tags.length > 0 ? shareInfo.tags.join('、') : '未设置'}}</text>
          <text class="edit-arrow">›</text>
        </view>
        <view class="edit-item press" bindtap="addSpeciesImage">
          <text class="edit-label">添加种群图片</text>
          <text class="edit-value">{{shareInfo.species.length}} 张，点击继续添加</text>
          <text class="edit-arrow">›</text>
        </view>
        <view wx:if="{{shareInfo.species.length > 0}}" class="edit-item press" bindtap="clearSpeciesImages">
          <text class="edit-label">清空种群图片</text>
          <text class="edit-value">清空 {{shareInfo.species.length}} 条记录</text>
          <text class="edit-arrow">›</text>
        </view>
        <view class="edit-item press" bindtap="chooseEnvImages">
          <text class="edit-label">环境照片</text>
          <text class="edit-value">{{shareInfo.envImages.length > 0 ? shareInfo.envImages.length + ' 张，可继续上传' : '未设置（最多3张）'}}</text>
          <text class="edit-arrow">›</text>
        </view>
        <view class="edit-item press" bindtap="editField" data-field="envDesc" data-title="环境描述" data-placeholder="如：室外生态池 / 室内恒温箱">
          <text class="edit-label">环境描述</text>
          <text class="edit-value">{{shareInfo.envDesc || '未设置'}}</text>
          <text class="edit-arrow">›</text>
        </view>
      </scroll-view>
      <view class="modal-actions">
        <view class="modal-btn modal-confirm press" bindtap="hideEditShareModal">完成</view>
      </view>
    </view>
  </view>

  <!-- 蓝牙设备选择弹窗 -->
  <view wx:if="{{showBluetoothModal}}" class="modal-mask" bindtap="hideBluetoothModal">
    <view class="modal-sheet" catchtap="stopPropagation">
      <view class="modal-head">
        <text class="modal-title">选择蓝牙打印机</text>
        <text class="modal-close" bindtap="hideBluetoothModal">×</text>
      </view>
      <view class="modal-body">
        <view wx:if="{{isScanning}}" class="bt-scanning-hint">
          <text>正在搜索蓝牙设备…</text>
        </view>
        <scroll-view scroll-y class="bt-device-list">
          <view wx:for="{{bluetoothDevices}}" wx:key="deviceId" class="bt-device-item press" bindtap="connectBluetooth" data-device-id="{{item.deviceId}}" data-device-name="{{item.name||item.localName}}">
            <view class="bt-device-icon">🖨</view>
            <view class="bt-device-info">
              <text class="bt-device-name">{{item.name||item.localName||'未知设备'}}</text>
              <text class="bt-device-id">{{item.deviceId}}</text>
            </view>
            <text class="bt-device-arrow">›</text>
          </view>
          <view wx:if="{{!isScanning && bluetoothDevices.length===0}}" class="bt-empty">
            <text>未找到蓝牙设备，请确保打印机已开启</text>
          </view>
        </scroll-view>
      </view>
      <view class="modal-actions">
        <view class="modal-btn modal-cancel press" bindtap="hideBluetoothModal">关闭</view>
      </view>
    </view>
  </view>
</view>
