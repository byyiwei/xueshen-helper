<view class="public-page">
  <view class="page-wrapper">
    <!-- 标题栏 -->
    <view class="section-header" style="margin-bottom: 32rpx;">
      <text class="section-title">公开宠物列表</text>
      <text class="section-subtitle">查看 {{userInfo.nickname || '用户'}} 的所有公开宠物</text>
    </view>

    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-state">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 空状态 -->
    <view wx:elif="{{pets.length === 0}}" class="empty-state">
      <text class="empty-text">暂无公开宠物</text>
    </view>

    <!-- 宠物列表 -->
    <view wx:else class="pets-grid">
      <view 
        wx:for="{{pets}}" 
        wx:key="id" 
        class="pet-card" 
        bindtap="viewDetail" 
        data-id="{{item.id}}"
      >
        <view class="pet-image-wrapper">
          <image wx:if="{{item.photos && item.photos.length > 0}}" class="pet-image" src="{{item.photos[0]}}" mode="aspectFill" binderror="onPhotoError" data-index="{{index}}" />
          <view wx:else class="pet-placeholder"></view>
          <view class="pet-gender-badge gender-{{item.gender === '公' ? 'male' : item.gender === '母' ? 'female' : 'unknown'}}">
            <text class="gender-icon">{{item.gender || '未知'}}</text>
          </view>
        </view>

        <!-- 宠物信息 -->
        <view class="pet-card-info">
          <text class="pet-card-name">{{item.alias || item.name}}</text>
          <text class="pet-card-meta">{{item.category || '未分类'}}</text>
        </view>
      </view>
    </view>
  </view>
</view>