.public-page {
  min-height: 100vh;
  background-color: #FFFFFF;
  padding-bottom: 60rpx;
}

.page-wrapper {
  max-width: 750rpx;
  margin: 0 auto;
}

.hero-section {
  position: relative;
  min-height: 420rpx;
  border-radius: 32rpx;
  overflow: hidden;
  margin: 20rpx;
}

.hero-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.hero-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #3A7CFF 0%, #6366F1 100%);
}

.hero-icon {
  font-size: 120rpx;
}

.hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(transparent 30%, rgba(0, 0, 0, 0.55) 100%);
  pointer-events: none;
}

.hero-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
}

.hero-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.hero-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 16rpx;
}

.hero-specialty {
  margin-bottom: 12rpx;
}

.hero-specialty-text {
  display: inline-block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.95);
  background: rgba(255, 140, 66, 0.6);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  backdrop-filter: blur(6rpx);
  -webkit-backdrop-filter: blur(6rpx);
}

.hero-info-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 14rpx;
}

.hero-info-item {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.hero-region {
  opacity: 0.9;
}

.hero-wechat {
  opacity: 0.9;
}

.hero-info-dot {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin: 0 10rpx;
}

.hero-info-hint {
  color: rgba(255, 255, 255, 0.5);
  font-size: 22rpx;
}

.hero-bottom {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.hero-tag {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.15);
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  backdrop-filter: blur(4rpx);
  -webkit-backdrop-filter: blur(4rpx);
}

.hero-placeholder-bg {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  background: linear-gradient(135deg, #3A7CFF 0%, #6366F1 100%);
}

.hero-badge {
  display: inline-flex;
  align-items: baseline;
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.badge-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  margin-right: 8rpx;
}

.badge-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.filter-section {
  padding: 0 20rpx;
  margin-bottom: 16rpx;
}

.filter-label {
  display: block;
  font-size: 26rpx;
  color: #64748B;
  margin-bottom: 16rpx;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-tags {
  display: inline-flex;
  gap: 16rpx;
  padding-right: 20rpx;
}

.filter-tag {
  display: inline-block;
  padding: 12rpx 28rpx;
  background: #F1F5F9;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #64748B;
}

.filter-tag.active {
  background: linear-gradient(135deg, #3A7CFF 0%, #2563EB 100%);
  color: #ffffff;
}

.filter-tag.highlight {
  background: rgba(34, 197, 94, 0.15);
  color: #22C55E;
}

.stats-section {
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  font-size: 26rpx;
  color: #64748B;
}

.stat-divider {
  margin: 0 20rpx;
  color: #CBD5E1;
}

.action-section {
  padding: 0 20rpx;
  margin-bottom: 24rpx;
  display: flex;
}

.back-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  padding: 0 32rpx;
  background: linear-gradient(135deg, #3A7CFF 0%, #2563EB 100%);
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(58, 124, 255, 0.3);
}

.back-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #E6F0FF;
  border-top-color: #3A7CFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #94A3B8;
  margin-top: 16rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #94A3B8;
}

.pets-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 0 20rpx;
}

.pet-card {
  width: calc(50% - 10rpx);
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  position: relative;
  box-shadow: 0 2rpx 16rpx rgba(58, 124, 255, 0.07), 0 0 0 1rpx rgba(58, 124, 255, 0.03);
}

.pet-image-wrapper {
  position: relative;
  width: 100%;
  padding-bottom: 100%;
  overflow: hidden;
  background: transparent;
  box-shadow: inset 0 -60rpx 60rpx -30rpx rgba(0, 0, 0, 0.35);
}

.pet-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.pet-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F8FAFC;
}

.placeholder-text {
  font-size: 60rpx;
  font-weight: bold;
  color: #94A3B8;
}

.warning-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 8rpx 16rpx;
  background: rgba(249, 115, 22, 0.9);
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(249, 115, 22, 0.3);
  z-index: 5;
}

.warning-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 性别角标（与宠物列表一致） */
.pet-gender-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background-color: rgba(58, 124, 255, 0.55);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.gender-icon {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 500;
}

.gender-male {
  background-color: rgba(58, 124, 255, 0.55);
}

.gender-female {
  background-color: rgba(236, 72, 153, 0.55);
}

.gender-unknown {
  background-color: rgba(148, 163, 184, 0.55);
}

/* 底部渐变遮挡 + 信息（与宠物列表一致） */
.pet-card-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx;
  background: rgba(0, 0, 0, 0.25);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  gap: 12rpx;
  z-index: 5;
}

/* 别名（白色加粗） */
.pet-card-alias {
  font-size: 30rpx;
  color: #ffffff;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

/* 用户名（白色半透明药丸标签） */
.pet-card-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  padding: 4rpx 12rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 8rpx;
  flex-shrink: 0;
}

.pet-detail-section {
  padding: 16rpx 20rpx 20rpx;
}

.price-line {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #D97706;
  margin-bottom: 8rpx;
}

.detail-records {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 8rpx;
  gap: 4rpx 0;
}

.record-item {
  font-size: 22rpx;
  color: #64748B;
  margin-right: 16rpx;
}