.public-page {
  position: relative;
  min-height: 100vh;
  background-color: #F8FAFB;
  padding: 32rpx 24rpx;
}

.page-wrapper {
  max-width: 750rpx;
  margin: 0 auto;
}

/* ====== 章节标题 ====== */
.section-header {
  margin-bottom: 32rpx;
}

.section-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #2D6A4F;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.section-subtitle {
  display: block;
  font-size: 24rpx;
  color: #94A3B8;
}

/* ====== 加载状态 ====== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #E8F5EE;
  border-top-color: #2D6A4F;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #94A3B8;
  margin-top: 16rpx;
}

/* ====== 空状态 ====== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #94A3B8;
}

/* ====== 宠物网格 ====== */
.pets-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-between;
}

.pet-card {
  width: calc(50% - 10rpx);
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  border: none;
  margin-bottom: 20rpx;
  transition: all 0.22s cubic-bezier(0.25, 0.8, 0.25, 1);
  position: relative;
  box-shadow: 0 2rpx 16rpx rgba(45, 106, 79, 0.07), 0 0 0 1rpx rgba(45, 106, 79, 0.03);
}

.pet-card:active {
  transform: scale(0.97) translateY(2rpx);
  box-shadow: 0 4rpx 24rpx rgba(45, 106, 79, 0.12), 0 0 0 1rpx rgba(45, 106, 79, 0.04);
}

/* 图片容器 */
.pet-image-wrapper {
  position: relative;
  width: 100%;
  padding-bottom: 100%;
  overflow: hidden;
  background: linear-gradient(135deg, #E8F5EE 0%, #F8FAFB 100%);
}

.pet-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.pet-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #E8F5EE 0%, #F8FAFB 100%);
}

.pet-gender-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(8rpx);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(45, 106, 79, 0.1);
}

.gender-icon {
  font-size: 20rpx;
  font-weight: 600;
  color: #2D6A4F;
}

/* 宠物信息 */
.pet-card-info {
  padding: 16rpx 20rpx 20rpx;
}

.pet-card-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2D6A4F;
  letter-spacing: 0.5rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pet-card-meta {
  display: block;
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 6rpx;
  letter-spacing: 0.3rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
