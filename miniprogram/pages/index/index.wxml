<view class="page" style="padding-top: {{totalNavHeight}}rpx;">
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px">
    <text class="nav-title">龟上心</text>
  </view>

  <!-- 骨架屏 -->
  <view wx:if="{{showSkeleton}}" class="skeleton-container">
    <!-- 快速卡片区域 -->
    <view class="skeleton-quick-cards">
      <view class="skeleton-quick-card"></view>
      <view class="skeleton-quick-card"></view>
    </view>
    <!-- 待办提醒区域 -->
    <view class="skeleton-reminder"></view>
    <!-- 疾病防治横幅 -->
    <view class="skeleton-banner"></view>
    <!-- 常用功能区域 -->
    <view class="skeleton-func">
      <view class="skeleton-func-item"></view>
      <view class="skeleton-func-item"></view>
      <view class="skeleton-func-item"></view>
      <view class="skeleton-func-item"></view>
    </view>
  </view>

  <view wx:if="{{!showSkeleton}}" class="content">
    <!-- 未登录提示栏 -->
    <view wx:if="{{!isLoggedIn}}" class="login-hint-bar">
      <text class="login-hint-text">登录后可管理宠物资料、记录和打印标签</text>
      <view class="login-hint-btn" bindtap="goToLogin">登录</view>
    </view>

    <view class="quick-cards">
      <view class="quick-card quick-card-green" bindtap="goToPetList">
        <view class="quick-card-inner">
          <view class="quick-card-accent"></view>
          <view class="quick-card-body">
            <text class="quick-card-label">精品龟档案</text>
            <view class="quick-card-count">
              <text class="count-num">{{stats.petCount}}</text>
              <text class="count-unit">只</text>
            </view>
          </view>
          <view class="quick-card-footer">
            <text class="quick-card-link">查看全部</text>
            <text class="quick-card-arrow">›</text>
          </view>
        </view>
      </view>
      <view class="quick-card quick-card-blue" bindtap="goToTank">
        <view class="quick-card-inner">
          <view class="quick-card-accent"></view>
          <view class="quick-card-body">
            <text class="quick-card-label">我的龟缸</text>
            <view class="quick-card-count">
              <text class="count-num">0</text>
              <text class="count-unit">个</text>
            </view>
          </view>
          <view class="quick-card-footer">
            <text class="quick-card-link">敬请期待</text>
            <text class="quick-card-arrow">›</text>
          </view>
        </view>
      </view>
    </view>

    <view class="reminder-summary-wrap">
      <view class="reminder-summary-header">
        <text class="reminder-summary-title">待办提醒</text>
        <text class="reminder-summary-count">共 {{allReminders.length}} 项</text>
      </view>

      <block wx:if="{{hasAnyReminder}}">
        <view wx:for="{{allReminders}}" wx:key="id"
              class="reminder-summary-card reminder-{{item.statusClass}}"
              bindtap="gotoPetDetailFromReminder" data-pet-id="{{item.petId}}">
          <view class="reminder-summary-main">
            <view class="reminder-summary-top">
              <text class="reminder-summary-type">{{item.type}}</text>
              <text class="reminder-summary-status">{{item.statusText}}</text>
            </view>
            <view class="reminder-summary-bottom">
              <text class="reminder-summary-name">{{item.petName}}</text>
              <text wx:if="{{item.petCategory}}" class="reminder-summary-category"> · {{item.petCategory}}</text>
              <text class="reminder-summary-meta"> · 下次 {{item.nextDueDate}}</text>
            </view>
          </view>
          <view class="reminder-summary-done-btn" catchtap="markReminderDoneFromIndex"
                data-pet-id="{{item.petId}}" data-reminder-id="{{item.id}}">
            <text>✓ 完成</text>
          </view>
        </view>
      </block>

      <view wx:else class="reminder-summary-empty">
        <text class="reminder-empty-icon">⏰</text>
        <text class="reminder-empty-text">暂无待办提醒</text>
        <text class="reminder-empty-hint">进入宠物详情页添加换水、喂食等定期提醒</text>
      </view>
    </view>

    <view class="disease-banner" bindtap="goToDiseasePrevention">
      <view class="disease-icon-wrap">
        <text class="disease-icon-shield">🛡️</text>
      </view>
      <view class="disease-info">
        <text class="disease-title">疾病防治</text>
        <text class="disease-desc">常见治疗方案及用药计算器</text>
      </view>
      <view class="disease-btn">
        <text class="disease-btn-text">进入</text>
        <text class="disease-btn-arrow">›</text>
      </view>
    </view>

    <view class="func-section">
      <view class="section-header">
        <text class="section-title">常用功能</text>
      </view>
      <view class="func-grid">
        <view class="func-card" bindtap="goToCalculator">
          <view class="func-icon-wrap func-icon-calc">
            <text class="func-icon-text">🔢</text>
          </view>
          <text class="func-name">粘缸计算器</text>
        </view>
        <view class="func-card" bindtap="goToEggReport">
          <view class="func-icon-wrap func-icon-egg">
            <text class="func-icon-text">🥚</text>
          </view>
          <text class="func-name">产蛋报表</text>
        </view>
        <view class="func-card" bindtap="goToHatchReport">
          <view class="func-icon-wrap func-icon-hatch">
            <text class="func-icon-text">🐣</text>
          </view>
          <text class="func-name">出苗报表</text>
        </view>
        <view class="func-card" bindtap="goToPublic">
          <view class="func-icon-wrap func-icon-public">
            <text class="func-icon-text">🌐</text>
          </view>
          <text class="func-name">公开档案</text>
        </view>
      </view>
    </view>
  </view>
</view>