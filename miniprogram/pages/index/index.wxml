<view class="page-index">
  <view class="nav-bar" style="padding-top:{{statusBarHeight}}px">
    <text class="nav-title">养龟档案</text>
  </view>

  <scroll-view style="padding-top:{{totalNavHeight}}rpx" scroll-y class="scroll-main" refresher-enabled bindrefresherrefresh="onPullDown">
    <view class="index-inner">
      <view wx:if="{{!isLoggedIn}}" class="login-bar" bindtap="goToLogin">
        <text class="login-bar-text">登录后可管理宠物资料、记录和打印标签</text>
        <view class="login-bar-btn"><text>立即登录 ›</text></view>
      </view>

      <view class="hero-panel">
        <view class="hero-copy">
          <text class="chip active hero-chip">{{greetingText}}</text>
          <text class="hero-title">{{isLoggedIn ? (userInfo.nickname || '龟友') : '龟友'}}</text>
          <text class="hero-desc">把档案、龟缸、待办和繁育记录收在一个清爽的首页里。</text>
        </view>
        <view class="hero-avatar" bindtap="goToLogin">
          <image wx:if="{{isLoggedIn && userInfo.avatar}}" src="{{userInfo.avatar}}" mode="aspectFill" binderror="onAvatarError"/>
          <text wx:else>龟</text>
        </view>
      </view>

      <view class="feature-row">
        <view class="feature-card feature-primary press" bindtap="goToPetList">
          <view class="feature-head">
            <text class="feature-kicker">精品龟档案</text>
            <text class="feature-arrow">›</text>
          </view>
          <text class="feature-number">{{stats.petCount}}</text>
          <text class="feature-desc">只龟已入档</text>
          <view class="feature-preview">
            <block wx:if="{{featuredPets.length}}">
              <view wx:for="{{featuredPets}}" wx:key="id" class="mini-pet">
                <image wx:if="{{item.cover}}" src="{{item.cover}}" mode="aspectFill"/>
                <text wx:else>{{item.shortName}}</text>
              </view>
            </block>
            <block wx:else>
              <view class="mini-pet placeholder"><text>+</text></view>
              <text class="feature-hint">添加第一只龟</text>
            </block>
          </view>
        </view>

        <view class="feature-card tank-card press" bindtap="goToTank">
          <view class="feature-head">
            <text class="feature-kicker">我的龟缸</text>
            <text class="feature-arrow">›</text>
          </view>
          <view class="tank-visual">
            <view class="water-line"></view>
            <view class="tank-bubble b1"></view>
            <view class="tank-bubble b2"></view>
          </view>
          <text class="feature-desc">水体、设备与环境记录</text>
          <text class="tank-status">即将上线</text>
        </view>
      </view>

      <view class="section-card todo-card">
        <view class="section-header">
          <view>
            <text class="section-title">待办事项</text>
            <text class="section-sub">{{hasAnyReminder ? '优先处理临近提醒' : '今天没有紧急提醒'}}</text>
          </view>
          <text wx:if="{{hasAnyReminder}}" class="chip active count-chip">{{allReminders.length}}项</text>
          <text wx:else class="chip clear-chip">已完成</text>
        </view>

        <view wx:if="{{hasAnyReminder}}" class="reminder-list">
          <view wx:for="{{allReminders}}" wx:key="id" class="reminder-item press" bindtap="gotoPetDetailFromReminder" data-pet-id="{{item.petId}}">
            <view class="rem-dot {{item.statusClass}}"></view>
            <view class="rem-info">
              <text class="rem-type">{{item.type}}</text>
              <text class="rem-pet">{{item.petName}}<text wx:if="{{item.petCategory}}"> · {{item.petCategory}}</text></text>
            </view>
            <view class="rem-meta">
              <text class="rem-status {{item.statusClass}}">{{item.statusText}}</text>
              <text class="rem-date">{{item.nextDueDate}}</text>
            </view>
            <view class="rem-done" catchtap="gotoPetDetailFromReminder" data-pet-id="{{item.petId}}">
              <text>进入</text>
            </view>
          </view>
        </view>
        <view wx:else class="empty-todo">
          <text class="empty-todo-title">暂无待办事项</text>
          <text class="empty-todo-desc">进入龟档案详情页添加喂食、换水、晒背等周期提醒。</text>
        </view>
      </view>

      <view class="section-card disease-card press" bindtap="goToDiseasePrevention">
        <view class="disease-icon">+</view>
        <view class="disease-copy">
          <text class="section-title">疾病防治</text>
          <text class="section-sub">常见处理方案、用药与水体计算工具</text>
        </view>
        <text class="feature-arrow">›</text>
      </view>

      <view class="section-card">
        <view class="section-header compact">
          <view>
            <text class="section-title">常用功能</text>
            <text class="section-sub">高频工具一键直达</text>
          </view>
        </view>
        <view class="func-grid">
          <view class="func-item press" bindtap="goToCalculator">
            <image class="func-icon-img" src="/icons/jisuanqi.png" mode="aspectFit"></image>
            <text class="func-name">粘缸计算器</text>
            <text class="func-desc">水量费用</text>
          </view>
          <view class="func-item press" bindtap="goToEggReport">
            <text class="func-icon">🥚</text>
            <text class="func-name">产蛋报表</text>
            <text class="func-desc">{{stats.eggCount}} 枚记录</text>
          </view>
          <view class="func-item press" bindtap="goToHatchReport">
            <text class="func-icon">🐣</text>
            <text class="func-name">出苗报表</text>
            <text class="func-desc">孵化追踪</text>
          </view>
          <view class="func-item press" bindtap="goToPublic">
            <image class="func-icon-img" src="/icons/gongkai.png" mode="aspectFit"></image>
            <text class="func-name">公开档案</text>
            <text class="func-desc">分享展示</text>
          </view>
        </view>
      </view>

      <view class="safe-bottom"></view>
    </view>
  </scroll-view>
</view>
