@import "/styles/design.wxss";

.page-index {
  min-height: 100vh;
  background: var(--c-bg);
}

.scroll-main {
  height: 100vh;
}

.index-inner {
  padding: 0 0 calc(190rpx + env(safe-area-inset-bottom));
}

.login-bar {
  margin-top: 20rpx;
}

.hero-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 24rpx 28rpx 0;
  padding: 34rpx 30rpx;
  background: var(--c-surface);
  border: 1.5rpx solid var(--c-border-light);
  border-radius: var(--r-xl);
  box-shadow: var(--shadow-sm);
}

.hero-copy {
  flex: 1;
  min-width: 0;
  padding-right: 24rpx;
}

.hero-chip {
  margin-bottom: 18rpx;
}

.hero-title {
  display: block;
  color: var(--c-text);
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.18;
}

.hero-desc {
  display: block;
  margin-top: 12rpx;
  color: var(--c-text2);
  font-size: var(--fs-small);
  line-height: 1.55;
}

.hero-avatar {
  width: 116rpx;
  height: 116rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  color: var(--c-primary);
  font-size: 34rpx;
  font-weight: 800;
  background: #FFF0CC;
  border: 2rpx solid var(--c-primary);
}

.hero-avatar image {
  width: 100%;
  height: 100%;
}

.feature-row {
  display: flex;
  gap: 18rpx;
  margin: 20rpx 28rpx 0;
}

.feature-card {
  flex: 1;
  min-width: 0;
  min-height: 260rpx;
  padding: 24rpx;
  border-radius: var(--r-xl);
  border: 1.5rpx solid var(--c-border);
  background: var(--c-surface);
  box-shadow: var(--shadow-sm);
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.feature-primary {
  background: var(--c-primary-light);
  border-color: rgba(232,164,0,.42);
}

.feature-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.feature-kicker {
  color: var(--c-text);
  font-size: var(--fs-small);
  font-weight: 700;
}

.feature-arrow {
  color: var(--c-text3);
  font-size: 42rpx;
  line-height: 1;
}

.feature-number {
  display: block;
  margin-top: 22rpx;
  color: var(--c-text);
  font-size: 58rpx;
  font-weight: 800;
  line-height: 1;
}

.feature-desc {
  display: block;
  margin-top: 10rpx;
  color: var(--c-text2);
  font-size: var(--fs-mini);
}

.feature-preview {
  display: flex;
  align-items: center;
  margin-top: 22rpx;
  min-height: 56rpx;
}

.mini-pet {
  width: 56rpx;
  height: 56rpx;
  margin-right: -10rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: #fff;
  border: 2rpx solid var(--c-surface);
  color: var(--c-primary);
  font-size: var(--fs-mini);
  font-weight: 700;
}

.mini-pet image {
  width: 100%;
  height: 100%;
}

.mini-pet.placeholder {
  margin-right: 14rpx;
  border-color: var(--c-primary);
  background: #fff;
}

.feature-hint {
  color: var(--c-primary);
  font-size: var(--fs-mini);
  font-weight: 600;
}

.tank-card {
  background: #fff;
}

.tank-visual {
  height: 94rpx;
  margin-top: 26rpx;
  border: 2rpx solid var(--c-border);
  border-radius: 18rpx;
  position: relative;
  overflow: hidden;
  background: #FFFCF5;
}

.water-line {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 54rpx;
  background: #FFF8E7;
  border-top: 2rpx solid rgba(232,164,0,.32);
}

.tank-bubble {
  position: absolute;
  border-radius: 50%;
  background: #fff;
  border: 2rpx solid rgba(232,164,0,.32);
}

.tank-bubble.b1 {
  width: 18rpx;
  height: 18rpx;
  left: 36rpx;
  top: 30rpx;
}

.tank-bubble.b2 {
  width: 26rpx;
  height: 26rpx;
  right: 44rpx;
  top: 20rpx;
}

.tank-status {
  display: inline-flex;
  margin-top: 14rpx;
  padding: 6rpx 18rpx;
  border-radius: var(--r-full);
  color: var(--c-primary);
  background: var(--c-primary-light);
  font-size: var(--fs-mini);
  font-weight: 600;
}

.section-card {
  margin: 20rpx 28rpx 0;
  padding: 28rpx;
  border-radius: var(--r-xl);
  border: 1.5rpx solid var(--c-border-light);
  background: var(--c-surface);
  box-shadow: var(--shadow-sm);
}

.section-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 22rpx;
}

.section-header.compact {
  margin-bottom: 18rpx;
}

.section-title {
  display: block;
  margin: 0;
  color: var(--c-text);
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.25;
}

.section-sub {
  display: block;
  margin-top: 8rpx;
  color: var(--c-text2);
  font-size: var(--fs-mini);
  line-height: 1.35;
}

.count-chip {
  margin: 0;
  flex-shrink: 0;
}

.clear-chip {
  margin: 0;
  flex-shrink: 0;
  color: var(--c-success);
  background: var(--c-success-bg);
  border-color: transparent;
  font-weight: 600;
}

.todo-card {
  background: var(--c-surface);
  border-color: var(--c-border-light);
}

.reminder-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.todo-card .reminder-item {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  min-height: 260rpx;
  padding: 24rpx;
  border-radius: var(--r-xl);
  background: #FFFFFF;
  border: 1.5rpx solid #F0EDE8;
  box-shadow: 0 4rpx 18rpx rgba(0,0,0,.05);
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.todo-card .reminder-item:nth-child(odd) {
  background: var(--c-primary-bg);
  border-color: rgba(232,164,0,.42);
}

.rem-dot {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--c-primary);
  margin: 0;
}

.rem-dot.overdue {
  background: var(--c-danger);
}

.rem-dot.tomorrow {
  background: var(--c-warning);
}

.rem-info {
  width: 100%;
  min-width: 0;
  padding-right: 42rpx;
  box-sizing: border-box;
}

.rem-type {
  display: block;
  color: var(--c-text);
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.25;
}

.rem-pet {
  display: block;
  margin-top: 52rpx;
  color: var(--c-text2);
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.25;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.todo-card .rem-meta {
  width: auto;
  margin: auto 0 0;
  padding-right: 64rpx;
  text-align: left;
  box-sizing: border-box;
}

.rem-status {
  display: inline-flex;
  padding: 6rpx 16rpx;
  border-radius: var(--r-full);
  background: var(--c-primary-light);
  color: var(--c-primary);
  font-size: var(--fs-mini);
  font-weight: 700;
  line-height: 1.2;
}

.rem-status.overdue {
  color: var(--c-danger);
}

.rem-status.tomorrow {
  color: var(--c-warning);
}

.rem-date {
  display: block;
  margin-top: 10rpx;
  color: var(--c-text3);
  font-size: 22rpx;
  line-height: 1.25;
}

.todo-card .rem-done {
  position: absolute;
  right: 22rpx;
  bottom: 22rpx;
  min-width: 72rpx;
  height: 48rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
  margin: 0;
  border-radius: var(--r-full);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--c-primary);
  background: var(--c-primary-light);
  border: 1.5rpx solid rgba(232,164,0,.32);
  font-size: var(--fs-mini);
  font-weight: 700;
  line-height: 1;
}

.rem-done:active {
  transform: scale(.9);
}

.empty-todo {
  padding: 30rpx 24rpx;
  border-radius: var(--r-lg);
  background: var(--c-bg);
}

.empty-todo-title {
  display: block;
  color: var(--c-text);
  font-size: var(--fs-small);
  font-weight: 700;
}

.empty-todo-desc {
  display: block;
  margin-top: 8rpx;
  color: var(--c-text2);
  font-size: var(--fs-mini);
  line-height: 1.5;
}

.disease-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: var(--c-primary-light);
  border-color: rgba(232,164,0,.36);
}

.disease-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #fff;
  background: var(--c-primary);
  font-size: 42rpx;
  font-weight: 300;
  line-height: 1;
}

.disease-copy {
  flex: 1;
  min-width: 0;
}

.func-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.func-item {
  width: calc(33.33% - 10rpx);
  min-height: 152rpx;
  padding: 18rpx 8rpx;
  border-radius: var(--r-lg);
  background: var(--c-bg);
  border: 1.5rpx solid var(--c-border-light);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.func-icon {
  display: block;
  font-size: 38rpx;
  line-height: 1;
  margin-bottom: 12rpx;
}

.func-icon-img {
  display: block;
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 12rpx;
}

.func-name {
  display: block;
  max-width: 100%;
  color: var(--c-text);
  font-size: var(--fs-mini);
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
}

.func-desc {
  display: block;
  max-width: 100%;
  margin-top: 6rpx;
  color: var(--c-text3);
  font-size: 20rpx;
  line-height: 1.2;
  text-align: center;
}
