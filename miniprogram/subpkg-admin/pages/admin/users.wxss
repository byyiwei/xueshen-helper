page {
  height: 100vh;
  background: #1a1a2e;
  margin: 0;
  padding: 0;
}

.admin-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #1a1a2e;
}

.admin-header {
  padding: 60rpx 32rpx 32rpx;
  background: linear-gradient(135deg, #1e3a5f 0%, #0f3460 50%, #16213e 100%);
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
}

.admin-header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(58, 124, 255, 0.5) 50%, transparent 100%);
}

.header-back {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  transition: all 0.2s ease;
}

.header-back:active {
  background: rgba(255, 255, 255, 0.2);
  transform: scale(0.95);
}

.back-icon {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
  margin-right: 4rpx;
  line-height: 1;
}

.back-text {
  font-size: 24rpx;
  color: #fff;
}

.header-center {
  flex: 1;
  text-align: center;
}

.header-placeholder {
  width: 120rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.search-bar {
  padding: 20rpx 24rpx;
  background: #1a1a2e;
}

.search-box {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 0 20rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 26rpx;
  color: #fff;
  background: transparent;
}

.filter-bar {
  display: flex;
  gap: 12rpx;
  padding: 0 24rpx 20rpx;
  background: #1a1a2e;
  flex-wrap: wrap;
}

.filter-item {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.1);
  flex-shrink: 0;
}

.filter-item.active {
  background: rgba(74, 222, 128, 0.2);
}

.filter-item text {
  font-size: 24rpx;
  color: #fff;
}

.sort-bar {
  display: flex;
  gap: 12rpx;
  margin-left: auto;
}

.sort-item {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.08);
}

.sort-item.active {
  background: rgba(59, 130, 246, 0.2);
}

.sort-item text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.sort-item.active text {
  color: #3b82f6;
}

.sort-icon {
  margin-left: 6rpx;
  font-size: 20rpx;
}

.admin-scroll {
  flex: 1;
  height: 0;
}

.admin-content {
  padding: 0 24rpx;
  padding-bottom: 140rpx;
}

.user-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.user-card {
  display: flex;
  align-items: flex-start;
  background: #16213e;
  border-radius: 16rpx;
  padding: 20rpx;
  gap: 16rpx;
}

.user-avatar-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.user-avatar-wrapper image {
  width: 100%;
  height: 100%;
}

.avatar-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  margin-right: 12rpx;
}

.status-badge {
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
}

.status-badge.normal {
  background: rgba(74, 222, 128, 0.2);
}

.status-badge.normal text {
  color: #4ade80;
}

.status-badge.banned {
  background: rgba(239, 68, 68, 0.2);
}

.status-badge.banned text {
  color: #ef4444;
}

.user-openid-wrapper {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.user-openid {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
  font-family: monospace;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.copy-icon {
  font-size: 20rpx;
  flex-shrink: 0;
  opacity: 0.6;
}

.user-meta {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

.user-actions {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex-shrink: 0;
}

.action-btn {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  text-align: center;
  min-width: 80rpx;
}

.action-btn.edit {
  background: rgba(59, 130, 246, 0.2);
}

.action-btn.edit text {
  font-size: 22rpx;
  color: #3b82f6;
}

.action-btn.ban {
  background: rgba(245, 158, 11, 0.2);
}

.action-btn.ban text {
  font-size: 22rpx;
  color: #f59e0b;
}

.action-btn.unban {
  background: rgba(74, 222, 128, 0.2);
}

.action-btn.unban text {
  font-size: 22rpx;
  color: #4ade80;
}

.action-btn.delete {
  background: rgba(239, 68, 68, 0.2);
}

.action-btn.delete text {
  font-size: 22rpx;
  color: #ef4444;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

.admin-nav-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #16213e;
  padding: 16rpx 0;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  z-index: 9999;
}

.nav-btn {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  margin: 0 4rpx;
}

.nav-btn.active {
  background: rgba(74, 222, 128, 0.2);
}

.nav-btn .nav-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.nav-btn.active .nav-text {
  color: #4ade80;
  font-weight: bold;
}
.loading-state { text-align: center; padding: 80rpx 0; color: rgba(255, 255, 255, 0.6); font-size: 28rpx; }
