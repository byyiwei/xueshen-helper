page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.container {
  padding: 0 24rpx;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.text-gray {
  color: #94A3B8;
}

.text-dark {
  color: #1E293B;
}

.bg-dark {
  background-color: #3A7CFF;
}

:root {
  --primary-color: #3A7CFF;
  --primary-light: #E6F0FF;
  --primary-dark: #1A5CD6;
  --accent-color: #FF8C42;
  --bg-color: #F0F7FF;
  --bg-light: #FFFFFF;
  --card-bg: #ffffff;
  --text-color: #1E293B;
  --text-secondary: #475569;
  --text-light: #94A3B8;
  --border-color: #E2E8F0;
}

.btn-primary {
  background-color: #3A7CFF;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 24rpx 48rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(58,124,255,0.2);
  transition: opacity 0.2s;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-secondary {
  background-color: #F0F7FF;
  color: #3A7CFF;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 24rpx 48rpx;
  border: 2rpx solid #E2E8F0;
  transition: opacity 0.2s;
}

.btn-secondary:active {
  opacity: 0.85;
}

.btn-accent {
  background-color: #FF8C42;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 24rpx 48rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(255,140,66,0.2);
  transition: opacity 0.2s;
}

.btn-accent:active {
  opacity: 0.85;
}

.btn-disabled {
  background-color: #E2E8F0;
  color: #94A3B8;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 24rpx 48rpx;
  border: none;
}

.card-shadow {
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  border-radius: 16rpx;
}

.btn-outline {
  background-color: transparent;
  color: #3A7CFF;
  border: 2rpx solid #E2E8F0;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 24rpx 48rpx;
}

.text-primary {
  color: var(--primary-color);
}

.bg-primary-light {
  background-color: var(--bg-light);
}

.bg-page {
  background-color: var(--bg-color);
}

/* 通用动画工具类 */
.fade-in {
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 平滑触摸反馈 */
.tap-scale {
  transition: transform 0.15s ease;
}

.tap-scale:active {
  transform: scale(0.96);
}

/* 页面内容淡入 */
.page-content {
  animation: pageEnter 0.25s ease-out;
}

@keyframes pageEnter {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* ===== 未登录提示 ===== */
.not-logged-in {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  text-align: center;
}

.not-logged-in-icon {
  font-size: 80rpx;
  margin-bottom: 32rpx;
}

.not-logged-in-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 16rpx;
}

.not-logged-in-desc {
  font-size: 28rpx;
  color: #94A3B8;
  line-height: 1.6;
  margin-bottom: 48rpx;
}

.not-logged-in-btn {
  width: 320rpx;
  height: 84rpx;
  background: linear-gradient(135deg, #3A7CFF 0%, #1A5CD6 100%);
  color: #ffffff;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(58, 124, 255, 0.2);
}

.not-logged-in-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}
