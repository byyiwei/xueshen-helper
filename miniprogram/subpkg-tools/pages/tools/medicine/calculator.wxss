@import "/styles/design.wxss";

/* ====== 页面骨架：flex 列，禁止滚动 ====== */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: var(--c-bg);
  box-sizing: border-box;
}

/* ====== 顶栏 ====== */
.nav {
  display: flex; align-items: center; justify-content: space-between;
  height: 88rpx; flex-shrink: 0;
  background: var(--c-surface);
  padding: 0 24rpx;
  border-bottom: 2rpx solid var(--c-border-light);
}

.nav-back {
  width: 52rpx; height: 52rpx;
  display: flex; align-items: center; justify-content: center;
  background: var(--c-primary-light); border-radius: 50%;
}
.nav-back-icon { font-size: 34rpx; color: var(--c-primary); font-weight: 300; line-height: 1; margin-top: -3rpx; }
.nav-title { font-size: 30rpx; font-weight: 700; color: var(--c-text); }
.nav-placeholder { width: 52rpx; }

/* ====== 主体：flex=1 自适应，溢出隐藏 ====== */
.body {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 16rpx 24rpx 24rpx;
}

/* ====== 通用面板 ====== */
.panel {
  background: var(--c-surface);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  flex-shrink: 0;
}

/* ====== 药品头部 ====== */
.med-row {
  display: flex; align-items: center; gap: 16rpx;
  margin-bottom: 14rpx;
}
.med-image {
  width: 96rpx;
  height: 96rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  border: 2rpx solid var(--c-border-light, #F5F2EE);
}
.med-info-text {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}
.med-name { font-size: 32rpx; font-weight: 700; color: var(--c-text); }
.med-cat {
  font-size: 22rpx; color: var(--c-primary);
  background: var(--c-primary-light);
  padding: 4rpx 14rpx; border-radius: 8rpx;
}

/* ====== 给药途径芯片 ====== */
.route-row { display: flex; gap: 12rpx; flex-wrap: wrap; margin-bottom: 12rpx; }
.route-chip {
  display: flex; flex-direction: column; align-items: center;
  padding: 12rpx 22rpx;
  background: var(--c-bg);
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  min-width: 120rpx;
}
.route-chip.active { background: var(--c-primary-light); border-color: var(--c-primary); }
.chip-route { font-size: 26rpx; font-weight: 600; color: var(--c-text); }
.chip-dose { font-size: 20rpx; color: var(--c-text2); margin-top: 2rpx; }
.route-chip.active .chip-route { color: var(--c-primary); }
.route-chip.active .chip-dose { color: var(--c-primary); }

/* ====== 剂型芯片 ====== */
.form-row { display: flex; gap: 10rpx; flex-wrap: wrap; }
.form-chip {
  padding: 8rpx 20rpx;
  background: var(--c-bg);
  border-radius: 20rpx;
  border: 2rpx solid var(--c-border);
}
.form-chip text { font-size: 24rpx; color: var(--c-text2); }
.form-chip.active { background: var(--c-primary); border-color: var(--c-primary); }
.form-chip.active text { color: #fff; font-weight: 600; }

/* ====== 药品说明信息 ====== */
.med-info {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 2rpx solid var(--c-border-light);
}
.med-info-label {
  display: block;
  font-size: 22rpx; color: var(--c-text3); font-weight: 600;
  margin-bottom: 6rpx;
}
.med-info-text {
  font-size: 24rpx; color: var(--c-text2);
  line-height: 1.5;
}

/* ====== 输入区 ====== */
.input-panel { padding: 20rpx 24rpx; }
.inp-line {
  display: flex; align-items: center; justify-content: space-between;
  padding: 18rpx 0;
}
.inp-label { font-size: 28rpx; color: var(--c-text); font-weight: 700; flex-shrink: 0; margin-right: 20rpx; }
.inp-wrap {
  flex: 1; display: flex; align-items: center; gap: 12rpx;
  background: var(--c-bg);
  border: 2rpx solid var(--c-border);
  border-radius: 12rpx;
  padding: 8rpx 12rpx;
}
.inp {
  flex: 1; text-align: right;
  font-size: 32rpx; color: var(--c-text);
  height: 56rpx; line-height: 56rpx;
  font-weight: 600;
}
.inp::placeholder { color: var(--c-text3); font-size: 26rpx; font-weight: 400; }
.inp-unit { font-size: 24rpx; color: var(--c-text2); }

/* 单位切换 */
.unit-btn {
  display: flex; align-items: center;
  background: var(--c-surface); border-radius: 8rpx; overflow: hidden;
  border: 2rpx solid var(--c-border);
}
.unit-btn text {
  padding: 8rpx 18rpx;
  font-size: 24rpx; color: var(--c-text2);
}
.unit-btn .on { background: var(--c-primary); color: #fff; font-weight: 600; }
.unit-btn .sep { padding: 8rpx 2rpx; color: var(--c-border); }

/* ====== 计算结果 ====== */
.res-panel {
  background: var(--c-primary-bg);
  border: 2rpx solid rgba(232, 164, 0, 0.18);
}
.res-main {
  display: flex; align-items: baseline; justify-content: center;
  gap: 8rpx; margin-bottom: 12rpx;
}
.res-num { font-size: 64rpx; font-weight: 800; color: var(--c-primary); line-height: 1; }
.res-u { font-size: 28rpx; color: var(--c-primary-dark); font-weight: 600; }
.res-sub { display: flex; flex-direction: column; align-items: center; gap: 4rpx; }
.res-sub text { font-size: 22rpx; color: var(--c-text2); }
.res-fml {
  margin-top: 6rpx;
  padding: 6rpx 18rpx;
  background: var(--c-surface);
  border-radius: var(--r-full);
  color: var(--c-primary) !important;
  font-weight: 600;
}

/* 注射体积 */
.res-inject {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid rgba(232, 164, 0, 0.15);
  display: flex; flex-direction: column; align-items: center; gap: 6rpx;
}
.res-inject-head {
  display: flex; align-items: baseline; gap: 8rpx;
}
.res-inject-label { font-size: 24rpx; color: var(--c-text3); font-weight: 600; }
.res-inject-num { font-size: 48rpx; font-weight: 800; color: var(--c-primary); line-height: 1; }
.res-inject-unit { font-size: 24rpx; color: var(--c-primary-dark); font-weight: 600; }

/* 注射建议 */
.res-advice {
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}
.advice-ok {
  background: rgba(34, 197, 94, 0.08);
  border: 2rpx solid rgba(34, 197, 94, 0.2);
}
.advice-warn {
  background: rgba(245, 158, 11, 0.1);
  border: 2rpx solid rgba(245, 158, 11, 0.3);
}
.advice-icon {
  font-size: 28rpx;
  flex-shrink: 0;
  line-height: 1.5;
}
.advice-ok .advice-icon { color: #22c55e; }
.advice-warn .advice-icon { color: #f59e0b; }
.advice-text {
  font-size: 24rpx;
  color: var(--c-text);
  line-height: 1.5;
  flex: 1;
}

/* 稀释详情 */
.res-dilute-detail {
  margin-top: 8rpx;
  padding: 10rpx 16rpx;
  background: var(--c-bg);
  border-radius: 8rpx;
}
.dilute-detail-text {
  font-size: 24rpx;
  color: var(--c-text2);
  line-height: 1.5;
  font-family: monospace;
}

/* 稀释说明 */
.res-dilution {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: var(--c-surface);
  border-radius: var(--r-lg);
  border-left: 6rpx solid var(--c-primary);
}
.res-dilution-label {
  display: block;
  font-size: 22rpx; color: var(--c-text3); font-weight: 600;
  margin-bottom: 6rpx;
}
.res-dilution-text {
  font-size: 26rpx; color: var(--c-text);
  line-height: 1.5;
}

/* ====== 状态提示 ====== */
.status-box {
  display: flex; flex-direction: column; align-items: center;
  padding: 160rpx 0 0; gap: 12rpx;
}
.status-icon { font-size: 56rpx; }
.status-text { font-size: 28rpx; color: var(--c-text2); font-weight: 600; }
.retry-btn {
  margin-top: 16rpx;
  padding: 12rpx 48rpx;
  background: var(--c-primary);
  border-radius: var(--r-full);
}
.retry-btn text { font-size: 28rpx; color: #fff; font-weight: 600; }

/* ====== 底部计算按钮 ====== */
.foot {
  flex-shrink: 0;
  padding: 12rpx 24rpx calc(12rpx + env(safe-area-inset-bottom));
  background: var(--c-surface);
  border-top: 2rpx solid var(--c-border-light);
}

.data-source {
  text-align: center;
  font-size: 22rpx;
  color: var(--c-text3);
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  line-height: 1.5;
}
.calc-btn {
  display: flex; align-items: center; justify-content: center;
  height: 84rpx;
  background: var(--c-primary);
  border-radius: var(--r-full);
  box-shadow: 0 4rpx 16rpx rgba(232, 164, 0, 0.25);
}
.calc-btn text { font-size: 30rpx; color: #fff; font-weight: 700; }
.calc-btn:active { background: var(--c-primary-dark); transform: scale(0.98); }
