<view class="page" style="padding-top: {{totalNavHeight}}rpx;">
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px">
    <view class="nav-back" bindtap="goBack">
      <text class="nav-back-icon">‹</text>
    </view>
    <text class="nav-title">疾病防治</text>
    <view class="nav-placeholder"></view>
  </view>

  <view class="content">
    <!-- 加载中 -->
    <view wx:if="{{loading}}" class="status-box">
      <text class="status-text">加载中…</text>
    </view>

    <!-- 加载失败 -->
    <view wx:elif="{{loadError}}" class="status-box">
      <text class="status-icon">😵</text>
      <text class="status-text">加载失败，请检查网络</text>
      <view class="retry-btn" bindtap="retryLoad">
        <text>重试</text>
      </view>
    </view>

    <!-- 数据为空（API返回空数组） -->
    <view wx:elif="{{medicines.length === 0}}" class="status-box">
      <text class="status-icon">📭</text>
      <text class="status-text">暂无药品数据</text>
      <text class="status-hint">请在后台管理中添加药品</text>
    </view>

    <block wx:else>
    <!-- 搜索栏 -->
    <view class="search-bar">
      <view class="search-input-wrap">
        <image class="search-icon-img" src="/icons/medicine-search.png" mode="aspectFit"></image>
        <input
          class="search-input"
          type="text"
          placeholder="搜索药品名称、适应症"
          value="{{keyword}}"
          bindinput="onSearchInput"
          confirm-type="search"
          bindconfirm="onSearchConfirm"
        />
        <view wx:if="{{keyword}}" class="search-clear" bindtap="clearSearch">
          <text>×</text>
        </view>
      </view>
    </view>

    <!-- 分类标签 -->
    <scroll-view class="category-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="category-list">
        <view
          wx:for="{{categories}}"
          wx:key="id"
          class="category-item {{activeCategory === item.id ? 'active' : ''}}"
          bindtap="switchCategory"
          data-id="{{item.id}}"
        >
          <text>{{item.name}}</text>
        </view>
      </view>
    </scroll-view>

    <!-- 药品列表 -->
    <view class="medicine-list">
      <view
        wx:for="{{filteredMedicines}}"
        wx:key="id"
        class="medicine-card"
      >
        <view class="medicine-header">
          <view class="medicine-main">
            <text class="medicine-name">{{item.name}}</text>
            <view class="medicine-tags">
              <text class="tag tag-primary">{{item.category}}</text>
            </view>
          </view>
          <view class="calc-nav-btn" bindtap="goToCalculator" data-id="{{item.id}}">
            <text>用药计算 ›</text>
          </view>
        </view>

        <view class="medicine-body">
          <view class="info-row">
            <text class="info-label">适应症</text>
            <text class="info-value">{{item.indications}}</text>
          </view>
          <view wx:if="{{item.usageDosages && item.usageDosages.length}}" class="info-row">
            <text class="info-label">给药方案</text>
            <view class="dosage-tags">
              <text wx:for="{{item.usageDosages}}" wx:key="route" wx:for-item="d" class="tag tag-dosage">{{d.route}} {{d.dose}}{{d.unit}}</text>
            </view>
          </view>
          <view wx:elif="{{item.dosage}}" class="info-row">
            <text class="info-label">用法用量</text>
            <text class="info-value highlight">{{item.dosage}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">注意事项</text>
            <text class="info-value">{{item.notes}}</text>
          </view>
        </view>
      </view>

      <!-- 搜索无结果 -->
      <view wx:if="{{filteredMedicines.length === 0 && !loading && !loadError && medicines.length > 0}}" class="status-box">
        <text class="status-icon">🔍</text>
        <text class="status-text">未找到相关药品</text>
        <text class="status-hint">换个关键词或分类试试</text>
        <view class="report-btn" bindtap="openReportModal">
          <text>上报药品</text>
        </view>
      </view>
    </view>

    <view class="safe-bottom"></view>
    <view class="data-source">⚠️ 数据仅供参考，请遵兽医医嘱用药<br/>数据来源：《最新异宠药物处方手册》爬行动物章节</view>
    </block>
  </view>

  <!-- 上报药品弹窗 -->
  <view wx:if="{{showReportModal}}" class="modal-mask" bindtap="closeReportModal">
    <view class="modal-sheet" catchtap="stopProp">
      <view class="modal-head">
        <text class="modal-title">上报缺失药品</text>
        <text class="modal-close" bindtap="closeReportModal">×</text>
      </view>
      <view class="modal-body">
        <view class="report-form-group">
          <text class="report-form-label">药品名称</text>
          <input class="report-form-input" placeholder="请输入药品名称" value="{{reportForm.medicineName}}" bindinput="onReportNameInput" maxlength="50" />
        </view>
        <view class="report-form-group">
          <text class="report-form-label">您的邮箱</text>
          <input class="report-form-input" placeholder="用于接收处理结果通知" value="{{reportForm.email}}" bindinput="onReportEmailInput" type="text" maxlength="100" />
        </view>
        <view class="report-tip">
          <text>提交后管理员将审核并添加该药品，添加完成后会通过邮件通知您。</text>
        </view>
        <view class="report-submit-btn {{reportSubmitting ? 'disabled' : ''}}" bindtap="submitReport">
          <text>{{reportSubmitting ? '提交中...' : '提交上报'}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
