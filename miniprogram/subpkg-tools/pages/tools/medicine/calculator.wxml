<view class="page" style="padding-top: {{statusBarHeight}}px">
  <!-- 顶栏 -->
  <view class="nav">
    <view class="nav-back" bindtap="goBack">
      <text class="nav-back-icon">‹</text>
    </view>
    <text class="nav-title">用药计算器</text>
    <view class="nav-placeholder"></view>
  </view>

  <!-- 主体 -->
  <view class="body">

    <!-- 加载/错误/空状态 -->
    <view wx:if="{{loading}}" class="status-box">
      <text class="status-text">加载中…</text>
    </view>

    <view wx:elif="{{loadError}}" class="status-box">
      <text class="status-icon">😵</text>
      <text class="status-text">{{errorMsg || '加载失败'}}</text>
      <view class="retry-btn" bindtap="retryLoad"><text>重试</text></view>
    </view>

    <view wx:elif="{{!selectedMedicine}}" class="status-box">
      <text class="status-icon">💊</text>
      <text class="status-text">未找到药品</text>
    </view>

    <!-- 有药品 -->
    <block wx:else>
      <!-- 药品头部 + 给药方案 -->
      <view class="panel">
        <view class="med-row">
          <image wx:if="{{selectedMedicine.image}}" class="med-image" src="{{selectedMedicine.image}}" mode="aspectFill" />
          <view class="med-info-text">
            <text class="med-name">{{selectedMedicine.name}}</text>
            <text class="med-cat">{{selectedMedicine.category}}</text>
          </view>
        </view>

        <view wx:if="{{usageDosages.length > 0}}" class="route-row">
          <view
            wx:for="{{usageDosages}}" wx:key="route" wx:for-index="idx"
            class="route-chip {{selectedRouteIdx === idx ? 'active' : ''}}"
            bindtap="selectRoute" data-idx="{{idx}}"
          >
            <text class="chip-route">{{item.route}}</text>
            <text class="chip-dose">{{item.dose}}{{item.unit}}</text>
          </view>
        </view>

        <view wx:if="{{selectedMedicine.indications}}" class="med-info">
          <text class="med-info-label">适应症</text>
          <text class="med-info-text">{{selectedMedicine.indications}}</text>
        </view>
        <view wx:if="{{selectedMedicine.notes}}" class="med-info">
          <text class="med-info-label">注意事项</text>
          <text class="med-info-text">{{selectedMedicine.notes}}</text>
        </view>
      </view>

      <!-- 输入区：只需体重 -->
      <view wx:if="{{selectedRoute}}" class="panel input-panel">
        <view class="inp-line">
          <text class="inp-label">龟龟体重</text>
          <view class="inp-wrap">
            <input class="inp" type="digit" placeholder="输入体重" value="{{weightValue}}" bindinput="onWeightInput"/>
            <view class="unit-btn" bindtap="toggleWeightUnit">
              <text class="{{weightUnit === 'g' ? 'on' : ''}}">g</text>
              <text class="sep">/</text>
              <text class="{{weightUnit === 'kg' ? 'on' : ''}}">kg</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 计算结果 -->
      <view wx:if="{{result}}" class="panel res-panel">
        <!-- 用药量 -->
        <view class="res-main">
          <text class="res-num">{{result.amountText}}</text>
          <text class="res-u">{{result.unit}}</text>
        </view>
        <view class="res-sub">
          <text>{{result.medicineName}} · {{result.routeName}}</text>
          <text>{{result.inputDesc}}</text>
          <text class="res-fml">{{result.formula}}</text>
        </view>

        <!-- 注射体积 -->
        <view wx:if="{{result.volumeText}}" class="res-inject">
          <view class="res-inject-head">
            <text class="res-inject-label">注射体积</text>
            <text class="res-inject-num">{{result.volumeText}}</text>
            <text class="res-inject-unit">{{result.volumeUnit}}</text>
          </view>
          <text class="res-fml">{{result.concFormula}}</text>

          <!-- 注射建议 -->
          <view wx:if="{{result.injectAdvice}}" class="res-advice {{result.adviceType === 'warn' ? 'advice-warn' : 'advice-ok'}}">
            <text class="advice-icon">{{result.adviceType === 'warn' ? '⚠' : '✓'}}</text>
            <text class="advice-text">{{result.injectAdvice}}</text>
          </view>
        </view>

        <!-- 稀释说明 -->
        <view wx:if="{{result.dilutionNote}}" class="res-dilution">
          <text class="res-dilution-label">稀释说明</text>
          <text class="res-dilution-text">{{result.dilutionNote}}</text>
        </view>
      </view>
    </block>
  </view>

  <!-- 底部按钮 -->
  <view wx:if="{{selectedMedicine && selectedRoute}}" class="foot">
    <view class="calc-btn" bindtap="calculate"><text>计算</text></view>
  </view>

  <view class="data-source">⚠️ 数据仅供参考，请遵兽医医嘱用药<br/>数据来源：《最新异宠药物处方手册》爬行动物章节</view>
</view>
