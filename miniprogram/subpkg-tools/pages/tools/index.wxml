<view class="page" style="padding-top: {{totalNavHeight}}rpx;">
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px">
    <text class="nav-title">宸ュ叿</text>
  </view>

  <!-- 未登录提示栏 -->
  <view wx:if="{{!isLoggedIn}}" class="login-hint-bar">
    <text class="login-hint-text">登录后可管理宠物资料、记录和打印标签</text>
    <view class="login-hint-btn" bindtap="goToLogin">登录</view>
  </view>

  <view class="content">
    <!-- 工具卡片列表 -->
    <view class="tools-grid">
      <view class="tool-card" bindtap="goToCalculator">
        <view class="tool-icon-wrap">
          <text class="tool-icon">🔢</text>
        </view>
        <text class="tool-name">粘缸费用计算器</text>
        <text class="tool-desc">计算玻璃尺寸和费用</text>
      </view>
      <view class="tool-card" bindtap="goToTank3D">
        <view class="tool-icon-wrap">
          <text class="tool-icon">🐟</text>
        </view>
        <text class="tool-name">3D 鱼缸可视化</text>
        <text class="tool-desc">旋转查看鱼缸尺寸与容积</text>
      </view>
    </view>
  </view>
</view>