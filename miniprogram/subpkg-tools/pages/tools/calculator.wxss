.page {
  min-height: 100vh;
  background-color: #FAF8F5;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFFCF5 100%);
  padding-left: 24rpx;
  padding-right: 24rpx;
  border-bottom: 2rpx solid #F0EDE8;
}

.nav-back {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF8E7;
  border-radius: 50%;
  border: 2rpx solid #F0EDE8;
}

.nav-back-icon {
  font-size: 36rpx;
  color: #E8A400;
  font-weight: 300;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  margin-top: -4rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1E293B;
}

.nav-placeholder {
  width: 56rpx;
}

.content {
  padding: 32rpx;
}

/* 模式切换 */
.mode-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(232,164,0,0.04);
}

/* 单位选择 */
.unit-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(232,164,0,0.04);
}

.unit-switch {
  display: flex;
  gap: 16rpx;
}

.unit-btn {
  flex: 1;
  background: #FFFCF5;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #F0EDE8;
  transition: all 0.2s ease;
}

.unit-btn.active {
  background: linear-gradient(135deg, #FFF8E7 0%, #FFE8B0 100%);
  border-color: #E8A400;
  box-shadow: 0 4rpx 16rpx rgba(232,164,0,0.2);
}

.unit-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #64748B;
}

.unit-btn.active .unit-text {
  color: #E8A400;
}

.section-label {
  font-size: 26rpx;
  color: #64748B;
  margin-bottom: 20rpx;
  display: block;
}

.mode-switch {
  display: flex;
  gap: 20rpx;
}

.mode-btn {
  flex: 1;
  background: #FFFCF5;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid #F0EDE8;
  transition: all 0.2s ease;
}

.mode-btn.active {
  background: linear-gradient(135deg, #E8A400 0%, #C98D00 100%);
  border-color: #E8A400;
  box-shadow: 0 8rpx 24rpx rgba(232,164,0,0.25);
}

.mode-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #475569;
}

.mode-btn.active .mode-text {
  color: #FFFFFF;
}

.mode-desc {
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 6rpx;
}

.mode-btn.active .mode-desc {
  color: rgba(255, 255, 255, 0.85);
}

/* 输入区域 */
.input-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(232,164,0,0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 24rpx;
  display: block;
}

.input-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.input-grid:nth-child(2) {
  grid-template-columns: repeat(2, 1fr);
}

.input-item {
  display: flex;
  flex-direction: column;
}

.input-label {
  font-size: 24rpx;
  color: #64748B;
  margin-bottom: 12rpx;
}

.input-wrap {
  display: flex;
  align-items: center;
  background: #FFFCF5;
  border-radius: 16rpx;
  padding: 0 20rpx;
  height: 80rpx;
  border: 2rpx solid #F0EDE8;
}

.input-field {
  flex: 1;
  font-size: 28rpx;
  color: #1E293B;
  font-weight: 600;
  text-align: right;
}

.input-unit {
  font-size: 24rpx;
  color: #94A3B8;
  margin-left: 8rpx;
}

/* 操作按钮行 */
.action-btn-row {
  display: flex;
  gap: 20rpx;
  margin: 32rpx 0;
}

/* 计算按钮 */
.calc-btn {
  flex: 1;
  background: linear-gradient(135deg, #E8A400 0%, #C98D00 100%);
  border-radius: 24rpx;
  padding: 28rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(232,164,0,0.25);
  transition: all 0.2s ease;
}

.calc-btn-secondary {
  background: #FFF8E7;
  border: 2rpx solid #E8A400;
  box-shadow: none;
}

.calc-btn-secondary .calc-btn-text {
  color: #E8A400;
}

.calc-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(232,164,0,0.2);
}

.calc-btn-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

/* 警告提示 */
.warning-box {
  background: #FEF3E0;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  border-left: 6rpx solid #E8A400;
}

.warning-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.warning-text {
  font-size: 26rpx;
  color: #92400E;
  flex: 1;
}

/* 结果区域 */
.result-section {
  margin-top: 24rpx;
}

.result-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(232,164,0,0.04);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #E8A400;
}

.copy-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #FFF8E7;
  border-radius: 20rpx;
  border: 2rpx solid #F0EDE8;
  transition: all 0.2s ease;
}

.copy-btn:active {
  background: #F0EDE8;
  transform: scale(0.96);
}

.copy-icon {
  font-size: 24rpx;
}

.copy-text {
  font-size: 24rpx;
  color: #E8A400;
  font-weight: 500;
}

/* 表格 */
.table-scroll {
  white-space: nowrap;
  overflow-x: auto;
}

.table {
  display: table;
  width: max-content;
  min-width: 100%;
}

.table-header {
  display: table-row;
  background: #FFFCF5;
  border-radius: 12rpx;
}

.th {
  display: table-cell;
  font-size: 22rpx;
  font-weight: 600;
  color: #64748B;
  text-align: center;
  padding: 16rpx 16rpx;
  min-width: 140rpx;
  white-space: nowrap;
}

.table-row {
  display: table-row;
}

.table-row:last-child {
  border-bottom: none;
}

.td {
  display: table-cell;
  font-size: 24rpx;
  color: #1E293B;
  text-align: center;
  padding: 16rpx 16rpx;
  min-width: 140rpx;
  border-bottom: 2rpx solid #F0EDE8;
  white-space: nowrap;
}

.total-row {
  background: #FFF0CC;
}

.total-label {
  font-weight: 600;
  color: #C98D00;
}

.total-value {
  font-weight: 600;
  color: #C98D00;
}

/* 费用明细 */
.expense-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #F0EDE8;
}

.expense-row:last-child {
  border-bottom: none;
}

.expense-row.total {
  background: #FFFCF5;
  margin: 16rpx -28rpx -28rpx;
  padding: 24rpx 28rpx;
  border-radius: 0 0 24rpx 24rpx;
}

.expense-label {
  font-size: 28rpx;
  color: #475569;
}

.expense-row.total .expense-label {
  font-weight: 700;
  color: #1E293B;
}

.expense-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #E8A400;
}

.expense-value.total-value {
  font-size: 36rpx;
  color: #C98D00;
}

/* 统计汇总 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.stat-item {
  background: #FFFCF5;
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #E8A400;
  display: block;
}

.stat-label {
  font-size: 20rpx;
  color: #94A3B8;
  margin-top: 8rpx;
  display: block;
}

/* 备注 */
.remark-box {
  background: #FFFCF5;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-top: 8rpx;
}

.remark-text {
  font-size: 24rpx;
  color: #94A3B8;
  line-height: 1.6;
}

/* 结构示意图已移除，使用 3D 模型页面查看 */